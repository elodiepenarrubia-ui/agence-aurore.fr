---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Simulateur d'économies — aurore",
  "description": "Calculez combien vous coûte vraiment votre site web avec un abonnement mensuel, et combien vous économiseriez avec aurore.",
  "url": "https://agence-aurore.fr/simulateur/",
  "provider": { "@type": "Organization", "name": "Aurore" }
};
---

<BaseLayout
  title="Simulateur d'économies site web | aurore — Aix-en-Provence"
  description="Calculez ce que vous coûte vraiment votre site web. Comparez abonnement mensuel vs site en propre avec aurore. Résultat instantané."
  slug="simulateur"
  schema={schema}
>

  <!-- ─── HERO ─── -->
  <section class="sim-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Simulateur · aurore
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="sim-h1">
        Calculez ce que vous coûte<br />
        <span class="hero-serif">vraiment votre site.</span>
      </h1>
      <p class="sim-sub">
        Abonnement mensuel ou investissement unique ? Faites le calcul en 30 secondes.
      </p>
    </div>
  </section>

  <!-- ─── SIMULATEUR ─── -->
  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="sim-card" id="simulateur">

        <!-- ÉTAPE 1 — Situation -->
        <div class="sim-step" id="step-1">
          <div class="sim-step-label">Étape 1 / 3</div>
          <h2 class="sim-step-title">Quelle est votre situation ?</h2>
          <div class="sim-radios">
            <label class="sim-radio-card" data-situation="existant">
              <input type="radio" name="situation" value="existant" />
              <div class="sim-radio-inner">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                <span class="sim-radio-label">J'ai déjà un site et je veux m'en libérer</span>
              </div>
            </label>
            <label class="sim-radio-card" data-situation="creation">
              <input type="radio" name="situation" value="creation" />
              <div class="sim-radio-inner">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
                <span class="sim-radio-label">Je veux créer mon premier site</span>
              </div>
            </label>
          </div>
        </div>

        <!-- ÉTAPE 2 — Plateforme & coût -->
        <div class="sim-step" id="step-2" hidden>
          <div class="sim-step-label">Étape 2 / 3</div>
          <h2 class="sim-step-title" id="step-2-title">Votre plateforme actuelle</h2>

          <div class="sim-field">
            <label class="form-label">Plateforme</label>
            <div class="sim-platforms">
              <button type="button" class="sim-platform" data-platform="wordpress" data-cost="25">WordPress</button>
              <button type="button" class="sim-platform" data-platform="wix" data-cost="17">Wix</button>
              <button type="button" class="sim-platform" data-platform="squarespace" data-cost="16">Squarespace</button>
              <button type="button" class="sim-platform" data-platform="autre" data-cost="20">Autre</button>
              <button type="button" class="sim-platform" data-platform="diy" data-cost="0">Je fais moi-même</button>
            </div>
          </div>

          <div class="sim-field">
            <label class="form-label" for="cout-mensuel" id="label-cout">Coût mensuel actuel</label>
            <div class="sim-input-wrap">
              <input type="number" id="cout-mensuel" class="form-input" value="25" min="0" max="500" />
              <span class="sim-input-suffix">€ / mois</span>
            </div>
          </div>

          <div class="sim-field" id="field-cout-initial" hidden>
            <label class="form-label" for="cout-initial">Coût initial de création du site (optionnel)</label>
            <div class="sim-input-wrap">
              <input type="number" id="cout-initial" class="form-input" value="" min="0" max="50000" placeholder="0" />
              <span class="sim-input-suffix">€</span>
            </div>
          </div>

          <div id="fields-diy" hidden>
            <div class="sim-field">
              <label class="form-label" for="cout-plugins">Coût annuel total (abonnement CMS + plugins + thèmes)</label>
              <div class="sim-input-wrap">
                <input type="number" id="cout-plugins" class="form-input" value="200" min="0" max="5000" />
                <span class="sim-input-suffix">€ / an</span>
              </div>
              <p class="sim-field-note">Incluez l'abonnement à votre CMS (WordPress.com, Elementor Pro, Divi...) + les plugins payants + les thèmes premium.</p>
            </div>
            <div class="sim-field">
              <label class="form-label" for="temps-maintenance">Temps consacré à la maintenance par mois</label>
              <div class="sim-input-wrap">
                <input type="number" id="temps-maintenance" class="form-input" value="3" min="0" max="80" />
                <span class="sim-input-suffix">h / mois</span>
              </div>
            </div>
            <div class="sim-diy-note" id="diy-note">
              À 25 €/h, c'est <strong>3h × 25 € = 75 €/mois</strong> de votre temps.
            </div>
          </div>

          <div class="sim-field" id="field-mois">
            <label class="form-label" for="nb-mois">Depuis combien de mois ?</label>
            <div class="sim-slider-wrap">
              <input type="range" id="nb-mois" min="1" max="60" value="12" class="sim-slider" />
              <output id="nb-mois-val" class="sim-slider-val">12 mois</output>
            </div>
          </div>

          <div class="sim-field" id="field-eval-mois" hidden>
            <label class="form-label" for="eval-mois">Sur combien de mois souhaitez-vous évaluer ?</label>
            <div class="sim-slider-wrap">
              <input type="range" id="eval-mois" min="12" max="60" value="36" class="sim-slider" />
              <output id="eval-mois-val" class="sim-slider-val">36 mois</output>
            </div>
          </div>

          <div class="sim-already-spent" id="already-spent" hidden>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            <span>Vous avez déjà dépensé <strong id="spent-amount">300 €</strong> et vous n'êtes pas propriétaire de votre code.</span>
          </div>

          <div class="sim-projection" id="projection-creation" hidden>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
            <span id="projection-text"></span>
          </div>

          <button type="button" class="btn btn-primary" id="btn-step3">Choisir ma formule →</button>
        </div>

        <!-- ÉTAPE 3 — Formule Aurore -->
        <div class="sim-step" id="step-3" hidden>
          <div class="sim-step-label">Étape 3 / 3</div>
          <h2 class="sim-step-title">Choisissez votre formule aurore</h2>
          <div class="sim-formules">
            <button type="button" class="sim-formule sim-formule-migration" data-formule="migration" data-price="190" hidden>
              <span class="sim-formule-name">Migration</span>
              <span class="sim-formule-price">190 €</span>
              <span class="sim-formule-desc">Récupération contenu, reconstruction code pur, même domaine</span>
            </button>
            <button type="button" class="sim-formule" data-formule="starter" data-price="290">
              <span class="sim-formule-name">Starter</span>
              <span class="sim-formule-price">290 €</span>
              <span class="sim-formule-desc">Site 3 pages, domaine, emails pro, fiche Google inclus</span>
            </button>
            <button type="button" class="sim-formule" data-formule="vitrine" data-price="690">
              <span class="sim-formule-name">Vitrine</span>
              <span class="sim-formule-price">690 €</span>
              <span class="sim-formule-desc">Jusqu'à 6 pages, SEO complet, formulaire, espace rédaction</span>
            </button>
            <button type="button" class="sim-formule" data-formule="pro" data-price="1290">
              <span class="sim-formule-name">Pro</span>
              <span class="sim-formule-price">1 290 €</span>
              <span class="sim-formule-desc">Jusqu'à 10 pages, blog, réservation, automatisations</span>
            </button>
          </div>
          <p class="sim-note">Le domaine (~15 €/an) est inclus dans le calcul aurore.</p>
        </div>

        <!-- RÉSULTAT -->
        <div class="sim-result" id="sim-result" hidden>
          <h2 class="sim-step-title" style="text-align:center;">Votre comparatif</h2>

          <div class="sim-compare">
            <div class="sim-col sim-col-abo">
              <h3 id="col-abo-title">Avec abonnement</h3>
              <div class="sim-row"><span>À 12 mois</span><strong id="abo-12">—</strong></div>
              <div class="sim-row"><span>À 24 mois</span><strong id="abo-24">—</strong></div>
              <div class="sim-row"><span>À 36 mois</span><strong id="abo-36">—</strong></div>
            </div>
            <div class="sim-col sim-col-aurore">
              <h3>Avec aurore</h3>
              <div class="sim-row"><span>À 12 mois</span><strong id="aur-12">—</strong></div>
              <div class="sim-row"><span>À 24 mois</span><strong id="aur-24">—</strong></div>
              <div class="sim-row"><span>À 36 mois</span><strong id="aur-36">—</strong></div>
            </div>
          </div>

          <div class="sim-badges">
            <div class="sim-badge" id="badge-rentabilise">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <span id="rentabilise-label"></span>
            </div>
            <div class="sim-badge sim-badge-orange" id="badge-economie" hidden>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
              <span id="economie-label"></span>
            </div>
            <div class="sim-badge sim-badge-dark">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Vous êtes propriétaire à 100 %
            </div>
          </div>

          <div class="sim-negative-note" id="negative-note" hidden>
            <p id="negative-note-text"></p>
          </div>

          <!-- Ce que les chiffres ne montrent pas -->
          <div class="sim-advantages">
            <h3 class="sim-advantages-title">Ce que les chiffres ne montrent pas</h3>
            <div class="sim-advantages-grid">
              <div class="sim-advantage">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                <span>Site 100 % sur mesure, aucun template générique</span>
              </div>
              <div class="sim-advantage">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>Votre site vous appartient à vie, code source inclus</span>
              </div>
              <div class="sim-advantage">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
                <span>Aucun risque de fermeture de plateforme : Wix, Squarespace peuvent changer leurs conditions du jour au lendemain</span>
              </div>
              <div class="sim-advantage">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>Aucune mention de la plateforme dans votre adresse ou footer</span>
              </div>
              <div class="sim-advantage">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Zéro plugin à maintenir, zéro mise à jour de sécurité</span>
              </div>
              <div class="sim-advantage">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                <span>Pas de maintenance abusive facturée pour des bugs que vous n'avez pas créés</span>
              </div>
              <div class="sim-advantage">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                <span>Performances excellentes : site 10x plus rapide qu'un WordPress moyen</span>
              </div>
              <div class="sim-advantage">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span>Image 100 % professionnelle : aucun visiteur ne voit que vous utilisez un outil tiers</span>
              </div>
            </div>
          </div>

          <div style="text-align:center;margin-top:32px;">
            <a class="btn btn-aurora btn-lg" id="cta-devis" href="/contact/">Demander un devis →</a>
          </div>

          <button type="button" class="sim-restart" id="btn-restart">← Recommencer la simulation</button>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── CTA MIGRATION ─── -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <div class="cta-section">
        <span class="section-label" style="color:var(--aurora);">Vous avez déjà un site ?</span>
        <h2>Migrez pour 190 € et arrêtez de payer.</h2>
        <p>Je récupère votre contenu, je reconstruis en code propre, vous gardez votre domaine.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:32px;">
          <a href="/migration/" class="btn btn-aurora btn-lg">Découvrir l'offre migration →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .sim-hero { padding: 140px 0 64px; text-align: center; }
  .sim-h1 { font-family: var(--font-display); font-size: clamp(32px,5vw,58px); font-weight: 700; letter-spacing: -0.05em; line-height: 1.05; margin: 20px 0 16px; }
  .sim-sub { font-size: clamp(15px,1.3vw,18px); line-height: 1.65; max-width: 520px; margin: 0 auto; color: var(--gray-700); }

  .sim-card { background: var(--white); border: 1.5px solid var(--gray-100); border-radius: var(--radius-xl); padding: 48px; }

  .sim-step-label { font-size: 11px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--aurora); margin-bottom: 8px; }
  .sim-step-title { font-family: var(--font-display); font-size: clamp(20px,2.5vw,28px); font-weight: 700; letter-spacing: -0.03em; margin-bottom: 28px; }

  /* Radios visuels */
  .sim-radios { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .sim-radio-card { cursor: pointer; }
  .sim-radio-card input { position: absolute; opacity: 0; pointer-events: none; }
  .sim-radio-inner { display: flex; flex-direction: column; align-items: center; gap: 12px; padding: 28px 20px; border: 1.5px solid var(--gray-100); border-radius: var(--radius-lg); text-align: center; transition: var(--transition); color: var(--gray-500); }
  .sim-radio-inner:hover { border-color: var(--gray-300); }
  .sim-radio-card input:checked ~ .sim-radio-inner { border-color: var(--aurora); background: var(--aurora-pale); color: var(--aurora); }
  .sim-radio-label { font-size: 14px; font-weight: 600; color: var(--black); }

  /* Plateformes */
  .sim-platforms { display: flex; gap: 8px; flex-wrap: wrap; }
  .sim-platform { padding: 10px 20px; border: 1.5px solid var(--gray-100); border-radius: 100px; font-size: 14px; font-weight: 500; font-family: var(--font-display); background: var(--white); color: var(--black); cursor: pointer; transition: var(--transition); }
  .sim-platform:hover { border-color: var(--gray-300); }
  .sim-platform.active { border-color: var(--aurora); background: var(--aurora-pale); color: var(--aurora); font-weight: 600; }

  .sim-field { margin-bottom: 20px; }
  .sim-field-note { margin: 6px 0 0; font-size: 12px; color: var(--gray-500); line-height: 1.5; }
  .sim-input-wrap { position: relative; display: flex; align-items: center; }
  .sim-input-wrap .form-input { padding-right: 80px; }
  .sim-input-suffix { position: absolute; right: 16px; font-size: 13px; color: var(--gray-500); font-weight: 500; pointer-events: none; }

  .sim-slider-wrap { display: flex; align-items: center; gap: 16px; }
  .sim-slider { flex: 1; appearance: none; height: 4px; background: var(--gray-100); border-radius: 2px; outline: none; }
  .sim-slider::-webkit-slider-thumb { appearance: none; width: 20px; height: 20px; border-radius: 50%; background: var(--aurora); cursor: pointer; border: 3px solid var(--white); box-shadow: 0 2px 8px rgba(255,107,26,0.3); }
  .sim-slider::-moz-range-thumb { width: 20px; height: 20px; border-radius: 50%; background: var(--aurora); cursor: pointer; border: 3px solid var(--white); box-shadow: 0 2px 8px rgba(255,107,26,0.3); }
  .sim-slider-val { font-size: 14px; font-weight: 600; color: var(--black); min-width: 70px; }

  .sim-already-spent { display: flex; align-items: flex-start; gap: 10px; padding: 16px; background: var(--aurora-pale); border-radius: var(--radius-md); font-size: 14px; color: var(--gray-700); line-height: 1.6; margin-bottom: 24px; }
  .sim-already-spent[hidden] { display: none; }

  /* Formules */
  .sim-formules { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; }
  .sim-formule { display: flex; flex-direction: column; gap: 4px; padding: 20px 16px; border: 1.5px solid var(--gray-100); border-radius: var(--radius-md); background: var(--white); cursor: pointer; text-align: center; transition: var(--transition); }
  .sim-formule:hover { border-color: var(--gray-300); }
  .sim-formule.active { border-color: var(--aurora); background: var(--aurora-pale); }
  .sim-formule-name { font-size: 13px; font-weight: 600; color: var(--black); }
  .sim-formule-price { font-size: 18px; font-weight: 700; color: var(--aurora); letter-spacing: -0.02em; }
  .sim-formule-desc { font-size: 12px; color: var(--gray-500); line-height: 1.4; text-align: center; }
  .sim-formule-badge { display: inline-block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; background: var(--aurora); color: var(--white); padding: 3px 10px; border-radius: 100px; }
  .sim-formule-migration { position: relative; border-color: var(--aurora-light); background: var(--aurora-pale); }
  .sim-formule-migration[hidden] { display: none; }
  .sim-note { font-size: 12px; color: var(--gray-500); margin-top: 12px; text-align: center; }

  /* Résultat */
  .sim-result { margin-top: 40px; padding-top: 40px; border-top: 1.5px solid var(--gray-100); }
  .sim-compare { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 28px 0; }
  .sim-col { padding: 24px; border-radius: var(--radius-lg); }
  .sim-col h3 { font-size: 14px; font-weight: 600; margin-bottom: 16px; }
  .sim-col-abo { background: var(--gray-50); border: 1.5px solid var(--gray-100); }
  .sim-col-abo h3 { color: var(--gray-500); }
  .sim-col-aurore { background: var(--aurora-pale); border: 1.5px solid rgba(255,107,26,0.2); }
  .sim-col-aurore h3 { color: var(--aurora); }
  .sim-row { display: flex; justify-content: space-between; padding: 8px 0; font-size: 14px; color: var(--gray-700); }
  .sim-row + .sim-row { border-top: 1px solid rgba(0,0,0,0.06); }
  .sim-row strong { font-weight: 700; color: var(--black); }

  .sim-badges { display: flex; flex-direction: column; gap: 10px; margin-top: 24px; }
  .sim-badge { display: flex; align-items: center; gap: 10px; padding: 14px 18px; border-radius: var(--radius-md); font-size: 14px; font-weight: 500; }
  .sim-badge strong { font-weight: 700; }
  .sim-badge-orange { background: var(--aurora-pale); color: #9A3412; border: 1px solid var(--aurora-light); }
  .sim-badge-orange svg { stroke: var(--aurora); }
  .sim-badge-dark { background: var(--black); color: var(--white); }
  .sim-badge-dark svg { stroke: var(--aurora); }

  .sim-projection { display: flex; align-items: flex-start; gap: 10px; padding: 16px; background: var(--aurora-pale); border-radius: var(--radius-md); font-size: 14px; color: var(--gray-700); line-height: 1.6; margin-bottom: 24px; }
  .sim-projection[hidden] { display: none; }
  .sim-projection strong { font-weight: 700; color: var(--aurora-dark); }

  .sim-negative-note { padding: 16px 18px; background: var(--gray-50); border-radius: var(--radius-md); margin-top: 16px; }
  .sim-negative-note p { font-size: 14px; color: var(--gray-500); line-height: 1.65; margin: 0; }
  .sim-negative-note strong { font-weight: 700; color: var(--black); }

  .sim-badge-green { background: #ECFDF5; color: #065F46; border: 1px solid #A7F3D0; }
  .sim-badge-green svg { stroke: #059669; }
  .sim-badge-blue { background: #EFF6FF; color: #1E40AF; border: 1px solid #93C5FD; }
  .sim-badge-blue svg { stroke: #3B82F6; }

  .sim-advantages { margin-top: 32px; padding-top: 32px; border-top: 1.5px solid var(--gray-100); }
  .sim-advantages-title { font-family: var(--font-display); font-size: 18px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 20px; color: var(--black); }
  .sim-advantages-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .sim-advantage { display: flex; align-items: flex-start; gap: 12px; padding: 14px 16px; background: var(--gray-50); border-radius: var(--radius-md); font-size: 13px; line-height: 1.55; color: var(--gray-700); }
  .sim-advantage svg { flex-shrink: 0; margin-top: 1px; }

  .sim-restart { display: block; margin: 24px auto 0; background: none; border: none; color: var(--gray-500); font-size: 13px; font-weight: 500; cursor: pointer; font-family: var(--font-display); transition: var(--transition); }
  .sim-restart:hover { color: var(--aurora); }

  #step-2, #step-3 { margin-top: 48px; }

  .sim-diy-note { padding: 14px 16px; background: var(--aurora-pale); border-radius: var(--radius-md); font-size: 14px; color: var(--gray-700); line-height: 1.6; margin-bottom: 20px; }
  .sim-diy-note strong { font-weight: 700; color: var(--aurora-dark); }
  #fields-diy[hidden] { display: none; }

  @media (max-width: 768px) {
    .sim-hero { padding: 110px 0 48px; }
    .sim-card { padding: 28px 20px; }
    .sim-radios { grid-template-columns: 1fr; }
    .sim-formules { grid-template-columns: 1fr 1fr; }
    .sim-compare { grid-template-columns: 1fr; }
    .sim-advantages-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .sim-formules { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    // ─── STATE ───
    var state = { situation: '', platform: '', mensuel: 25, mois: 12, evalMois: 36, formule: '', formulePrice: 0, plugins: 200, heures: 3, coutInitial: 0 };

    // ─── ELEMENTS ───
    var step1 = document.getElementById('step-1');
    var step2 = document.getElementById('step-2');
    var step3 = document.getElementById('step-3');
    var result = document.getElementById('sim-result');
    var coutInput = document.getElementById('cout-mensuel');
    var moisSlider = document.getElementById('nb-mois');
    var moisVal = document.getElementById('nb-mois-val');
    var spentBlock = document.getElementById('already-spent');
    var spentAmount = document.getElementById('spent-amount');
    var fieldMois = document.getElementById('field-mois');
    var fieldEvalMois = document.getElementById('field-eval-mois');
    var evalSlider = document.getElementById('eval-mois');
    var evalVal = document.getElementById('eval-mois-val');
    var projectionBlock = document.getElementById('projection-creation');
    var projectionText = document.getElementById('projection-text');
    var step2Title = document.getElementById('step-2-title');
    var labelCout = document.getElementById('label-cout');
    var fieldsDiy = document.getElementById('fields-diy');
    var fieldCout = document.getElementById('cout-mensuel').closest('.sim-field');
    var pluginsInput = document.getElementById('cout-plugins');
    var heuresInput = document.getElementById('temps-maintenance');
    var diyNote = document.getElementById('diy-note');
    var colAboTitle = document.getElementById('col-abo-title');
    var coutInitialInput = document.getElementById('cout-initial');
    var fieldCoutInitial = document.getElementById('field-cout-initial');

    var migrationCard = document.querySelector('.sim-formule-migration');

    function fmt(n) { return n.toLocaleString('fr-FR') + ' €'; }

    function toggleMigrationCard() {
      if (migrationCard) {
        migrationCard.hidden = (state.situation !== 'existant');
      }
    }

    // ─── ÉTAPE 1 : Situation ───
    document.querySelectorAll('input[name="situation"]').forEach(function(radio) {
      radio.addEventListener('change', function() {
        state.situation = this.value;
        step2.hidden = false;
        step2.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

        if (state.situation === 'existant') {
          step2Title.textContent = 'Votre plateforme actuelle';
          labelCout.textContent = 'Coût mensuel actuel';
          fieldMois.hidden = false;
          fieldEvalMois.hidden = true;
          fieldCoutInitial.hidden = (state.platform === 'diy' || !state.platform);
        } else {
          step2Title.textContent = 'Quelle plateforme envisagez-vous ?';
          labelCout.textContent = 'Coût mensuel estimé';
          fieldMois.hidden = true;
          fieldEvalMois.hidden = false;
          fieldCoutInitial.hidden = true;
          state.evalMois = parseInt(evalSlider.value);
        }
        toggleMigrationCard();
        updateSpent();
        updateProjection();
      });
    });

    // ─── ÉTAPE 2 : Plateforme ───
    document.querySelectorAll('.sim-platform').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.sim-platform').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        state.platform = btn.dataset.platform;

        if (state.platform === 'diy') {
          fieldCout.hidden = true;
          fieldsDiy.hidden = false;
          fieldCoutInitial.hidden = true;
          updateDiy();
        } else {
          fieldCout.hidden = false;
          fieldsDiy.hidden = true;
          fieldCoutInitial.hidden = (state.situation !== 'existant');
          state.mensuel = parseInt(btn.dataset.cost);
          coutInput.value = state.mensuel;
        }
        updateSpent();
        updateProjection();
        updateResult();
      });
    });

    coutInput.addEventListener('input', function() {
      state.mensuel = parseInt(this.value) || 0;
      updateSpent();
      updateProjection();
      updateResult();
    });

    coutInitialInput.addEventListener('input', function() {
      state.coutInitial = parseInt(this.value) || 0;
      updateSpent();
      updateResult();
    });

    function updateDiy() {
      state.plugins = parseInt(pluginsInput.value) || 0;
      state.heures = parseInt(heuresInput.value) || 0;
      var tempsCoût = state.heures * 25;
      diyNote.innerHTML = "À 25 €/h, c&#39;est <strong>" + state.heures + "h × 25 € = " + tempsCoût + " €/mois</strong> de votre temps.";
      state.mensuel = Math.round(state.plugins / 12) + tempsCoût;
    }

    pluginsInput.addEventListener('input', function() {
      updateDiy();
      updateSpent();
      updateProjection();
      updateResult();
    });

    heuresInput.addEventListener('input', function() {
      updateDiy();
      updateSpent();
      updateProjection();
      updateResult();
    });

    moisSlider.addEventListener('input', function() {
      state.mois = parseInt(this.value);
      moisVal.textContent = state.mois + ' mois';
      updateSpent();
    });

    evalSlider.addEventListener('input', function() {
      state.evalMois = parseInt(this.value);
      evalVal.textContent = state.evalMois + ' mois';
      updateProjection();
    });

    function updateSpent() {
      if (state.situation === 'creation') {
        spentBlock.style.display = 'none';
        return;
      }
      if (state.situation === 'existant' && state.mensuel > 0 && state.platform !== 'diy') {
        var aboTotal = state.mensuel * state.mois;
        var spent = state.coutInitial + aboTotal;
        if (state.coutInitial > 0) {
          spentBlock.querySelector('span').innerHTML = 'Vous avez déjà dépensé <strong>' + fmt(spent) + '</strong> (dont ' + fmt(state.coutInitial) + ' à la création + ' + fmt(aboTotal) + ' d\'abonnements) et vous n\'êtes pas propriétaire de votre code.';
        } else {
          spentBlock.querySelector('span').innerHTML = 'Vous avez déjà dépensé <strong>' + fmt(spent) + '</strong> et vous n\'êtes pas propriétaire de votre code.';
        }
        spentBlock.style.display = 'flex';
        projectionBlock.style.display = 'none';
      } else if (state.situation === 'existant' && state.platform === 'diy') {
        var pluginsMois = Math.round(state.plugins / 12);
        var tempsCoût = state.heures * 25;
        projectionText.innerHTML = 'Vous investissez <strong>' + fmt(pluginsMois) + '/mois</strong> en plugins et <strong>' + state.heures + 'h</strong> de votre temps, soit <strong>' + fmt(pluginsMois + tempsCoût) + '/mois</strong> au total.';
        projectionBlock.style.display = 'flex';
        spentBlock.style.display = 'none';
      } else {
        spentBlock.style.display = 'none';
      }
    }

    function updateProjection() {
      if (state.situation === 'creation' && state.platform === 'diy') {
        var pluginsMois = Math.round(state.plugins / 12);
        var tempsCoût = state.heures * 25;
        projectionText.innerHTML = 'Vous investissez <strong>' + fmt(pluginsMois) + '/mois</strong> en plugins et <strong>' + state.heures + 'h</strong> de votre temps, soit <strong>' + fmt(pluginsMois + tempsCoût) + '/mois</strong> au total.';
        projectionBlock.style.display = 'flex';
        spentBlock.style.display = 'none';
      } else if (state.situation === 'creation' && state.mensuel > 0) {
        var platformName = state.platform ? state.platform.charAt(0).toUpperCase() + state.platform.slice(1) : 'cette plateforme';
        var totalEval = state.mensuel * state.evalMois;
        projectionText.innerHTML = 'Si vous choisissez <strong>' + platformName + '</strong>, vous paierez <strong>' + fmt(state.mensuel) + '/mois</strong>, soit <strong>' + fmt(totalEval) + ' sur ' + state.evalMois + ' mois</strong>, sans jamais posséder votre site.';
        projectionBlock.style.display = 'flex';
        spentBlock.style.display = 'none';
      } else if (state.situation !== 'existant') {
        projectionBlock.style.display = 'none';
      }
    }

    // ─── Bouton vers étape 3 ───
    document.getElementById('btn-step3').addEventListener('click', function() {
      step3.hidden = false;
      step3.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });

    // ─── ÉTAPE 3 : Formule ───
    document.querySelectorAll('.sim-formule').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.sim-formule').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        state.formule = btn.dataset.formule;
        state.formulePrice = parseInt(btn.dataset.price);
        updateResult();
      });
    });

    // ─── CALCUL RÉSULTAT ───
    function updateResult() {
      if (state.mensuel <= 0 || state.formulePrice <= 0) return;

      result.hidden = false;

      colAboTitle.textContent = state.platform === 'diy' ? 'En faisant vous-même' : 'Avec abonnement';

      var mensuel = state.mensuel;
      var auroreBase = state.formulePrice;
      var domaine = 15; // €/an

      // Abonnement (inclut le coût initial si existant)
      var ci = (state.situation === 'existant') ? state.coutInitial : 0;
      var abo12 = ci + mensuel * 12;
      var abo24 = ci + mensuel * 24;
      var abo36 = ci + mensuel * 36;

      // Aurore
      var aur12 = auroreBase + domaine;
      var aur24 = auroreBase + domaine * 2;
      var aur36 = auroreBase + domaine * 3;

      document.getElementById('abo-12').textContent = fmt(abo12);
      document.getElementById('abo-24').textContent = fmt(abo24);
      document.getElementById('abo-36').textContent = fmt(abo36);
      document.getElementById('aur-12').textContent = fmt(aur12);
      document.getElementById('aur-24').textContent = fmt(aur24);
      document.getElementById('aur-36').textContent = fmt(aur36);

      // Rentabilisé en X mois
      var rentaMois = mensuel > 0 ? Math.ceil(auroreBase / mensuel) : 0;
      var badgeRenta = document.getElementById('badge-rentabilise');
      var rentaLabel = document.getElementById('rentabilise-label');
      var negativeNote = document.getElementById('negative-note');
      var negativeNoteText = document.getElementById('negative-note-text');

      // Badge : vert si <= 36 mois, bleu si > 36 mois
      badgeRenta.className = 'sim-badge';
      if (rentaMois > 36) {
        badgeRenta.classList.add('sim-badge-blue');
        rentaLabel.innerHTML = 'Rentabilisé en <strong>' + rentaMois + '</strong> mois, puis 100 % économies';
      } else {
        badgeRenta.classList.add('sim-badge-green');
        rentaLabel.innerHTML = 'Rentabilisé en <strong>' + rentaMois + '</strong> mois';
      }

      // Économie sur 3 ans
      var eco3 = abo36 - aur36;
      var ecoLabel = document.getElementById('economie-label');
      var badgeEco = document.getElementById('badge-economie');

      if (eco3 > 0) {
        ecoLabel.innerHTML = 'Économie sur 3 ans : <strong>' + fmt(eco3) + '</strong>';
        badgeEco.style.display = 'flex';
        negativeNote.style.display = 'none';
      } else {
        // Économie négative : ne pas afficher le montant négatif
        badgeEco.style.display = 'none';
        var ecoMensuel = mensuel - (domaine / 12);
        negativeNoteText.innerHTML = 'Sur 3 ans, aurore représente un investissement légèrement supérieur. Mais au-delà, chaque mois vous faites une économie de <strong>' + fmt(Math.round(ecoMensuel)) + '</strong>.';
        negativeNote.style.display = 'block';
      }

      // CTA lien avec query params
      var situationLabel = state.situation === 'existant' ? 'migration' : 'creation';
      var params = new URLSearchParams({
        formule: state.formule,
        economie: String(eco3),
        situation: situationLabel,
        plateforme: state.platform || 'non-precise',
        mensuel: String(mensuel)
      });
      document.getElementById('cta-devis').href = '/contact/?' + params.toString();

      result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // ─── RESTART ───
    document.getElementById('btn-restart').addEventListener('click', function() {
      state = { situation: '', platform: '', mensuel: 25, mois: 12, evalMois: 36, formule: '', formulePrice: 0, plugins: 200, heures: 3, coutInitial: 0 };
      step2.hidden = true;
      step3.hidden = true;
      result.hidden = true;
      spentBlock.style.display = 'none';
      projectionBlock.style.display = 'none';
      fieldEvalMois.hidden = true;
      fieldsDiy.hidden = true;
      fieldCoutInitial.hidden = true;
      fieldCout.hidden = false;
      document.getElementById('negative-note').style.display = 'none';
      coutInput.value = '25';
      coutInitialInput.value = '';
      moisSlider.value = '12';
      moisVal.textContent = '12 mois';
      evalSlider.value = '36';
      evalVal.textContent = '36 mois';
      pluginsInput.value = '200';
      heuresInput.value = '3';
      diyNote.innerHTML = "À 25 €/h, c&#39;est <strong>3h × 25 € = 75 €/mois</strong> de votre temps.";
      document.querySelectorAll('.sim-platform, .sim-formule').forEach(function(b) { b.classList.remove('active'); });
      if (migrationCard) migrationCard.hidden = true;
      document.querySelectorAll('input[name="situation"]').forEach(function(r) { r.checked = false; });
      document.querySelectorAll('.sim-radio-inner').forEach(function(el) { el.style = ''; });
      step1.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });
</script>
