---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formations, pack } from '../../data/formations';

const formationsCode = import.meta.env.PUBLIC_FORMATIONS_CODE;
const totalPrix = formations.reduce((sum, f) => sum + f.prix, 0);
---

<BaseLayout
  title="Formations vidéo — Gérez votre présence en ligne | aurore"
  description="Formations vidéo courtes et concrètes pour artisans et indépendants : Google Business, Search Console, Analytics, blog, charte graphique, Stripe, réservation. Par aurore, Aix-en-Provence."
  slug="formations"
>

  <!-- ─── HERO ─── -->
  <section class="fm-hero section-aurora-gradient">
    <div class="container">
      <span class="section-label">Formations vidéo</span>
      <h1 class="fm-h1">Gérez votre présence en ligne<br /><span class="hero-serif">comme un pro.</span></h1>
      <p class="fm-sub">Des formations courtes et concrètes pour les artisans, thérapeutes et indépendants. Chaque formation inclut une checklist PDF téléchargeable.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- ─── SECTION VERROUILLÉE (tarifs + achat) ─── -->
      <div id="formations-locked">
        <div class="pack-card">
          <span class="pack-badge">Meilleure valeur</span>
          <h2 class="pack-title">Pack complet — 7 formations</h2>
          <p class="pack-desc">Toutes les formations + tous les PDFs. Accès 1 an.</p>
          <div class="pack-price">{pack.prix / 100}€ <span>au lieu de {totalPrix / 100}€</span></div>
          <button class="btn btn-aurora" id="btn-pack">Accéder au pack →</button>
        </div>
      </div>

      <!-- ─── GRILLE DES FORMATIONS (toujours visible) ─── -->
      <div class="formations-grid">
        {formations.map((f) => (
          <div class="formation-card">
            <div class="formation-header">
              <span class={`formation-tag ${f.gratuit ? 'formation-tag-free' : ''}`}>
                {f.gratuit ? 'Gratuit' : f.duree}
              </span>
              {!f.gratuit && <span class="formation-duration">{f.duree}</span>}
            </div>
            <h3 class="formation-card-title">{f.titre}</h3>
            <p class="formation-card-desc">{f.description}</p>
            <ul class="formation-points">
              {f.points.slice(0, 3).map((p) => (
                <li>{p}</li>
              ))}
            </ul>
            <div class="formation-footer">
              <span class="formation-price formations-price-tag">{f.gratuit ? 'Gratuit' : `${f.prix / 100}€`}</span>
              <a href={`/formations/${f.slug}/`} class="btn btn-outline btn-sm">
                Voir la formation →
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- ─── SECTION DÉVERROUILLÉE (visible après connexion) ─── -->
      <div id="formations-unlocked" style="display:none;">
        <div class="fm-access-badge">Accès activé</div>
        <div class="formations-resource">
          <p>&#x1F4C4; Guide de prise en main - PDF</p>
          <a href="/formations/guide-formations-aurore.pdf" download class="btn btn-outline">Télécharger le guide →</a>
        </div>
      </div>

      <!-- ─── CODE CLIENT ─── -->
      <div id="client-code-section" class="client-code-section">
        <p class="client-code-text">Déjà client Aurore ? Accédez gratuitement à toutes les formations.</p>
        <div class="code-input-group">
          <input type="text" id="code-input" class="input" placeholder="Entrez votre code d'accès" autocomplete="off" />
          <button id="btn-code" class="btn btn-aurora">Accéder</button>
        </div>
        <p id="code-error" class="code-error">Code incorrect</p>
      </div>

    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <div class="cta-section">
        <h2>Besoin d'un site web professionnel ?</h2>
        <p>Votre site en ligne en 2 semaines, avec toutes les formations incluses.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
          <a href="/tarifs/" class="btn btn-aurora btn-lg">Voir les offres →</a>
          <a href="/contact/" class="btn btn-outline btn-lg">Demander un devis</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .fm-hero {
    padding: 160px 0 80px;
    text-align: center;
  }
  .fm-h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1.05;
    color: var(--black);
    margin: 20px 0 16px;
  }
  .fm-sub {
    font-size: clamp(15px, 1.3vw, 18px);
    color: var(--gray-500);
    line-height: 1.65;
    max-width: 580px;
    margin: 0 auto;
  }

  /* ─── PACK ─── */
  .pack-card {
    background: var(--aurora-pale);
    border: 2px solid var(--aurora);
    border-radius: 16px;
    padding: 32px;
    text-align: center;
    position: relative;
    margin: 32px 0;
  }
  .pack-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--aurora);
    color: white;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 16px;
    border-radius: 100px;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .pack-title {
    font-family: var(--font-display);
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--black);
    margin: 0 0 8px;
  }
  .pack-desc {
    color: var(--gray-500);
    font-size: 15px;
    margin: 0;
  }
  .pack-price {
    font-size: 36px;
    font-weight: 800;
    color: var(--aurora);
    margin: 16px 0;
  }
  .pack-price span {
    font-size: 16px;
    color: var(--gray-500);
    text-decoration: line-through;
    font-weight: 400;
  }

  /* ─── GRID ─── */
  .formations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
    margin: 48px 0;
  }
  .formation-card {
    background: white;
    border: 1px solid var(--gray-100);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: box-shadow 0.2s;
  }
  .formation-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }
  .formation-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .formation-tag {
    background: var(--aurora-pale);
    color: var(--aurora);
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 100px;
    text-transform: uppercase;
  }
  .formation-tag-free {
    background: #dcfce7;
    color: #16a34a;
  }
  .formation-duration {
    font-size: 12px;
    color: var(--gray-500);
  }
  .formation-card-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--black);
    margin: 0;
  }
  .formation-card-desc {
    font-size: 14px;
    color: var(--gray-500);
    line-height: 1.6;
    margin: 0;
  }
  .formation-points {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 13px;
    color: var(--gray-700);
  }
  .formation-points li::before {
    content: "→ ";
    color: var(--aurora);
    font-weight: 700;
  }
  .formation-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid var(--gray-100);
  }
  .formation-price {
    font-size: 20px;
    font-weight: 800;
    color: var(--aurora);
  }

  /* ─── CODE CLIENT ─── */
  .client-code-section {
    text-align: center;
    padding: 48px 0;
    border-top: 1px solid var(--gray-100);
    margin-top: 48px;
  }
  .client-code-text {
    font-size: 15px;
    color: var(--gray-500);
    margin: 0;
  }
  .code-input-group {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 16px;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }
  .code-error {
    display: none;
    color: #dc2626;
    font-size: 13px;
    margin-top: 8px;
  }

  /* ─── ACCÈS ACTIVÉ ─── */
  .fm-access-badge {
    display: inline-block;
    background: #dcfce7;
    color: #16a34a;
    font-size: 12px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .formations-resource {
    background: var(--gray-50);
    border: 1.5px solid var(--gray-100);
    border-radius: 12px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .formations-resource p {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--black);
  }

  @media (max-width: 768px) {
    .fm-hero { padding: 120px 0 56px; }
    .formations-grid { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ formationsCode }}>
  // ─── GESTION ACCÈS ───
  function showFormations() {
    var locked = document.getElementById('formations-locked');
    var unlocked = document.getElementById('formations-unlocked');
    var codeSection = document.getElementById('client-code-section');
    // Masquer tarifs et code client
    if (locked) locked.style.display = 'none';
    if (codeSection) codeSection.style.display = 'none';
    // Masquer les prix individuels dans la grille
    var priceTags = document.querySelectorAll('.formations-price-tag');
    for (var i = 0; i < priceTags.length; i++) { priceTags[i].style.display = 'none'; }
    // Afficher section déverrouillée
    if (unlocked) unlocked.style.display = 'block';
  }

  // Vérifier si déjà connecté
  if (sessionStorage.getItem('formations-access') === 'true') {
    showFormations();
  }

  // ─── PACK ACHAT ───
  var btnPack = document.getElementById('btn-pack');
  if (btnPack) {
    btnPack.addEventListener('click', function() {
      btnPack.disabled = true;
      btnPack.textContent = 'Redirection\u2026';
      fetch('/api/create-formation-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: 'pack-complet' }),
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.url) {
            window.location.href = data.url;
          } else {
            alert('Erreur : ' + (data.error || 'Impossible de cr\u00E9er le paiement'));
            btnPack.disabled = false;
            btnPack.textContent = 'Acc\u00E9der au pack \u2192';
          }
        })
        .catch(function() {
          alert('Erreur r\u00E9seau, veuillez r\u00E9essayer.');
          btnPack.disabled = false;
          btnPack.textContent = 'Acc\u00E9der au pack \u2192';
        });
    });
  }

  // ─── CODE CLIENT ───
  var btnCode = document.getElementById('btn-code');
  if (btnCode) {
    btnCode.addEventListener('click', function() {
      var input = document.getElementById('code-input');
      var code = input.value.trim().toUpperCase();
      if (code === formationsCode) {
        sessionStorage.setItem('formations-access', 'true');
        showFormations();
      } else {
        document.getElementById('code-error').style.display = 'block';
      }
    });
  }

  var codeInput = document.getElementById('code-input');
  if (codeInput) {
    codeInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        document.getElementById('btn-code').click();
      }
      document.getElementById('code-error').style.display = 'none';
    });
  }
</script>
