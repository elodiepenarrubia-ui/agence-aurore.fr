---
import BaseLayout from '../../layouts/BaseLayout.astro';

const formationsCode = import.meta.env.PUBLIC_FORMATIONS_CODE;
---

<BaseLayout
  title="Accès activé — Formations aurore"
  description="Votre accès aux formations Aurore est activé."
  slug="formations/merci"
  noindex={true}
>

  <section class="section" style="padding-top:160px;">
    <div class="container" style="max-width:520px;text-align:center;">

      <div class="merci-icon" aria-hidden="true">
        <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
          <circle cx="32" cy="32" r="32" fill="var(--aurora-pale)"/>
          <path d="M20 33l8 8L44 25" stroke="var(--aurora)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <h1 class="merci-h1">Accès activé !</h1>
      <p class="merci-sub">Merci pour votre achat.</p>

      <div class="merci-code">
        <p class="merci-code-label">Votre code d'accès valable 1 an :</p>
        <div class="code-display">{formationsCode}</div>
        <p class="code-note">Conservez ce code — il vous donne accès à toutes les formations.</p>
      </div>

      <a href="/formations/" class="btn btn-aurora btn-lg" style="margin-top:24px;">Accéder aux formations →</a>

    </div>
  </section>

</BaseLayout>

<style>
  .merci-icon {
    margin-bottom: 24px;
  }
  .merci-h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--black);
    margin: 0 0 8px;
  }
  .merci-sub {
    font-size: 16px;
    color: var(--gray-500);
    line-height: 1.65;
    margin: 0 0 24px;
  }
  .merci-code {
    margin: 0 0 8px;
  }
  .merci-code-label {
    font-size: 14px;
    color: var(--gray-500);
    margin: 0 0 12px;
  }
  .code-display {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: var(--aurora);
    background: var(--aurora-pale);
    border: 2px solid rgba(255, 107, 26, 0.2);
    padding: 16px 32px;
    border-radius: var(--radius-md);
    user-select: all;
  }
  .code-note {
    font-size: 13px;
    color: var(--gray-500);
    margin: 12px 0 0;
    line-height: 1.6;
  }
</style>

<script>
  // Activer automatiquement l'accès
  sessionStorage.setItem('formations-access', 'true');

  // Stocker les formations individuelles achetées
  var params = new URLSearchParams(window.location.search);
  var slug = params.get('formation');
  if (slug) {
    var achats = JSON.parse(sessionStorage.getItem('formations-achetees') || '[]');
    if (achats.indexOf(slug) === -1) achats.push(slug);
    sessionStorage.setItem('formations-achetees', JSON.stringify(achats));
  }
</script>
