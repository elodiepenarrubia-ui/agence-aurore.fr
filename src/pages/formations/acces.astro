---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Accès formations vidéo — 7€ pour 1 an | aurore"
  description="Accédez à toutes les formations vidéo Aurore pendant 1 an : Google Business, Search Console, Analytics, espace rédaction, charte graphique. 7€."
  slug="formations/acces"
  noindex={true}
>

  <section class="section" style="padding-top:160px;">
    <div class="container" style="max-width:480px;text-align:center;">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Formations · aurore
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="acces-h1">Accès formations Aurore</h1>
      <p class="acces-sub">Accès à toutes les formations vidéo pendant 1 an.</p>

      <div class="acces-card">
        <p class="acces-price">7<span class="acces-price-symbol">€</span></p>
        <p class="acces-price-note">paiement unique · accès 1 an</p>
        <ul class="acces-list">
          <li>Google Business Profile</li>
          <li>Google Search Console</li>
          <li>Google Analytics</li>
          <li>Espace rédaction</li>
          <li>Votre charte graphique</li>
        </ul>
        <button id="btn-pay" class="btn btn-aurora" style="width:100%;justify-content:center;">Payer 7€ →</button>
        <p id="pay-error" style="display:none;color:#dc2626;font-size:13px;margin-top:12px;"></p>
      </div>

      <p class="acces-already">Déjà client Aurore ? <a href="/formations/">Entrez votre code ici</a></p>
    </div>
  </section>

</BaseLayout>

<style>
  .acces-h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--black);
    margin: 20px 0 8px;
  }
  .acces-sub {
    font-size: 16px;
    color: var(--gray-500);
    line-height: 1.65;
    margin: 0 0 32px;
  }
  .acces-card {
    background: white;
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-xl);
    padding: 36px 32px;
    position: relative;
    overflow: hidden;
  }
  .acces-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--aurora), var(--aurora-mid));
  }
  .acces-price {
    font-family: var(--font-display);
    font-size: 64px;
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1;
    color: var(--aurora);
    margin: 0;
  }
  .acces-price-symbol {
    font-size: 32px;
    font-weight: 700;
    vertical-align: super;
    margin-left: 2px;
  }
  .acces-price-note {
    font-size: 13px;
    color: var(--gray-500);
    margin: 4px 0 24px;
  }
  .acces-list {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    text-align: left;
  }
  .acces-list li {
    font-size: 14px;
    color: var(--gray-700);
    padding: 6px 0;
    border-bottom: 1px solid var(--gray-100);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .acces-list li::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--aurora);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .acces-already {
    font-size: 13px;
    color: var(--gray-500);
    margin-top: 24px;
  }
  .acces-already a {
    color: var(--aurora);
    text-decoration: none;
    font-weight: 500;
  }
  .acces-already a:hover {
    text-decoration: underline;
  }
</style>

<script>
  document.getElementById('btn-pay')?.addEventListener('click', function() {
    var btn = this as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Redirection...';
    var errorEl = document.getElementById('pay-error')!;
    errorEl.style.display = 'none';

    fetch('/api/create-formations-checkout', { method: 'POST' })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.url) {
          window.location.href = data.url;
        } else {
          errorEl.textContent = data.error || 'Erreur lors de la création du paiement';
          errorEl.style.display = 'block';
          btn.disabled = false;
          btn.textContent = 'Payer 7€ →';
        }
      })
      .catch(function(err) {
        errorEl.textContent = 'Erreur : ' + err.message;
        errorEl.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Payer 7€ →';
      });
  });
</script>
