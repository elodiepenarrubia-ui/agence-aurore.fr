---
import BaseLayout from '../../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de site vitrine professionnel",
  "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://agence-aurore.fr" },
  "areaServed": "France",
  "description": "Création de site vitrine pour artisans, thérapeutes et professionnels indépendants. Hébergement gratuit, SEO et fiche Google inclus, livraison en 2 semaines. À partir de 690 €.",
  "offers": [
    { "@type": "Offer", "name": "Vitrine", "priceCurrency": "EUR", "price": "690" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "À qui s'adresse le site vitrine ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le site vitrine est idéal pour les artisans, thérapeutes, praticiens, consultants, auto-entrepreneurs et toute TPE qui a besoin d'une présence professionnelle en ligne pour se faire connaître et être trouvé sur Google, sans système de réservation ni paiement en ligne." }},
    { "@type": "Question", "name": "Combien de pages sont incluses dans un site vitrine ?",
      "acceptedAnswer": { "@type": "Answer", "text": "La formule Vitrine inclut jusqu'à 6 pages. La formule Pro monte jusqu'à 10 pages + un blog. Chaque page supplémentaire est disponible à 120 €." }},
    { "@type": "Question", "name": "Puis-je modifier les textes et les images moi-même ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, un espace de rédaction est inclus dans la formule Vitrine. Vous modifiez textes, images et articles depuis une interface web simple, sans aucune connaissance technique. Une formation vidéo est incluse." }},
    { "@type": "Question", "name": "Le site sera-t-il bien positionné sur Google ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le SEO on-page et la fiche Google Business sont inclus dans toutes les formules : balises title, meta description, structure Hn, Schema.org, Google Business, Google Search Console. Cela donne une base solide pour le référencement local. Un travail de contenu régulier (blog) amplifie ensuite les résultats." }},
    { "@type": "Question", "name": "Qu'est-ce qui est inclus dans 'clé en main' ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Clé en main signifie : achat et configuration du nom de domaine, création et configuration des emails professionnels Zoho, mise en ligne sur GitHub Pages, paramétrage Google Business, connexion Google Search Console, et test final sur mobile et desktop. Vous n'avez rien à configurer vous-même." }},
    { "@type": "Question", "name": "Quelle différence entre un site vitrine et un site avec réservation ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le site vitrine présente votre activité et permet à vos clients de vous contacter par formulaire. Le site avec réservation y ajoute la prise de rendez-vous et le paiement en ligne. Si vous facturez des créneaux horaires ou des prestations unitaires, le site avec réservation est plus adapté." }},
  ],
};

const benefices = [
  { titre: "Visibilité Google immédiate",   desc: "SEO on-page, Google Business optimisé, Search Console connectée, le tout livré et actif dès le jour J." },
  { titre: "Crédibilité professionnelle",   desc: "Un site soigné transmet confiance et sérieux. Les clients comparent avant de vous appeler, soyez à la hauteur." },
  { titre: "Email @votre-domaine",          desc: "contact@votre-activite.fr inclus. Finies les adresses Gmail pour les échanges professionnels." },
  { titre: "Mobile avant tout",             desc: "70 % des recherches locales se font sur smartphone. Votre site est conçu mobile-first, puis adapté au desktop." },
  { titre: "0 € d'hébergement à vie",       desc: "GitHub Pages est gratuit et fiable. Votre seul coût récurrent : le nom de domaine (~15 €/an)." },
  { titre: "Livré en 2 semaines",           desc: "Pas de projet interminable. Du briefing initial à la mise en ligne : 14 jours maximum." },
];

const catalogSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de site vitrine",
  "description": "Site vitrine professionnel pour artisans et indépendants. SEO on-page, fiche Google Business, emails pro et hébergement inclus. Livraison en 2 semaines.",
  "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://www.agence-aurore.fr" },
  "areaServed": "France",
  "offers": { "@type": "Offer", "name": "Pack Vitrine", "price": "690", "priceCurrency": "EUR", "description": "Site vitrine jusqu'à 6 pages avec blog, espace rédaction, SEO et fiche Google Business." }
};
---

<BaseLayout
  title="Création de site vitrine professionnel, À partir de 690 € | aurore"
  description="Site vitrine professionnel pour artisans et indépendants. SEO, fiche Google, emails pro, hébergement gratuit. Livraison en 2 semaines. À partir de 690 €. aurore, Aix-en-Provence."
  slug="creation-site-web/site-vitrine"
  schema={[serviceSchema, faqSchema, catalogSchema]}
>

  <section class="service-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow"><span class="eyebrow-line" aria-hidden="true"></span>Site vitrine · aurore<span class="eyebrow-line" aria-hidden="true"></span></div>
      <h1 class="service-h1">Votre site vitrine,<br /><span class="hero-serif">clé en main.</span></h1>
      <p class="service-sub">Site, emails professionnels, SEO et Google Business, tout ce qu'il faut pour exister en ligne et être trouvé par vos clients locaux. À partir de 690 €.</p>
      <div class="hero-ctas">
        <a href="/contact/" class="btn btn-primary btn-lg">Demander un devis →</a>
        <a href="/tarifs/" class="btn btn-outline btn-lg">Voir les tarifs</a>
      </div>
    </div>
  </section>

  <!-- INCLUS -->
  <section class="section">
    <div class="container">
      <span class="section-label fade-in">Ce qui est inclus</span>
      <h2 class="section-title fade-in">Tout ce dont vous avez besoin,<br />rien de superflu.</h2>
      <div class="inclus-grid fade-in" style="margin-top:48px;">
        {[
          { titre:"Design sur mesure",        desc:"Maquette unique à votre activité et votre image. Pas de template générique." },
          { titre:"Jusqu'à 8 pages",          desc:"Accueil, Services, À propos, Contact, Blog, selon vos besoins." },
          { titre:"Logo + charte graphique",  desc:"Logotype, palette de couleurs, typographies cohérentes avec votre positionnement." },
          { titre:"Nom de domaine",           desc:"Achat, configuration DNS, HTTPS, tout est géré pour vous." },
          { titre:"Emails professionnels",    desc:"Adresses @votre-domaine.fr via Zoho Mail. Opérationnelles le jour J." },
          { titre:"SEO on-page complet",      desc:"Balises, structure, vitesse, Schema.org, Google Business, Search Console." },
          { titre:"Formulaire de contact",    desc:"Formulaire fonctionnel avec notifications email instantanées." },
          { titre:"Site responsive",          desc:"Mobile-first. Testé sur smartphone, tablette et desktop avant livraison." },
        ].map(item => (
          <div class="card inclus-item">
            <div class="inclus-dot" aria-hidden="true"></div>
            <div>
              <h3 class="inclus-titre">{item.titre}</h3>
              <p class="inclus-desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BÉNÉFICES -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <span class="section-label fade-in">Bénéfices concrets</span>
      <h2 class="section-title fade-in">Ce que ça change pour votre activité.</h2>
      <div class="grid-3 fade-in" style="margin-top:48px;">
        {benefices.map(b => (
          <div class="card">
            <h3 style="font-size:16px;font-weight:600;letter-spacing:-0.02em;margin-bottom:8px;">{b.titre}</h3>
            <p style="font-size:14px;line-height:1.65;margin:0;">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PACKS -->
  <section class="section">
    <div class="container">
      <span class="section-label fade-in">Formule</span>
      <h2 class="section-title fade-in">La formule Vitrine.</h2>
      <div class="fade-in" style="margin-top:48px;max-width:400px;margin-left:auto;margin-right:auto;">
        <div class="pricing-card pricing-card-featured">
          <span class="pricing-badge">Recommandé</span>
          <div class="pricing-name">Vitrine</div>
          <div class="pricing-price"><span class="pricing-currency">€</span><span class="pricing-amount">690</span></div>
          <p class="pricing-desc">La solution complète pour une présence professionnelle.</p>
          <ul class="pricing-features">
            {["Site jusqu'à 6 pages","SEO on-page complet + Schema.org","Formulaire de contact","Fiche Google Business optimisée","Espace rédaction inclus","Accès formation vidéo complète"].map(f => (
              <li class="pricing-feature">
                <span class="pricing-check" aria-hidden="true"><svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#FF6B1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>{f}
              </li>
            ))}
          </ul>
          <a href="/contact/" class="btn btn-aurora" style="width:100%;justify-content:center;">Choisir Vitrine</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container" style="max-width:720px;">
      <span class="section-label fade-in">FAQ</span>
      <h2 class="section-title fade-in">Questions sur le site vitrine.</h2>
      <div style="margin-top:36px;" class="fade-in">
        {faqSchema.mainEntity.map((item: any) => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">{item.name}<span class="faq-icon" aria-hidden="true">+</span></button>
            <div class="faq-answer">{item.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section"><div class="container"><div class="cta-section fade-in">
    <h2>Parlons de votre site vitrine.</h2>
    <p>Décrivez votre activité en quelques lignes. Je reviens vers vous sous 48h avec un devis détaillé.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="/contact/" class="btn btn-aurora btn-lg">Demander un devis →</a>
      <a href="/realisations/" class="btn btn-outline btn-lg">Voir les réalisations</a>
    </div>
  </div></div></section>

</BaseLayout>

<style>
  .service-hero { padding:160px 0 80px; text-align:center; }
  .service-h1 { font-family:var(--font-display); font-size:clamp(34px,5vw,62px); font-weight:700; letter-spacing:-0.05em; line-height:1.05; margin:20px 0 16px; }
  .service-sub { font-size:clamp(15px,1.3vw,18px); line-height:1.65; max-width:520px; margin:0 auto 32px; }

  .inclus-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; }
  .inclus-item { display:flex; align-items:flex-start; gap:12px; padding:20px; }
  .inclus-dot  { width:8px; height:8px; border-radius:50%; background:var(--aurora); flex-shrink:0; margin-top:6px; }
  .inclus-titre { font-size:14px; font-weight:600; letter-spacing:-0.01em; margin-bottom:4px; }
  .inclus-desc  { font-size:13px; color:var(--gray-500); line-height:1.55; margin:0; }

  @media (max-width:1024px) { .inclus-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:768px)  { .service-hero { padding:120px 0 56px; } .inclus-grid { grid-template-columns:1fr; } }
</style>