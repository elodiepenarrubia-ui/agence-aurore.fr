---
import BaseLayout from '../../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de site web à Aix-en-Provence",
  "provider": { "@type": "ProfessionalService", "name": "Aurore", "url": "https://www.agence-aurore.fr" },
  "areaServed": "France",
  "description": "Création de sites web professionnels pour TPE et indépendants : site vitrine, site avec réservation, logiciel métier. Hébergement gratuit, livraison en 2 semaines. Basé à Aix-en-Provence.",
  "offers": [
    { "@type": "Offer", "name": "Starter",  "priceCurrency": "EUR", "price": "290"  },
    { "@type": "Offer", "name": "Vitrine",  "priceCurrency": "EUR", "price": "1035"  },
    { "@type": "Offer", "name": "Pro",      "priceCurrency": "EUR", "price": "1290" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Combien coûte la création d'un site web à Aix-en-Provence ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Les tarifs d'aurore commencent à 290 € pour le Starter (site 5 pages, domaine, emails, Google Business, SEO inclus). La formule Vitrine est à 1 035 € et la formule Pro avec réservation en ligne à 1 290 €. Le SEO on-page et la fiche Google Business sont inclus dans toutes les formules." }},
    { "@type": "Question", "name": "Combien de temps faut-il pour créer un site web ?",
      "acceptedAnswer": { "@type": "Answer", "text": "La plupart des sites vitrines sont livrés en 2 semaines à compter du briefing et de la réception de vos contenus. Les sites avec réservation ou les logiciels métier peuvent nécessiter 3 à 4 semaines selon la complexité." }},
    { "@type": "Question", "name": "Quel est l'avantage de Vercel par rapport à un hébergement classique ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Vercel est un hébergement statique gratuit, fiable (SLA 99,9 %) et maintenu par Microsoft. Il n'y a aucun frais mensuel, aucune base de données à maintenir, aucune mise à jour de serveur à gérer. Votre seul coût récurrent est le nom de domaine (~15 €/an)." }},
    { "@type": "Question", "name": "Puis-je modifier le contenu de mon site moi-même ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, avec les formules Vitrine et Pro, un espace de rédaction est intégré au site. Vous pouvez modifier textes, images et articles de blog depuis une interface simple, sans aucune connaissance technique." }},
    { "@type": "Question", "name": "Aurore crée-t-elle des sites WordPress ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Non. Aurore se spécialise dans les sites statiques (HTML/CSS/JS), qui sont plus rapides, plus sécurisés et ne nécessitent aucun hébergement payant. Pour les cas nécessitant un espace de rédaction, un outil custom est développé, sans les lourdeurs ni les failles de sécurité de WordPress." }},
    { "@type": "Question", "name": "Intervenez-vous uniquement à Aix-en-Provence ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Non. Aurore intervient dans toute la France en télétravail. La totalité du projet se déroule à distance : briefing en visio, prévisualisation en ligne, livraison par lien. La qualité est identique quelle que soit votre localisation." }},
  ],
};

const sousServices = [
  { href: "/creation-site-web/site-vitrine/",   titre: "Site vitrine",         desc: "Vos clients vous trouvent, vous contactent et vous font confiance. Jusqu'à 8 pages, visibilité Google complète.", prix: "1 035 €" },
  { href: "/creation-site-web/site-reservation/", titre: "Site avec réservation", desc: "Vos clients réservent et paient en ligne pendant que vous travaillez. Confirmations automatiques incluses.", prix: "1 290 €" },
  { href: "/creation-site-web/logiciel-metier/",  titre: "Logiciel métier",      desc: "Un outil taillé pour votre activité. Vos clients et votre équipe gagnent du temps au quotidien.", prix: "Sur devis" },
];

const benefices = [
  { titre: "En ligne avant la fin du mois",  desc: "Pas de projet qui traîne 3 mois. Vos clients vous trouvent en 2 semaines." },
  { titre: "Zéro abonnement mensuel",       desc: "Votre site tourne 24h/24 sans rien payer chaque mois. Vous êtes propriétaire pour toujours." },
  { titre: "Google vous montre à vos futurs clients", desc: "Quand quelqu'un cherche votre métier près de chez vous, c'est votre site qui apparaît." },
  { titre: "Vos clients vous trouvent sur mobile", desc: "Votre site s'affiche aussi bien sur un téléphone que sur un ordinateur, et il charge en moins d'une seconde." },
  { titre: "Vous n'avez rien à faire",      desc: "Votre adresse web, vos emails pro, votre visibilité Google : tout fonctionne le jour de la livraison." },
  { titre: "Une seule personne, du début à la fin", desc: "Pas de relais entre 3 interlocuteurs. Vous parlez toujours à la même personne, celle qui construit votre site." },
];

const catalogSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de site web",
  "description": "Création de site web clé en main pour artisans, thérapeutes et indépendants. SEO, fiche Google Business et hébergement inclus. Livraison en 2 semaines.",
  "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://www.agence-aurore.fr" },
  "areaServed": "France",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Offres création de site web",
    "itemListElement": [
      { "@type": "Offer", "name": "Pack Starter", "price": "290", "priceCurrency": "EUR", "description": "Site 5 pages, domaine, emails pro, SEO on-page, fiche Google Business inclus." },
      { "@type": "Offer", "name": "Pack Vitrine", "price": "1035", "priceCurrency": "EUR", "description": "Jusqu'à 8 pages, blog, espace rédaction, SEO avancé, fiche Google Business inclus." },
      { "@type": "Offer", "name": "Pack Pro", "price": "1290", "priceCurrency": "EUR", "description": "Jusqu'à 12 pages, réservation en ligne, paiement Stripe, blog, automatisations inclus." }
    ]
  }
};
---

<BaseLayout
  title="Création de site web Aix-en-Provence, Site vitrine, réservation | aurore"
  description="Aurore crée votre site web à Aix-en-Provence et partout en France : Starter dès 290 €, Vitrine 1 035 €, Pro 1 290 €. SEO et fiche Google inclus. Hébergement gratuit, livraison 2 semaines."
  slug="creation-site-web"
  schema={[serviceSchema, faqSchema, catalogSchema]}
>

  <!-- ─── HERO ─── -->
  <section class="service-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Service · Création de site web
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="service-h1">Votre site web professionnel,<br /><span class="hero-serif">livré en 2 semaines.</span></h1>
      <p class="service-sub">Vos clients vous trouvent sur Google, vous contactent directement et reviennent. En ligne avant la fin du mois, à partir de 290 €.</p>
      <div class="hero-ctas">
        <a href="/contact/" class="btn btn-primary btn-lg">Demander un devis →</a>
        <a href="/tarifs/" class="btn btn-outline btn-lg">Voir les tarifs</a>
      </div>
    </div>
  </section>

  <!-- ─── SOUS-SERVICES ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label fade-in">Trois formules</span>
      <h2 class="section-title fade-in">Quel résultat attendez-vous ?</h2>
      <div class="grid-3 fade-in" style="margin-top:48px;">
        {sousServices.map(s => (
          <a href={s.href} class="card service-card sous-service-card">
            <div class="sous-service-prix">{s.prix}</div>
            <h3>{s.titre}</h3>
            <p>{s.desc}</p>
            <span class="service-card-link">En savoir plus →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── BÉNÉFICES ─── -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <span class="section-label fade-in">Pourquoi aurore</span>
      <h2 class="section-title fade-in">Ce que vous obtenez,<br />concrètement.</h2>
      <div class="grid-3 fade-in" style="margin-top:48px;">
        {benefices.map(b => (
          <div class="card benefice-card">
            <div class="benefice-check" aria-hidden="true">
              <svg width="14" height="12" viewBox="0 0 14 12" fill="none"><path d="M1 6l4 4L13 1" stroke="#FF6B1A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3>{b.titre}</h3>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── STACK TECHNIQUE ─── -->
  <section class="section">
    <div class="container">
      <div class="stack-grid fade-in">
        <div>
          <span class="section-label">Technique</span>
          <h2 class="section-title">Pourquoi votre site sera plus rapide et moins cher ?</h2>
          <p class="section-subtitle">Les plateformes classiques vous coûtent 20 à 50 € par mois d'abonnement, nécessitent des mises à jour constantes et ralentissent votre site. La technologie que j'utilise élimine tout ça.</p>
          <ul class="stack-liste" style="margin-top:24px;">
            {[
              "Votre site charge 2 à 5 fois plus vite",
              "Aucune faille de sécurité à surveiller",
              "Zéro abonnement mensuel pour l'hébergement",
              "Sauvegarde automatique de chaque modification",
              "Visible sur Google dès la mise en ligne",
            ].map(item => (
              <li class="stack-item">
                <span class="stack-dot" aria-hidden="true"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="stack-versus">
          <div class="versus-col versus-col-other">
            <div class="versus-titre">WordPress / Wix</div>
            {["20–50 €/mois d'hébergement","Mises à jour permanentes","Failles de sécurité régulières","Chargement lent (3–8 s)","Dépendance au prestataire"].map(i => (
              <div class="versus-item"><span aria-hidden="true">✕</span>{i}</div>
            ))}
          </div>
          <div class="versus-col versus-col-us">
            <div class="versus-titre">aurore</div>
            {["0 € d'hébergement","Aucune mise à jour serveur","Sécurisé par nature","Chargement < 1 s","Code livré, vous êtes propriétaire"].map(i => (
              <div class="versus-item"><span aria-hidden="true">✓</span>{i}</div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container" style="max-width:720px;">
      <span class="section-label fade-in">FAQ</span>
      <h2 class="section-title fade-in">Questions fréquentes sur la création de site web.</h2>
      <div style="margin-top:36px;" class="fade-in">
        {faqSchema.mainEntity.map((item: any) => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              {item.name}<span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer">{item.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="section">
    <div class="container">
      <div class="cta-section fade-in">
        <h2>Prêt à être trouvé par vos futurs clients ?</h2>
        <p>Décrivez votre projet en 2 minutes. Je vous réponds sous 48h avec un devis détaillé.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
          <a href="/contact/" class="btn btn-aurora btn-lg">Demander un devis gratuit →</a>
          <a href="/tarifs/" class="btn btn-outline btn-lg">Voir tous les tarifs</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .service-hero { padding: 160px 0 80px; text-align: center; }
  .service-h1 { font-family:var(--font-display); font-size:clamp(34px,5vw,62px); font-weight:700; letter-spacing:-0.05em; line-height:1.05; margin:20px 0 16px; }
  .service-sub { font-size:clamp(15px,1.3vw,18px); line-height:1.65; max-width:520px; margin:0 auto 32px; }

  .sous-service-card { text-decoration:none; display:flex; flex-direction:column; gap:12px; }
  .sous-service-prix { font-family:var(--font-display); font-size:22px; font-weight:700; letter-spacing:-0.04em; color:var(--aurora); }
  .sous-service-card h3 { font-size:18px; font-weight:600; letter-spacing:-0.02em; color:var(--black); }
  .sous-service-card p { font-size:14px; color:var(--gray-500); line-height:1.65; flex:1; margin:0; }

  .benefice-card { display:flex; flex-direction:column; gap:12px; }
  .benefice-check { width:28px; height:28px; background:var(--aurora-pale); border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .benefice-card h3 { font-size:16px; font-weight:600; letter-spacing:-0.02em; }
  .benefice-card p  { font-size:14px; color:var(--gray-500); line-height:1.6; margin:0; }

  .stack-grid { display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:start; }
  .stack-liste { display:flex; flex-direction:column; gap:10px; padding:0; }
  .stack-item  { display:flex; align-items:center; gap:10px; font-size:14px; color:var(--gray-700); }
  .stack-dot   { width:6px; height:6px; border-radius:50%; background:var(--aurora); flex-shrink:0; }

  .stack-versus { display:grid; grid-template-columns:1fr 1fr; border-radius:var(--radius-lg); overflow:hidden; border:1.5px solid var(--gray-100); }
  .versus-col    { display:flex; flex-direction:column; }
  .versus-titre  { padding:14px 18px; font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; border-bottom:1px solid var(--gray-100); }
  .versus-col-other .versus-titre { background:var(--gray-50); color:var(--gray-500); }
  .versus-col-us    .versus-titre { background:var(--aurora-pale); color:var(--aurora-dark); border-left:1px solid rgba(255,107,26,0.15); }
  .versus-item { display:flex; align-items:center; gap:8px; padding:11px 18px; font-size:13px; border-bottom:1px solid var(--gray-100); }
  .versus-item:last-child { border-bottom:none; }
  .versus-col-other .versus-item { color:var(--gray-500); }
  .versus-col-other .versus-item span { color:var(--gray-300); font-size:11px; }
  .versus-col-us .versus-item    { color:var(--gray-700); font-weight:500; background:var(--aurora-pale); border-left:1px solid rgba(255,107,26,0.12); }
  .versus-col-us .versus-item span { color:var(--aurora); font-weight:700; font-size:11px; }

  @media (max-width:768px) {
    .service-hero { padding:120px 0 56px; }
    .stack-grid   { grid-template-columns:1fr; gap:40px; }
    .stack-versus { grid-template-columns:1fr; }
    .versus-col-us .versus-item { border-left:none; }
  }
</style>
