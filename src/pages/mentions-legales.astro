</BaseLayout>

<style>
  .mentions-h1   { font-family:var(--font-display); font-size:clamp(28px,4vw,44px); font-weight:700; letter-spacing:-0.04em; color:var(--black); margin-bottom:8px; }
  .mentions-date { font-size:13px; color:var(--gray-500); margin-bottom:48px; }

  .prose         { font-size:15px; line-height:1.8; color:var(--gray-700); }
  .prose h2      { font-family:var(--font-display); font-size:18px; font-weight:700; letter-spacing:-0.02em; color:var(--black); margin:40px 0 12px; padding-top:8px; border-top:1.5px solid var(--gray-100); }
  .prose h3      { font-size:15px; font-weight:600; color:var(--black); margin:24px 0 8px; }
  .prose p       { margin:0 0 16px; }
  .prose ul      { padding-left:20px; margin:0 0 16px; }
  .prose li      { margin-bottom:6px; }
  .prose strong  { font-weight:600; color:var(--black); }
  .prose a       { color:var(--aurora); text-decoration:underline; text-underline-offset:3px; }
  .prose a:hover { color:var(--aurora-dark); }
</style>
