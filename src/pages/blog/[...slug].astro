---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

function readingTime(body: string) {
  return Math.max(1, Math.round((body ?? '').split(/\s+/).length / 200));
}

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline":       post.data.title,
  "description":    post.data.description,
  "datePublished":  post.data.date.toISOString(),
  "url":            `https://agence-aurore.fr/blog/${post.id}/`,
  "author": { "@type": "Person", "name": "Élodie", "url": "https://agence-aurore.fr/a-propos/" },
  "publisher": { "@type": "Organization", "name": "Aurore", "url": "https://agence-aurore.fr" },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  slug={`blog/${post.id}`}
  schema={articleSchema}
>

  <article class="article">

    <header class="article-header section-aurora-gradient">
      <div class="container" style="max-width:760px;">
        <div class="article-meta">
          <time datetime={post.data.date.toISOString()} class="article-date">
            {formatDate(post.data.date)}
          </time>
          <span class="article-sep" aria-hidden="true">·</span>
          <span class="article-reading">{readingTime(post.body ?? '')} min de lecture</span>
        </div>
        <h1 class="article-h1">{post.data.title}</h1>
        <p class="article-lead">{post.data.description}</p>
      </div>
    </header>

    <div class="article-body section">
      <div class="container" style="max-width:720px;">
        <div class="article-content prose">
          <Content />
        </div>

        <div class="article-cta-box">
          <p class="article-cta-title">Prêt à passer à l'action ?</p>
          <p class="article-cta-sub">Un devis gratuit en 2 minutes.</p>
          <a href="/contact/" class="btn btn-aurora">Demander un devis →</a>
        </div>

        <footer class="article-footer">
          <div class="article-author card">
            <div class="author-avatar" aria-hidden="true">É</div>
            <div>
              <div class="author-name">Élodie, aurore</div>
              <p class="author-bio">Créatrice de présences digitales pour TPE et indépendants, basée à Aix-en-Provence.</p>
              <a href="/a-propos/" class="author-link">En savoir plus →</a>
            </div>
          </div>

          <nav class="article-nav" aria-label="Navigation blog">
            <a href="/blog/" class="btn btn-ghost">← Retour au blog</a>
          </nav>
        </footer>
      </div>
    </div>

  </article>

</BaseLayout>

<style>
  .article-header  { padding:140px 0 64px; text-align:center; }
  .article-meta    { display:flex; align-items:center; justify-content:center; gap:10px; margin-bottom:20px; }
  .article-date { font-size:13px; color:var(--gray-500); }
  .article-sep { color:var(--gray-300); }
  .article-reading { font-size:13px; color:var(--gray-500); }
  .article-h1 { font-family:var(--font-display); font-size:clamp(26px,4vw,48px); font-weight:700; letter-spacing:-0.04em; line-height:1.1; color:var(--black); margin-bottom:16px; }
  .article-lead { font-size:clamp(15px,1.2vw,18px); line-height:1.65; color:var(--gray-500); max-width:560px; margin:0 auto; }

  .article-footer  { margin-top:64px; display:flex; flex-direction:column; gap:0; }
  .article-author  { display:flex; align-items:flex-start; gap:20px; }
  .author-avatar   { width:48px; height:48px; border-radius:50%; background:var(--aurora-pale); color:var(--aurora); font-family:var(--font-display); font-size:18px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .author-name     { font-size:14px; font-weight:600; color:var(--black); margin-bottom:4px; }
  .author-bio      { font-size:13px; color:var(--gray-500); line-height:1.55; margin:0 0 6px; }
  .author-link     { font-size:13px; color:var(--aurora); text-decoration:none; font-weight:500; }
  .author-link:hover { text-decoration:underline; }

  .article-nav     { margin-top:32px; }

  .article-cta-box { background:var(--aurora-pale); border-radius:12px; padding:32px; margin-top:48px; text-align:center; }
  .article-cta-title { font-weight:700; font-size:18px; margin:0 0 8px; color:var(--black); }
  .article-cta-sub { color:var(--gray-500); margin:0 0 20px; font-size:15px; }

  @media (max-width:768px) {
    .article-header { padding:110px 0 48px; }
    .article-author { flex-direction:column; gap:12px; }
  }
</style>

<!-- Styles prose en is:global car <Content /> génère du HTML hors du scope Astro -->
<style is:global>
  .prose { font-size:17px; line-height:1.9; color:var(--gray-700); word-spacing:0.05em; }
  .prose p         { margin-bottom:1.5rem; line-height:1.9; }
  .prose h2        { font-family:var(--font-display); font-size:1.5rem; font-weight:700; color:#1a1a1a; margin-top:3rem; margin-bottom:1rem; padding-left:16px; border-left:4px solid var(--aurora); }
  .prose h3        { font-family:var(--font-display); font-size:1.15rem; font-weight:700; color:#1a1a1a; margin-top:2rem; margin-bottom:0.75rem; }
  .prose strong    { font-weight:700; color:#1a1a1a; background:linear-gradient(180deg, transparent 60%, rgba(255,107,26,0.15) 60%); padding:0 2px; }

  /* Listes non ordonnées */
  .prose ul        { list-style:none; padding-left:0; margin:1.25rem 0; }
  .prose ul li     { padding-left:24px; position:relative; margin-bottom:0.75rem; line-height:1.8; }
  .prose ul li::before { content:"→"; color:var(--aurora); font-weight:700; position:absolute; left:0; }

  /* Listes ordonnées */
  .prose ol        { counter-reset:step-counter; list-style:none; padding-left:0; margin:1.25rem 0; }
  .prose ol li     { counter-increment:step-counter; padding-left:48px; position:relative; margin-bottom:1rem; line-height:1.8; }
  .prose ol li::before { content:counter(step-counter); position:absolute; left:0; top:2px; width:28px; height:28px; background:var(--aurora); color:white; border-radius:50%; font-size:13px; font-weight:700; display:flex; align-items:center; justify-content:center; }

  .prose a         { color:var(--aurora); text-decoration:underline; text-underline-offset:3px; }
  .prose a:hover   { color:var(--aurora-dark); }

  /* Blockquotes "À retenir" */
  .prose blockquote { background:#FFF4EE; border-left:4px solid var(--aurora); border-radius:0 8px 8px 0; padding:20px 24px; margin:2rem 0; font-style:normal; font-size:15px; line-height:1.8; color:#1a1a1a; }
  .prose blockquote::before { content:"À retenir"; display:block; font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--aurora); margin-bottom:8px; }

  /* Séparateurs */
  .prose hr        { border:none; height:1px; background:linear-gradient(to right, var(--aurora), transparent); margin:3rem 0; opacity:0.4; }

  .prose code      { background:var(--gray-100); padding:2px 6px; border-radius:4px; font-size:0.9em; }
  .prose pre       { background:var(--gray-700); color:var(--white); padding:24px; border-radius:var(--radius-md); overflow-x:auto; margin:24px 0; }
  .prose pre code  { background:none; padding:0; }

  /* Table des matières */
  .toc             { background:#f9f9f9; border-radius:8px; padding:20px 24px; margin-bottom:2.5rem; }
  .toc-title       { font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--aurora); margin:0 0 12px; }
  .toc a           { display:block; font-size:14px; color:#1a1a1a; text-decoration:none; padding:4px 0; border-bottom:1px solid #f0f0f0; background:none; }
  .toc a:hover     { color:var(--aurora); }
  .toc a:last-child { border-bottom:none; }

  /* Badge étape dans les titres */
  .step-badge      { display:inline-flex; align-items:center; justify-content:center; width:32px; height:32px; background:var(--aurora); color:white; border-radius:50%; font-size:14px; font-weight:700; margin-right:12px; flex-shrink:0; vertical-align:middle; }
</style>

<script>
  // Table des matières automatique
  const h2s = document.querySelectorAll('.article-content h2');
  if (h2s.length >= 3) {
    const toc = document.createElement('nav');
    toc.className = 'toc';
    const title = document.createElement('p');
    title.className = 'toc-title';
    title.textContent = 'Dans cet article';
    toc.appendChild(title);
    h2s.forEach((h2, i) => {
      h2.id = 'section-' + i;
      const link = document.createElement('a');
      link.href = '#section-' + i;
      link.textContent = h2.textContent;
      toc.appendChild(link);
    });
    const firstH2 = h2s[0];
    if (firstH2 && firstH2.parentNode) {
      firstH2.parentNode.insertBefore(toc, firstH2);
    }
  }

  // Badges étapes numérotées dans les titres H2/H3
  document.querySelectorAll('.article-content h2, .article-content h3').forEach(heading => {
    const match = heading.textContent.match(/^[ÉéEe]tape\s+(\d+)\s*[:\s - –-]\s*/i);
    if (match) {
      const badge = document.createElement('span');
      badge.className = 'step-badge';
      badge.textContent = match[1];
      heading.textContent = heading.textContent.replace(match[0], '');
      heading.prepend(badge);
    }
  });
</script>
