<script is:inline>
  // GSAP animations spécifiques à la page d'accueil
  // Nav scroll + FAQ accordion sont gérés par BaseLayout
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap === 'undefined') return;
    const { gsap, ScrollTrigger } = window;
    if (typeof ScrollTrigger !== 'undefined') gsap.registerPlugin(ScrollTrigger);

    // Hero
    const tl = gsap.timeline({ delay: 0.1 });
    tl.from('.hero-eyebrow', { y: 20, opacity: 0, duration: 1.0, ease: 'power2.out' })
      .from('.hero-h1',      { y: 28, opacity: 0, duration: 1.2, ease: 'power2.out' }, '-=0.3')
      .from('.hero-serif',   { clipPath: 'inset(0 100% 0 0)', duration: 0.9, ease: 'power3.out' }, '-=0.4')
      .from('.hero-sub',     { y: 20, opacity: 0, duration: 1.0, ease: 'power2.out' }, '-=0.3')
      .from('.hero-ctas',    { y: 16, opacity: 0, duration: 0.9, ease: 'power2.out' }, '-=0.2')
      .from('.hero-metrics', { y: 16, opacity: 0, duration: 0.9, ease: 'power2.out' }, '-=0.1');

    // Orbe
    gsap.to('.aurora-orb', {
      scale: 1.3, opacity: 0.1,
      duration: 10, repeat: -1, yoyo: true, ease: 'sine.inOut'
    });

    // Scroll reveals
    if (typeof ScrollTrigger !== 'undefined') {
      gsap.utils.toArray('.reveal').forEach(el => {
        gsap.from(el, {
          scrollTrigger: { trigger: el, start: 'top 88%' },
          y: 32, opacity: 0, duration: 1.1, ease: 'power2.out'
        });
      });

      gsap.utils.toArray('.reveal-stagger').forEach(container => {
        gsap.from(container.children, {
          scrollTrigger: { trigger: container, start: 'top 82%' },
          y: 28, opacity: 0, stagger: 0.15, duration: 1.0, ease: 'power2.out'
        });
      });
    }
  });
</script>