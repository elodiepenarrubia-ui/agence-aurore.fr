---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Aurore",
  "description": "Création de présence digitale clé en main pour TPE et professionnels. Logo, site web, emails, SEO et automatisations.",
  "url": "https://agence-aurore.fr",
  "email": "elodie@agence-aurore.fr",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Aix-en-Provence",
    "addressRegion": "Provence-Alpes-Côte d'Azur",
    "addressCountry": "FR"
  },
  "areaServed": "France",
  "serviceType": ["Création de site web", "Identité visuelle", "SEO", "Automatisation email"],
  "priceRange": "€€",
  "founder": { "@type": "Person", "name": "Élodie", "jobTitle": "Fondatrice" },
  "sameAs": ["https://agence-aurore.fr", "https://www.linkedin.com/in/elodie-penarrubia"]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Combien coûte la création d'un site web avec aurore ?", "acceptedAnswer": { "@type": "Answer", "text": "Nos tarifs commencent à 290 € pour le Starter et vont jusqu'à 1 290 € pour le pack Pro avec réservation en ligne, blog et automatisations." } },
    { "@type": "Question", "name": "Combien de temps faut-il pour créer un site web ?", "acceptedAnswer": { "@type": "Answer", "text": "La plupart de nos sites sont livrés en 2 semaines." } },
    { "@type": "Question", "name": "Aurore intervient-elle uniquement à Aix-en-Provence ?", "acceptedAnswer": { "@type": "Answer", "text": "Non, aurore intervient dans toute la France." } },
    { "@type": "Question", "name": "Est-ce que je peux modifier mon site moi-même ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui, avec nos formules Vitrine et Pro, un espace de rédaction est intégré. Une formation vidéo est incluse dans toutes les formules." } },
    { "@type": "Question", "name": "Y a-t-il des frais d'hébergement ?", "acceptedAnswer": { "@type": "Answer", "text": "L'hébergement est gratuit grâce à GitHub Pages. Vous ne payez que le nom de domaine (~15 €/an)." } }
  ]
};
---

<BaseLayout
  title="Création de site web Aix-en-Provence | aurore"
  description="Aurore crée votre présence digitale de A à Z : logo, site web, emails professionnels, SEO et automatisations. Basé à Aix-en-Provence. À partir de 290 €."
  slug="/"
  schema={[schema, faqSchema]}
>

  <div class="announcement-bar">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:4px;"><path d="M17 18a5 5 0 0 0-10 0"/><line x1="12" y1="9" x2="12" y2="2"/></svg>
    Site web clé en main à partir de <strong>290 €</strong> · SEO et fiche Google inclus
    <a href="/tarifs/"> Voir les offres →</a>
  </div>

  <!-- ─── HERO ─── -->
  <section class="service-hero" style="background:var(--white);">
    <div class="aurora-orb" id="aurora-orb" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Accueil · Aurore
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="service-h1">
        De l'ombre à la<br /><span class="hero-serif">lumière.</span>
      </h1>
      <p class="service-sub">
        Logo, site web, emails, SEO et automatisations : tout ce dont votre entreprise a besoin pour exister en ligne, livré clé en main en 2 semaines.
      </p>
      <div class="hero-ctas">
        <a href="/tarifs/" class="btn btn-primary btn-lg">Voir les offres →</a>
        <a href="/contact/" class="btn btn-outline btn-lg">Demander un devis gratuit</a>
      </div>
      <div class="hero-metrics">
        <div class="metric">
          <span class="metric-value" data-count="2">0<span>sem.</span></span>
          <span class="metric-label">de délai moyen</span>
        </div>
        <div class="metric-sep" aria-hidden="true"></div>
        <div class="metric">
          <span class="metric-value" data-count="290">0<span>€</span></span>
          <span class="metric-label">à partir de</span>
        </div>
        <div class="metric-sep" aria-hidden="true"></div>
        <div class="metric">
          <span class="metric-value" data-count="100">0<span>%</span></span>
          <span class="metric-label">clé en main</span>
        </div>
        <div class="metric-sep" aria-hidden="true"></div>
        <div class="metric">
          <span class="metric-value" data-count="0">0<span>€</span></span>
          <span class="metric-label">d'hébergement</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SERVICES ─── -->
  <section class="section fade-in" id="services">
    <div class="container">
      <span class="section-label">Ce qu'on crée ensemble</span>
      <h2 class="section-title">Tout ce dont vous avez besoin,<br />rien de superflu.</h2>
      <p class="section-subtitle">Une offre complète pensée pour les artisans, commerçants et professionnels qui veulent une présence digitale sérieuse.</p>
      <div class="services-grid">
        <article class="card service-card">
          <div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
          <h3>Création de site web</h3>
          <p>Sites vitrine, sites avec réservation en ligne, logiciels métier. Rapides, bien référencés, sans frais d'hébergement.</p>
          <a href="/creation-site-web/" class="service-card-link">Découvrir →</a>
        </article>
        <article class="card service-card">
          <div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
          <h3>Identité visuelle</h3>
          <p>Logo, palette de couleurs, typographie, supports print, une marque cohérente qui inspire confiance dès le premier regard.</p>
          <a href="/identite-visuelle/" class="service-card-link">Découvrir →</a>
        </article>
        <article class="card service-card">
          <div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div>
          <h3>Référencement SEO</h3>
          <p>Optimisation on-page, fiche Google Business, Search Console, soyez trouvé par vos clients locaux avant vos concurrents.</p>
          <a href="/referencement-seo/" class="service-card-link">Découvrir →</a>
        </article>
        <article class="card service-card">
          <div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
          <h3>Automatisation</h3>
          <p>Emails transactionnels, rappels de RDV, formulaires intelligents, gagnez du temps sur les tâches répétitives.</p>
          <a href="/automatisation/" class="service-card-link">Découvrir →</a>
        </article>
        <article class="card service-card">
          <div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
          <h3>Logiciel métier</h3>
          <p>Application web sur mesure pour vos processus internes : espace client, tableau de bord, gestion de planning.</p>
          <a href="/creation-site-web/logiciel-metier/" class="service-card-link">Découvrir →</a>
        </article>
        <article class="card card-dark service-card">
          <p style="color:rgba(255,255,255,0.5);font-size:13px;text-transform:uppercase;letter-spacing:0.12em;font-weight:600;">Pack Starter</p>
          <h3 style="color:white;font-size:clamp(22px,2.5vw,32px);margin:8px 0;">Site clé en main<br /><span style="color:var(--aurora);">à 290 €</span></h3>
          <p style="color:rgba(255,255,255,0.6);">Domaine, emails pro, SEO on-page et fiche Google Business inclus dans toutes les formules.</p>
          <a href="/tarifs/" class="btn btn-aurora" style="margin-top:auto;align-self:flex-start;">Voir les offres →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- ─── COMMENT ÇA MARCHE ─── -->
  <section class="section section-aurora-gradient fade-in" id="comment">
    <div class="container">
      <div style="text-align:center;margin-bottom:56px;">
        <span class="section-label">Le processus</span>
        <h2 class="section-title">De zéro à en ligne<br />en 3 étapes.</h2>
      </div>
      <div class="steps-grid">
        <div class="step-large">
          <div class="step-number-large">01</div>
          <h3>Briefing</h3>
          <p>Un formulaire de 2 minutes pour décrire votre activité, vos clients, vos objectifs. Je prépare un devis précis sous 48h.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step-large">
          <div class="step-number-large">02</div>
          <h3>Création</h3>
          <p>Je m'occupe de tout : domaine, design, développement, SEO, emails, fiche Google. Vous validez les étapes clés.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step-large">
          <div class="step-number-large">03</div>
          <h3>Livraison</h3>
          <p>Votre site est en ligne, tous vos accès vous sont remis dans un document récapitulatif. Vous êtes autonome dès le premier jour.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── POURQUOI AURORE ─── -->
  <section class="section fade-in">
    <div class="container">
      <span class="section-label">Pourquoi aurore</span>
      <h2 class="section-title">Pas une agence.<br />Pas un freelance ordinaire.</h2>
      <p class="section-subtitle">Une interlocutrice unique qui gère tout de A à Z, avec la rigueur d'une agence et la réactivité d'un indépendant.</p>
      <div class="why-grid">
        <div class="card">
          <div class="why-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
          <h3>Livraison en 2 semaines</h3>
          <p>Pas de projet qui traîne 3 mois. Grâce au processus rodé, votre site est livré vite, sans sacrifier la qualité.</p>
        </div>
        <div class="card">
          <div class="why-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg></div>
          <h3>Vraiment clé en main</h3>
          <p>Domaine, emails, SEO, Google Business, tout est configuré et opérationnel à la livraison. Rien à faire de votre côté.</p>
        </div>
        <div class="card card-aurora">
          <div class="why-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg></div>
          <h3>Vous restez autonome</h3>
          <p>Avec les formules Vitrine et Pro, un espace rédaction est intégré pour modifier vos textes et publier vos articles. Aucune connaissance technique requise.</p>
        </div>
        <div class="card">
          <div class="why-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
          <h3>0 € d'hébergement</h3>
          <p>GitHub Pages, c'est gratuit et fiable. Vos seuls frais récurrents : le nom de domaine (~15 €/an). Aucun abonnement caché.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TÉMOIGNAGES ─── -->
  <section class="section fade-in" style="background:var(--gray-50);">
    <div class="container">
      <span class="section-label">Ils nous font confiance</span>
      <h2 class="section-title">Ce que disent nos clients.</h2>
      <div class="testimonials-grid">
        <blockquote class="card testimonial">
          <p class="testimonial-quote">« Élodie a créé mon site en 10 jours. Résultat impeccable, elle a compris exactement ce que je voulais sans que j'aie besoin de tout expliquer. »</p>
          <footer class="testimonial-author">
            <div class="testimonial-avatar-placeholder">D</div>
            <div>
              <cite class="testimonial-name">Delphine M.</cite>
              <div class="testimonial-role">Massothérapeute · Brignoles</div>
            </div>
          </footer>
        </blockquote>
        <blockquote class="card testimonial">
          <p class="testimonial-quote">« Notre site pour la conciergerie a été livré clé en main, SEO inclus. On est maintenant en première page Google sur nos mots-clés principaux. »</p>
          <footer class="testimonial-author">
            <div class="testimonial-avatar-placeholder">M</div>
            <div>
              <cite class="testimonial-name">Le Mazarin</cite>
              <div class="testimonial-role">Conciergerie · Aix-en-Provence</div>
            </div>
          </footer>
        </blockquote>
        <div class="card testimonial-cta">
          <svg class="marching-ants" aria-hidden="true"><rect width="100%" height="100%" rx="22" ry="22" fill="none" stroke="var(--aurora)" stroke-width="2" stroke-dasharray="8 6"/></svg>
          <div class="testimonial-cta-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3 class="testimonial-cta-title">Soyez le prochain</h3>
          <p class="testimonial-cta-sub">Rejoignez nos clients et donnez vie à votre présence digitale.</p>
          <a href="/contact/" class="btn btn-aurora">Demander un devis →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="section fade-in" id="faq">
    <div class="container" style="max-width:720px;">
      <span class="section-label">Questions fréquentes</span>
      <h2 class="section-title">Tout ce que vous voulez savoir.</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">Combien coûte la création d'un site web avec aurore ?<span class="faq-icon">+</span></button>
          <div class="faq-answer">Nos tarifs commencent à <strong>290 €</strong> pour le Starter et vont jusqu'à <strong>1 290 €</strong> pour le pack Pro avec réservation en ligne, blog et automatisations. Le SEO on-page et la fiche Google Business sont inclus dans toutes les formules. <a href="/tarifs/" style="color:var(--aurora);">Voir tous les tarifs →</a></div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">Combien de temps faut-il pour créer un site ?<span class="faq-icon">+</span></button>
          <div class="faq-answer">La plupart de nos sites sont livrés en <strong>2 semaines</strong>. Le délai dépend de la complexité du projet et de la réactivité pour fournir les contenus.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">Vous intervenez uniquement à Aix-en-Provence ?<span class="faq-icon">+</span></button>
          <div class="faq-answer">Non, aurore intervient dans <strong>toute la France</strong>. Basée à Aix-en-Provence, nous travaillons à distance avec des clients sur tout le territoire.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">Puis-je modifier mon site moi-même après livraison ?<span class="faq-icon">+</span></button>
          <div class="faq-answer">Oui, avec nos formules <strong>Vitrine</strong> et <strong>Pro</strong>, un espace de rédaction est intégré qui vous permet de modifier textes, images et articles sans aucune connaissance technique. Une formation vidéo est incluse dans toutes les formules.</div>
        </div>
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">Y a-t-il des frais d'hébergement mensuels ?<span class="faq-icon">+</span></button>
          <div class="faq-answer">L'hébergement est <strong>gratuit</strong> grâce à GitHub Pages. Vous ne payez que le nom de domaine (~15 €/an). Aucun abonnement, aucun frais caché.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA FINAL ─── -->
  <section class="section fade-in">
    <div class="container">
      <div class="cta-section">
        <span class="section-label" style="color:var(--aurora);">On commence ?</span>
        <h2>Parlons de votre projet.</h2>
        <p>Un formulaire de 2 minutes suffit pour recevoir un devis détaillé sous 48h.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:32px;">
          <a href="/contact/" class="btn btn-aurora btn-lg">Demander un devis →</a>
          <a href="/realisations/" class="btn btn-outline btn-lg">Voir les réalisations</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .service-hero { padding: 120px 0 80px; text-align: center; position: relative; overflow: hidden; }
  .service-hero > .container { position: relative; z-index: 1; }
  .service-h1 { font-family: var(--font-display); font-size: clamp(34px,5vw,62px); font-weight: 700; letter-spacing: -0.05em; line-height: 1.05; margin: 20px 0 16px; }
  .service-sub { font-size: clamp(15px,1.3vw,18px); line-height: 1.65; max-width: 520px; margin: 0 auto 32px; color: var(--gray-700); }
  .metric-value span { font-size: 0.55em; letter-spacing: -0.02em; opacity: 0.7; }
  .metric-sep { width: 1px; height: 32px; background: var(--gray-300); flex-shrink: 0; }

  .services-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-top: 48px; }
  .service-card-link { margin-top: auto; }

  .steps-grid { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; gap: 24px; align-items: start; }
  .step-large { display: flex; flex-direction: column; gap: 12px; }
  .step-number-large { font-family: var(--font-display); font-size: 48px; font-weight: 800; letter-spacing: -0.05em; color: var(--aurora); line-height: 1; }
  .step-large h3 { font-size: 20px; font-weight: 700; color: var(--black); }
  .step-large p { font-size: 15px; color: var(--gray-700); line-height: 1.65; }
  .step-arrow { font-size: 28px; color: var(--aurora); opacity: 0.4; padding-top: 16px; }

  .why-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 20px; margin-top: 48px; }
  .why-icon { margin-bottom: 8px; }
  .why-grid h3 { font-size: 18px; font-weight: 600; color: var(--black); margin-bottom: 8px; }
  .why-grid p { font-size: 14px; color: var(--gray-500); line-height: 1.65; }

  .testimonials-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-top: 48px; }
  .testimonial { display: flex; flex-direction: column; gap: 20px; }
  .testimonial-quote { font-size: 15px; color: var(--gray-700); line-height: 1.7; font-style: italic; flex: 1; }
  .testimonial-author { display: flex; align-items: center; gap: 12px; }
  .testimonial-avatar-placeholder { width: 40px; height: 40px; border-radius: 50%; background: var(--aurora-pale); color: var(--aurora); font-weight: 700; font-size: 16px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .testimonial-name { font-size: 14px; font-weight: 600; color: var(--black); font-style: normal; display: block; }
  .testimonial-role { font-size: 13px; color: var(--gray-500); }

  .testimonial-cta { background: var(--aurora-pale); border: none !important; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 16px; position: relative; overflow: hidden; }
  .marching-ants { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }
  .marching-ants rect { animation: marchingAnts 2s linear infinite; }
  @keyframes marchingAnts { to { stroke-dashoffset: -28; } }
  .testimonial-cta-title { font-size: 20px; font-weight: 700; letter-spacing: -0.03em; color: var(--black); }
  .testimonial-cta-sub { font-size: 14px; color: var(--gray-500); line-height: 1.6; max-width: 240px; }

  .faq-list { margin-top: 40px; }
  .faq-item { border-bottom: 1px solid var(--gray-100); }
  .faq-question { width: 100%; text-align: left; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 0; font-size: 16px; font-weight: 600; color: var(--black); cursor: pointer; background: none; border: none; font-family: var(--font-display); transition: color 0.2s ease; }
  .faq-question:hover { color: var(--aurora); }
  .faq-icon { width: 28px; height: 28px; border-radius: 50%; background: var(--gray-100); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; color: var(--gray-500); transition: all 0.2s ease; }
  .faq-item.open .faq-icon { background: var(--aurora-pale); color: var(--aurora); transform: rotate(45deg); }
  .faq-answer { font-size: 15px; color: var(--gray-700); line-height: 1.7; padding-bottom: 20px; display: none; }
  .faq-item.open .faq-answer { display: block; }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2,1fr); }
