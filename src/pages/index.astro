<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ─── PARALLAX HERO ORB ───
    if (!reducedMotion) {
      var orb = document.getElementById('aurora-orb');
      if (orb) {
        window.addEventListener('scroll', function() {
          orb.style.transform = 'translate(-50%, -50%) translateY(' + (window.scrollY * 0.3) + 'px)';
        }, { passive: true });
      }
    }
  });
</script>