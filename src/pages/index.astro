---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Aurore",
  "description": "Création de sites web clé en main pour TPE, artisans et indépendants. Livraison en 2 semaines, hébergement inclus.",
  "url": "https://www.agence-aurore.fr",
  "telephone": "+33659659218",
  "email": "elodie@agence-aurore.fr",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "17 rue Fermée",
    "addressLocality": "Aix-en-Provence",
    "postalCode": "13100",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "43.5297",
    "longitude": "5.4474"
  },
  "areaServed": "France",
  "priceRange": "€€",
  "founder": {
    "@type": "Person",
    "name": "Élodie Penarrubia"
  },
  "sameAs": [
    "https://maps.app.goo.gl/ufBFSYzddh9PQzhw6"
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Combien coûte la création d'un site web avec aurore ?", "acceptedAnswer": { "@type": "Answer", "text": "Nos tarifs commencent à 290 € pour le Starter et vont jusqu'à 1 290 € pour le pack Pro avec réservation en ligne, blog et automatisations. Le SEO on-page et la fiche Google Business sont inclus dans toutes les formules." } },
    { "@type": "Question", "name": "Combien de temps faut-il pour créer un site web ?", "acceptedAnswer": { "@type": "Answer", "text": "La plupart de nos sites sont livrés en 2 semaines. Le délai dépend de la complexité du projet et de la réactivité pour fournir les contenus." } },
    { "@type": "Question", "name": "Vous intervenez uniquement à Aix-en-Provence ?", "acceptedAnswer": { "@type": "Answer", "text": "Non, aurore intervient dans toute la France. Basée à Aix-en-Provence, nous travaillons à distance avec des clients sur tout le territoire." } },
    { "@type": "Question", "name": "Puis-je modifier mon site moi-même après livraison ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui, avec nos formules Vitrine et Pro, un espace de rédaction est intégré qui vous permet de modifier textes, images et articles sans aucune connaissance technique. Une formation vidéo est incluse dans toutes les formules." } },
    { "@type": "Question", "name": "Y a-t-il des frais d'hébergement mensuels ?", "acceptedAnswer": { "@type": "Answer", "text": "L'hébergement est gratuit grâce à GitHub Pages. Vous ne payez que le nom de domaine (~15 €/an). Aucun abonnement, aucun frais caché." } },
    { "@type": "Question", "name": "Pourquoi vos tarifs sont-ils inférieurs à ceux d'une agence classique ?", "acceptedAnswer": { "@type": "Answer", "text": "Aurore est une auto-entreprise avec zéro frais généraux : pas de locaux, pas d'équipe commerciale, pas d'intermédiaire. Vous payez uniquement le travail de création." } },
    { "@type": "Question", "name": "Est-ce que je reste propriétaire de mon site ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui, entièrement. Votre site, votre code, votre domaine vous appartiennent à 100%. Vous pouvez partir avec votre site à tout moment, sans frais ni blocage." } },
    { "@type": "Question", "name": "Quelle est la différence entre vos formules Starter, Vitrine et Pro ?", "acceptedAnswer": { "@type": "Answer", "text": "Le Starter est idéal pour démarrer avec une présence efficace en 5 pages. La Vitrine ajoute un blog, des pages supplémentaires et un espace pour gérer votre contenu vous-même (8 pages). Le Pro est conçu pour aller plus loin avec 12 pages, prise de rendez-vous, paiement en ligne et automatisations. Le SEO et la fiche Google Business sont inclus dans toutes les formules." } },
    { "@type": "Question", "name": "Mon site sera-t-il visible sur Google dès la mise en ligne ?", "acceptedAnswer": { "@type": "Answer", "text": "Votre site est optimisé pour le référencement dès le premier jour. L'indexation prend 1 à 4 semaines. Les premiers résultats concrets arrivent en 1 à 3 mois selon votre secteur." } },
    { "@type": "Question", "name": "Comment fournir mes textes et mes photos ?", "acceptedAnswer": { "@type": "Answer", "text": "Après votre commande vous recevez un formulaire guidé qui vous demande tout ce dont on a besoin, étape par étape. Pas besoin de tout avoir prêt dès le départ." } },
    { "@type": "Question", "name": "Quelle différence avec une agence web classique ?", "acceptedAnswer": { "@type": "Answer", "text": "Une agence classique facture entre 2 000 et 8 000€ avec des délais de 2 à 4 mois et des interlocuteurs multiples. Aurore propose un interlocuteur unique, des délais de 2 semaines, des tarifs accessibles et zéro frais récurrents." } },
    { "@type": "Question", "name": "Est-ce que mon site fonctionnera sur mobile ?", "acceptedAnswer": { "@type": "Answer", "text": "Tous les sites Aurore sont conçus en priorité pour mobile, où se font plus de 70% des recherches locales. Votre site s'affiche parfaitement sur smartphone, tablette et ordinateur." } },
    { "@type": "Question", "name": "Que se passe-t-il si le résultat ne me convient pas ?", "acceptedAnswer": { "@type": "Answer", "text": "Chaque projet inclut des allers-retours de révision avant la mise en ligne. Vous validez votre site avant de régler le solde. Vous ne payez le reste que quand vous êtes satisfait." } },
    { "@type": "Question", "name": "Puis-je avoir un blog ou publier des actualités ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui, avec les formules Vitrine et Pro. Vous disposez d'un espace de rédaction simple pour publier vos articles et actualités. Chaque article publié renforce votre référencement sur Google." } },
    { "@type": "Question", "name": "Aurore travaille-t-elle avec tous les secteurs d'activité ?", "acceptedAnswer": { "@type": "Answer", "text": "Aurore travaille principalement avec des artisans, thérapeutes, professions libérales, commerçants, conciergeries et restaurants. Chaque site est créé sur mesure selon votre secteur et votre clientèle cible." } },
    { "@type": "Question", "name": "Comment se passe le suivi après la livraison ?", "acceptedAnswer": { "@type": "Answer", "text": "Vous recevez une formation vidéo pour prendre en main votre site en autonomie. Un suivi est assuré pendant 30 jours après la livraison. Pour tout besoin ultérieur, une assistance est disponible sur devis." } },
    { "@type": "Question", "name": "Puis-je migrer mon site existant vers Aurore ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui. Que vous soyez sur WordPress, Wix ou Squarespace, on reprend votre contenu, on l'optimise et on le reconstruit sur une base moderne. Votre adresse web reste la même, sans interruption de service." } },
    { "@type": "Question", "name": "Pourquoi ne pas faire mon site moi-même sur Wix ?", "acceptedAnswer": { "@type": "Answer", "text": "Faire son site sur Wix prend du temps, donne souvent un résultat générique et coûte en abonnements mensuels sans jamais vous appartenir. Avec Aurore, vous êtes en ligne en 2 semaines avec un site sur mesure qui vous appartient." } },
    { "@type": "Question", "name": "Qu'est-ce que le référencement local et pourquoi c'est important ?", "acceptedAnswer": { "@type": "Answer", "text": "Le référencement local cible les recherches géolocalisées comme 'plombier Marseille' ou 'massothérapeute Aix-en-Provence'. C'est ce qui vous fait apparaître quand un client cherche votre métier près de chez lui." } },
    { "@type": "Question", "name": "Est-ce qu'Aurore propose des formations pour gérer mon site ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui. Une formation vidéo est incluse dans toutes les formules. Elle couvre la prise en main de votre espace rédaction, la publication d'articles et les bonnes pratiques pour maintenir votre référencement." } },
    { "@type": "Question", "name": "Comment démarrer un projet avec Aurore ?", "acceptedAnswer": { "@type": "Answer", "text": "Remplissez le formulaire de contact en 2 minutes. Je vous envoie un devis détaillé sous 48h. Vous réglez 50% pour démarrer, je crée votre site en 2 semaines, vous validez et votre site est en ligne." } }
  ]
};

const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Aurore",
  "url": "https://www.agence-aurore.fr",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "2",
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": [
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Delphine M." },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Élodie a créé mon site en 10 jours. Résultat impeccable, elle a compris exactement ce que je voulais sans que j'aie besoin de tout expliquer.",
      "datePublished": "2025-11-01",
      "publisher": { "@type": "Organization", "name": "Aurore" }
    },
    {
      "@type": "Review",
      "author": { "@type": "Organization", "name": "Le Mazarin" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Notre site a été livré clé en main, SEO inclus. On est maintenant en première page Google sur nos mots-clés principaux.",
      "datePublished": "2025-12-01",
      "publisher": { "@type": "Organization", "name": "Aurore" }
    }
  ]
};
---

<BaseLayout
  title="Création de site web Aix-en-Provence | aurore"
  description="Site web professionnel livré en 2 semaines à partir de 290 €. Logo, SEO, emails pro et fiche Google inclus. Hébergement gratuit. aurore, Aix-en-Provence."
  slug="/"
  schema={[schema, faqSchema, reviewSchema]}
>

  <div class="announcement-bar">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:4px;"><path d="M17 18a5 5 0 0 0-10 0"/><line x1="12" y1="9" x2="12" y2="2"/></svg>
    Vos futurs clients vous trouvent sur Google dès le premier mois
    <a href="/tarifs/"> Découvrir comment →</a>
  </div>

  <!-- ─── HERO ─── -->
  <section class="service-hero" style="background: radial-gradient(ellipse at 60% 50%, rgba(255, 107, 26, 0.12) 0%, transparent 70%), #ffffff;">
    <div class="aurora-orb" id="aurora-orb" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Accueil · Aurore
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="service-h1">
        Votre site web professionnel, livré en 2 semaines<br /><span class="hero-serif">à partir de 290 €</span>
      </h1>
      <p class="service-sub">
        Votre site, votre logo, vos emails pro et votre visibilité sur Google : tout est prêt, vous n'avez qu'à accueillir vos premiers clients.
      </p>
      <div class="hero-pills">
        <a href="/site-web-massotherapeute/" class="hero-pill">Thérapeute</a>
        <a href="/site-web-artisan/" class="hero-pill">Artisan</a>
        <a href="/site-web-conciergerie/" class="hero-pill">Conciergerie</a>
        <a href="/site-web-restaurant/" class="hero-pill">Restaurant</a>
      </div>
      <div class="hero-ctas">
        <a href="/tarifs/" class="btn btn-primary btn-lg">Voir ce qui est inclus →</a>
        <a href="/contact/" class="btn btn-outline btn-lg">Parler de mon projet</a>
      </div>
      <div class="hero-metrics">
        <div class="metric">
          <span class="metric-value" data-counter data-target="2">2<span>sem.</span></span>
          <span class="metric-label">en ligne avant la fin du mois</span>
        </div>
        <div class="metric-sep" aria-hidden="true"></div>
        <div class="metric">
          <span class="metric-value" data-counter data-target="290">290<span>€</span></span>
          <span class="metric-label">votre premier client le rembourse</span>
        </div>
        <div class="metric-sep" aria-hidden="true"></div>
        <div class="metric">
          <span class="metric-value" data-counter data-target="100">100<span>%</span></span>
          <span class="metric-label">vous n'avez rien à faire</span>
        </div>
        <div class="metric-sep" aria-hidden="true"></div>
        <div class="metric">
          <span class="metric-value">0<span>€</span></span>
          <span class="metric-label">d'abonnement mensuel, jamais</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SERVICES ─── -->
  <section class="section fade-in" id="services">
    <div class="container">
      <span class="section-label">Ce que ça change pour vous</span>
      <h2 class="section-title">Des clients qui vous trouvent,<br />vous contactent et reviennent.</h2>
      <p class="section-subtitle">Chaque brique de votre présence en ligne a un seul objectif : vous apporter des clients concrets.</p>
      <div class="services-grid">
        <article class="card service-card">
          <div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></div>
          <h3>Création de site web</h3>
          <p>Vos clients vous trouvent sur Google, découvrent ce que vous faites et vous contactent directement. Sans abonnement mensuel.</p>
          <a href="/creation-site-web/" class="service-card-link">Découvrir →</a>
        </article>
        <article class="card service-card">
          <div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
          <h3>Identité visuelle</h3>
          <p>Vos clients vous reconnaissent au premier coup d'oeil. Un logo et une image qui inspirent confiance avant même que vous ayez parlé.</p>
          <span class="service-card-option">En option avec chaque pack</span>
          <a href="/identite-visuelle/" class="service-card-link">Découvrir →</a>
        </article>
        <article class="card service-card">
          <div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div>
          <h3>Référencement SEO</h3>
          <p>Quand quelqu'un cherche votre métier près de chez vous, c'est votre nom qui apparaît. Pas celui de votre concurrent.</p>
          <a href="/referencement-seo/" class="service-card-link">Découvrir →</a>
        </article>
        <article class="card service-card">
          <div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
          <h3>Automatisation</h3>
          <p>Chaque nouveau contact reçoit une réponse immédiate, même le dimanche à 23h. Vous ne manquez plus aucune opportunité.</p>
          <a href="/automatisation/" class="service-card-link">Découvrir →</a>
        </article>
        <article class="card service-card">
          <div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></div>
          <h3>Logiciel métier</h3>
          <p>Un outil taillé pour votre activité : vos clients réservent, paient et suivent leur dossier en ligne pendant que vous travaillez.</p>
          <a href="/creation-site-web/logiciel-metier/" class="service-card-link">Découvrir →</a>
        </article>
        <article class="card card-dark service-card">
          <p style="color:rgba(255,255,255,0.5);font-size:13px;text-transform:uppercase;letter-spacing:0.12em;font-weight:600;">Pack Starter</p>
          <h3 style="color:white;font-size:clamp(22px,2.5vw,32px);margin:8px 0;">Visible sur Google<br /><span style="color:var(--aurora);">dès 290 €</span></h3>
          <p style="color:rgba(255,255,255,0.6);">Votre site, vos emails pro et votre fiche Google : tout ce qu'il faut pour que vos clients vous trouvent.</p>
          <a href="/simulateur/" class="btn btn-aurora" style="margin-top:auto;align-self:flex-start;">Calculer mon budget →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- ─── COMMENT ÇA MARCHE ─── -->
  <section class="section section-aurora-gradient fade-in" id="comment">
    <div class="container">
      <div style="text-align:center;margin-bottom:56px;">
        <span class="section-label">Le processus</span>
        <h2 class="section-title">En ligne avant la fin du mois,<br />en 3 étapes.</h2>
      </div>
      <div class="steps-grid">
        <div class="step-large">
          <div class="step-number-large">01</div>
          <h3>Briefing</h3>
          <p>Décrivez votre activité en 2 minutes. Je vous réponds sous 48h avec un plan clair et un devis détaillé, sans engagement.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step-large">
          <div class="step-number-large">02</div>
          <h3>Création</h3>
          <p>Je m'occupe de tout : votre adresse web, votre design, votre visibilité Google, vos emails pro. Vous validez, c'est tout.</p>
        </div>
        <div class="step-arrow">→</div>
        <div class="step-large">
          <div class="step-number-large">03</div>
          <h3>Livraison</h3>
          <p>Votre site est en ligne, vos clients peuvent vous trouver et vous contacter. Tous vos accès vous sont remis, vous êtes autonome.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── POURQUOI AURORE ─── -->
  <section class="section fade-in">
    <div class="container">
      <span class="section-label">Pourquoi aurore</span>
      <h2 class="section-title">Pas une agence.<br />Pas un freelance ordinaire.</h2>
      <p class="section-subtitle">Une seule interlocutrice qui gère tout de A à Z. Vous savez toujours où en est votre projet et à qui parler.</p>
      <div class="why-grid">
        <div class="card">
          <div class="why-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
          <h3>En ligne avant la fin du mois</h3>
          <p>Pas de projet qui traîne 3 mois. Vos clients vous trouvent en ligne dans 2 semaines, pas dans 6 mois.</p>
        </div>
        <div class="card">
          <div class="why-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg></div>
          <h3>Vous n'avez rien à faire</h3>
          <p>Votre adresse web, vos emails pro, votre visibilité Google : tout fonctionne le jour de la livraison. Zéro configuration de votre côté.</p>
        </div>
        <div class="card card-aurora">
          <div class="why-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg></div>
          <h3>Vous restez autonome</h3>
          <p>Publiez vos actualités et modifiez vos textes vous-même, sans appeler personne. Une formation vidéo est incluse pour vous guider.</p>
        </div>
        <div class="card">
          <div class="why-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--aurora)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
          <h3>Zéro abonnement mensuel</h3>
          <p>Votre site tourne 24h/24 sans rien payer chaque mois. Vos seuls frais : le nom de domaine (~15 €/an). Vous êtes propriétaire pour toujours.</p>
        </div>
      </div>
      <div class="elodie-block">
        <img src="/elodie.webp" alt="Élodie Penarrubia - Fondatrice d'Aurore" class="elodie-portrait" />
        <div class="elodie-text">
          <p class="elodie-quote">
            "J'ai moi-même galéré à trouver un prestataire web fiable quand je gérais ma conciergerie.
            Aujourd'hui, je crée pour vous le service que j'aurais aimé trouver à l'époque."
          </p>
          <p class="elodie-signature">
            <strong>Élodie Penarrubia</strong> · Fondatrice d'Aurore · Aix-en-Provence
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TÉMOIGNAGES ─── -->
  <section class="section fade-in" style="background:var(--gray-50);">
    <div class="container">
      <span class="section-label">Résultats concrets</span>
      <h2 class="section-title">Ce que ça a changé pour eux.</h2>
      <div class="testimonials-grid">
        <blockquote class="card testimonial">
          <p class="testimonial-quote">« Élodie a créé mon site en 10 jours. Résultat impeccable, elle a compris exactement ce que je voulais sans que j'aie besoin de tout expliquer. »</p>
          <footer class="testimonial-author">
            <div class="testimonial-avatar-placeholder">D</div>
            <div>
              <cite class="testimonial-name">Delphine M.</cite>
              <div class="testimonial-role">Massothérapeute · Brignoles</div>
              <div class="testimonial-stars">★★★★★</div>
            </div>
          </footer>
        </blockquote>
        <blockquote class="card testimonial">
          <p class="testimonial-quote">« Notre site pour la conciergerie a été livré clé en main, SEO inclus. On est maintenant en première page Google sur nos mots-clés principaux. »</p>
          <footer class="testimonial-author">
            <div class="testimonial-avatar-placeholder">M</div>
            <div>
              <cite class="testimonial-name">Le Mazarin</cite>
              <div class="testimonial-role">Conciergerie · Aix-en-Provence</div>
              <div class="testimonial-stars">★★★★★</div>
            </div>
          </footer>
        </blockquote>
        <div class="card testimonial-cta">
          <svg class="marching-ants" aria-hidden="true"><rect width="100%" height="100%" rx="22" ry="22" fill="none" stroke="var(--aurora)" stroke-width="2" stroke-dasharray="8 6"/></svg>
          <div class="testimonial-cta-icon">
