---
import BaseLayout from '../layouts/BaseLayout.astro';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Squarespace vs site sur mesure : le vrai comparatif",
  "description": "Squarespace est beau mais cher et limité. 16 à 49€/mois pour un site que vous ne possédez pas. Comparatif honnête Squarespace vs aurore.",
  "author": { "@type": "Person", "name": "Élodie", "jobTitle": "Fondatrice d'Aurore" },
  "publisher": { "@type": "Organization", "name": "Aurore", "url": "https://agence-aurore.fr" },
  "datePublished": "2026-03-26",
  "url": "https://agence-aurore.fr/alternatives-squarespace/"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Squarespace est-il vraiment si limité ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Pour un site vitrine basique, Squarespace fait le travail. Les limitations apparaissent quand vous voulez personnaliser, intégrer des outils spécifiques ou optimiser votre SEO en profondeur."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je récupérer mon contenu si je quitte Squarespace ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Squarespace permet d'exporter une partie du contenu, mais pas le design ni toutes les pages. Je récupère tout manuellement lors d'une migration."
      }
    },
    {
      "@type": "Question",
      "name": "Mon SEO sera-t-il préservé en migrant ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, les redirections sont mises en place et votre contenu optimisé est conservé."
      }
    },
    {
      "@type": "Question",
      "name": "Squarespace est-il bon pour le SEO ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Les bases sont couvertes, mais les options avancées (Schema.org personnalisé, vitesse, données structurées) sont limitées ou absentes."
      }
    }
  ]
};

const comparatif = [
  { critere: "Prix",                     sqsp: "16–49 €/mois (192–588 €/an)", aurore: "Investissement unique 290–1 290 €" },
  { critere: "Propriété du site",        sqsp: "Non, vous louez",              aurore: "Oui, code source inclus" },
  { critere: "Hébergement",              sqsp: "Inclus dans l'abonnement",     aurore: "Gratuit à vie (GitHub Pages)" },
  { critere: "Templates",               sqsp: "Beaux mais fixes",             aurore: "100 % sur mesure" },
  { critere: "Flexibilité technique",   sqsp: "Très limitée",                 aurore: "Totale" },
  { critere: "SEO",                      sqsp: "Basique",                      aurore: "Complet inclus" },
  { critere: "Vitesse",                  sqsp: "Moyenne (JS lourd)",           aurore: "Ultra-rapide (site statique)" },
  { critere: "Export du site",           sqsp: "Partiel uniquement",           aurore: "Code source livré" },
  { critere: "Mention Squarespace",     sqsp: "Visible sur certains plans",   aurore: "Aucune" },
];

const calculs = [
  { plan: "Personal",  prix: "16 €/mois", total: "576 €", note: "fonctions limitées, pas d'e-commerce" },
  { plan: "Business",  prix: "23 €/mois", total: "828 €", note: "commission 3 % sur les ventes" },
  { plan: "Commerce",  prix: "49 €/mois", total: "1 764 €", note: "pour les fonctions e-commerce avancées" },
];

const blocages = [
  {
    titre: "Vous voulez une fonctionnalité spécifique",
    desc: "Si Squarespace ne la propose pas, vous ne pouvez pas l'ajouter. Pas de code personnalisé, pas de liberté.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`
  },
  {
    titre: "Squarespace augmente ses prix",
    desc: "Vous n'avez aucun recours — c'est payer ou partir. Et partir signifie tout reconstruire.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>`
  },
  {
    titre: "Vous voulez changer d'hébergeur",
    desc: "Impossible — votre site est prisonnier de Squarespace. Aucune exportation complète, aucun transfert.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`
  },
  {
    titre: "Votre site grossit",
    desc: "Les limitations techniques de Squarespace deviennent bloquantes à mesure que votre activité se développe.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`
  },
  {
    titre: "Vous voulez un vrai SEO technique",
    desc: "Les options avancées — Schema.org personnalisé, optimisation de la vitesse, données structurées — ne sont pas disponibles.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="m8 11 2 2 4-4"/></svg>`
  },
];

const migrationPoints = [
  {
    texte: "Récupération de tout votre contenu existant",
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`
  },
  {
    texte: "Reconstruction en code pur, rapide et léger",
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`
  },
  {
    texte: "Conservation de votre domaine actuel",
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`
  },
  {
    texte: "SEO préservé + redirections mises en place",
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`
  },
];
---

<BaseLayout
  title="Squarespace vs site sur mesure : le vrai comparatif | aurore"
  description="Squarespace est beau mais cher et limité. 16 à 49€/mois pour un site que vous ne possédez pas. Comparatif honnête Squarespace vs aurore."
  slug="alternatives-squarespace"
  schema={[articleSchema, faqSchema]}
>

  <!-- ─── HERO ─── -->
  <section class="sqsp-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Comparatif honnête
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="sqsp-h1">Squarespace est élégant.<br />Mais vous ne serez jamais propriétaire.</h1>
      <p class="hero-serif">Ce que le design cache.</p>
      <p class="sqsp-sub">Des templates magnifiques, une interface intuitive — et un abonnement mensuel à vie pour un site qui ne vous appartient pas. Voici la vérité sur Squarespace.</p>
      <div class="hero-ctas">
        <a href="/simulateur/" class="btn btn-primary btn-lg">Calculer mon économie →</a>
        <a href="/tarifs/" class="btn btn-outline btn-lg">Voir les tarifs</a>
      </div>
    </div>
  </section>

  <!-- ─── TABLEAU COMPARATIF ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label reveal">Ce que Squarespace ne vous dit pas</span>
      <h2 class="section-title reveal">Squarespace, c'est 16 €/mois minimum.<br />Et ça monte vite.</h2>
      <p class="section-subtitle reveal">Un comparatif point par point, sans parti pris. Les faits, rien que les faits.</p>

      <div class="comparatif-table reveal" style="margin-top: 48px;">
        <!-- En-tête -->
        <div class="comparatif-row comparatif-header">
          <div class="comparatif-cell comparatif-critere"></div>
          <div class="comparatif-cell comparatif-col-sqsp">Squarespace</div>
          <div class="comparatif-cell comparatif-col-aurore">aurore</div>
        </div>
        <!-- Lignes -->
        {comparatif.map(row => (
          <div class="comparatif-row">
            <div class="comparatif-cell comparatif-critere">{row.critere}</div>
            <div class="comparatif-cell comparatif-col-sqsp">
              <span class="comparatif-icon comparatif-icon-sqsp" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3.5 3.5l7 7M10.5 3.5l-7 7" stroke="#DC2626" stroke-width="1.6" stroke-linecap="round"/></svg>
              </span>
              {row.sqsp}
            </div>
            <div class="comparatif-cell comparatif-col-aurore">
              <span class="comparatif-icon comparatif-icon-aurore" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2.5 7.5l3 3L11.5 4" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              {row.aurore}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CALCUL SUR 3 ANS ─── -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <span class="section-label reveal">Le calcul que Squarespace ne veut pas que vous fassiez</span>
      <h2 class="section-title reveal">Sur 3 ans, Squarespace coûte plus cher<br />qu'un site sur mesure.</h2>

      <div class="calcul-grid reveal" style="margin-top: 48px;">
        {calculs.map(item => (
          <div class="calcul-card card">
            <div class="calcul-plan">{item.plan}</div>
            <div class="calcul-prix">{item.prix}</div>
            <div class="calcul-total">{item.total}<span class="calcul-duree"> sur 3 ans</span></div>
            <p class="calcul-note">{item.note}</p>
          </div>
        ))}
      </div>

      <div class="calcul-message reveal" style="margin-top: 40px;">
        <p>Avec <strong>aurore</strong>, votre investissement est unique. Dans 3 ans, 5 ans, 10 ans — <strong>vous ne payez plus rien.</strong></p>
        <a href="/simulateur/" class="btn btn-aurora" style="margin-top: 20px;">Calculer mon économie personnalisée →</a>
      </div>
    </div>
  </section>

  <!-- ─── 5 BLOCAGES ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label reveal">5 situations où Squarespace vous bloque</span>
      <h2 class="section-title reveal">Squarespace est élégant au début.<br />Puis vient le moment où…</h2>

      <div class="blocages-grid reveal" style="margin-top: 48px;">
        {blocages.map(item => (
          <div class="blocage-card card">
            <div class="blocage-icon" set:html={item.icon} />
            <h3 class="blocage-titre">{item.titre}</h3>
            <p class="blocage-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── MIGRATION ─── -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <span class="section-label reveal">Vous avez déjà un site Squarespace ?</span>
      <h2 class="section-title reveal">Vous avez un site Squarespace ?<br />Migrez pour 190 €.</h2>
      <p class="section-subtitle reveal">Je récupère votre contenu existant, je le reconstruis en code pur. Vous gardez votre domaine, vos textes, vos images. Vous arrêtez de payer pour toujours.</p>

      <div class="migration-points reveal" style="margin-top: 40px;">
        {migrationPoints.map(item => (
          <div class="migration-point">
            <span class="migration-check" aria-hidden="true" set:html={item.icon} />
            <span>{item.texte}</span>
          </div>
        ))}
      </div>

      <div class="hero-ctas reveal" style="margin-top: 40px;">
        <a href="/contact/?type=migration" class="btn btn-aurora btn-lg">Demander ma migration →</a>
        <a href="/migration/" class="btn btn-outline btn-lg">En savoir plus</a>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="section">
    <div class="container" style="max-width: 720px;">
      <span class="section-label reveal">Questions fréquentes</span>
      <h2 class="section-title reveal">Quitter Squarespace, mode d'emploi.</h2>

      <div style="margin-top: 40px;" class="reveal">
        {faqSchema.mainEntity.map((item: any) => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              {item.name}
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer">
              {item.acceptedAnswer.text}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA FINAL ─── -->
  <section class="section">
    <div class="container">
      <div class="cta-section cta-dark reveal">
        <h2>Un site plus rapide, plus flexible, sans abonnement.</h2>
        <p>Un investissement unique. Un site qui vous appartient. Zéro abonnement.</p>
        <a href="/contact/" class="btn btn-aurora btn-lg">Demander un devis gratuit →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ─── */
  .sqsp-hero {
    padding: 160px 0 80px;
    text-align: center;
  }

  .sqsp-h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1.05;
    color: var(--black);
    margin: 20px 0 0;
  }

  .sqsp-hero .hero-serif {
    color: var(--aurora);
    margin-top: 8px;
    margin-bottom: 0;
  }

  .sqsp-sub {
    font-size: clamp(15px, 1.3vw, 18px);
    color: var(--gray-500);
    line-height: 1.65;
    max-width: 560px;
    margin: 20px auto 0;
  }

  /* ─── TABLEAU COMPARATIF ─── */
  .comparatif-table {
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .comparatif-row {
    display: grid;
    grid-template-columns: 180px 1fr 1fr;
    border-bottom: 1px solid var(--gray-100);
  }

  .comparatif-row:last-child {
    border-bottom: none;
  }

  .comparatif-header {
    background: var(--gray-50);
    font-weight: 700;
    font-size: 14px;
  }

  .comparatif-header .comparatif-col-aurore {
    color: var(--aurora);
  }

  .comparatif-cell {
    padding: 14px 20px;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 1.5;
  }

  .comparatif-critere {
    font-weight: 600;
    color: var(--black);
    background: var(--gray-50);
  }

  .comparatif-col-sqsp {
    color: var(--gray-700);
    border-left: 1px solid var(--gray-100);
  }

  .comparatif-col-aurore {
    color: var(--gray-700);
    border-left: 1px solid var(--gray-100);
    background: var(--aurora-pale);
  }

  .comparatif-row:not(.comparatif-header) .comparatif-col-aurore {
    font-weight: 500;
    color: var(--black);
  }

  .comparatif-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .comparatif-icon-sqsp {
    background: #FEE2E2;
  }

  .comparatif-icon-aurore {
    background: var(--aurora-pale);
  }

  /* ─── CALCUL 3 ANS ─── */
  .calcul-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .calcul-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .calcul-plan {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray-500);
  }

  .calcul-prix {
    font-size: 15px;
    color: var(--gray-700);
  }

  .calcul-total {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: #DC2626;
    line-height: 1;
  }

  .calcul-duree {
    font-size: 16px;
    font-weight: 500;
    color: var(--gray-500);
    letter-spacing: 0;
  }

  .calcul-note {
    font-size: 13px;
    color: var(--gray-500);
    font-style: italic;
    margin: 0;
  }

  .calcul-message {
    text-align: center;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .calcul-message p {
    font-size: clamp(16px, 1.3vw, 19px);
    line-height: 1.7;
    color: var(--gray-700);
  }

  /* ─── BLOCAGES ─── */
  .blocages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .blocage-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .blocage-icon {
    width: 48px;
    height: 48px;
    background: var(--aurora-pale);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--aurora);
  }

  .blocage-titre {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--black);
    line-height: 1.3;
  }

  .blocage-desc {
    font-size: 14px;
    color: var(--gray-500);
    line-height: 1.65;
    margin: 0;
  }

  /* ─── MIGRATION POINTS ─── */
  .migration-points {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 480px;
  }

  .migration-point {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: var(--gray-700);
  }

  .migration-point .migration-check {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── CTA DARK ─── */
  .cta-dark {
    background: var(--black);
    color: var(--white);
  }

  .cta-dark h2 {
    color: var(--white);
  }

  .cta-dark p {
    color: var(--gray-300);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .comparatif-row {
      grid-template-columns: 140px 1fr 1fr;
    }

    .blocages-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .sqsp-hero {
      padding: 120px 0 56px;
    }

    .comparatif-table {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .comparatif-row {
      grid-template-columns: 120px 1fr 1fr;
      min-width: 580px;
    }

    .comparatif-cell {
      padding: 12px 14px;
      font-size: 13px;
    }

    .calcul-grid {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin-left: auto;
      margin-right: auto;
    }

    .blocages-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);
    gsap.config({ force3D: true });

    // Hero
    // @ts-ignore
    gsap.timeline({ delay: 0.15 })
      // @ts-ignore
      .fromTo('.hero-eyebrow', { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' })
      // @ts-ignore
      .fromTo('.sqsp-h1',       { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 1.0, ease: 'power2.out' }, '-=0.25')
      // @ts-ignore
      .fromTo('.sqsp-hero .hero-serif', { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' }, '-=0.25')
      // @ts-ignore
      .fromTo('.sqsp-sub',      { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' }, '-=0.2')
      // @ts-ignore
      .fromTo('.hero-ctas',    { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' }, '-=0.2');

    // Scroll reveals
    // @ts-ignore
    gsap.utils.toArray('.reveal').forEach((el: any) => {
      // @ts-ignore
      gsap.fromTo(el, { y: 40, opacity: 0 }, {
        y: 0, opacity: 1,
        scrollTrigger: { trigger: el, start: 'top 85%' },
        duration: 1.1, ease: 'power2.out'
      });
    });
  });
</script>
