---
import BaseLayout from '../layouts/BaseLayout.astro';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Élodie",
  "jobTitle": "Fondatrice",
  "worksFor": {
    "@type": "LocalBusiness",
    "name": "Aurore",
    "url": "https://agence-aurore.fr"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Aix-en-Provence",
    "addressRegion": "Provence-Alpes-Côte d'Azur",
    "addressCountry": "FR"
  },
  "knowsAbout": [
    "Création de site web",
    "Identité visuelle",
    "Référencement SEO",
    "Automatisation email",
    "Gestion de location saisonnière"
  ],
  "description": "Élodie est la fondatrice d'Aurore, auto-entreprise de création de présence digitale clé en main basée à Aix-en-Provence. Ancienne gérante de la conciergerie Le Mazarin, elle crée des sites web, logos et outils numériques pour les TPE et professionnels indépendants."
};

const valeurs = [
  {
    titre: "Transparence totale",
    desc:  "Tarifs affichés, délais tenus, contenu de chaque pack précisé avant signature. Aucune mauvaise surprise.",
    icon:  `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  },
  {
    titre: "Livraison clé en main",
    desc:  "Domaine, hébergement, emails, SEO, Google Business — tout est configuré et opérationnel le jour de la livraison.",
    icon:  `<path d="M21 10H3"/><path d="M21 6H3"/><path d="M21 14H3"/><path d="M21 18H3"/>`,
  },
  {
    titre: "Autonomie du client",
    desc:  "Vous repartez avec les clés. Formation incluse dans les packs Autonome, documentation fournie, accès à votre site garanti.",
    icon:  `<circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>`,
  },
  {
    titre: "Expertise terrain",
    desc:  "J'ai géré moi-même les besoins digitaux d'une conciergerie. Je comprends vos contraintes parce que je les ai vécues.",
    icon:  `<path d="M12 2a10 10 0 0 1 10 10H2A10 10 0 0 1 12 2z"/><rect x="2" y="12" width="20" height="10" rx="1"/>`,
  },
];
---

<BaseLayout
  title="À propos d'Élodie — Fondatrice d'aurore | Aix-en-Provence"
  description="Élodie, fondatrice d'Aurore, crée des présences digitales clé en main pour les TPE. Ancienne gérante de conciergerie, elle comprend vos besoins de l'intérieur."
  slug="a-propos"
  schema={personSchema}
>

  <!-- ─── HERO ─── -->
  <section class="apropos-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        À propos · Élodie
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="apropos-h1">
        La personne derrière<br />
        <span class="hero-serif">aurore.</span>
      </h1>
      <p class="apropos-sub">
        Je m'appelle Élodie. Je crée des présences digitales clé en main pour les professionnels et TPE
        qui veulent exister en ligne — sans jargon, sans délais interminables, sans frais cachés.
      </p>
    </div>
  </section>

  <!-- ─── PRÉSENTATION PRINCIPALE ─── -->
  <section class="section">
    <div class="container">
      <div class="apropos-grid reveal">
        <!-- Photo placeholder -->
        <div class="photo-col">
          <div class="photo-placeholder" role="img" aria-label="Photo d'Élodie, fondatrice d'Aurore, basée à Aix-en-Provence">
            <div class="photo-inner">
              <div class="photo-initiales" aria-hidden="true">É</div>
              <div class="photo-caption">
                <span class="photo-nom">Élodie</span>
                <span class="photo-lieu">Aix-en-Provence</span>
              </div>
            </div>
          </div>
          <div class="photo-badge">
            <span class="badge badge-aurora">Fondatrice · Aurore</span>
          </div>
        </div>

        <!-- Texte -->
        <div class="bio-col">
          <span class="section-label">Parcours</span>
          <h2 class="section-title">Une expérience<br />du terrain, pas des manuels.</h2>

          <div class="bio-text">
            <p>
              Avant de créer aurore, j'ai dirigé <strong>Le Mazarin</strong>, une conciergerie de location saisonnière
              à Aix-en-Provence. Pendant cette période, j'ai dû construire ma propre présence digitale :
              trouver un prestataire web fiable, négocier un logo, comprendre le SEO local, gérer des emails
              professionnels, optimiser ma fiche Google Business.
            </p>
            <p>
              Ce que j'y ai appris, c'est que <strong>la grande majorité des artisans, indépendants et TPE
              n'ont pas accès à des solutions digitales sérieuses à un tarif raisonnable</strong>. Soit c'est
              trop cher, soit c'est trop compliqué, soit le prestataire disparaît après la livraison.
            </p>
            <p>
              J'ai créé aurore pour combler ce manque. Une offre transparente, des délais réalistes,
              et une vraie relation de confiance avec chaque client — parce que je sais ce que c'est
              d'être de l'autre côté.
            </p>
          </div>

          <div class="bio-facts">
            <div class="fact">
              <span class="fact-value">2024</span>
              <span class="fact-label">Création d'aurore</span>
            </div>
            <div class="fact">
              <span class="fact-value">Aix</span>
              <span class="fact-label">Basée à Aix-en-Provence</span>
            </div>
            <div class="fact">
              <span class="fact-value">France</span>
              <span class="fact-label">Intervention partout en France</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── PARCOURS DÉTAILLÉ ─── -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <div class="parcours-grid">
        <div>
          <span class="section-label reveal">Le Mazarin</span>
          <h2 class="section-title reveal">De conciergerie<br />à agence digitale.</h2>
          <p class="section-subtitle reveal">Un parcours qui n'était pas prévu, mais qui fait toute la différence.</p>
        </div>

        <div class="timeline reveal">
          <div class="timeline-item">
            <div class="timeline-dot" aria-hidden="true"></div>
            <div class="timeline-content">
              <div class="timeline-date">Avant aurore</div>
              <h3 class="timeline-titre">Gestion de Le Mazarin</h3>
              <p>Direction d'une conciergerie de location saisonnière à Aix-en-Provence. Gestion opérationnelle complète : annonces, accueil des voyageurs, relations propriétaires, comptabilité.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot" aria-hidden="true"></div>
            <div class="timeline-content">
              <div class="timeline-date">Le déclic</div>
              <h3 class="timeline-titre">Construction de ma propre présence digitale</h3>
              <p>Pour faire connaître Le Mazarin, j'ai dû apprendre le SEO local, créer un site, configurer Google Business, mettre en place des emails pro. Ce que j'ai découvert : ces compétences sont rares, chères, et pourtant indispensables.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot timeline-dot-aurora" aria-hidden="true"></div>
            <div class="timeline-content">
              <div class="timeline-date">2024</div>
              <h3 class="timeline-titre">Création d'aurore</h3>
              <p>Lancement d'aurore, auto-entreprise de présence digitale clé en main. L'idée : rendre accessibles aux TPE et indépendants les outils digitaux que seules les grandes entreprises pouvaient se payer.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot" aria-hidden="true"></div>
            <div class="timeline-content">
              <div class="timeline-date">Aujourd'hui</div>
              <h3 class="timeline-titre">Sites livrés, clients autonomes</h3>
              <p>Des professionnels du bien-être aux conciergeries, en passant par les artisans — chaque projet est unique, chaque client repart avec une présence dont il est fier.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── VALEURS ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label reveal">Ce qui me guide</span>
      <h2 class="section-title reveal">Quatre valeurs,<br />pas une de plus.</h2>

      <div class="grid-2 reveal-stagger" style="margin-top: 48px;">
        {valeurs.map(v => (
          <div class="card valeur-card">
            <div class="valeur-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={v.icon} />
            </div>
            <h3>{v.titre}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CE QUI ME DIFFÉRENCIE ─── -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <div class="diff-grid">
        <div>
          <span class="section-label reveal">La différence</span>
          <h2 class="section-title reveal">Pourquoi travailler<br />avec moi plutôt qu'une agence ?</h2>
        </div>

        <div class="diff-col">
          <div class="diff-comparaison reveal">
            <div class="diff-col-header diff-col-them">
              <span>Agence traditionnelle</span>
            </div>
            <div class="diff-col-header diff-col-us">
              <span>aurore</span>
            </div>

            {[
              ["Devis opaque, prix non affichés",         "Tarifs publics, tout est annoncé"],
              ["Délai moyen 2–4 mois",                    "Livraison en 2 semaines"],
              ["Frais d'hébergement 20–50 €/mois",        "Hébergement gratuit (GitHub Pages)"],
              ["Chef de projet + développeur = surcoût",  "Un seul interlocuteur, du brief à la livraison"],
              ["Vous dépendez d'eux pour modifier",       "Vous repartez autonome, CMS inclus"],
              ["Aucune expérience client des TPE",        "J'ai vécu vos problèmes de l'intérieur"],
            ].map(([them, us]) => (
              <>
                <div class="diff-item diff-item-them">
                  <span class="diff-cross" aria-hidden="true">✕</span>
                  {them}
                </div>
                <div class="diff-item diff-item-us">
                  <span class="diff-check" aria-hidden="true">✓</span>
                  {us}
                </div>
              </>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── LOCALISATION ─── -->
  <section class="section">
    <div class="container">
      <div class="localisation-block reveal">
        <div class="localisation-text">
          <span class="section-label">Localisation</span>
          <h2 class="section-title">Basée à Aix-en-Provence,<br />j'interviens partout en France.</h2>
          <p class="section-subtitle">
            Je travaille en remote avec tous mes clients — un appel suffit pour démarrer.
            Que vous soyez à Marseille, Lyon, Paris ou Brignoles, la distance ne change rien
            à la qualité du résultat.
          </p>
          <div style="margin-top: 32px; display: flex; gap: 12px; flex-wrap: wrap;">
            <a href="/contact/" class="btn btn-primary">Me contacter →</a>
            <a href="/realisations/" class="btn btn-ghost">Voir mes réalisations</a>
          </div>
        </div>
        <div class="localisation-carte" aria-hidden="true">
          <div class="carte-france">
            <svg viewBox="0 0 200 220" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <!-- Silhouette France simplifiée -->
              <path d="M 72 8 L 90 5 L 110 12 L 130 8 L 148 20 L 158 38 L 165 55 L 170 75 L 162 90 L 175 105 L 170 125 L 155 140 L 148 158 L 132 168 L 115 175 L 100 178 L 85 172 L 68 162 L 52 148 L 42 132 L 35 115 L 30 95 L 35 78 L 28 62 L 35 45 L 48 30 L 60 18 Z" fill="var(--gray-100)" stroke="var(--gray-300)" stroke-width="1.5"/>
              <!-- Point Aix-en-Provence -->
              <circle cx="130" cy="148" r="6" fill="var(--aurora)" opacity="0.9"/>
              <circle cx="130" cy="148" r="12" fill="var(--aurora)" opacity="0.2"/>
              <!-- Rayonnement -->
              <circle cx="130" cy="148" r="20" fill="var(--aurora)" opacity="0.08"/>
            </svg>
            <div class="carte-label">Aix-en-Provence</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA ─── -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="cta-section reveal">
        <h2>Vous avez un projet en tête ?</h2>
        <p>Parlons-en lors d'un appel gratuit de 30 minutes. Je vous dis honnêtement si je peux vous aider et comment.</p>
        <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
          <a href="/contact/" class="btn btn-aurora btn-lg">Prendre contact →</a>
          <a href="/tarifs/" class="btn btn-outline btn-lg">Voir les tarifs</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ─── */
  .apropos-hero {
    padding: 160px 0 80px;
    text-align: center;
  }

  .apropos-h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1.05;
    margin: 20px 0 16px;
  }

  .apropos-sub {
    font-size: clamp(15px, 1.3vw, 18px);
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ─── GRILLE PRÉSENTATION ─── */
  .apropos-grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 80px;
    align-items: start;
  }

  /* Photo */
  .photo-col {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .photo-placeholder {
    width: 100%;
    aspect-ratio: 3 / 4;
    background: linear-gradient(145deg, var(--aurora-pale) 0%, #FFE4CC 50%, var(--aurora-pale) 100%);
    border-radius: var(--radius-xl);
    border: 1.5px solid rgba(255, 107, 26, 0.15);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    position: relative;
  }

  .photo-inner {
    width: 100%;
    padding: 24px;
    background: linear-gradient(to top, rgba(255,107,26,0.12), transparent);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .photo-initiales {
    width: 80px;
    height: 80px;
    background: var(--aurora);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 8px;
  }

  .photo-nom {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--black);
    display: block;
    text-align: center;
  }

  .photo-lieu {
    font-size: 13px;
    color: var(--gray-500);
    display: block;
    text-align: center;
  }

  /* Bio */
  .bio-col {
    padding-top: 8px;
  }

  .bio-text {
    margin: 24px 0 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .bio-text p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--gray-500);
  }

  .bio-facts {
    display: flex;
    gap: 32px;
    margin-top: 36px;
    padding-top: 32px;
    border-top: 1px solid var(--gray-100);
    flex-wrap: wrap;
  }

  .fact {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .fact-value {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--black);
    line-height: 1;
  }

  .fact-label {
    font-size: 12px;
    color: var(--gray-500);
  }

  /* ─── PARCOURS / TIMELINE ─── */
  .parcours-grid {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 80px;
    align-items: start;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    padding-left: 32px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: linear-gradient(to bottom, var(--gray-100), var(--aurora-light), var(--gray-100));
  }

  .timeline-item {
    position: relative;
    padding-bottom: 36px;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -29px;
    top: 6px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--white);
    border: 2px solid var(--gray-300);
  }

  .timeline-dot-aurora {
    border-color: var(--aurora);
    background: var(--aurora);
    box-shadow: 0 0 0 4px var(--aurora-glow);
  }

  .timeline-date {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--aurora);
    margin-bottom: 6px;
  }

  .timeline-titre {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--black);
    margin-bottom: 8px;
  }

  .timeline-item p {
    font-size: 14px;
    color: var(--gray-500);
    line-height: 1.65;
    margin: 0;
  }

  /* ─── VALEURS ─── */
  .valeur-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .valeur-icon {
    width: 44px;
    height: 44px;
    background: var(--aurora-pale);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--aurora);
    flex-shrink: 0;
  }

  .valeur-card h3 {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .valeur-card p {
    font-size: 14px;
    line-height: 1.65;
    margin: 0;
  }

  /* ─── COMPARAISON ─── */
  .diff-grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 80px;
    align-items: start;
  }

  .diff-comparaison {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .diff-col-header {
    padding: 14px 20px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .diff-col-them {
    background: var(--gray-50);
    color: var(--gray-500);
    border-bottom: 1px solid var(--gray-100);
  }

  .diff-col-us {
    background: var(--aurora-pale);
    color: var(--aurora-dark);
    border-left: 1px solid rgba(255,107,26,0.15);
    border-bottom: 1px solid rgba(255,107,26,0.15);
  }

  .diff-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 14px 20px;
    font-size: 13px;
    line-height: 1.5;
    border-bottom: 1px solid var(--gray-100);
  }

  .diff-item:last-child,
  .diff-item:nth-last-child(2) {
    border-bottom: none;
  }

  .diff-item-them {
    color: var(--gray-500);
    background: var(--white);
  }

  .diff-item-us {
    color: var(--gray-700);
    background: var(--aurora-pale);
    border-left: 1px solid rgba(255,107,26,0.12);
    font-weight: 500;
  }

  .diff-cross {
    color: var(--gray-300);
    font-size: 12px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .diff-check {
    color: var(--aurora);
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ─── LOCALISATION ─── */
  .localisation-block {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 64px;
    align-items: center;
  }

  .localisation-carte {
    display: flex;
    justify-content: center;
  }

  .carte-france {
    position: relative;
    width: 240px;
  }

  .carte-france svg {
    width: 100%;
    height: auto;
  }

  .carte-label {
    position: absolute;
    bottom: 28px;
    right: 8px;
    font-size: 11px;
    font-weight: 600;
    color: var(--aurora-dark);
    background: var(--white);
    padding: 3px 8px;
    border-radius: 100px;
    border: 1px solid var(--aurora-light);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .apropos-grid {
      grid-template-columns: 300px 1fr;
      gap: 48px;
    }

    .parcours-grid,
    .diff-grid,
    .localisation-block {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .photo-col {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .apropos-hero {
      padding: 120px 0 56px;
    }

    .apropos-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .photo-placeholder {
      max-width: 300px;
      margin: 0 auto;
    }

    .bio-facts {
      gap: 20px;
    }

    .diff-comparaison {
      grid-template-columns: 1fr;
    }

    .diff-col-us,
    .diff-item-us {
      border-left: none;
    }

    .diff-col-header,
    .diff-item {
      border-bottom: 1px solid var(--gray-100);
    }

    .localisation-carte {
      display: none;
    }

    .timeline {
      padding-left: 24px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore
    if (typeof gsap === 'undefined') return;
    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);

    // @ts-ignore
    gsap.timeline({ delay: 0.1 })
      // @ts-ignore
      .from('.hero-eyebrow', { y: 16, opacity: 0, duration: 0.5, ease: 'power2.out' })
      // @ts-ignore
      .from('.apropos-h1',   { y: 24, opacity: 0, duration: 0.6, ease: 'power2.out' }, '-=0.25')
      // @ts-ignore
      .from('.apropos-sub',  { y: 16, opacity: 0, duration: 0.5, ease: 'power2.out' }, '-=0.25');

    // @ts-ignore
    gsap.utils.toArray('.reveal').forEach((el: any) => {
      // @ts-ignore
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: 'top 85%' },
        y: 40, opacity: 0, duration: 0.65, ease: 'power2.out'
      });
    });

    // @ts-ignore
    gsap.utils.toArray('.reveal-stagger').forEach((container: any) => {
      // @ts-ignore
      gsap.from(container.children, {
        scrollTrigger: { trigger: container, start: 'top 80%' },
        y: 24, opacity: 0, stagger: 0.1, duration: 0.55, ease: 'power2.out'
      });
    });
  });
</script>
