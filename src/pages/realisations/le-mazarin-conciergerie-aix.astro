---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projet = {
  client:      "Le Mazarin",
  activite:    "Conciergerie de location saisonnière",
  ville:       "Aix-en-Provence (13)",
  url:         "https://lemazarin.com",
  urlLabel:    "lemazarin.com",
  prestations: ["Site vitrine", "Identité visuelle", "SEO", "Fiche Google"],
  delai:       "2 semaines",
  annee:       "2024",
};

const schema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": "Site web, Le Mazarin, conciergerie à Aix-en-Provence",
  "creator": { "@type": "Organization", "name": "Aurore", "url": "https://agence-aurore.fr" },
  "description": "Création du site vitrine de Le Mazarin, conciergerie de location saisonnière à Aix-en-Provence. Logo, identité visuelle, SEO local et fiche Google Business.",
  "url": "https://lemazarin.com",
  "locationCreated": { "@type": "Place", "name": "Aix-en-Provence, Bouches-du-Rhône, France" },
  "dateCreated": "2024",
  "keywords": "site vitrine conciergerie, identité visuelle location saisonnière, SEO local Aix-en-Provence"
};
---

<BaseLayout
  title="Réalisation, Site vitrine Le Mazarin, conciergerie à Aix-en-Provence | aurore"
  description="Découvrez comment aurore a créé la présence digitale complète du Mazarin, conciergerie de location saisonnière à Aix-en-Provence : logo, site, SEO et fiche Google."
  slug="realisations/le-mazarin-conciergerie-aix"
  schema={schema}
>


  <!-- ─── HERO ─── -->
  <section class="fiche-hero">
    <div class="container">
      <div class="fiche-hero-inner">
        <div class="fiche-hero-content">
          <div class="tags" style="margin-bottom: 20px;">
            {projet.prestations.map(p => (
              <span class="badge badge-aurora">{p}</span>
            ))}
          </div>
          <h1 class="fiche-h1">
            Le Mazarin<br />
            <span class="hero-serif">Conciergerie.</span>
          </h1>
          <p class="fiche-sub">
            Présence digitale complète pour une conciergerie de location saisonnière à Aix-en-Provence.
            Logo, site web, SEO local et fiche Google, tout en {projet.delai}.
          </p>

          <!-- Tableau client -->
          <table class="client-table" aria-label="Informations du projet">
            <tbody>
              <tr>
                <th scope="row">Client</th>
                <td>{projet.client}</td>
              </tr>
              <tr>
                <th scope="row">Activité</th>
                <td>{projet.activite}</td>
              </tr>
              <tr>
                <th scope="row">Ville</th>
                <td>{projet.ville}</td>
              </tr>
              <tr>
                <th scope="row">Site livré</th>
                <td>
                  <a
                    href={projet.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="table-link"
                  >
                    {projet.urlLabel} ↗
                  </a>
                </td>
              </tr>
              <tr>
                <th scope="row">Prestations</th>
                <td>{projet.prestations.join(", ")}</td>
              </tr>
              <tr>
                <th scope="row">Délai</th>
                <td>{projet.delai}</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Capture du site -->
        <div class="fiche-hero-capture">
          <img src="/lemazarin-portrait.webp" alt="Le Mazarin, conciergerie à Aix-en-Provence" style="max-width:320px; margin:0 auto; display:block; border-radius:var(--radius-md); object-fit:cover; object-position:center top; aspect-ratio:3/4;" />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SECTION 1 : CONTEXTE ─── -->
  <section class="section fiche-section">
    <div class="container fiche-container">
      <div class="fiche-section-label">
        <span class="section-label">01, Contexte</span>
      </div>
      <div class="fiche-section-content">
        <h2 class="section-title reveal">Le besoin du Mazarin.</h2>
        <div class="fiche-text reveal">
          <p>Le Mazarin est une conciergerie de location saisonnière basée à Aix-en-Provence. Spécialisée dans la gestion de biens immobiliers pour des propriétaires qui souhaitent louer leur appartement ou maison sans s'occuper de la logistique, elle intervient de la mise en ligne des annonces jusqu'à l'accueil des voyageurs.</p>
          <p>Au démarrage, Le Mazarin n'avait ni logo, ni site web, ni présence Google. Les propriétaires potentiels ne pouvaient pas les trouver en ligne. La crédibilité d'une conciergerie passe pourtant par une présence digitale irréprochable, les propriétaires confient leurs biens, ils ont besoin de faire confiance.</p>
          <p>Le projet : construire une <strong>identité complète de A à Z</strong>, avec un logo, un site qui inspire confiance et une présence Google optimisée pour capter les propriétaires locaux.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SECTION 2 : SOLUTION ─── -->
  <section class="section fiche-section" style="background: var(--gray-50);">
    <div class="container fiche-container">
      <div class="fiche-section-label">
        <span class="section-label">02, Solution</span>
      </div>
      <div class="fiche-section-content">
        <h2 class="section-title reveal">Une présence complète, clé en main.</h2>
        <div class="fiche-text reveal">
          <p>Contrairement au projet de Delphine, Le Mazarin avait besoin de repartir de zéro sur tout, marque, design, web et SEO local. C'est le cas d'usage idéal pour notre pack complet.</p>
        </div>
        <div class="solution-grid reveal-stagger" style="margin-top: 32px;">
          <div class="solution-item">
            <div class="solution-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div>
              <h3>Logo + identité visuelle</h3>
              <p>Création d'un logotype élégant, palette de couleurs et typographies cohérentes avec le positionnement premium de la conciergerie.</p>
            </div>
          </div>
          <div class="solution-item">
            <div class="solution-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
            <div>
              <h3>Site vitrine complet</h3>
              <p>Présentation des services, secteurs d'intervention, processus et formulaire de contact. Navigation claire, copywriting orienté conversion.</p>
            </div>
          </div>
          <div class="solution-item">
            <div class="solution-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m21 21-6-6m6 6v-4.8m0 4.8h-4.8"/><path d="M3 16.2V21m0 0h4.8M3 21l6-6"/><path d="M21 7.8V3m0 0h-4.8M21 3l-6 6"/><path d="M3 7.8V3m0 0h4.8M3 3l6 6"/></svg>
            </div>
            <div>
              <h3>SEO local optimisé</h3>
              <p>Optimisation on-page sur les mots-clés "conciergerie Aix-en-Provence" et "gestion location saisonnière 13". Balises, structure, contenu.</p>
            </div>
          </div>
          <div class="solution-item">
            <div class="solution-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <h3>Fiche Google Business</h3>
              <p>Création et optimisation complète de la fiche Google Business Profile : description, catégories, photos, lien vers le site, zone d'intervention.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SECTION 3 : IDENTITÉ VISUELLE ─── -->
  <section class="section fiche-section">
    <div class="container fiche-container">
      <div class="fiche-section-label">
        <span class="section-label">03, Identité</span>
      </div>
      <div class="fiche-section-content">
        <h2 class="section-title reveal">Une marque qui inspire confiance.</h2>
        <div class="fiche-text reveal">
          <p>Pour une conciergerie, la confiance est tout. Les propriétaires confient leurs biens, parfois leur résidence principale ou un investissement de plusieurs centaines de milliers d'euros. L'identité visuelle devait le refléter.</p>
          <p>Nous avons opté pour une palette sobre et élégante, une typographie Serif avec empattements qui évoque la tradition et le soin, et un logo qui fonctionne aussi bien sur un site web que sur un document contractuel ou une carte de visite.</p>
        </div>
        <div class="identite-showcase reveal" style="margin-top: 32px;">
          <div class="identite-card" style="background: #F0EBE8;">
            <div class="identite-logo-mock" aria-hidden="true">
              <div class="logo-mock-text">Le Mazarin</div>
              <div class="logo-mock-sub">Conciergerie · Aix-en-Provence</div>
            </div>
          </div>
          <div class="identite-colors" aria-label="Palette de couleurs">
            <div class="color-swatch" style="background: #2C2416;" title="Brun profond"></div>
            <div class="color-swatch" style="background: #8B6F47;" title="Caramel chaud"></div>
            <div class="color-swatch" style="background: #C4A882;" title="Sable doux"></div>
            <div class="color-swatch" style="background: #F0EBE8;" title="Crème ivoire"></div>
            <div class="color-swatch" style="background: #FFFFFF; border: 1px solid #E8E0DB;" title="Blanc pur"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SECTION 4 : RÉSULTAT ─── -->
  <section class="section fiche-section" style="background: var(--gray-50);">
    <div class="container fiche-container">
      <div class="fiche-section-label">
        <span class="section-label">04, Résultat</span>
      </div>
      <div class="fiche-section-content">
        <h2 class="section-title reveal">Livré en 2 semaines, visible sur Google.</h2>
        <div class="fiche-text reveal">
          <p>En deux semaines, Le Mazarin est passé de zéro présence à un écosystème digital complet : logo, site en ligne sur <a href="https://lemazarin.com" target="_blank" rel="noopener noreferrer" class="table-link">lemazarin.com</a>, emails professionnels configurés, fiche Google active et Search Console raccordée.</p>
        </div>

        <div class="resultat-screens reveal" style="margin-top: 32px;">
          <img src="/lemazarin-1.webp" alt="Site web Le Mazarin, conciergerie à Aix-en-Provence" style="width:100%; border-radius:var(--radius-md); object-fit:contain; background:var(--gray-50, #f9f9f9);" loading="lazy" />
        </div>

        <div class="metrics-row reveal" style="margin-top:32px;">
          <div class="metric-card">
            <div class="metric-card-value">2 sem.</div>
            <div class="metric-card-label">Délai tout compris</div>
          </div>
          <div class="metric-card">
            <div class="metric-card-value">4</div>
            <div class="metric-card-label">Prestations livrées</div>
          </div>
          <div class="metric-card">
            <div class="metric-card-value">0 €</div>
            <div class="metric-card-label">Hébergement mensuel</div>
          </div>
          <div class="metric-card">
            <div class="metric-card-value">P.1</div>
            <div class="metric-card-label">Google local</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SECTION 5 : TÉMOIGNAGE ─── -->
  <section class="section fiche-section">
    <div class="container fiche-container">
      <div class="fiche-section-label">
        <span class="section-label">05, Témoignage</span>
      </div>
      <div class="fiche-section-content">
        <div class="temoignage-block reveal">
          <div class="temoignage-quote-mark" aria-hidden="true">"</div>
          <blockquote class="temoignage-texte">
            Notre site a été livré clé en main en deux semaines, logo, site, SEO, Google Business, tout était prêt. On est maintenant en première page sur nos mots-clés à Aix-en-Provence. Les propriétaires qui nous contactent nous disent souvent qu'ils ont trouvé notre site en cherchant "conciergerie Aix". C'est exactement ce qu'on voulait.
          </blockquote>
          <div class="temoignage-auteur">
            <div class="temoignage-avatar" style="background: #8B6F47;" aria-hidden="true">
              <span>LM</span>
            </div>
            <div>
              <div class="temoignage-nom">Le Mazarin</div>
              <div class="temoignage-role">Conciergerie de location saisonnière · Aix-en-Provence (13)</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SECTION 6 : CTA PROJET SIMILAIRE ─── -->
  <section class="section fiche-section" style="background: var(--gray-50);">
    <div class="container fiche-container">
      <div class="fiche-section-label">
        <span class="section-label">06, Et vous ?</span>
      </div>
      <div class="fiche-section-content">
        <h2 class="section-title reveal">Votre projet ressemble à celui-ci ?</h2>
        <div class="fiche-text reveal">
          <p>Vous lancez une activité ou une entreprise et vous avez besoin de construire votre présence digitale de zéro, logo, site, SEO et Google Business ? C'est exactement ce que propose le pack Vitrine Complet d'aurore.</p>
          <p>Basée à Aix-en-Provence, j'interviens dans toute la France. Un formulaire de 2 minutes suffit pour recevoir un devis détaillé sous 48h.</p>
        </div>
        <div class="fiche-cta-buttons reveal">
          <a href="/contact/" class="btn btn-aurora btn-lg">Démarrer mon projet →</a>
          <a href="/tarifs/" class="btn btn-outline btn-lg">Voir les tarifs</a>
          <a href="/realisations/" class="btn btn-ghost btn-lg">Voir toutes les réalisations</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── NAVIGATION ENTRE FICHES ─── -->
  <nav class="fiche-nav" aria-label="Navigation entre les réalisations">
    <div class="container">
      <div class="fiche-nav-inner">
        <a href="/realisations/delphine-millot-massage-brignoles/" class="fiche-nav-prev-link">
          <span class="fiche-nav-label">Réalisation précédente</span>
          <span class="fiche-nav-titre">← Delphine Millot, Massothérapeute</span>
        </a>
        <div class="fiche-nav-next" aria-label="Pas de projet suivant">
          <span class="fiche-nav-label">Réalisation suivante</span>
          <span class="fiche-nav-empty">— dernière réalisation</span>
        </div>
      </div>
    </div>
  </nav>

</BaseLayout>

<style>
  /* ─── HERO FICHE ─── */
  .fiche-hero {
    padding: 32px 0 80px;
  }

  .fiche-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .fiche-h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.5vw, 56px);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1.05;
    color: var(--black);
    margin-bottom: 16px;
  }

  .fiche-sub {
    font-size: clamp(15px, 1.2vw, 17px);
    color: var(--gray-500);
    line-height: 1.65;
    margin-bottom: 32px;
  }

  /* Tableau client */
  .client-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .client-table tr {
    border-bottom: 1px solid var(--gray-100);
  }

  .client-table tr:last-child {
    border-bottom: none;
  }

  .client-table th {
    text-align: left;
    font-weight: 600;
    color: var(--black);
    padding: 10px 16px 10px 0;
    width: 130px;
    vertical-align: top;
  }

  .client-table td {
    color: var(--gray-500);
    padding: 10px 0;
    vertical-align: top;
  }

  .table-link {
    color: var(--aurora);
    font-weight: 500;
    transition: var(--transition);
  }

  .table-link:hover {
    color: var(--aurora-dark);
  }

  /* ─── LAYOUT SECTIONS ─── */
  .fiche-section { padding: 80px 0; }

  .fiche-container {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 64px;
    align-items: start;
  }

  .fiche-section-label { padding-top: 6px; }

  .fiche-text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .fiche-text p {
    font-size: 16px;
    color: var(--gray-500);
    line-height: 1.75;
    margin: 0;
  }

  /* ─── SOLUTION GRID ─── */
  .solution-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .solution-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .solution-icon {
    width: 40px;
    height: 40px;
    background: var(--aurora-pale);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--aurora);
    flex-shrink: 0;
  }

  .solution-item h3 {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }

  .solution-item p {
    font-size: 14px;
    color: var(--gray-500);
    line-height: 1.6;
    margin: 0;
  }

  /* ─── IDENTITÉ SHOWCASE ─── */
  .identite-showcase {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .identite-card {
    border-radius: var(--radius-lg);
    padding: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 160px;
    border: 1.5px solid rgba(0,0,0,0.06);
  }

  .identite-logo-mock {
    text-align: center;
  }

  .logo-mock-text {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 400;
    color: #2C2416;
    letter-spacing: 0.08em;
    line-height: 1;
    margin-bottom: 6px;
  }

  .logo-mock-sub {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #8B6F47;
  }

  .identite-colors {
    display: flex;
    gap: 8px;
  }

  .color-swatch {
    flex: 1;
    height: 40px;
    border-radius: var(--radius-sm);
  }

  /* ─── RÉSULTAT ─── */
  .resultat-screens {
    display: flex;
    flex-direction: column;
  }

  /* Métriques */
  .metrics-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .metric-card {
    background: var(--white);
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-md);
    padding: 20px 16px;
    text-align: center;
  }

  .metric-card-value {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--black);
    line-height: 1;
    margin-bottom: 6px;
  }

  .metric-card-label {
    font-size: 12px;
    color: var(--gray-500);
    line-height: 1.4;
  }

  /* ─── TÉMOIGNAGE ─── */
  .temoignage-block {
    background: var(--aurora-pale);
    border: 1.5px solid rgba(255,107,26,0.15);
    border-radius: var(--radius-xl);
    padding: 48px;
    position: relative;
  }

  .temoignage-quote-mark {
    font-family: var(--font-serif);
    font-size: 96px;
    line-height: 0.8;
    color: var(--aurora-light);
    margin-bottom: 16px;
    font-style: italic;
  }

  .temoignage-texte {
    font-size: clamp(17px, 1.5vw, 20px);
    font-style: italic;
    color: var(--gray-700);
    line-height: 1.7;
    margin-bottom: 32px;
    font-family: var(--font-serif);
    border: none;
    padding: 0;
  }

  .temoignage-auteur {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .temoignage-avatar {
    width: 44px;
    height: 44px;
    background: var(--aurora-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    color: var(--white);
    flex-shrink: 0;
  }

  .temoignage-nom {
    font-size: 15px;
    font-weight: 600;
    color: var(--black);
    letter-spacing: -0.01em;
  }

  .temoignage-role {
    font-size: 13px;
    color: var(--gray-500);
    margin-top: 2px;
  }

  /* ─── CTA BOUTONS FICHE ─── */
  .fiche-cta-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 24px;
  }

  /* ─── NAVIGATION FICHES ─── */
  .fiche-nav {
    border-top: 1px solid var(--gray-100);
    padding: 32px 0;
  }

  .fiche-nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .fiche-nav-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-500);
    margin-bottom: 4px;
  }

  .fiche-nav-empty {
    font-size: 14px;
    color: var(--gray-300);
  }

  .fiche-nav-next {
    text-align: right;
  }

  .fiche-nav-prev-link {
    display: block;
  }

  .fiche-nav-titre {
    display: block;
    font-size: 16px;
    font-weight: 600;
    color: var(--black);
    letter-spacing: -0.02em;
    transition: var(--transition);
  }

  .fiche-nav-prev-link:hover .fiche-nav-titre {
    color: var(--aurora);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .fiche-hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .fiche-container {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .fiche-section-label { padding-top: 0; }
  }

  @media (max-width: 768px) {
    .fiche-hero { padding: 16px 0 56px; }

    .solution-grid { grid-template-columns: 1fr; }

    .metrics-row { grid-template-columns: 1fr 1fr; }

    .temoignage-block { padding: 28px 24px; }

    .fiche-cta-buttons { flex-direction: column; }

    .fiche-cta-buttons .btn {
      width: 100%;
      justify-content: center;
    }

    .identite-card { padding: 32px 24px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore
    if (typeof gsap === 'undefined') return;
    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);
    gsap.config({ force3D: true });

    // @ts-ignore
    gsap.timeline({ delay: 0.15 })
      // @ts-ignore
      .fromTo('.fiche-h1', { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 1.1, ease: 'power2.out' })
      // @ts-ignore
      .fromTo('.fiche-sub', { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' }, '-=0.3')
      // @ts-ignore
      .fromTo('.client-table', { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' }, '-=0.2')
      // @ts-ignore
      .fromTo('.fiche-hero-capture', { x: 24, opacity: 0 }, { x: 0, opacity: 1, duration: 1.2, ease: 'power2.out' }, '-=0.5');

    // @ts-ignore
    gsap.utils.toArray('.reveal').forEach((el: any) => {
      // @ts-ignore
      gsap.fromTo(el, { y: 40, opacity: 0 }, {
        y: 0, opacity: 1,
        scrollTrigger: { trigger: el, start: 'top 85%' },
        duration: 1.1, ease: 'power2.out'
      });
    });

    // @ts-ignore
    gsap.utils.toArray('.reveal-stagger').forEach((container: any) => {
      // @ts-ignore
      gsap.fromTo(container.children, { y: 24, opacity: 0 }, {
        y: 0, opacity: 1,
        scrollTrigger: { trigger: container, start: 'top 80%' },
        stagger: 0.15, duration: 0.55, ease: 'power2.out'
      });
    });
  });
</script>
