<script>
  document.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore
    if (typeof gsap === 'undefined') return;
    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);

    // @ts-ignore
    gsap.timeline({ delay: 0.15 })
      // @ts-ignore
      .from('.fiche-h1',  { y: 24, opacity: 0, duration: 1.1, ease: 'power2.out' })
      // @ts-ignore
      .from('.fiche-sub', { y: 16, opacity: 0, duration: 0.9, ease: 'power2.out' }, '-=0.3')
      // @ts-ignore
      .from('.client-table', { y: 16, opacity: 0, duration: 0.9, ease: 'power2.out' }, '-=0.2')
      // @ts-ignore
      .from('.fiche-hero-capture', { x: 24, opacity: 0, duration: 1.2, ease: 'power2.out' }, '-=0.5');

    // @ts-ignore
    gsap.utils.toArray('.reveal').forEach((el: any) => {
      // @ts-ignore
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: 'top 85%' },
        y: 40, opacity: 0, duration: 1.1, ease: 'power2.out'
      });
    });

    // @ts-ignore
    gsap.utils.toArray('.reveal-stagger').forEach((container: any) => {
      // @ts-ignore
      gsap.from(container.children, {
        scrollTrigger: { trigger: container, start: 'top 80%' },
        y: 24, opacity: 0, stagger: 0.15, duration: 0.55, ease: 'power2.out'
      });
    });
  });
</script>
