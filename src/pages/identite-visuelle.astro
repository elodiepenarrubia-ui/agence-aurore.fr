---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création d'identité visuelle",
  "provider": { "@type": "ProfessionalService", "name": "Aurore", "url": "https://www.agence-aurore.fr" },
  "areaServed": "France",
  "description": "Création d'identité visuelle complète pour TPE et indépendants : logo, charte graphique, couleurs, typographies. À partir de 150 €. Basé à Aix-en-Provence.",
  "offers": [
    { "@type": "Offer", "name": "Création de logo (option pack)", "priceCurrency": "EUR", "price": "150" },
    { "@type": "Offer", "name": "Charte graphique (option pack)", "priceCurrency": "EUR", "price": "100" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Qu'est-ce qui est inclus dans la création d'un logo ?",
      "acceptedAnswer": { "@type": "Answer", "text": "La création d'un logo comprend : la conception du logotype (typographie, symbole ou combinaison), la déclinaison en version claire et sombre, les formats livrés (SVG, PNG transparent, PDF), et le guide d'utilisation minimal. Tout est livré prêt à l'emploi sur votre site, vos cartes de visite et vos réseaux sociaux." }},
    { "@type": "Question", "name": "Quelle est la différence entre un logo et une charte graphique ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le logo est votre signature visuelle : le symbole ou le mot qui vous identifie. La charte graphique va plus loin : elle définit la palette de couleurs complète, les typographies à utiliser (titres, corps de texte), les règles d'utilisation du logo, les espacements et la cohérence visuelle à appliquer sur tous vos supports." }},
    { "@type": "Question", "name": "Combien de propositions de logo sont faites ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Deux propositions distinctes sont soumises à l'issue du brief créatif. Vous choisissez la direction qui vous correspond, puis deux rondes de retouches sont incluses pour affiner le résultat final. L'objectif est d'arriver à un logo que vous assumez pleinement, pas juste un logo générique." }},
    { "@type": "Question", "name": "Mon identité visuelle sera-t-elle cohérente avec mon site web ?",
      "acceptedAnswer": { "@type": "Answer", "text": "C'est précisément l'avantage de travailler avec Aurore sur les deux : le logo et la charte graphique sont conçus dès le départ en tenant compte de votre site, de vos réseaux sociaux et de vos supports imprimés. Tout est pensé ensemble pour une cohérence totale, pas assemblé après coup." }},
    { "@type": "Question", "name": "L'identité visuelle est-elle disponible séparément ?",
      "acceptedAnswer": { "@type": "Answer", "text": "La création de logo (+150 €) et la charte graphique (+100 €) sont disponibles en option avec chaque pack (Starter, Vitrine, Pro ou Migration). Elles ne sont pas proposées comme prestations indépendantes. Vous recevez tous les fichiers sources et pouvez les utiliser librement sur tous vos supports." }},
  ],
};

const catalogSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création d'identité visuelle",
  "description": "Création de logo et charte graphique sur mesure pour artisans et indépendants. Option disponible avec chaque pack de création ou migration de site.",
  "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://www.agence-aurore.fr" },
  "areaServed": "France",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Options identité visuelle",
    "itemListElement": [
      { "@type": "Offer", "name": "Création de logo", "price": "150", "priceCurrency": "EUR", "description": "Création de logo sur mesure, livré en formats SVG, PNG et PDF." },
      { "@type": "Offer", "name": "Charte graphique", "price": "100", "priceCurrency": "EUR", "description": "Charte graphique complète : couleurs, typographies, règles d'usage." }
    ]
  }
};
---

<BaseLayout
  title="Création d'identité visuelle, Logo et charte graphique | aurore"
  description="Création de logo et charte graphique sur mesure pour artisans et indépendants. 2 propositions, retouches incluses, fichiers sources livrés. À partir de 150 €. aurore, France."
  slug="identite-visuelle"
  schema={[serviceSchema, faqSchema, catalogSchema]}
>

  <section class="service-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow"><span class="eyebrow-line" aria-hidden="true"></span>Identité visuelle · aurore<span class="eyebrow-line" aria-hidden="true"></span></div>
      <h1 class="service-h1">Votre image,<br /><span class="hero-serif">enfin cohérente.</span></h1>
      <p class="service-sub">Vos clients vous reconnaissent au premier coup d'oeil et savent immédiatement que vous êtes un professionnel sérieux.</p>
      <div class="hero-ctas">
        <a href="/contact/" class="btn btn-primary btn-lg">Ajouter à mon projet →</a>
        <a href="/tarifs/" class="btn btn-outline btn-lg">Voir les offres</a>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="service-notice">
      Votre identité visuelle s'ajoute en option à votre projet de site. Tout est pensé ensemble pour un résultat cohérent.
      <a href="/tarifs/">Voir les offres →</a>
    </div>
  </div>

  <!-- CE QUI EST LIVRÉ -->
  <section class="section">
    <div class="container">
      <span class="section-label fade-in">Ce qui est livré</span>
      <h2 class="section-title fade-in">Tout ce qu'il faut pour<br />inspirer confiance au premier regard.</h2>
      <div class="grid-3 fade-in" style="margin-top:48px;">
        {[
          { titre:"Logo vectoriel",          desc:"Votre logo s'adapte partout : carte de visite, enseigne, site web. Toujours net, quelle que soit la taille." },
          { titre:"Versions clair & sombre",  desc:"Votre logo reste lisible sur n'importe quel fond : site web, réseaux sociaux, documents imprimés." },
          { titre:"Palette de couleurs",      desc:"Des couleurs cohérentes qui renforcent votre image professionnelle, sur le web comme à l'impression." },
          { titre:"Typographies",             desc:"Deux polices qui s'accordent et donnent à votre communication une personnalité reconnaissable." },
          { titre:"Guide d'utilisation",      desc:"Vous savez exactement comment utiliser votre identité correctement, même sans connaissances en graphisme." },
          { titre:"Fichiers sources",         desc:"Tout vous appartient. Vous pouvez faire évoluer votre identité librement, sans dépendre de personne." },
        ].map(item => (
          <div class="card livraison-card">
            <div class="livraison-dot" aria-hidden="true"></div>
            <div>
              <h3 class="livraison-titre">{item.titre}</h3>
              <p class="livraison-desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESSUS -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <span class="section-label fade-in">Comment ça se passe</span>
      <h2 class="section-title fade-in">De la première idée à un logo<br />que vous montrez avec fierté.</h2>
      <div class="process-grid fade-in" style="margin-top:48px;">
        {[
          { n:"01", titre:"Brief créatif",          desc:"On parle de votre activité, vos valeurs, votre cible et vos inspirations visuelles. 30 minutes par email ou en appel." },
          { n:"02", titre:"2 propositions",         desc:"Deux directions distinctes vous sont soumises. Pas de pré-sélection interne : vous voyez deux vraies options." },
          { n:"03", titre:"Retouches & validation", desc:"Deux rondes de retouches incluses sur la direction choisie. On affine jusqu'à ce que ce soit juste." },
          { n:"04", titre:"Livraison des fichiers", desc:"Tous les formats livrés par email ou Dropbox. Logo, charte, fichiers sources, vous êtes propriétaire à 100 %." },
        ].map(s => (
          <div class="process-item card">
            <div class="process-num" aria-hidden="true">{s.n}</div>
            <h3 class="process-titre">{s.titre}</h3>
            <p class="process-desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BÉNÉFICES -->
  <section class="section">
    <div class="container">
      <span class="section-label fade-in">Pourquoi c'est important</span>
      <h2 class="section-title fade-in">Ce que ça change pour votre activité.</h2>
      <div class="grid-2 fade-in" style="margin-top:48px;">
        {[
          { titre:"Première impression professionnelle", desc:"Vos clients vous jugent en 3 secondes. Un logo soigné et cohérent leur dit immédiatement que vous êtes sérieux, avant même que vous ayez parlé." },
          { titre:"Cohérence sur tous vos supports",    desc:"Même couleurs, même police, même esprit, sur votre site, vos cartes, Instagram, vos devis. La cohérence construit la confiance." },
          { titre:"Vous vous démarquez",                desc:"La plupart des indépendants utilisent un logo bricolé ou générique. Une identité sur mesure vous différencie immédiatement et reste en mémoire." },
          { titre:"Vous assumez votre communication",   desc:"Quand vous aimez votre logo, vous le montrez. Vous publiez plus, vous envoyez vos devis avec plus de confiance, vous vous positionnez mieux." },
        ].map(b => (
          <div class="card">
            <h3 style="font-size:16px;font-weight:600;letter-spacing:-0.02em;margin-bottom:8px;">{b.titre}</h3>
            <p style="font-size:14px;line-height:1.65;margin:0;">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TARIFS EN OPTION -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <span class="section-label fade-in">Tarifs</span>
      <h2 class="section-title fade-in">En option avec chaque pack.</h2>
      <div class="options-note fade-in" style="margin-top:48px;max-width:800px;margin-left:auto;margin-right:auto;">
        <p class="options-title">Options disponibles avec chaque pack</p>
        <div class="options-grid">
          <div class="option-item">
            <span class="option-price">+150 €</span>
            <span class="option-label">Création de logo</span>
            <ul class="option-features">
              {["Logotype sur mesure","2 propositions créatives","2 rondes de retouches","Versions clair & sombre","Formats SVG, PNG, PDF","Fichiers sources inclus"].map(f => (
                <li>{f}</li>
              ))}
            </ul>
          </div>
          <div class="option-item">
            <span class="option-price">+100 €</span>
            <span class="option-label">Charte graphique complète</span>
            <ul class="option-features">
              {["Palette de couleurs complète","Typographies sélectionnées","Guide d'utilisation","Déclinaisons supports (digital + print)"].map(f => (
                <li>{f}</li>
              ))}
            </ul>
          </div>
        </div>
        <p class="options-mention">Ces options s'ajoutent uniquement à un pack Starter, Vitrine, Pro ou Migration.</p>
      </div>
      <div style="text-align:center;margin-top:32px;" class="fade-in">
        <a href="/tarifs/" class="btn btn-primary btn-lg">Voir les offres →</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width:720px;">
      <span class="section-label fade-in">FAQ</span>
      <h2 class="section-title fade-in">Questions sur l'identité visuelle.</h2>
      <div style="margin-top:36px;" class="fade-in">
        {faqSchema.mainEntity.map((item: any) => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">{item.name}<span class="faq-icon" aria-hidden="true">+</span></button>
            <div class="faq-answer">{item.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--gray-50);"><div class="container"><div class="cta-section fade-in">
    <h2>Vos clients vous reconnaissent-ils au premier regard ?</h2>
    <p>Décrivez votre activité et ce que vous souhaitez transmettre. L'identité visuelle s'ajoute en option à votre projet de site.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="/contact/" class="btn btn-aurora btn-lg">Ajouter à mon projet →</a>
      <a href="/tarifs/" class="btn btn-outline btn-lg">Voir les offres</a>
    </div>
  </div></div></section>

</BaseLayout>

<style>
  .service-hero  { padding:160px 0 80px; text-align:center; }
  .service-h1    { font-family:var(--font-display); font-size:clamp(34px,5vw,62px); font-weight:700; letter-spacing:-0.05em; line-height:1.05; margin:20px 0 16px; }
  .service-sub   { font-size:clamp(15px,1.3vw,18px); line-height:1.65; max-width:520px; margin:0 auto 32px; }

  .livraison-card  { display:flex; align-items:flex-start; gap:14px; }
  .livraison-dot   { width:8px; height:8px; border-radius:50%; background:var(--aurora); flex-shrink:0; margin-top:6px; }
  .livraison-titre { font-size:15px; font-weight:600; letter-spacing:-0.02em; margin-bottom:4px; }
  .livraison-desc  { font-size:14px; color:var(--gray-500); line-height:1.6; margin:0; }

  .process-grid  { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; }
  .process-item  { display:flex; flex-direction:column; gap:12px; }
  .process-num   { font-family:var(--font-display); font-size:32px; font-weight:800; letter-spacing:-0.06em; color:var(--aurora-light); line-height:1; }
  .process-titre { font-size:15px; font-weight:600; letter-spacing:-0.02em; color:var(--black); }
  .process-desc  { font-size:14px; color:var(--gray-500); line-height:1.6; margin:0; }

  .service-notice {
    background: var(--aurora-pale);
    border: 1px solid rgba(255,107,26,0.2);
    border-radius: var(--radius-md);
    padding: 16px 24px;
    font-size: 14px;
    color: var(--gray-700);
    line-height: 1.6;
    text-align: center;
    margin-top: -32px;
    margin-bottom: 32px;
    position: relative;
    z-index: 1;
  }
  .service-notice a {
    color: var(--aurora);
    font-weight: 600;
    text-decoration: none;
  }
  .service-notice a:hover {
    text-decoration: underline;
  }

  .options-note {
    background: var(--white);
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-lg);
    padding: 40px 32px;
    text-align: center;
  }
  .options-title {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--aurora);
    margin-bottom: 24px;
  }
  .options-grid {
    display: flex;
    gap: 48px;
    justify-content: center;
    margin-bottom: 16px;
  }
  .option-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .option-price {
    font-size: 24px;
    font-weight: 700;
    color: var(--black);
  }
  .option-label {
    font-size: 14px;
    color: var(--gray-500);
    margin-bottom: 12px;
  }
  .option-features {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: left;
  }
  .option-features li {
    font-size: 13px;
    color: var(--gray-500);
    line-height: 1.8;
    padding-left: 16px;
    position: relative;
  }
  .option-features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--aurora);
    font-size: 11px;
  }
  .options-mention {
    font-size: 12px;
    color: var(--gray-500);
    font-style: italic;
    margin: 0;
  }

  @media (max-width:1024px) { .process-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:768px)  {
    .service-hero { padding:120px 0 56px; }
    .process-grid { grid-template-columns:1fr; }
    .options-grid { flex-direction: column; gap: 32px; }
  }
</style>