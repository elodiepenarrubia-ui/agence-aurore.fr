---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqContact = [
  {
    q: "Travaillez-vous uniquement avec des clients locaux à Aix-en-Provence ?",
    r: "Non, je travaille avec des clients dans toute la France. Tout se fait à distance : un formulaire pour démarrer, des échanges par email ou visio. La distance ne change rien à la qualité du résultat.",
  },
  {
    q: "Faut-il avoir un brief précis pour vous contacter ?",
    r: "Pas du tout. Si vous avez juste l'idée de créer une présence en ligne sans savoir par où commencer, décrivez simplement votre projet dans le formulaire. Je vous réponds avec un plan clair sous 48h.",
  },
  {
    q: "Comment se passe la suite après le formulaire ?",
    r: "Je vous réponds sous 48h ouvrées avec un devis détaillé, ligne par ligne. Vous validez avant tout démarrage, pas de surprise.",
  },
];
---

<BaseLayout
  title="Contact, Demandez un devis gratuit | aurore Aix-en-Provence"
  description="Contactez Élodie d'aurore pour votre projet de site web, identité visuelle ou SEO. Réponse sous 48h avec un devis détaillé, sans engagement."
  slug="contact"
>

  <!-- ─── HERO GRADIENT ─── -->
  <section class="contact-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Contact · aurore
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="contact-h1">
        Parlons de<br />
        <span class="hero-serif">votre projet.</span>
      </h1>
      <p class="contact-sub">
        Décrivez votre activité en 2 minutes. Je vous réponds sous 48h avec un plan clair pour que vos clients vous trouvent en ligne.
      </p>
    </div>
  </section>

  <!-- ─── CORPS : FORMULAIRE + INFOS ─── -->
  <section class="section contact-section">
    <div class="container">
      <div class="contact-grid">

        <!-- ── Formulaire multi-étapes ── -->
        <div class="formulaire-col">
          <div class="contact-form-wrapper" id="contact-form-wrapper">

            <!-- Barre de progression -->
            <div class="mf-progress-wrapper">
              <div class="mf-progress-bar">
                <div class="mf-progress-fill" id="mf-progress-fill"></div>
              </div>
              <div class="mf-progress-text" id="mf-progress-text">Étape 1 / 3</div>
            </div>

            <!-- ─── ÉTAPE 1  -  Votre projet ─── -->
            <div class="mf-step" id="mf-step-1" data-step="1">
              <h2 class="mf-step-title">Quel est votre projet ?</h2>

              <div class="mf-cards-grid" id="mf-project-type">
                <label class="mf-card">
                  <input type="radio" name="projectType" value="site-vitrine" />
                  <div class="mf-card-inner">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                    <span class="mf-card-label">Nouveau site vitrine</span>
                    <span class="mf-card-desc">Présenter mon activité en ligne</span>
                  </div>
                </label>
                <label class="mf-card">
                  <input type="radio" name="projectType" value="site-reservation" />
                  <div class="mf-card-inner">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><path d="M9 16l2 2 4-4"/></svg>
                    <span class="mf-card-label">Site avec réservation ou paiement</span>
                    <span class="mf-card-desc">Prendre des RDV ou vendre en ligne</span>
                  </div>
                </label>
                <label class="mf-card">
                  <input type="radio" name="projectType" value="logiciel-metier" />
                  <div class="mf-card-inner">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                    <span class="mf-card-label">Logiciel sur mesure</span>
                    <span class="mf-card-desc">Un outil métier spécifique à mon activité</span>
                  </div>
                </label>
                <label class="mf-card">
                  <input type="radio" name="projectType" value="prestation-carte" />
                  <div class="mf-card-inner">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                    <span class="mf-card-label">Prestation à la carte</span>
                    <span class="mf-card-desc">J'ai déjà un site, je veux améliorer un point précis</span>
                  </div>
                </label>
              </div>

              <div class="mf-fields-row">
                <div class="form-group">
                  <label class="form-label" for="mf-activite">Votre activité / secteur</label>
                  <input class="form-input" type="text" id="mf-activite" name="activite" placeholder="ex. massothérapeute, artisan plombier..." />
                </div>
                <div class="form-group">
                  <label class="form-label" for="mf-ville">Votre ville</label>
                  <input class="form-input" type="text" id="mf-ville" name="ville" placeholder="ex. Aix-en-Provence" />
                </div>
              </div>

              <div class="mf-nav">
                <div></div>
                <button type="button" class="btn btn-aurora mf-btn-next" id="mf-next-1" disabled>Suivant →</button>
              </div>
            </div>

            <!-- ─── ÉTAPE 2  -  Votre situation ─── -->
            <div class="mf-step" id="mf-step-2" data-step="2" hidden>
              <h2 class="mf-step-title">Votre situation</h2>

              <!-- Contenu conditionnel : site-vitrine / site-reservation -->
              <div class="mf-conditional" id="mf-cond-site" hidden>
                <div class="mf-field-group">
                  <label class="form-label">Vous avez déjà un logo ?</label>
                  <div class="mf-toggle-group">
                    <button type="button" class="mf-toggle" data-field="hasLogo" data-value="oui">Oui</button>
                    <button type="button" class="mf-toggle" data-field="hasLogo" data-value="non">Non</button>
                  </div>
                </div>
                <div class="mf-field-group">
                  <label class="form-label">Vous avez déjà un nom de domaine ?</label>
                  <div class="mf-toggle-group">
                    <button type="button" class="mf-toggle" data-field="hasDomain" data-value="oui">Oui</button>
                    <button type="button" class="mf-toggle" data-field="hasDomain" data-value="non">Non</button>
                  </div>
                </div>
                <div class="mf-field-group">
                  <label class="form-label">Votre budget estimé</label>
                  <div class="mf-cards-grid mf-cards-4" id="mf-budget-site">
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="budgetSite" value="moins-500" />
                      <div class="mf-card-inner"><span class="mf-card-label">Moins de 500 €</span></div>
                    </label>
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="budgetSite" value="500-1000" />
                      <div class="mf-card-inner"><span class="mf-card-label">500 € à 1 000 €</span></div>
                    </label>
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="budgetSite" value="1000-1500" />
                      <div class="mf-card-inner"><span class="mf-card-label">1 000 € à 1 500 €</span></div>
                    </label>
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="budgetSite" value="plus-1500" />
                      <div class="mf-card-inner"><span class="mf-card-label">Plus de 1 500 €</span></div>
                    </label>
                  </div>
                </div>
                <div class="mf-field-group">
                  <label class="form-label">Délai souhaité</label>
                  <div class="mf-cards-grid mf-cards-3" id="mf-delai-site">
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="delaiSite" value="asap" />
                      <div class="mf-card-inner"><span class="mf-card-label">Dès que possible</span></div>
                    </label>
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="delaiSite" value="dans-le-mois" />
                      <div class="mf-card-inner"><span class="mf-card-label">Dans le mois</span></div>
                    </label>
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="delaiSite" value="pas-urgent" />
                      <div class="mf-card-inner"><span class="mf-card-label">Pas urgent</span></div>
                    </label>
                  </div>
                </div>
              </div>

              <!-- Contenu conditionnel : logiciel-metier -->
              <div class="mf-conditional" id="mf-cond-logiciel" hidden>
                <div class="mf-field-group">
                  <label class="form-label" for="mf-besoin">Décrivez votre besoin en quelques mots</label>
                  <textarea class="form-textarea" id="mf-besoin" name="besoin" rows="3" placeholder="Décrivez ce que l'outil devrait faire..."></textarea>
                </div>
                <div class="mf-field-group">
                  <label class="form-label">Vous avez des outils existants à connecter ?</label>
                  <div class="mf-toggle-group">
                    <button type="button" class="mf-toggle" data-field="hasTools" data-value="oui">Oui</button>
                    <button type="button" class="mf-toggle" data-field="hasTools" data-value="non">Non</button>
                  </div>
                  <div class="mf-sub-field" id="mf-tools-detail" hidden>
                    <input class="form-input" type="text" id="mf-outils" name="outils" placeholder="Lesquels ? ex. Google Sheets, Stripe..." />
                  </div>
                </div>
                <div class="mf-field-group">
                  <label class="form-label">Votre budget estimé</label>
                  <div class="mf-cards-grid mf-cards-3" id="mf-budget-logiciel">
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="budgetLogiciel" value="1000-3000" />
                      <div class="mf-card-inner"><span class="mf-card-label">1 000 € à 3 000 €</span></div>
                    </label>
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="budgetLogiciel" value="3000-6000" />
                      <div class="mf-card-inner"><span class="mf-card-label">3 000 € à 6 000 €</span></div>
                    </label>
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="budgetLogiciel" value="plus-6000" />
                      <div class="mf-card-inner"><span class="mf-card-label">Plus de 6 000 €</span></div>
                    </label>
                  </div>
                </div>
                <div class="mf-field-group">
                  <label class="form-label">Délai souhaité</label>
                  <div class="mf-cards-grid mf-cards-3" id="mf-delai-logiciel">
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="delaiLogiciel" value="asap" />
                      <div class="mf-card-inner"><span class="mf-card-label">Dès que possible</span></div>
                    </label>
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="delaiLogiciel" value="dans-le-mois" />
                      <div class="mf-card-inner"><span class="mf-card-label">Dans le mois</span></div>
                    </label>
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="delaiLogiciel" value="pas-urgent" />
                      <div class="mf-card-inner"><span class="mf-card-label">Pas urgent</span></div>
                    </label>
                  </div>
                </div>
              </div>

              <!-- Contenu conditionnel : prestation-carte -->
              <div class="mf-conditional" id="mf-cond-carte" hidden>
                <div class="mf-field-group">
                  <label class="form-label">Quelle prestation vous intéresse ?</label>
                  <div class="mf-checkboxes">
                    <label class="mf-checkbox-label"><input type="checkbox" name="prestations" value="logo" class="mf-checkbox" /> Logo <span class="mf-option-tag">(option pack)</span></label>
                    <label class="mf-checkbox-label"><input type="checkbox" name="prestations" value="charte-graphique" class="mf-checkbox" /> Charte graphique <span class="mf-option-tag">(option pack)</span></label>
                    <label class="mf-checkbox-label"><input type="checkbox" name="prestations" value="seo" class="mf-checkbox" /> SEO</label>
                    <label class="mf-checkbox-label"><input type="checkbox" name="prestations" value="formulaire" class="mf-checkbox" /> Formulaire de contact</label>
                    <label class="mf-checkbox-label"><input type="checkbox" name="prestations" value="automatisation" class="mf-checkbox" /> Automatisation</label>
                    <label class="mf-checkbox-label"><input type="checkbox" name="prestations" value="migration" class="mf-checkbox" /> Migration de site</label>
                    <label class="mf-checkbox-label"><input type="checkbox" name="prestations" value="autre" class="mf-checkbox" /> Autre</label>
                  </div>
                </div>
                <div class="mf-field-group">
                  <label class="form-label">Vous avez déjà un site ?</label>
                  <div class="mf-toggle-group">
                    <button type="button" class="mf-toggle" data-field="hasSite" data-value="oui">Oui</button>
                    <button type="button" class="mf-toggle" data-field="hasSite" data-value="non">Non</button>
                  </div>
                  <div class="mf-sub-field" id="mf-site-detail" hidden>
                    <input class="form-input" type="text" id="mf-plateforme" name="plateforme" placeholder="Sur quelle plateforme ? ex. WordPress, Wix..." />
                  </div>
                </div>
                <div class="mf-field-group">
                  <label class="form-label">Votre budget estimé</label>
                  <div class="mf-cards-grid mf-cards-3" id="mf-budget-carte">
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="budgetCarte" value="moins-200" />
                      <div class="mf-card-inner"><span class="mf-card-label">Moins de 200 €</span></div>
                    </label>
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="budgetCarte" value="200-500" />
                      <div class="mf-card-inner"><span class="mf-card-label">200 € à 500 €</span></div>
                    </label>
                    <label class="mf-card mf-card-sm">
                      <input type="radio" name="budgetCarte" value="plus-500" />
                      <div class="mf-card-inner"><span class="mf-card-label">Plus de 500 €</span></div>
                    </label>
                  </div>
                </div>
              </div>

              <div class="mf-nav">
                <button type="button" class="btn btn-outline mf-btn-prev" data-prev="1">← Retour</button>
                <button type="button" class="btn btn-aurora mf-btn-next" id="mf-next-2">Suivant →</button>
              </div>
            </div>

            <!-- ─── ÉTAPE 3  -  Vos coordonnées ─── -->
            <div class="mf-step" id="mf-step-3" data-step="3" hidden>
              <h2 class="mf-step-title">Vos coordonnées</h2>

              <div class="mf-fields-row">
                <div class="form-group">
                  <label class="form-label" for="mf-prenom">Prénom <span class="form-required" aria-hidden="true">*</span></label>
                  <input class="form-input" type="text" id="mf-prenom" name="prenom" required autocomplete="given-name" placeholder="Marie" />
                </div>
                <div class="form-group">
                  <label class="form-label" for="mf-nom">Nom <span class="form-required" aria-hidden="true">*</span></label>
                  <input class="form-input" type="text" id="mf-nom" name="nom" required autocomplete="family-name" placeholder="Dupont" />
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="mf-email">Email <span class="form-required" aria-hidden="true">*</span></label>
                <input class="form-input" type="email" id="mf-email" name="email" required autocomplete="email" placeholder="marie@monentreprise.fr" />
              </div>

              <div class="form-group">
                <label class="form-label" for="mf-telephone">Téléphone</label>
                <input class="form-input" type="tel" id="mf-telephone" name="telephone" autocomplete="tel" placeholder="06 12 34 56 78" />
                <span class="form-hint">Facultatif, pour un rappel si vous préférez</span>
              </div>

              <div class="form-group">
                <label class="form-label" for="mf-message">Message complémentaire</label>
                <textarea class="form-textarea" id="mf-message" name="messageComplementaire" rows="3" placeholder="Tout ce que vous souhaitez ajouter..."></textarea>
              </div>

              <div class="form-group form-consent">
                <label class="form-checkbox-label">
                  <input type="checkbox" required name="consentement" class="form-checkbox" id="mf-consent" />
                  <span>J'accepte que mes données soient utilisées pour traiter ma demande, conformément à la <a href="/mentions-legales/">politique de confidentialité</a>.</span>
                </label>
              </div>

              <div class="mf-nav">
                <button type="button" class="btn btn-outline mf-btn-prev" data-prev="2">← Retour</button>
                <button type="button" class="btn btn-aurora btn-lg mf-btn-submit" id="mf-submit" disabled>
                  <span class="mf-btn-text">Envoyer ma demande →</span>
                  <span class="mf-btn-loading" aria-hidden="true"><span class="spinner"></span> Envoi en cours…</span>
                </button>
              </div>
              <p class="form-rgpd">Aucun démarchage, aucune revente de vos données.</p>
            </div>
          </div>

          <!-- Message de confirmation -->
          <div class="form-success" id="form-success" aria-live="polite" hidden>
            <div class="success-icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
            </div>
            <h3>Demande envoyée !</h3>
            <p>Je vous réponds sous <strong>48h</strong> avec un devis détaillé.<br />Vous allez recevoir un email de confirmation.</p>
            <a href="/" class="btn btn-ghost" style="margin-top: 16px;">Retour à l'accueil</a>
          </div>

          <!-- Message d'erreur -->
          <div class="form-error-banner" id="form-error" aria-live="polite" hidden>
            Une erreur est survenue, merci de m'écrire directement à
            <a href="mailto:elodie@agence-aurore.fr">elodie@agence-aurore.fr</a>
          </div>
        </div>

        <!-- ── Infos de contact ── -->
        <aside class="contact-infos" aria-label="Informations de contact">
          <div class="info-bloc">
            <div class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <div class="info-label">Email</div>
              <a href="mailto:elodie@agence-aurore.fr" class="info-value">elodie@agence-aurore.fr</a>
            </div>
          </div>
          <div class="info-bloc">
            <div class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <div class="info-label">Délai de réponse</div>
              <div class="info-value">Devis détaillé en 48h</div>
            </div>
          </div>
          <div class="info-bloc">
            <div class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <div class="info-label">Basée à</div>
              <div class="info-value">Aix-en-Provence</div>
              <div class="info-sub">Intervention dans toute la France</div>
            </div>
          </div>
          <div class="info-bloc">
            <a href="https://wa.me/33659659218?text=Bonjour%20Élodie%2C%20je%20souhaite%20en%20savoir%20plus%20sur%20vos%20services." target="_blank" rel="noopener" class="whatsapp-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#25D366">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <span>Écrire sur WhatsApp</span>
              <span style="font-size:12px;color:var(--gray-500);">(messages uniquement)</span>
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ─── FAQ CONTACT ─── -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container" style="max-width: 720px;">
      <span class="section-label fade-in">Questions</span>
      <h2 class="section-title fade-in">Avant de remplir le formulaire.</h2>
      <div style="margin-top: 36px;" class="fade-in">
        {faqContact.map(item => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              {item.q}
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer">{item.r}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ─── */
  .contact-hero { padding: 160px 0 80px; text-align: center; }
  .contact-h1 { font-family: var(--font-display); font-size: clamp(36px, 5vw, 64px); font-weight: 700; letter-spacing: -0.05em; line-height: 1.05; margin: 20px 0 16px; }
  .contact-sub { font-size: clamp(15px, 1.3vw, 18px); line-height: 1.65; max-width: 520px; margin: 0 auto; }

  /* ─── GRID CONTACT ─── */
  .contact-section { padding-top: 0; }
  .contact-grid { display: grid; grid-template-columns: 1fr 340px; gap: 64px; align-items: start; }

  /* ─── FORM WRAPPER ─── */
  .contact-form-wrapper {
    background: var(--white);
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-xl);
    padding: 40px;
    position: relative;
    overflow: hidden;
  }

  /* ─── PROGRESS BAR ─── */
  .mf-progress-wrapper { margin-bottom: 32px; }
  .mf-progress-bar { width: 100%; height: 4px; background: var(--gray-100); border-radius: 2px; overflow: hidden; }
  .mf-progress-fill { height: 100%; background: var(--aurora); border-radius: 2px; transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1); width: 33.33%; }
  .mf-progress-text { font-size: 12px; font-weight: 600; color: var(--aurora); letter-spacing: 0.05em; margin-top: 8px; }

  /* ─── STEPS ─── */
  .mf-step {
    display: flex;
    flex-direction: column;
    gap: 20px;
    animation: mfSlideIn 0.3s ease;
  }
  .mf-step[hidden] { display: none; }
  .mf-step-title { font-family: var(--font-display); font-size: clamp(20px, 2.5vw, 26px); font-weight: 700; letter-spacing: -0.03em; color: var(--black); margin: 0; }

  @keyframes mfSlideIn {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* ─── CLICKABLE CARDS ─── */
  .mf-cards-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .mf-cards-grid.mf-cards-3 { grid-template-columns: repeat(3, 1fr); }
  .mf-cards-grid.mf-cards-4 { grid-template-columns: repeat(2, 1fr); }

  .mf-card { cursor: pointer; }
  .mf-card input { position: absolute; opacity: 0; pointer-events: none; }
  .mf-card-inner {
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    padding: 24px 16px; border: 1.5px solid var(--gray-100); border-radius: var(--radius-lg);
    text-align: center; transition: var(--transition); color: var(--gray-500);
  }
  .mf-card-inner:hover { border-color: var(--gray-300); }
  .mf-card input:checked ~ .mf-card-inner { border-color: var(--aurora); background: var(--aurora-pale); color: var(--aurora); }
  .mf-card-label { font-size: 14px; font-weight: 600; color: var(--black); }
  .mf-card input:checked ~ .mf-card-inner .mf-card-label { color: var(--aurora-dark); }
  .mf-card-desc { font-size: 12px; line-height: 1.4; }

  .mf-card-sm .mf-card-inner { padding: 16px 12px; gap: 6px; }

  /* ─── TOGGLE BUTTONS ─── */
  .mf-toggle-group { display: flex; gap: 8px; }
  .mf-toggle {
    padding: 10px 24px; border: 1.5px solid var(--gray-100); border-radius: 100px;
    font-size: 14px; font-weight: 500; font-family: var(--font-display);
    background: var(--white); color: var(--black); cursor: pointer; transition: var(--transition);
  }
  .mf-toggle:hover { border-color: var(--gray-300); }
  .mf-toggle.active { border-color: var(--aurora); background: var(--aurora-pale); color: var(--aurora); font-weight: 600; }

  /* ─── CHECKBOXES ─── */
  .mf-checkboxes { display: flex; flex-wrap: wrap; gap: 8px; }
  .mf-checkbox-label {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 18px; border: 1.5px solid var(--gray-100); border-radius: 100px;
    font-size: 14px; font-weight: 500; cursor: pointer; transition: var(--transition);
    user-select: none;
  }
  .mf-checkbox-label:hover { border-color: var(--gray-300); }
  .mf-checkbox-label:has(.mf-checkbox:checked) { border-color: var(--aurora); background: var(--aurora-pale); color: var(--aurora); font-weight: 600; }
  .mf-checkbox { accent-color: var(--aurora); width: 15px; height: 15px; }
  .mf-option-tag { font-size: 10px; color: var(--gray-500); font-weight: 400; }

  /* ─── FIELD GROUPS ─── */
  .mf-field-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
  .mf-field-group:last-child { margin-bottom: 0; }
  .mf-sub-field { margin-top: 8px; }
  .mf-sub-field[hidden] { display: none; }
  .mf-fields-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .mf-conditional[hidden] { display: none; }

  /* ─── NAV BUTTONS ─── */
  .mf-nav { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; }
  .mf-btn-next:disabled, .mf-btn-submit:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ─── SUBMIT BUTTON ─── */
  .mf-btn-submit { position: relative; justify-content: center; }
  .mf-btn-loading { display: none; align-items: center; gap: 8px; }
  .mf-btn-submit.loading .mf-btn-text { display: none; }
  .mf-btn-submit.loading .mf-btn-loading { display: inline-flex; }

  /* ─── CONSENT ─── */
  .form-consent { margin-top: 4px; }
  .form-checkbox-label { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; line-height: 1.55; color: var(--gray-700); cursor: pointer; }
  .form-checkbox { margin-top: 3px; flex-shrink: 0; accent-color: var(--aurora); width: 16px; height: 16px; }
  .form-checkbox-label a { color: var(--aurora); text-decoration: underline; text-underline-offset: 3px; }
  .form-checkbox-label a:hover { color: var(--aurora-dark); }
  .form-required { color: var(--aurora); margin-left: 2px; }
  .form-rgpd { font-size: 12px; color: var(--gray-500); line-height: 1.6; margin: 8px 0 0; text-align: center; }

  /* ─── SUCCESS / ERROR ─── */
  .form-success { background: var(--aurora-pale); border: 1.5px solid rgba(255,107,26,0.2); border-radius: var(--radius-xl); padding: 48px 40px; text-align: center; }
  .success-icon { width: 56px; height: 56px; background: var(--aurora); color: var(--white); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; }
  .form-success h3 { font-size: 22px; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 8px; }
  .form-success p { font-size: 15px; color: var(--gray-500); margin: 0; }
  .form-error-banner { background: #FEF2F2; border: 1.5px solid #FECACA; border-radius: var(--radius-md); padding: 16px 20px; color: #991B1B; font-size: 14px; line-height: 1.6; text-align: center; margin-top: 12px; }
  .form-error-banner a { color: #991B1B; font-weight: 600; text-decoration: underline; }

  /* ─── INFOS LATÉRALES ─── */
  .contact-infos { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 20px; }
  .info-bloc { display: flex; align-items: flex-start; gap: 14px; }
  .info-icon { width: 40px; height: 40px; background: var(--aurora-pale); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--aurora); flex-shrink: 0; }
  .info-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gray-500); margin-bottom: 3px; }
  .info-value { font-size: 15px; font-weight: 600; color: var(--black); letter-spacing: -0.01em; transition: var(--transition); }
  a.info-value:hover { color: var(--aurora); }
  .info-sub { font-size: 12px; color: var(--gray-500); margin-top: 2px; }

  .whatsapp-link {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 12px 20px; border: 1.5px solid #e0e0e0;
    border-radius: 100px; font-size: 14px; color: var(--black);
    text-decoration: none; transition: border-color 0.2s;
  }
  .whatsapp-link:hover { border-color: #25D366; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .contact-infos { position: static; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  }

  @media (max-width: 768px) {
    .contact-hero { padding: 120px 0 56px; }
    .contact-form-wrapper { padding: 24px 20px; border-radius: var(--radius-lg); }
    .contact-infos { grid-template-columns: 1fr; }
    .mf-cards-grid { grid-template-columns: 1fr; }
    .mf-cards-grid.mf-cards-3 { grid-template-columns: 1fr; }
    .mf-cards-grid.mf-cards-4 { grid-template-columns: 1fr; }
    .mf-cards-grid.mf-cards-2 { grid-template-columns: 1fr; }
    .mf-fields-row { grid-template-columns: 1fr; }
    .mf-nav { flex-direction: column-reverse; gap: 12px; }
    .mf-nav .btn { width: 100%; justify-content: center; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ─── State ───
    const state: Record<string, any> = {
      step: 1,
      projectType: '',
      activite: '',
      ville: '',
      // Step 2 - site
      hasLogo: '',
      hasDomain: '',
      budgetSite: '',
      delaiSite: '',
      // Step 2 - logiciel
      besoin: '',
      hasTools: '',
      outils: '',
      budgetLogiciel: '',
      delaiLogiciel: '',
      // Step 2 - carte
      prestations: [] as string[],
      hasSite: '',
      plateforme: '',
      budgetCarte: '',
      // Step 3 - coordonnées
      prenom: '',
      nom: '',
      email: '',
      telephone: '',
      messageComplementaire: '',
      consentement: false,
    };

    const wrapper = document.getElementById('contact-form-wrapper') as HTMLElement;
    const progressFill = document.getElementById('mf-progress-fill') as HTMLElement;
    const progressText = document.getElementById('mf-progress-text') as HTMLElement;
    const successBlock = document.getElementById('form-success') as HTMLElement;
    const errorBlock = document.getElementById('form-error') as HTMLElement;

    // ─── Navigation ───
    const totalSteps = 3;

    function goToStep(n: number) {
      document.querySelectorAll('.mf-step').forEach(s => (s as HTMLElement).hidden = true);
      state.step = n;

      const target = document.getElementById(`mf-step-${n}`) as HTMLElement;
      if (target) {
        target.hidden = false;
        target.style.animation = 'none';
        target.offsetHeight; // force reflow
        target.style.animation = '';
      }

      const progress = (n / totalSteps) * 100;
      progressFill.style.width = `${progress}%`;
      progressText.textContent = `Étape ${n} / ${totalSteps}`;

      if (state.step === 2) showConditionalStep2();

      updateSubmitState();
      wrapper.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function showConditionalStep2() {
      const condSite = document.getElementById('mf-cond-site') as HTMLElement;
      const condLogiciel = document.getElementById('mf-cond-logiciel') as HTMLElement;
      const condCarte = document.getElementById('mf-cond-carte') as HTMLElement;
      condSite.hidden = true;
      condLogiciel.hidden = true;
      condCarte.hidden = true;

      if (state.projectType === 'site-vitrine' || state.projectType === 'site-reservation') {
        condSite.hidden = false;
      } else if (state.projectType === 'logiciel-metier') {
        condLogiciel.hidden = false;
      } else if (state.projectType === 'prestation-carte') {
        condCarte.hidden = false;
      }
    }

    // ─── Step 1: Project type cards ───
    const projectCards = document.querySelectorAll('#mf-project-type input[type="radio"]');
    const nextBtn1 = document.getElementById('mf-next-1') as HTMLButtonElement;

    projectCards.forEach(radio => {
      radio.addEventListener('change', () => {
        state.projectType = (radio as HTMLInputElement).value;
        nextBtn1.disabled = false;
      });
    });

    nextBtn1.addEventListener('click', () => {
      state.activite = (document.getElementById('mf-activite') as HTMLInputElement).value;
      state.ville = (document.getElementById('mf-ville') as HTMLInputElement).value;
      goToStep(2);
    });

    // ─── Toggle buttons ───
    document.querySelectorAll('.mf-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const field = (btn as HTMLElement).dataset.field!;
        const value = (btn as HTMLElement).dataset.value!;
        state[field] = value;

        // Update active state within group
        const group = btn.parentElement!;
        group.querySelectorAll('.mf-toggle').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Show/hide sub-fields
        if (field === 'hasTools') {
          (document.getElementById('mf-tools-detail') as HTMLElement).hidden = value !== 'oui';
        }
        if (field === 'hasSite') {
          (document.getElementById('mf-site-detail') as HTMLElement).hidden = value !== 'oui';
        }
      });
    });

    // ─── Step 2 next ───
    const nextBtn2 = document.getElementById('mf-next-2') as HTMLButtonElement;
    nextBtn2.addEventListener('click', () => {
      // Collect step 2 state
      if (state.projectType === 'site-vitrine' || state.projectType === 'site-reservation') {
        const budgetRadio = document.querySelector('input[name="budgetSite"]:checked') as HTMLInputElement;
        const delaiRadio = document.querySelector('input[name="delaiSite"]:checked') as HTMLInputElement;
        state.budgetSite = budgetRadio?.value || '';
        state.delaiSite = delaiRadio?.value || '';
      } else if (state.projectType === 'logiciel-metier') {
        state.besoin = (document.getElementById('mf-besoin') as HTMLTextAreaElement).value;
        state.outils = (document.getElementById('mf-outils') as HTMLInputElement).value;
        const budgetRadio = document.querySelector('input[name="budgetLogiciel"]:checked') as HTMLInputElement;
        const delaiRadio = document.querySelector('input[name="delaiLogiciel"]:checked') as HTMLInputElement;
        state.budgetLogiciel = budgetRadio?.value || '';
        state.delaiLogiciel = delaiRadio?.value || '';
      } else if (state.projectType === 'prestation-carte') {
        const checked = document.querySelectorAll('input[name="prestations"]:checked');
        state.prestations = Array.from(checked).map(c => (c as HTMLInputElement).value);
        state.plateforme = (document.getElementById('mf-plateforme') as HTMLInputElement)?.value || '';
        const budgetRadio = document.querySelector('input[name="budgetCarte"]:checked') as HTMLInputElement;
        state.budgetCarte = budgetRadio?.value || '';
      }
      goToStep(3);
    });

    // ─── Prev buttons ───
    document.querySelectorAll('.mf-btn-prev').forEach(btn => {
      btn.addEventListener('click', () => {
        const prev = parseInt((btn as HTMLElement).dataset.prev || '1');
        goToStep(prev);
      });
    });

    // ─── Step 3: Submit validation ───
    const submitBtn = document.getElementById('mf-submit') as HTMLButtonElement;
    const prenomInput = document.getElementById('mf-prenom') as HTMLInputElement;
    const nomInput = document.getElementById('mf-nom') as HTMLInputElement;
    const emailInput = document.getElementById('mf-email') as HTMLInputElement;
    const consentInput = document.getElementById('mf-consent') as HTMLInputElement;

    function updateSubmitState() {
      if (state.step !== 3) return;
      const valid = prenomInput.value.trim() !== '' &&
                    nomInput.value.trim() !== '' &&
                    emailInput.value.trim() !== '' &&
                    emailInput.validity.valid &&
                    consentInput.checked;
      submitBtn.disabled = !valid;
    }

    [prenomInput, nomInput, emailInput, consentInput].forEach(el => {
      el.addEventListener('input', updateSubmitState);
      el.addEventListener('change', updateSubmitState);
    });

    // ─── Submit ───
    submitBtn.addEventListener('click', async () => {
      // Collect step 3 data
      state.prenom = prenomInput.value.trim();
      state.nom = nomInput.value.trim();
      state.email = emailInput.value.trim();
      state.telephone = (document.getElementById('mf-telephone') as HTMLInputElement).value.trim();
      state.messageComplementaire = (document.getElementById('mf-message') as HTMLTextAreaElement).value.trim();

      // Validate
      if (!state.prenom || !state.nom || !state.email) return;

      // UI loading
      submitBtn.classList.add('loading');
      submitBtn.disabled = true;
      errorBlock.hidden = true;

      // Labels for project types
      const projectLabels: Record<string, string> = {
        'site-vitrine': 'Nouveau site vitrine',
        'site-reservation': 'Site avec réservation ou paiement',
        'logiciel-metier': 'Logiciel sur mesure',
        'prestation-carte': 'Prestation à la carte',
      };

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            // Step 1
            projectType: state.projectType,
            projectTypeLabel: projectLabels[state.projectType] || state.projectType,
            activite: state.activite,
            ville: state.ville,
            // Step 2
            hasLogo: state.hasLogo,
            hasDomain: state.hasDomain,
            budgetSite: state.budgetSite,
            delaiSite: state.delaiSite,
            besoin: state.besoin,
            hasTools: state.hasTools,
            outils: state.outils,
            budgetLogiciel: state.budgetLogiciel,
            delaiLogiciel: state.delaiLogiciel,
            prestations: state.prestations,
            hasSite: state.hasSite,
            plateforme: state.plateforme,
            budgetCarte: state.budgetCarte,
            // Step 3
            prenom: state.prenom,
            nom: state.nom,
            email: state.email,
            telephone: state.telephone,
            messageComplementaire: state.messageComplementaire,
          }),
        });

        const data = await response.json();

        if (response.ok && data.success) {
          wrapper.hidden = true;
          successBlock.hidden = false;
          successBlock.focus();
        } else {
          throw new Error(data.error || 'Erreur serveur');
        }
      } catch {
        errorBlock.hidden = false;
        errorBlock.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } finally {
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
        updateSubmitState();
      }
    });

  });
</script>
