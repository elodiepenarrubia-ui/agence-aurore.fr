---
import BaseLayout from '../layouts/BaseLayout.astro';

const typesProjets = [
  { value: "",                        label: "Type de projet — choisissez" },
  { value: "pack-starter",            label: "Pack Starter (290 €)" },
  { value: "site-statique",           label: "Site statique (590–790 €)" },
  { value: "site-vitrine-complet",    label: "Site vitrine complet (1 100–1 490 €)" },
  { value: "site-reservation",        label: "Site avec réservation (1 400–1 800 €)" },
  { value: "logiciel-metier",         label: "Logiciel métier (sur devis)" },
  { value: "identite-visuelle",       label: "Identité visuelle seule" },
  { value: "seo",                     label: "Référencement SEO" },
  { value: "autre",                   label: "Autre / Je ne sais pas encore" },
];

const budgets = [
  { value: "",           label: "Budget estimé — choisissez" },
  { value: "moins-500",  label: "Moins de 500 €" },
  { value: "500-1000",   label: "500 € – 1 000 €" },
  { value: "1000-2000",  label: "1 000 € – 2 000 €" },
  { value: "plus-2000",  label: "Plus de 2 000 €" },
  { value: "pas-encore", label: "Pas encore défini" },
];

const rassurants = [
  { icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`, titre: "Réponse sous 48h ouvrées", desc: "Je lis chaque message personnellement et réponds dans les 2 jours ouvrés." },
  { icon: `<circle cx="12" cy="12" r="10"/><path d="M8 12l2.5 2.5L16 9"/>`,   titre: "Appel de 30 min gratuit", desc: "Pas d'engagement. On fait le point sur votre projet avant tout devis." },
  { icon: `<path d="M12 2a10 10 0 0 1 10 10H2A10 10 0 0 1 12 2z"/><rect x=\"2\" y=\"12\" width=\"20\" height=\"10\" rx=\"1\"/>`, titre: "Devis détaillé sous 48h", desc: "Un devis précis, ligne par ligne, sans surprises ni zones grises." },
];

const faqContact = [
  {
    q: "Travaillez-vous uniquement avec des clients locaux à Aix-en-Provence ?",
    r: "Non, j'interviens dans toute la France. Tout se fait à distance via appel vidéo, email et liens de prévisualisation. La localisation n'a aucun impact sur la qualité du travail.",
  },
  {
    q: "Faut-il avoir un brief précis pour vous contacter ?",
    r: "Pas du tout. Si vous avez juste l'idée de créer une présence en ligne sans savoir par où commencer, c'est exactement pour ça que l'appel de 30 min existe. On structure ensemble.",
  },
  {
    q: "Comment se passe la suite après le formulaire ?",
    r: "Je vous réponds sous 48h ouvrées. Si votre projet correspond à mon offre, je vous propose un appel de 30 min gratuit. Ensuite, je prépare un devis détaillé que vous validez avant tout démarrage.",
  },
];
---

<BaseLayout
  title="Contact — Demandez un devis gratuit | aurore Aix-en-Provence"
  description="Contactez Élodie d'aurore pour votre projet de site web, identité visuelle ou SEO. Réponse sous 48h, devis gratuit, appel de 30 min sans engagement."
  slug="contact"
>

  <!-- ─── HERO GRADIENT ─── -->
  <section class="contact-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Contact · aurore
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="contact-h1">
        Parlons de<br />
        <span class="hero-serif">votre projet.</span>
      </h1>
      <p class="contact-sub">
        Un message suffit pour démarrer. Je vous réponds personnellement sous 48h ouvrées
        avec un premier retour honnête sur votre projet.
      </p>
    </div>
  </section>

  <!-- ─── CORPS : FORMULAIRE + INFOS ─── -->
  <section class="section contact-section">
    <div class="container">
      <div class="contact-grid">

        <!-- ── Formulaire ── -->
        <div class="formulaire-col">
          <form
            class="contact-form"
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            novalidate
            aria-label="Formulaire de contact"
          >
            <!-- Honeypot anti-spam -->
            <input type="hidden" name="form-name" value="contact" />
            <p class="visually-hidden">
              <label>Ne pas remplir si vous êtes humain : <input name="bot-field" /></label>
            </p>

            <!-- Ligne 1 : Nom + Email -->
            <div class="form-grid">
              <div class="form-group">
                <label class="form-label" for="nom">Prénom et nom <span class="form-required" aria-hidden="true">*</span></label>
                <input
                  class="form-input"
                  type="text"
                  id="nom"
                  name="nom"
                  placeholder="Marie Dupont"
                  required
                  autocomplete="name"
                />
              </div>
              <div class="form-group">
                <label class="form-label" for="email">Email <span class="form-required" aria-hidden="true">*</span></label>
                <input
                  class="form-input"
                  type="email"
                  id="email"
                  name="email"
                  placeholder="marie@monentreprise.fr"
                  required
                  autocomplete="email"
                />
              </div>
            </div>

            <!-- Ligne 2 : Téléphone + Type de projet -->
            <div class="form-grid">
              <div class="form-group">
                <label class="form-label" for="telephone">Téléphone</label>
                <input
                  class="form-input"
                  type="tel"
                  id="telephone"
                  name="telephone"
                  placeholder="06 12 34 56 78"
                  autocomplete="tel"
                />
                <span class="form-hint">Facultatif — pour un rappel si vous préférez</span>
              </div>
              <div class="form-group">
                <label class="form-label" for="type-projet">Type de projet <span class="form-required" aria-hidden="true">*</span></label>
                <select class="form-select" id="type-projet" name="type-projet" required>
                  {typesProjets.map(t => (
                    <option value={t.value} disabled={t.value === ""}>{t.label}</option>
                  ))}
                </select>
              </div>
            </div>

            <!-- Message -->
            <div class="form-group">
              <label class="form-label" for="message">Décrivez votre projet <span class="form-required" aria-hidden="true">*</span></label>
              <textarea
                class="form-textarea"
                id="message"
                name="message"
                rows={5}
                placeholder="Parlez-moi de votre activité, de ce que vous souhaitez créer, de vos clients cibles... Pas besoin d'être précis, on affine ensemble lors de l'appel."
                required
              ></textarea>
            </div>

            <!-- Budget -->
            <div class="form-group">
              <label class="form-label" for="budget">Budget estimé</label>
              <select class="form-select" id="budget" name="budget">
                {budgets.map(b => (
                  <option value={b.value} disabled={b.value === ""}>{b.label}</option>
                ))}
              </select>
              <span class="form-hint">
                Aucune obligation — cela m'aide à vous proposer la solution la plus adaptée.
                <a href="/tarifs/" class="form-hint-link">Voir les tarifs →</a>
              </span>
            </div>

            <!-- Submit -->
            <div class="form-submit">
              <button type="submit" class="btn btn-aurora btn-lg form-btn">
                <span class="form-btn-text">Envoyer ma demande →</span>
                <span class="form-btn-loading" aria-hidden="true">
                  <span class="spinner"></span> Envoi en cours…
                </span>
              </button>
              <p class="form-rgpd">
                En envoyant ce formulaire, vous acceptez que vos données soient utilisées
                uniquement pour répondre à votre demande. Aucun démarchage, aucune revente.
              </p>
            </div>
          </form>

          <!-- Message de confirmation (caché par défaut) -->
          <div class="form-success" id="form-success" aria-live="polite" hidden>
            <div class="success-icon" aria-hidden="true">✓</div>
            <h3>Message envoyé !</h3>
            <p>Merci pour votre message. Je vous réponds personnellement sous <strong>48h ouvrées</strong>.</p>
            <a href="/" class="btn btn-ghost" style="margin-top: 16px;">Retour à l'accueil</a>
          </div>
        </div>

        <!-- ── Infos de contact ── -->
        <aside class="contact-infos" aria-label="Informations de contact">

          <!-- Email direct -->
          <div class="info-bloc">
            <div class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <div class="info-label">Email</div>
              <a href="mailto:contact@agence-aurore.fr" class="info-value">
                contact@agence-aurore.fr
              </a>
            </div>
          </div>

          <!-- Délai de réponse -->
          <div class="info-bloc">
            <div class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <div class="info-label">Délai de réponse</div>
              <div class="info-value">48h ouvrées</div>
            </div>
          </div>

          <!-- Localisation -->
          <div class="info-bloc">
            <div class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <div class="info-label">Basée à</div>
              <div class="info-value">Aix-en-Provence</div>
              <div class="info-sub">Intervention dans toute la France</div>
            </div>
          </div>

          <!-- Séparateur -->
          <hr class="info-sep" />

          <!-- Calendly (emplacement prévu) -->
          <div class="calendly-bloc" id="calendly-slot">
            <div class="calendly-label">Préférez-vous planifier directement ?</div>
            <!-- Remplacer ce bloc par le widget Calendly quand disponible -->
            <div class="calendly-placeholder">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8"  y1="2" x2="8"  y2="6"/>
                <line x1="3"  y1="10" x2="21" y2="10"/>
              </svg>
              <div>
                <div class="calendly-titre">Réserver un créneau</div>
                <div class="calendly-desc">Disponible prochainement</div>
              </div>
            </div>
            <!-- Décommenter quand Calendly est configuré :
            <div
              class="calendly-inline-widget"
              data-url="https://calendly.com/votre-lien/30min"
              style="min-width:280px; height:400px;"
            ></div>
            <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
            -->
          </div>

          <!-- Rassurants -->
          <div class="rassurants">
            {rassurants.map(r => (
              <div class="rassurant-item">
                <div class="rassurant-icon" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={r.icon} />
                </div>
                <div>
                  <div class="rassurant-titre">{r.titre}</div>
                  <div class="rassurant-desc">{r.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ─── FAQ CONTACT ─── -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container" style="max-width: 720px;">
      <span class="section-label reveal">Questions</span>
      <h2 class="section-title reveal">Avant de remplir le formulaire.</h2>

      <div style="margin-top: 36px;" class="reveal">
        {faqContact.map(item => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              {item.q}
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer">{item.r}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ─── */
  .contact-hero {
    padding: 160px 0 80px;
    text-align: center;
  }

  .contact-h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1.05;
    margin: 20px 0 16px;
  }

  .contact-sub {
    font-size: clamp(15px, 1.3vw, 18px);
    line-height: 1.65;
    max-width: 520px;
    margin: 0 auto;
  }

  /* ─── GRID CONTACT ─── */
  .contact-section {
    padding-top: 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 64px;
    align-items: start;
  }

  /* ─── FORMULAIRE ─── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    background: var(--white);
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-xl);
    padding: 40px;
  }

  .form-required {
    color: var(--aurora);
    margin-left: 2px;
  }

  .form-hint-link {
    color: var(--aurora);
    font-weight: 500;
    margin-left: 4px;
    transition: var(--transition);
  }

  .form-hint-link:hover {
    color: var(--aurora-dark);
  }

  /* Submit */
  .form-submit {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-top: 4px;
  }

  .form-btn {
    width: 100%;
    justify-content: center;
    position: relative;
  }

  .form-btn-loading {
    display: none;
    align-items: center;
    gap: 8px;
  }

  .form-btn.loading .form-btn-text   { display: none; }
  .form-btn.loading .form-btn-loading { display: inline-flex; }

  .form-rgpd {
    font-size: 12px;
    color: var(--gray-500);
    line-height: 1.6;
    margin: 0;
    text-align: center;
  }

  /* Confirmation */
  .form-success {
    background: var(--aurora-pale);
    border: 1.5px solid rgba(255,107,26,0.2);
    border-radius: var(--radius-xl);
    padding: 48px 40px;
    text-align: center;
  }

  .success-icon {
    width: 56px;
    height: 56px;
    background: var(--aurora);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    font-weight: 700;
    margin: 0 auto 20px;
  }

  .form-success h3 {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
  }

  .form-success p {
    font-size: 15px;
    color: var(--gray-500);
    margin: 0;
  }

  /* ─── INFOS LATÉRALES ─── */
  .contact-infos {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .info-bloc {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .info-icon {
    width: 40px;
    height: 40px;
    background: var(--aurora-pale);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--aurora);
    flex-shrink: 0;
  }

  .info-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-500);
    margin-bottom: 3px;
  }

  .info-value {
    font-size: 15px;
    font-weight: 600;
    color: var(--black);
    letter-spacing: -0.01em;
    transition: var(--transition);
  }

  a.info-value:hover {
    color: var(--aurora);
  }

  .info-sub {
    font-size: 12px;
    color: var(--gray-500);
    margin-top: 2px;
  }

  .info-sep {
    border: none;
    border-top: 1px solid var(--gray-100);
    margin: 4px 0;
  }

  /* Calendly */
  .calendly-bloc {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .calendly-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-500);
  }

  .calendly-placeholder {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px;
    border: 1.5px dashed var(--gray-300);
    border-radius: var(--radius-md);
    color: var(--gray-500);
    transition: var(--transition);
  }

  .calendly-placeholder svg {
    flex-shrink: 0;
    color: var(--gray-300);
  }

  .calendly-titre {
    font-size: 14px;
    font-weight: 600;
    color: var(--gray-700);
    letter-spacing: -0.01em;
  }

  .calendly-desc {
    font-size: 12px;
    color: var(--gray-500);
    margin-top: 2px;
  }

  /* Rassurants */
  .rassurants {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 20px;
    background: var(--gray-50);
    border-radius: var(--radius-md);
    border: 1.5px solid var(--gray-100);
  }

  .rassurant-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .rassurant-icon {
    width: 28px;
    height: 28px;
    background: var(--aurora-pale);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--aurora);
    flex-shrink: 0;
  }

  .rassurant-titre {
    font-size: 13px;
    font-weight: 600;
    color: var(--black);
    letter-spacing: -0.01em;
    margin-bottom: 2px;
  }

  .rassurant-desc {
    font-size: 12px;
    color: var(--gray-500);
    line-height: 1.5;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .contact-infos {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .info-sep,
    .calendly-bloc {
      grid-column: 1 / -1;
    }

    .rassurants {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 768px) {
    .contact-hero {
      padding: 120px 0 56px;
    }

    .contact-form {
      padding: 24px 20px;
      border-radius: var(--radius-lg);
    }

    .contact-infos {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ─── Animations GSAP ───
    // @ts-ignore
    if (typeof gsap !== 'undefined') {
      // @ts-ignore
      gsap.registerPlugin(ScrollTrigger);
      // @ts-ignore
      gsap.timeline({ delay: 0.1 })
        // @ts-ignore
        .from('.hero-eyebrow', { y: 16, opacity: 0, duration: 0.9, ease: 'power2.out' })
        // @ts-ignore
        .from('.contact-h1',   { y: 24, opacity: 0, duration: 1.0, ease: 'power2.out' }, '-=0.25')
        // @ts-ignore
        .from('.contact-sub',  { y: 16, opacity: 0, duration: 0.9, ease: 'power2.out' }, '-=0.25')
        // @ts-ignore
        .from('.contact-form', { y: 32, opacity: 0, duration: 1.1, ease: 'power2.out' }, '-=0.2')
        // @ts-ignore
        .from('.contact-infos', { y: 24, opacity: 0, duration: 0.55, ease: 'power2.out' }, '-=0.4');

      // @ts-ignore
      gsap.utils.toArray('.reveal').forEach((el: any) => {
        // @ts-ignore
        gsap.from(el, {
          scrollTrigger: { trigger: el, start: 'top 85%' },
          y: 40, opacity: 0, duration: 1.1, ease: 'power2.out'
        });
      });
    }

    // ─── Validation & soumission formulaire ───
    const form = document.querySelector('.contact-form') as HTMLFormElement | null;
    const successBlock = document.getElementById('form-success');
    const submitBtn = form?.querySelector('.form-btn') as HTMLButtonElement | null;

    if (!form || !successBlock || !submitBtn) return;

    // Validation inline
    form.querySelectorAll('[required]').forEach(field => {
      field.addEventListener('blur', () => validateField(field as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement));
    });

    function validateField(field: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement): boolean {
      const group = field.closest('.form-group');
      const existing = group?.querySelector('.form-error');
      if (existing) existing.remove();

      if (!field.validity.valid) {
        const err = document.createElement('span');
        err.className = 'form-error';
        err.setAttribute('role', 'alert');
        err.textContent = field.type === 'email'
          ? 'Adresse email invalide.'
          : `Ce champ est requis.`;
        group?.appendChild(err);
        return false;
      }
      return true;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Valider tous les champs requis
      let valid = true;
      form.querySelectorAll('[required]').forEach(field => {
        if (!validateField(field as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement)) {
          valid = false;
        }
      });
      if (!valid) return;

      // UI loading
      submitBtn.classList.add('loading');
      submitBtn.disabled = true;

      try {
        const data = new FormData(form);
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(data as unknown as Record<string, string>).toString(),
        });

        if (response.ok) {
          form.hidden = true;
          successBlock.hidden = false;
          successBlock.focus();
        } else {
          throw new Error('Erreur serveur');
        }
      } catch {
        // Fallback : ouvrir le client mail
        const nom     = (form.querySelector('#nom')     as HTMLInputElement)?.value;
        const email   = (form.querySelector('#email')   as HTMLInputElement)?.value;
        const message = (form.querySelector('#message') as HTMLTextAreaElement)?.value;
        const body    = encodeURIComponent(`Nom : ${nom}\n\n${message}`);
        window.location.href = `mailto:contact@agence-aurore.fr?subject=Demande de devis — aurore&body=${body}`;
      } finally {
        submitBtn.classList.remove('loading');
        submitBtn.disabled = false;
      }
    });
  });
</script>
