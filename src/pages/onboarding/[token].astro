---
export const prerender = false;
import { db } from '../../lib/firebase-admin';
import BaseLayout from '../../layouts/BaseLayout.astro';

const { token } = Astro.params;
if (!token) return Astro.redirect('/404');

let lead: any = null;
let error = '';
try {
  const leadDoc = await db.collection('leads').doc(token).get();
  if (!leadDoc.exists) { error = 'notfound'; }
  else {
    lead = leadDoc.data();
    if (lead.onboardingCompleted) error = 'completed';
  }
} catch (e) { error = 'error'; }

// Determine offer type for form structure
function getOfferType(offre: string): string {
  if (!offre) return 'site';
  const lower = offre.toLowerCase();
  if (lower.includes('starter') || lower.includes('vitrine') || lower.includes('pro') || lower.includes('réservation') || lower.includes('reservation')) return 'site';
  if (lower.includes('migration')) return 'migration';
  if (lower.includes('seo')) return 'seo';
  if (lower.includes('automatisation')) return 'auto';
  if (lower.includes('google') || lower.includes('gbp')) return 'gbp';
  if (lower.includes('logiciel')) return 'logiciel';
  return 'site';
}

const offerType = lead ? getOfferType(lead.offre || '') : 'site';

const stepConfigs: Record<string, {labels: string[], count: number}> = {
  site:      { labels: ['Activité', 'Identité', 'Contenu', 'SEO', 'Récap'], count: 5 },
  migration: { labels: ['Site actuel', 'Identité', 'SEO actuel', 'Récap'], count: 4 },
  seo:       { labels: ['Situation', 'Objectifs', 'Récap'], count: 3 },
  auto:      { labels: ['Situation', 'Accès', 'Récap'], count: 3 },
  gbp:       { labels: ['Fiche Google', 'Récap'], count: 2 },
  logiciel:  { labels: ['Projet', 'Technique', 'Récap'], count: 3 },
};
const steps = stepConfigs[offerType] || stepConfigs.site;
---

<BaseLayout
  title="Complétez votre dossier - aurore"
  description="Formulaire d'onboarding client"
  slug={`onboarding/${token}`}
  noindex={true}
>

{error === 'notfound' && (
  <section class="onboarding-message">
    <div class="container">
      <span class="logo logo-lg">aur<span class="logo-o">o</span>re</span>
      <h1>Lien invalide</h1>
      <p>Ce lien d'onboarding n'existe pas ou a expiré.<br>Contactez-nous à <a href="mailto:elodie@agence-aurore.fr">elodie@agence-aurore.fr</a></p>
    </div>
  </section>
)}

{error === 'completed' && (
  <section class="onboarding-message">
    <div class="container">
      <span class="logo logo-lg">aur<span class="logo-o">o</span>re</span>
      <div class="success-icon">&#10003;</div>
      <h1>Dossier déjà complété</h1>
      <p>Votre dossier a déjà été envoyé. Je vous contacte très prochainement !</p>
      <p class="contact-line">Une question ? <a href="mailto:elodie@agence-aurore.fr">elodie@agence-aurore.fr</a> - 06 59 65 92 18</p>
    </div>
  </section>
)}

{error === 'error' && (
  <section class="onboarding-message">
    <div class="container">
      <span class="logo logo-lg">aur<span class="logo-o">o</span>re</span>
      <h1>Une erreur est survenue</h1>
      <p>Veuillez réessayer ou nous contacter à <a href="mailto:elodie@agence-aurore.fr">elodie@agence-aurore.fr</a></p>
    </div>
  </section>
)}

{!error && lead && (
  <section class="onboarding-section">
    <div class="container onboarding-container">

      <!-- Header -->
      <div class="onboarding-header">
        <span class="logo logo-lg">aur<span class="logo-o">o</span>re</span>
        <h1 class="onboarding-title">Complétez votre dossier</h1>
        <p class="onboarding-sub">Plus votre dossier est complet, plus vite je pourrai démarrer votre projet. Environ 10 minutes.</p>
      </div>

      <!-- Intro box -->
      <div class="ob-intro">
        <strong>Remplissez ce que vous savez.</strong> Tous les champs sont optionnels,
        les informations manquantes seront complétées par Élodie lors de la création.
        Plus vous en donnez, plus vite on démarre !
      </div>

      <!-- Progress bar -->
      <div class="stepper" id="stepper">
        <div class="stepper-bar">
          <div class="stepper-fill" id="stepper-fill"></div>
        </div>
        <div class="stepper-labels" id="stepper-labels"></div>
      </div>

      <form id="onboarding-form" data-token={token} data-offre={lead.offre || ''} data-offer-type={offerType} data-total={steps.count} data-steps={JSON.stringify(steps.labels)}>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- SITE  -  Step 1: Activité                        -->
        <!-- ═══════════════════════════════════════════════ -->
        <div class="step" data-step="1" data-offer="site" style="display:none;">
          <h2 class="step-title">Votre activité</h2>
          <div class="field-row">
            <div class="field">
              <label for="ob-prenom">Prénom <span class="field-req">*</span></label>
              <input type="text" id="ob-prenom" class="input" value={lead.prenom || ''} required />
            </div>
            <div class="field">
              <label for="ob-nom">Nom <span class="field-req">*</span></label>
              <input type="text" id="ob-nom" class="input" value={lead.nom?.split(' ').slice(1).join(' ') || lead.nom || ''} required />
            </div>
          </div>
          <div class="field">
            <label for="ob-email">Email</label>
            <input type="email" id="ob-email" class="input input-readonly" value={lead.email || ''} readonly />
          </div>
          <div class="field-row">
            <div class="field">
              <label for="ob-telephone">Téléphone</label>
              <input type="tel" id="ob-telephone" class="input" value={lead.telephone || ''} />
            </div>
            <div class="field">
              <label for="ob-entreprise">Nom commercial / Entreprise</label>
              <input type="text" id="ob-entreprise" class="input" value={lead.entreprise || ''} />
            </div>
          </div>
          <div class="field">
            <label for="ob-secteur">Secteur d'activité</label>
            <select id="ob-secteur" class="input">
              <option value="">Sélectionner...</option>
              <option value="santé">Santé / Bien-être</option>
              <option value="restaurant">Restaurant / Café</option>
              <option value="artisan">Artisan / BTP</option>
              <option value="coach">Coach / Consultant</option>
              <option value="immobilier">Immobilier</option>
              <option value="avocat">Avocat / Juridique</option>
              <option value="architecte">Architecte / Design</option>
              <option value="photographe">Photographe / Créatif</option>
              <option value="commerce">Commerce / Boutique</option>
              <option value="autre">Autre</option>
            </select>
          </div>
          <div class="field">
            <label for="ob-adresse">Adresse complète</label>
            <input type="text" id="ob-adresse" class="input" placeholder="12 rue des Lilas" />
          </div>
          <div class="field-row">
            <div class="field">
              <label for="ob-ville">Ville</label>
              <input type="text" id="ob-ville" class="input" value={lead.ville || ''} />
            </div>
            <div class="field">
              <label for="ob-codepostal">Code postal</label>
              <input type="text" id="ob-codepostal" class="input" placeholder="13100" />
            </div>
          </div>
          <div class="field field-pro-only">
            <label for="ob-siren">SIREN</label>
            <input type="text" id="ob-siren" class="input" placeholder="123 456 789" />
          </div>
          <div class="field">
            <label>Objectif principal du site</label>
            <div class="radio-group">
              <label class="radio-card"><input type="radio" name="ob-objectif" value="leads" /><span>Générer des contacts</span></label>
              <label class="radio-card"><input type="radio" name="ob-objectif" value="vente" /><span>Vendre en ligne</span></label>
              <label class="radio-card"><input type="radio" name="ob-objectif" value="notoriete" /><span>Gagner en visibilité</span></label>
              <label class="radio-card"><input type="radio" name="ob-objectif" value="info" /><span>Informer mes clients</span></label>
            </div>
          </div>
          <div class="field">
            <label>Public cible</label>
            <div class="field-row">
              <div class="field">
                <label for="ob-tranche-age">Tranche d'âge</label>
                <select id="ob-tranche-age" class="input">
                  <option value="">Sélectionner...</option>
                  <option value="18-25">18-25 ans</option>
                  <option value="26-35">26-35 ans</option>
                  <option value="36-50">36-50 ans</option>
                  <option value="50+">50 ans et +</option>
                </select>
              </div>
              <div class="field">
                <label>Type de clientèle</label>
                <div class="radio-group">
                  <label class="radio-card"><input type="radio" name="ob-clientele" value="particuliers" /><span>Particuliers</span></label>
                  <label class="radio-card"><input type="radio" name="ob-clientele" value="pro" /><span>Professionnels</span></label>
                  <label class="radio-card"><input type="radio" name="ob-clientele" value="les-deux" /><span>Les deux</span></label>
                </div>
              </div>
            </div>
          </div>
          <div class="field">
            <label for="ob-douleur">Douleur principale de vos clients</label>
            <textarea id="ob-douleur" class="input textarea" rows="3" placeholder="Qu'est-ce qui empêche vos clients de dormir ?"></textarea>
          </div>
          <div class="field">
            <label>Réseaux sociaux <span class="field-opt">(optionnel)</span></label>
            <div class="field-row">
              <div class="field">
                <input type="url" id="ob-instagram" class="input" placeholder="Instagram" />
              </div>
              <div class="field">
                <input type="url" id="ob-facebook" class="input" placeholder="Facebook" />
              </div>
            </div>
            <div class="field-row" style="margin-top:8px;">
              <div class="field">
                <input type="url" id="ob-linkedin" class="input" placeholder="LinkedIn" />
              </div>
              <div class="field">
                <input type="url" id="ob-tiktok" class="input" placeholder="TikTok" />
              </div>
            </div>
          </div>
          <div class="field">
            <label>Avez-vous des avis Google ?</label>
            <div class="radio-group">
              <label class="radio-card"><input type="radio" name="ob-avis-google" value="oui" /><span>Oui</span></label>
              <label class="radio-card"><input type="radio" name="ob-avis-google" value="non" /><span>Non</span></label>
            </div>
          </div>
          <div class="field" id="field-avis-lien" style="display:none;">
            <label for="ob-avis-lien">Lien vers votre profil Google</label>
            <input type="url" id="ob-avis-lien" class="input" placeholder="https://g.page/..." />
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- SITE  -  Step 2: Identité visuelle               -->
        <!-- ═══════════════════════════════════════════════ -->
        <div class="step" data-step="2" data-offer="site,migration" style="display:none;">
