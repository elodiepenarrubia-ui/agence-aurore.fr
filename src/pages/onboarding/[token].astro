            <input type="text" id="ob-motcle3" class="input" placeholder="Ex: ostéo sportif" style="margin-bottom:8px;" />
            <input type="text" id="ob-motcle4" class="input" placeholder="Ex: ostéopathie bébé" />
          </div>
          <div class="field">
            <label for="ob-gbp">Description pour Google Business <span class="field-opt">(750 caractères max)</span></label>
            <textarea id="ob-gbp" class="input textarea" rows="4" maxlength="750" placeholder="Décrivez votre activité pour Google..."></textarea>
            <span class="char-count"><span id="gbp-count">0</span>/750</span>
          </div>
          <div class="field">
            <label for="ob-horaires">Horaires d'ouverture</label>
            <textarea id="ob-horaires" class="input textarea" rows="3" placeholder="Lun-Ven : 9h-18h&#10;Sam : 9h-12h&#10;Dim : Fermé"></textarea>
          </div>
          <div class="field">
            <label>Fourchette de prix</label>
            <div class="radio-group">
              <label class="radio-card"><input type="radio" name="ob-prix" value="€" /><span>&euro;</span></label>
              <label class="radio-card"><input type="radio" name="ob-prix" value="€€" /><span>&euro;&euro;</span></label>
              <label class="radio-card"><input type="radio" name="ob-prix" value="€€€" /><span>&euro;&euro;&euro;</span></label>
            </div>
          </div>
          <div class="field">
            <label for="ob-domaine">Nom de domaine souhaité ou existant</label>
            <input type="text" id="ob-domaine" class="input" placeholder="ex: mon-entreprise.fr" />
          </div>
          <div class="field">
            <label for="ob-registrar">Registrar <span class="field-opt">(si vous avez déjà un domaine)</span></label>
            <input type="text" id="ob-registrar" class="input" placeholder="ex: OVH, Gandi..." />
          </div>
          <div class="field">
            <label for="ob-notes">Notes libres <span class="field-opt">(tout ce que vous souhaitez ajouter)</span></label>
            <textarea id="ob-notes" class="input textarea" rows="4" placeholder="Informations supplémentaires, demandes particulières..."></textarea>
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- SITE  -  Step 5: Récap                           -->
        <!-- ═══════════════════════════════════════════════ -->
        <div class="step" data-step="5" data-offer="site" style="display:none;">
          <h2 class="step-title">Récapitulatif</h2>
          <p class="recap-intro">Vérifiez vos informations avant d'envoyer votre dossier.</p>
          <div class="recap-box" id="recap-box">
            <div id="recap-content"></div>
          </div>
          <div class="files-reminder">
            <p class="files-reminder-title">Pensez à m'envoyer par email :</p>
            <p>&rarr; Votre logo (SVG, PNG ou PDF)</p>
            <p>&rarr; Vos photos (lieu, réalisations, portrait)</p>
            <p>&rarr; Tout document utile (plaquette, ancien site...)</p>
            <p class="files-reminder-email">À <a href="mailto:elodie@agence-aurore.fr">elodie@agence-aurore.fr</a></p>
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- MIGRATION  -  Step 1: Site actuel                -->
        <!-- ═══════════════════════════════════════════════ -->
        <div class="step" data-step="1" data-offer="migration" style="display:none;">
          <h2 class="step-title">Votre site actuel</h2>
          <div class="field-row">
            <div class="field">
              <label for="ob-mig-prenom">Prénom <span class="field-req">*</span></label>
              <input type="text" id="ob-mig-prenom" class="input" value={lead.prenom || ''} required />
            </div>
            <div class="field">
              <label for="ob-mig-nom">Nom <span class="field-req">*</span></label>
              <input type="text" id="ob-mig-nom" class="input" value={lead.nom?.split(' ').slice(1).join(' ') || lead.nom || ''} required />
            </div>
          </div>
          <div class="field">
            <label for="ob-mig-email">Email</label>
            <input type="email" id="ob-mig-email" class="input input-readonly" value={lead.email || ''} readonly />
          </div>
          <div class="field">
            <label for="ob-mig-telephone">Téléphone</label>
            <input type="tel" id="ob-mig-telephone" class="input" value={lead.telephone || ''} />
          </div>
          <div class="field">
            <label for="ob-mig-url">URL de votre site actuel <span class="field-req">*</span></label>
            <input type="url" id="ob-mig-url" class="input" placeholder="https://mon-site-actuel.fr" required />
          </div>
          <div class="field">
            <label for="ob-mig-plateforme">Plateforme actuelle</label>
            <select id="ob-mig-plateforme" class="input">
              <option value="">Sélectionner...</option>
              <option value="wordpress">WordPress</option>
              <option value="wix">Wix</option>
              <option value="squarespace">Squarespace</option>
              <option value="jimdo">Jimdo</option>
              <option value="autre">Autre</option>
            </select>
          </div>
          <div class="field-row">
            <div class="field">
              <label for="ob-mig-hebergeur">Hébergeur</label>
              <select id="ob-mig-hebergeur" class="input">
                <option value="">Sélectionner...</option>
                <option value="ovh">OVH</option>
                <option value="ionos">Ionos</option>
                <option value="infomaniak">Infomaniak</option>
                <option value="o2switch">O2Switch</option>
                <option value="autre">Autre</option>
              </select>
            </div>
