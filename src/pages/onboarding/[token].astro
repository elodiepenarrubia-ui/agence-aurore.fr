  // ─── Char counters ───
  function setupCharCounter(textareaId, countId) {
    var ta = document.getElementById(textareaId);
    var counter = document.getElementById(countId);
    if (!ta || !counter) return;
    ta.addEventListener('input', function() { counter.textContent = ta.value.length; });
  }
  setupCharCounter('ob-presentation', 'presentation-count');
  setupCharCounter('ob-gbp', 'gbp-count');
  setupCharCounter('ob-gbp-description', 'gbp-desc-count');

  // ─── Clear error on input ───
  form.addEventListener('input', function(e) {
    if (e.target.classList && e.target.classList.contains('input-error')) {
      e.target.classList.remove('input-error');
    }
  });

  // ─── SAVE / RESTORE from localStorage ───
  function saveProgress() {
    try {
      var data = collectFormData();
      data._currentStep = currentStep;
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    } catch(e) {}
  }

  function restoreProgress() {
    var saved = localStorage.getItem(STORAGE_KEY);
    if (!saved) return;
    try {
      var data = JSON.parse(saved);
      // Restore all text/url/tel/number inputs
      var inputs = form.querySelectorAll('input[id], textarea[id], select[id]');
      for (var i = 0; i < inputs.length; i++) {
        var el = inputs[i];
        if (el.type === 'color' || el.readOnly) continue;
        var key = el.id;
        if (data[key] !== undefined && data[key] !== '') {
          el.value = data[key];
        }
      }
      // Restore radio buttons
      if (data._radios) {
        for (var name in data._radios) {
          var r = document.querySelector('input[name="' + name + '"][value="' + data._radios[name] + '"]');
          if (r) { r.checked = true; r.dispatchEvent(new Event('change', {bubbles:true})); }
        }
      }
      // Restore checkboxes
      if (data._checkboxes) {
        for (var name in data._checkboxes) {
          var vals = data._checkboxes[name];
          for (var v = 0; v < vals.length; v++) {
            var cb = document.querySelector('input[name="' + name + '"][value="' + vals[v] + '"]');
            if (cb) cb.checked = true;
          }
        }
      }
      // Restore colors
      if (data._colors) {
        var lists = [document.getElementById('colors-list')];
        for (var li = 0; li < lists.length; li++) {
          var list = lists[li];
          if (!list) continue;
          var colorsArr = data._colors;
          if (!colorsArr || !colorsArr.length) continue;
          // Set the first one
          var firstRow = list.querySelector('.color-row');
          if (firstRow && colorsArr[0]) {
            firstRow.querySelector('.ob-color').value = colorsArr[0];
            firstRow.querySelector('.color-hex').textContent = colorsArr[0].toUpperCase();
          }
          // Add extra colors
          for (var c = 1; c < colorsArr.length; c++) {
            var row = document.createElement('div');
            row.className = 'color-row';
            row.innerHTML = '<input type="color" class="ob-color" value="' + colorsArr[c] + '" /><span class="color-hex">' + colorsArr[c].toUpperCase() + '</span><button type="button" class="color-remove">\u00d7</button>';
            list.appendChild(row);
            row.querySelector('input').addEventListener('input', function() {
              this.closest('.color-row').querySelector('.color-hex').textContent = this.value.toUpperCase();
            });
            row.querySelector('.color-remove').addEventListener('click', function() { this.closest('.color-row').remove(); });
          }
        }
      }
      // Update char counts
      setupCharCounter('ob-presentation', 'presentation-count');
      setupCharCounter('ob-gbp', 'gbp-count');
      setupCharCounter('ob-gbp-description', 'gbp-desc-count');
      var pres = document.getElementById('ob-presentation');
      var presC = document.getElementById('presentation-count');
      if (pres && presC) presC.textContent = pres.value.length;
      var gbp = document.getElementById('ob-gbp');
      var gbpC = document.getElementById('gbp-count');
      if (gbp && gbpC) gbpC.textContent = gbp.value.length;
      var gbpD = document.getElementById('ob-gbp-description');
      var gbpDC = document.getElementById('gbp-desc-count');
      if (gbpD && gbpDC) gbpDC.textContent = gbpD.value.length;
    } catch(e) {}
  }

  // ─── Collect form data ───
  function collectFormData() {
    var data = {};

    // All text/url/tel/email/number/password inputs + textareas + selects
    var inputs = form.querySelectorAll('input[id], textarea[id], select[id]');
    for (var i = 0; i < inputs.length; i++) {
      var el = inputs[i];
      if (el.type === 'color') continue;
      // Only collect from visible steps
      var stepEl = el.closest('.step');
      if (stepEl && stepEl.dataset.visibleIndex === undefined) continue;
      data[el.id] = el.value.trim ? el.value.trim() : el.value;
    }

    // Radio buttons
    data._radios = {};
    var radioNames = {};
    var radios = form.querySelectorAll('input[type="radio"]');
    for (var i = 0; i < radios.length; i++) {
      var r = radios[i];
      var stepEl = r.closest('.step');
      if (stepEl && stepEl.dataset.visibleIndex === undefined) continue;
      radioNames[r.name] = true;
    }
    for (var name in radioNames) {
      var checked = form.querySelector('input[name="' + name + '"]:checked');
      if (checked) data._radios[name] = checked.value;
    }

    // Checkboxes
    data._checkboxes = {};
    var cbNames = {};
    var cbs = form.querySelectorAll('input[type="checkbox"]');
    for (var i = 0; i < cbs.length; i++) {
      var cb = cbs[i];
      var stepEl = cb.closest('.step');
      if (stepEl && stepEl.dataset.visibleIndex === undefined) continue;
      cbNames[cb.name] = true;
    }
    for (var name in cbNames) {
      var checkedCbs = form.querySelectorAll('input[name="' + name + '"]:checked');
      var vals = [];
      for (var i = 0; i < checkedCbs.length; i++) vals.push(checkedCbs[i].value);
      if (vals.length) data._checkboxes[name] = vals;
    }

    // Colors
    var colorsList1 = document.getElementById('colors-list');
    if (colorsList1) {
      var colorInputs = colorsList1.querySelectorAll('.ob-color');
      data._colors = [];
      for (var i = 0; i < colorInputs.length; i++) data._colors.push(colorInputs[i].value);
    }
    // Services
    data._services = collectServices();

    // Temoignages
    data._temoignages = collectTemoignages();

    return data;
  }

  function collectServices() {
    var rows = document.querySelectorAll('.service-row');
    var services = [];
    for (var i = 0; i < rows.length; i++) {
      var row = rows[i];
      var nom = row.querySelector('.svc-nom');
      var desc = row.querySelector('.svc-desc');
      var prix = row.querySelector('.svc-prix');
      if (nom && nom.value.trim()) {
        services.push({ nom: nom.value.trim(), description: desc ? desc.value.trim() : '', prix: prix ? prix.value.trim() : '' });
      }
    }
    return services;
  }

  function collectTemoignages() {
    var rows = document.querySelectorAll('.temoignage-row');
    var tems = [];
    for (var i = 0; i < rows.length; i++) {
      var row = rows[i];
      var nom = row.querySelector('.tem-nom');
      var texte = row.querySelector('.tem-texte');
      var ent = row.querySelector('.tem-entreprise');
      if (nom && nom.value.trim() && texte && texte.value.trim()) {
        tems.push({ nom: nom.value.trim(), texte: texte.value.trim(), entreprise: ent ? ent.value.trim() : '' });
      }
    }
    return tems;
  }

  // ─── Validation ───
  function validateStep(n) {
    var stepEl = visibleSteps[n - 1];
    if (!stepEl) return true;
    var requiredInputs = stepEl.querySelectorAll('[required]');
    var valid = true;
    for (var i = 0; i < requiredInputs.length; i++) {
      var el = requiredInputs[i];
      // Skip hidden fields
      if (el.closest('[style*="display:none"]') || el.closest('[style*="display: none"]')) continue;
      if (!el.value || !el.value.trim()) {
        el.classList.add('input-error');
        valid = false;
      } else {
        el.classList.remove('input-error');
      }
    }
    if (!valid) {
      showToast('Veuillez remplir les champs obligatoires', 'error');
    }
    return valid;
  }

  // ─── Step navigation ───
  function showStep(n) {
    currentStep = n;
    for (var i = 0; i < visibleSteps.length; i++) {
      visibleSteps[i].style.display = 'none';
    }
    if (visibleSteps[n - 1]) visibleSteps[n - 1].style.display = '';

    btnPrev.style.visibility = n === 1 ? 'hidden' : 'visible';
    btnNext.style.display = n === TOTAL_STEPS ? 'none' : '';
    btnSubmit.style.display = n === TOTAL_STEPS ? '' : 'none';

    stepperFill.style.width = (n / TOTAL_STEPS * 100) + '%';

    var labels = document.querySelectorAll('.stepper-label');
    for (var i = 0; i < labels.length; i++) {
      var s = parseInt(labels[i].dataset.step);
      labels[i].classList.toggle('active', s === n);
      labels[i].classList.toggle('done', s < n);
    }

    if (n === TOTAL_STEPS) buildRecap();
    saveProgress();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  btnPrev.addEventListener('click', function() {
    if (currentStep > 1) showStep(currentStep - 1);
  });

  btnNext.addEventListener('click', function() {
    if (!validateStep(currentStep)) return;
    if (currentStep < TOTAL_STEPS) showStep(currentStep + 1);
  });

  // ─── Save on every field change ───
  form.addEventListener('input', function() { saveProgress(); });
  form.addEventListener('change', function() { saveProgress(); });

