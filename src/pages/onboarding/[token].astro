          <div class="field">
            <label>Couleurs <span class="field-opt">(jusqu'à 6)</span></label>
            <div id="colors-list">
              <div class="color-row">
                <input type="color" class="ob-color" value="#FF6B1A" />
                <span class="color-hex">#FF6B1A</span>
              </div>
            </div>
            <button type="button" id="add-color" class="btn-add">+ Ajouter une couleur</button>
          </div>
          <div class="field">
            <label for="ob-polices">Polices souhaitées <span class="field-opt">(optionnel)</span></label>
            <input type="text" id="ob-polices" class="input" placeholder="ex: Montserrat, serif élégant..." />
          </div>
          <div class="field">
            <label>Ton rédactionnel</label>
            <div class="checkbox-group">
              <label class="checkbox-card"><input type="checkbox" name="ob-ton" value="professionnel" /><span>Professionnel</span></label>
              <label class="checkbox-card"><input type="checkbox" name="ob-ton" value="chaleureux" /><span>Chaleureux</span></label>
              <label class="checkbox-card"><input type="checkbox" name="ob-ton" value="moderne" /><span>Moderne</span></label>
              <label class="checkbox-card"><input type="checkbox" name="ob-ton" value="luxueux" /><span>Luxueux</span></label>
              <label class="checkbox-card"><input type="checkbox" name="ob-ton" value="humoristique" /><span>Humoristique</span></label>
            </div>
          </div>
          <div class="field">
            <label>3 exemples de sites que vous aimez <span class="field-opt">(optionnel)</span></label>
            <input type="url" id="ob-inspi1" class="input" placeholder="https://site-que-j-aime.fr" style="margin-bottom:8px;" />
            <input type="url" id="ob-inspi2" class="input" placeholder="https://autre-exemple.com" style="margin-bottom:8px;" />
            <input type="url" id="ob-inspi3" class="input" placeholder="https://troisieme-exemple.fr" />
          </div>
          <div class="field">
            <label>3 concurrents <span class="field-opt">(nom ou URL)</span></label>
            <input type="text" id="ob-concurrent1" class="input" placeholder="Nom ou URL du concurrent" style="margin-bottom:8px;" />
            <input type="text" id="ob-concurrent2" class="input" placeholder="Nom ou URL du concurrent" style="margin-bottom:8px;" />
            <input type="text" id="ob-concurrent3" class="input" placeholder="Nom ou URL du concurrent" />
          </div>
          <div class="info-note">
            Si vous avez déjà un logo, envoyez-le par email à <a href="mailto:elodie@agence-aurore.fr">elodie@agence-aurore.fr</a> (formats SVG, PNG ou PDF).
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- SITE  -  Step 3: Contenu                         -->
        <!-- ═══════════════════════════════════════════════ -->
        <div class="step" data-step="3" data-offer="site" style="display:none;">
          <h2 class="step-title">Votre contenu</h2>
          <div class="field">
            <label for="ob-titre">Titre accrocheur pour la page d'accueil</label>
            <input type="text" id="ob-titre" class="input" placeholder="Ostéopathe à Aix-en-Provence" />
          </div>
          <div class="field">
            <label for="ob-sous-titre">Sous-titre</label>
            <input type="text" id="ob-sous-titre" class="input" placeholder="Retrouvez votre équilibre naturellement" />
          </div>
          <div class="field">
            <label for="ob-presentation">Texte de présentation <span class="field-opt">(500 caractères max)</span></label>
            <textarea id="ob-presentation" class="input textarea" rows="5" maxlength="500" placeholder="Parlez de vous, de votre parcours, de ce qui vous motive..."></textarea>
            <span class="char-count"><span id="presentation-count">0</span>/500</span>
          </div>
          <div class="field">
            <label>Vos services <span class="field-opt">(jusqu'à 6)</span></label>
            <div id="services-list">
              <div class="service-row">
                <input type="text" class="input svc-nom" placeholder="Nom du service" />
                <input type="text" class="input svc-desc" placeholder="Description courte" />
                <input type="text" class="input svc-prix" placeholder="Prix (optionnel)" />
              </div>
            </div>
            <button type="button" id="add-service" class="btn-add">+ Ajouter un service</button>
          </div>
          <div class="field">
            <label>Vos 3 points forts</label>
            <input type="text" id="ob-fort1" class="input" placeholder="Ex: 15 ans d'expérience" style="margin-bottom:8px;" />
            <input type="text" id="ob-fort2" class="input" placeholder="Ex: Approche personnalisée" style="margin-bottom:8px;" />
            <input type="text" id="ob-fort3" class="input" placeholder="Ex: Résultats rapides" />
          </div>
          <div class="field">
            <label>Témoignages clients <span class="field-opt">(jusqu'à 3)</span></label>
            <div id="temoignages-list">
              <div class="temoignage-row">
                <input type="text" class="input tem-nom" placeholder="Prénom Nom du client" />
                <textarea class="input textarea tem-texte" rows="2" placeholder="Son témoignage..."></textarea>
                <input type="text" class="input tem-entreprise" placeholder="Entreprise (optionnel)" />
              </div>
            </div>
            <button type="button" id="add-temoignage" class="btn-add">+ Ajouter un témoignage</button>
          </div>
          <div class="field field-pro-only">
            <label>Système de réservation souhaité</label>
            <div class="radio-group">
              <label class="radio-card"><input type="radio" name="ob-reservation" value="calendly" /><span>Calendly</span></label>
              <label class="radio-card"><input type="radio" name="ob-reservation" value="doctolib" /><span>Doctolib</span></label>
              <label class="radio-card"><input type="radio" name="ob-reservation" value="planity" /><span>Planity</span></label>
              <label class="radio-card"><input type="radio" name="ob-reservation" value="sur-mesure" /><span>Sur mesure</span></label>
              <label class="radio-card"><input type="radio" name="ob-reservation" value="aucun" /><span>Aucun</span></label>
            </div>
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- SITE  -  Step 4: SEO                             -->
        <!-- ═══════════════════════════════════════════════ -->
        <div class="step" data-step="4" data-offer="site" style="display:none;">
          <h2 class="step-title">SEO &amp; visibilité</h2>
          <div class="field">
            <label for="ob-motcle">Mot-clé principal <span class="field-opt">(ce que vos clients tapent sur Google)</span></label>
            <input type="text" id="ob-motcle" class="input" placeholder="Ex: ostéopathe aix-en-provence" />
