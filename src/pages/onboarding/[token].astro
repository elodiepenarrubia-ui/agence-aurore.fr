<script is:inline>
(function() {
  var form = document.getElementById('onboarding-form');
  if (!form) return;

  var TOKEN = form.dataset.token;
  var OFFRE = form.dataset.offre || '';
  var OFFER_TYPE = form.dataset.offerType || 'site';
  var TOTAL_STEPS = parseInt(form.dataset.total) || 5;
  var STEP_LABELS = [];
  try { STEP_LABELS = JSON.parse(form.dataset.steps); } catch(e) { STEP_LABELS = []; }
  var STORAGE_KEY = 'onboarding-' + TOKEN;
  var currentStep = 1;

  // ─── DOM refs ───
  var btnPrev = document.getElementById('btn-prev');
  var btnNext = document.getElementById('btn-next');
  var btnSubmit = document.getElementById('btn-submit');
  var stepperFill = document.getElementById('stepper-fill');
  var stepperLabels = document.getElementById('stepper-labels');

  // ─── Build stepper labels dynamically ───
  function buildStepper() {
    if (!stepperLabels) return;
    stepperLabels.innerHTML = '';
    for (var i = 0; i < STEP_LABELS.length; i++) {
      var span = document.createElement('span');
      span.className = 'stepper-label';
      span.dataset.step = String(i + 1);
      span.textContent = (i + 1) + '. ' + STEP_LABELS[i];
      stepperLabels.appendChild(span);
    }
  }
  buildStepper();

  // ─── Filter and re-index steps by offer type ───
  var allSteps = form.querySelectorAll('.step');
  var visibleSteps = [];

  for (var i = 0; i < allSteps.length; i++) {
    var stepEl = allSteps[i];
    var offerAttr = stepEl.dataset.offer || '';
    var offers = offerAttr.split(',');
    var match = false;
    for (var j = 0; j < offers.length; j++) {
      if (offers[j].trim() === OFFER_TYPE) { match = true; break; }
    }
    if (match) {
      visibleSteps.push(stepEl);
    }
  }

  // Re-index visible steps
  for (var i = 0; i < visibleSteps.length; i++) {
    visibleSteps[i].dataset.visibleIndex = String(i + 1);
  }

  // Update TOTAL_STEPS to match actual visible steps
  TOTAL_STEPS = visibleSteps.length;

  // ─── Show/hide pro-only fields ───
  var offreLower = OFFRE.toLowerCase();
  var isPro = offreLower.indexOf('pro') !== -1 || offreLower.indexOf('réservation') !== -1 || offreLower.indexOf('reservation') !== -1;
  if (isPro) {
    var proFields = document.querySelectorAll('.field-pro-only');
    for (var i = 0; i < proFields.length; i++) {
      proFields[i].style.display = '';
    }
  }

  // ─── Conditional field toggles ───
  function setupRadioToggle(radioName, showValue, targetId) {
    var radios = document.querySelectorAll('input[name="' + radioName + '"]');
    var target = document.getElementById(targetId);
    if (!target || radios.length === 0) return;
    for (var i = 0; i < radios.length; i++) {
      radios[i].addEventListener('change', function() {
        target.style.display = this.value === showValue ? '' : 'none';
      });
    }
  }

  setupRadioToggle('ob-avis-google', 'oui', 'field-avis-lien');
  setupRadioToggle('ob-gbp-existante', 'oui', 'field-gbp-existante-details');
  setupRadioToggle('ob-log-hebergeur', 'oui', 'field-log-hebergeur-details');

  // ─── Dynamic colors ───
  var colorsList = document.getElementById('colors-list');
  var addColorBtn = document.getElementById('add-color');
  if (addColorBtn && colorsList) {
    addColorBtn.addEventListener('click', function() {
      if (colorsList.querySelectorAll('.color-row').length >= 6) return;
      var row = document.createElement('div');
      row.className = 'color-row';
      row.innerHTML = '<input type="color" class="ob-color" value="#000000" /><span class="color-hex">#000000</span><button type="button" class="color-remove">\u00d7</button>';
      colorsList.appendChild(row);
      row.querySelector('input').addEventListener('input', function() {
        row.querySelector('.color-hex').textContent = this.value.toUpperCase();
      });
      row.querySelector('.color-remove').addEventListener('click', function() { row.remove(); });
    });
  }

  // Sync color hex for existing inputs
  document.querySelectorAll('.ob-color').forEach(function(inp) {
    inp.addEventListener('input', function() {
      var hex = inp.closest('.color-row').querySelector('.color-hex');
      if (hex) hex.textContent = inp.value.toUpperCase();
    });
  });

  // ─── Dynamic services ───
  var addServiceBtn = document.getElementById('add-service');
  if (addServiceBtn) {
    addServiceBtn.addEventListener('click', function() {
      var list = document.getElementById('services-list');
      if (list.querySelectorAll('.service-row').length >= 6) return;
      var div = document.createElement('div');
      div.className = 'service-row';
      div.innerHTML = '<input type="text" class="input svc-nom" placeholder="Nom du service" /><input type="text" class="input svc-desc" placeholder="Description courte" /><input type="text" class="input svc-prix" placeholder="Prix (optionnel)" />';
      list.appendChild(div);
    });
  }

  // ─── Dynamic témoignages ───
  var addTemBtn = document.getElementById('add-temoignage');
  if (addTemBtn) {
    addTemBtn.addEventListener('click', function() {
      var list = document.getElementById('temoignages-list');
      if (list.querySelectorAll('.temoignage-row').length >= 3) return;
      var div = document.createElement('div');
      div.className = 'temoignage-row';
