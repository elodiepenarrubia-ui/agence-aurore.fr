---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de site web pour restaurant et café",
  "serviceType": "Création de site web pour restaurant",
  "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://agence-aurore.fr" },
  "areaServed": "France",
  "description": "Site web professionnel pour restaurant, café, food truck et traiteur. Menu en ligne, réservation, SEO local. Livré en 2 semaines.",
  "offers": [
    { "@type": "Offer", "name": "Pack Starter", "priceCurrency": "EUR", "price": "290" },
    { "@type": "Offer", "name": "Pack Vitrine", "priceCurrency": "EUR", "price": "690" },
    { "@type": "Offer", "name": "Pack Pro",     "priceCurrency": "EUR", "price": "1290" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Puis-je mettre à jour mon menu moi-même ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, avec les packs Vitrine et Pro, un espace rédaction vous permet de modifier votre carte, vos plats du jour et vos tarifs sans aucune connaissance technique." }},
    { "@type": "Question", "name": "Puis-je intégrer un système de réservation ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, la réservation en ligne est disponible en option ou incluse dans le pack Pro. Vos clients réservent directement depuis votre site, sans commission." }},
    { "@type": "Question", "name": "Comment apparaître sur Google Maps ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Toutes les formules incluent la création et l'optimisation de votre fiche Google Business avec vos horaires, photos et menu. C'est ce qui vous fait apparaître sur Google Maps." }},
    { "@type": "Question", "name": "Puis-je recevoir des commandes en ligne ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, un système de commande en ligne peut être intégré en option. Vous recevez les commandes directement, sans commission de plateforme." }},
  ],
};
---

<BaseLayout
  title="Création de site web pour restaurant et café | aurore — À partir de 290 €"
  description="Site web professionnel pour restaurant, café, food truck et traiteur. Menu en ligne, réservation, SEO local inclus. Livré en 2 semaines. À partir de 290 €."
  slug="site-web-restaurant"
  schema={[serviceSchema, faqSchema]}
>

  <!-- ─── HERO ─── -->
  <section class="lp-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Spécial restaurants, cafés et traiteurs
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="lp-h1">
        Un site qui donne faim<br />avant même l'entrée.
      </h1>
      <p class="hero-serif-line">Livré en 2 semaines.</p>
      <p class="lp-sub">
        Restaurant, café, food truck, traiteur — votre site web doit mettre l'eau à la bouche et remplir votre salle. SEO local, menu en ligne, réservation. À partir de 290&nbsp;€.
      </p>
      <div class="hero-ctas">
        <a href="/tarifs/" class="btn btn-primary btn-lg">Voir les tarifs →</a>
        <a href="/contact/?type=restaurant" class="btn btn-outline btn-lg">Demander un devis</a>
      </div>
    </div>
  </section>

  <!-- ─── PROBLÈME ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label reveal">Le problème</span>
      <h2 class="section-title reveal">Sans site, votre salle reste vide.<br />Avec le mauvais site, vos clients fuient.</h2>
      <div class="lp-problems reveal-stagger">
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
          <p>Vos clients cherchent où manger sur Google Maps avant de sortir — <strong>sans site, vous n'apparaissez pas</strong>.</p>
        </div>
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <p>Un site avec des photos de mauvaise qualité ou un menu non à jour <strong>fait fuir les clients</strong> avant qu'ils franchissent la porte.</p>
        </div>
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <p>Les plateformes comme TheFork prennent des commissions — <strong>votre propre site vous appartient à 100 %</strong>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CE QU'AURORE CRÉE ─── -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <span class="section-label reveal">Ce qu'aurore crée pour vous</span>
      <h2 class="section-title reveal">Un site pensé pour remplir votre salle.</h2>
      <div class="lp-features reveal-stagger">
        {[
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`, title: "Photos de vos plats mises en valeur", desc: "Galerie gourmande, photos plein écran et mise en page pensée pour donner envie à vos visiteurs." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`, title: "Menu en ligne toujours à jour", desc: "Votre carte, vos plats du jour et vos formules accessibles en un clic, modifiables à tout moment." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`, title: "Système de réservation en ligne (option)", desc: "Vos clients réservent directement depuis votre site, sans passer par une plateforme à commission." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`, title: "SEO local « restaurant [votre ville] »", desc: "Optimisation on-page pour apparaître dans les résultats Google quand vos clients cherchent où manger." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`, title: "Fiche Google Business optimisée avec horaires", desc: "Créée et configurée pour apparaître sur Google Maps avec vos horaires, photos de plats et avis clients." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`, title: "Lien vers vos réseaux sociaux", desc: "Instagram, Facebook, TikTok — vos réseaux connectés à votre site pour une présence digitale cohérente." },
        ].map(f => (
          <div class="card lp-feature">
            <div class="lp-feature-icon" set:html={f.icon} />
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── TÉMOIGNAGES ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label reveal">Ils nous font confiance</span>
      <h2 class="section-title reveal">Des professionnels satisfaits partout en France.</h2>
      <div class="lp-testimonials reveal-stagger">
        <div class="card lp-testimonial-card">
          <blockquote>
            <p>« Élodie a compris exactement l'univers de mon établissement. Le site est à notre image et les réservations ont augmenté dès la première semaine. »</p>
            <footer><cite>Restaurant client</cite>, Aix-en-Provence</footer>
          </blockquote>
        </div>
        <div class="card lp-testimonial-card">
          <blockquote>
            <p>« Rapide, professionnel, et un résultat qui dépasse mes attentes. Je recommande les yeux fermés. »</p>
            <footer><cite>Client aurore</cite>, Provence</footer>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TARIFS ─── -->
  <section class="section section-aurora-gradient">
    <div class="container">
      <span class="section-label reveal" style="color:var(--aurora);">Tarifs</span>
      <h2 class="section-title reveal">Des tarifs clairs, sans surprise.</h2>
      <div class="lp-pricing reveal-stagger">
        <div class="card lp-price-card">
          <div class="lp-price-badge">Starter</div>
          <div class="lp-price">290 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Site 3 pages + design responsive</li>
            <li>Domaine + emails pro</li>
            <li>Fiche Google Business</li>
          </ul>
          <a href="/tarifs/" class="btn btn-outline" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
        <div class="card lp-price-card lp-price-card-highlight">
          <div class="lp-price-badge lp-price-badge-aurora">Vitrine</div>
          <div class="lp-price">690 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Jusqu'à 6 pages + logo</li>
            <li>SEO on-page + Search Console</li>
            <li>Formulaire de contact</li>
          </ul>
          <a href="/tarifs/" class="btn btn-aurora" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
        <div class="card lp-price-card">
          <div class="lp-price-badge">Pro</div>
          <div class="lp-price">1 290 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Jusqu'à 8 pages + blog + réservation</li>
            <li>Automatisation email</li>
            <li>Espace rédaction autonome</li>
          </ul>
          <a href="/tarifs/" class="btn btn-outline" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="section" id="faq">
    <div class="container" style="max-width:720px;">
      <span class="section-label reveal">FAQ</span>
      <h2 class="section-title reveal">Questions fréquentes.</h2>
      <div class="faq-list reveal">
        {faqSchema.mainEntity.map((item: any) => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">{item.name}<span class="faq-icon" aria-hidden="true">+</span></button>
            <div class="faq-answer">{item.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA FINAL ─── -->
  <section class="section">
    <div class="container">
      <div class="cta-section">
        <h2>Remplissez votre salle tous les soirs.</h2>
        <p>Un formulaire de 2 minutes suffit pour recevoir un devis détaillé sous 48h.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:32px;">
          <a href="/contact/?type=restaurant" class="btn btn-aurora btn-lg">Demander mon devis gratuit →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ─── */
  .lp-hero { padding: 140px 0 80px; text-align: center; position: relative; overflow: hidden; }
  .lp-hero > .container { position: relative; z-index: 1; }
  .lp-h1 { font-family: var(--font-display); font-size: clamp(32px, 5vw, 58px); font-weight: 700; letter-spacing: -0.05em; line-height: 1.08; margin: 20px 0 12px; color: var(--black); }
  .hero-serif-line { font-family: var(--font-serif); font-style: italic; font-size: clamp(36px, 5.5vw, 64px); color: var(--aurora); line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 20px; }
  .lp-sub { font-size: clamp(15px, 1.3vw, 18px); line-height: 1.65; max-width: 540px; margin: 0 auto 32px; color: var(--gray-700); }

  /* ─── PROBLÈMES ─── */
  .lp-problems { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
  .lp-problem-card { display: flex; flex-direction: column; gap: 16px; }
  .lp-problem-card p { font-size: 15px; line-height: 1.65; color: var(--gray-700); }
  .lp-problem-icon { width: 44px; height: 44px; background: #FFF0E6; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; }

  /* ─── FEATURES ─── */
  .lp-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 48px; }
  .lp-feature { display: flex; flex-direction: column; gap: 10px; }
  .lp-feature-icon { width: 44px; height: 44px; background: var(--aurora-pale); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--aurora); }
  .lp-feature h3 { font-size: 17px; font-weight: 600; letter-spacing: -0.02em; }
  .lp-feature p { font-size: 14px; line-height: 1.65; color: var(--gray-500); }

  /* ─── TÉMOIGNAGES ─── */
  .lp-testimonials { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 48px; }
  .lp-testimonial-card blockquote p { font-size: 16px; line-height: 1.7; color: var(--gray-700); font-style: italic; margin-bottom: 16px; }
  .lp-testimonial-card blockquote footer { font-size: 14px; color: var(--gray-500); }
  .lp-testimonial-card blockquote cite { font-style: normal; font-weight: 600; color: var(--black); }

  /* ─── PRICING ─── */
  .lp-pricing { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
  .lp-price-card { display: flex; flex-direction: column; gap: 20px; text-align: center; }
  .lp-price-card-highlight { border-color: var(--aurora); position: relative; }
  .lp-price-card-highlight::before { content: ''; position: absolute; top: 0; left: 24px; right: 24px; height: 2px; background: linear-gradient(90deg, transparent, var(--aurora), transparent); border-radius: 2px; }
  .lp-price-badge { font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-500); }
  .lp-price-badge-aurora { color: var(--aurora); }
  .lp-price { font-family: var(--font-display); font-size: 48px; font-weight: 800; letter-spacing: -0.05em; color: var(--black); line-height: 1; }
  .lp-price span { font-size: 0.5em; opacity: 0.6; }
  .lp-price-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .lp-price-list li { font-size: 14px; color: var(--gray-700); line-height: 1.5; padding-left: 20px; position: relative; text-align: left; }
  .lp-price-list li::before { content: ''; position: absolute; left: 0; top: 7px; width: 8px; height: 8px; border-radius: 50%; background: var(--aurora-pale); border: 1.5px solid var(--aurora); }

  /* ─── FAQ ─── */
  .faq-list { margin-top: 40px; }
  .faq-item { border-bottom: 1px solid var(--gray-100); }
  .faq-question { width: 100%; text-align: left; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 0; font-size: 16px; font-weight: 600; color: var(--black); cursor: pointer; background: none; border: none; font-family: var(--font-display); transition: color 0.2s ease; }
  .faq-question:hover { color: var(--aurora); }
  .faq-icon { width: 28px; height: 28px; border-radius: 50%; background: var(--gray-100); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; color: var(--gray-500); transition: all 0.2s ease; }
  .faq-item.open .faq-icon { background: var(--aurora-pale); color: var(--aurora); transform: rotate(45deg); }
  .faq-answer { font-size: 15px; color: var(--gray-700); line-height: 1.7; padding-bottom: 20px; display: none; }
  .faq-item.open .faq-answer { display: block; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .lp-problems { grid-template-columns: 1fr; }
    .lp-pricing { grid-template-columns: 1fr; max-width: 400px; margin-left: auto; margin-right: auto; }
  }
  @media (max-width: 768px) {
    .lp-hero { padding: 100px 0 56px; }
    .lp-features { grid-template-columns: 1fr; }
    .lp-testimonials { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore
    if (typeof gsap === 'undefined') return; gsap.registerPlugin(ScrollTrigger);
    gsap.config({ force3D: true });
    // @ts-ignore
    gsap.timeline({ delay: 0.1 })
      .fromTo('.hero-eyebrow', { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' })
      .fromTo('.lp-h1', { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 1.0, ease: 'power2.out' }, '-=0.25')
      .fromTo('.hero-serif-line', { clipPath: 'inset(0 100% 0 0)' }, { clipPath: 'inset(0 0% 0 0)', duration: 0.9, ease: 'power3.out' }, '-=0.4')
      .fromTo('.lp-sub', { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' }, '-=0.25')
      .fromTo('.hero-ctas', { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.4, ease: 'power2.out' }, '-=0.2');
    // @ts-ignore
    gsap.utils.toArray('.reveal').forEach((el: any) => gsap.fromTo(el, { y: 40, opacity: 0 }, { y: 0, opacity: 1, scrollTrigger: { trigger: el, start: 'top 85%' }, duration: 1.1, ease: 'power2.out' }));
    // @ts-ignore
    gsap.utils.toArray('.reveal-stagger').forEach((c: any) => gsap.fromTo(c.children, { y: 24, opacity: 0 }, { y: 0, opacity: 1, scrollTrigger: { trigger: c, start: 'top 80%' }, stagger: 0.15, duration: 0.55, ease: 'power2.out' }));
  });
</script>
