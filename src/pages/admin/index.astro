---
import BaseLayout from '../../layouts/BaseLayout.astro';
const apiToken = import.meta.env.API_SECRET_TOKEN;
---

<BaseLayout
  title="Admin - aurore"
  description="Espace admin aurore"
  slug="admin"
  noindex={true}
>

<!-- ─── ÉCRAN CONNEXION ─── -->
<div id="login-screen" class="admin-login">
  <!-- Étape 1 : mot de passe -->
  <div id="step-password" class="login-box">
    <div class="login-logo">aur<span style="color:#FF6B1A">o</span>re</div>
    <h1 class="login-title">Espace admin</h1>
    <div class="login-form">
      <input type="password" id="login-password" class="input" placeholder="Mot de passe" autocomplete="off" />
      <p id="password-error" class="login-error" style="display:none;">Mot de passe incorrect</p>
      <button id="btn-password" class="btn btn-aurora" style="width:100%;justify-content:center;">Continuer →</button>
    </div>
  </div>
  <!-- Étape 2 : code OTP -->
  <div id="step-otp" class="login-box" style="display:none;">
    <div class="login-logo">aur<span style="color:#FF6B1A">o</span>re</div>
    <h1 class="login-title">Vérification</h1>
    <p style="color:#6B6B6B;font-size:14px;margin:0 0 20px;">Un code à 6 chiffres a été envoyé à elodie@agence-aurore.fr</p>
    <div class="login-form">
      <input type="text" id="otp-input" class="input" placeholder="000000" maxlength="6" inputmode="numeric" style="letter-spacing:8px;font-size:20px;text-align:center;" autocomplete="one-time-code" />
      <p id="otp-error" class="login-error" style="display:none;">Code incorrect ou expiré</p>
      <button id="btn-otp" class="btn btn-aurora" style="width:100%;justify-content:center;">Accéder →</button>
      <button id="btn-resend" style="background:none;border:none;color:#FF6B1A;font-size:13px;cursor:pointer;margin-top:8px;">Renvoyer le code</button>
    </div>
  </div>
</div>

<!-- ─── APP ADMIN ─── -->
<div id="admin-app" style="display:none;" data-api-token={apiToken}>
  <aside id="admin-sidebar">
    <div class="sidebar-logo">aur<span>o</span>re</div>
    <nav class="sidebar-nav">
      <button class="sidebar-item active" data-section="devis">
        <span class="sidebar-icon">&#x1F4C4;</span>
        <span class="sidebar-label">Devis</span>
      </button>
      <button class="sidebar-item" data-section="audit">
        <span class="sidebar-icon">&#x1F50D;</span>
        <span class="sidebar-label">Audit SEO</span>
      </button>
      <button class="sidebar-item" data-section="dashboard">
        <span class="sidebar-icon">&#x1F4CA;</span>
        <span class="sidebar-label">Dashboard</span>
      </button>
      <button class="sidebar-item" data-section="articles">
        <span class="sidebar-icon">&#x270F;</span>
        <span class="sidebar-label">Articles</span>
      </button>
    </nav>
    <button id="btn-logout" class="sidebar-logout">Déconnexion</button>
  </aside>

  <main id="admin-main">

    <!-- ═══ SECTION DEVIS ═══ -->
    <div id="section-devis" class="admin-section active">
      <div class="admin-section-header">
        <h2>Générateur de devis</h2>
        <p>Créez et envoyez vos devis en quelques clics</p>
      </div>
      <section class="devis-layout">
        <div class="form-col">
          <div id="message-prefill-box" class="message-prefill-box" style="display:none;">
            <p class="message-prefill-label">Message du client</p>
            <p id="client-message-prefill" class="message-prefill-text"></p>
          </div>
          <fieldset class="devis-fieldset">
            <legend class="devis-legend">Client</legend>
            <div class="field-row"><div class="field"><label for="client-prenom">Prénom</label><input type="text" id="client-prenom" class="input" /></div><div class="field"><label for="client-nom">Nom</label><input type="text" id="client-nom" class="input" /></div></div>
            <div class="field"><label for="client-entreprise">Entreprise <span class="field-opt">(optionnel)</span></label><input type="text" id="client-entreprise" class="input" /></div>
            <div class="field-row"><div class="field"><label for="client-email">Email</label><input type="email" id="client-email" class="input" /></div><div class="field"><label for="client-tel">Téléphone</label><input type="tel" id="client-tel" class="input" placeholder="06 12 34 56 78" /></div></div>
            <div class="field-row"><div class="field"><label for="client-activite">Activité <span class="field-opt">(optionnel)</span></label><input type="text" id="client-activite" class="input" placeholder="ex. massothérapeute" /></div><div class="field"><label for="client-ville">Ville <span class="field-opt">(optionnel)</span></label><input type="text" id="client-ville" class="input" placeholder="ex. Aix-en-Provence" /></div></div>
            <div class="field"><label for="client-adresse">Adresse complète</label><textarea id="client-adresse" class="input textarea" rows="2" placeholder="12 rue des Lilas, 13100 Aix-en-Provence"></textarea></div>
          </fieldset>
          <fieldset class="devis-fieldset">
            <legend class="devis-legend">Prestations</legend>
            <div id="prestations-list"></div>
            <button type="button" id="add-prestation" class="btn btn-outline btn-sm">+ Ajouter une prestation</button>
            <div class="total-row"><span>Total HT</span><strong id="total-ht">0,00 €</strong></div>
            <p class="tva-mention">TVA non applicable, art. 293B du CGI</p>
          </fieldset>
          <fieldset class="devis-fieldset">
            <legend class="devis-legend">Conditions</legend>
            <div class="field-row"><div class="field"><label for="devis-numero">N° de devis</label><input type="text" id="devis-numero" class="input" readonly /></div><div class="field"><label for="devis-date">Date</label><input type="date" id="devis-date" class="input" /></div></div>
            <div class="field-row"><div class="field"><label for="devis-acompte">Acompte (%)</label><input type="number" id="devis-acompte" class="input" value="50" min="0" max="100" /></div><div class="field"><label for="devis-validite">Validité</label><input type="text" id="devis-validite" class="input" value="30 jours" /></div></div>
            <div class="field"><label for="devis-delai">Délai de livraison estimé</label><input type="text" id="devis-delai" class="input" value="2 semaines" /></div>
            <div class="field"><label for="devis-notes">Notes <span class="field-opt">(optionnel)</span></label><textarea id="devis-notes" class="input textarea" rows="3"></textarea></div>
          </fieldset>
          <div class="devis-actions">
            <button type="button" id="btn-download" class="btn btn-outline btn-action">Télécharger le PDF</button>
            <button type="button" id="btn-send" class="btn btn-aurora btn-action">&#9993; Envoyer au client</button>
            <button type="button" id="btn-invoice" class="btn btn-invoice btn-action">€ Facture d'acompte</button>
          </div>
        </div>
        <div class="preview-col">
          <div class="devis-paper" id="devis-paper">
            <div class="paper-header"><span class="logo">aur<span class="logo-o">o</span>re</span><span class="paper-title">DEVIS</span></div>
            <div class="paper-header-line"></div>
            <div class="paper-meta-row"><div class="paper-emetteur"><strong>Élodie Penarrubia</strong><br/>Entrepreneur individuel<br/>Nom commercial : Aurore<br/>17 rue Fermée, 13100 Aix-en-Provence<br/>elodie@agence-aurore.fr<br/>06 59 65 92 18<br/>SIRET 91387543100029 - Code APE 62.01Z</div><div class="paper-devis-info"><p>Devis n° <strong id="p-numero"></strong></p><p>Date : <span id="p-date"></span></p><p>Validité : <span id="p-validite">30 jours</span></p></div></div>
            <div class="paper-client"><p class="paper-label">Client</p><p id="p-client-nom"><em></em></p><p id="p-client-entreprise"></p><p id="p-client-email"></p><p id="p-client-tel"></p><p id="p-client-adresse" style="white-space:pre-line;"></p></div>
            <table class="paper-table"><thead><tr><th class="col-desc">Description</th><th class="col-qty">Qté</th><th class="col-pu">Prix unit.</th><th class="col-total">Total</th></tr></thead><tbody id="p-prestations-body"><tr class="empty-row"><td colspan="4">Aucune prestation ajoutée</td></tr></tbody></table>
            <div class="paper-total"><span>Total HT</span><strong id="p-total">0,00 €</strong></div>
            <p class="paper-tva">TVA non applicable, art. 293B du CGI</p>
            <div class="paper-conditions"><p class="paper-conditions-title">Conditions de paiement</p><p id="p-acompte">Acompte de 50 % à la commande : 0,00 €</p><p id="p-solde">Solde de 50 % à la livraison : 0,00 €</p><p id="p-delai">Délai estimé : 2 semaines</p><p id="p-notes" style="display:none;"></p></div>
            <div class="paper-legales"><p>En cas de retard de paiement, des pénalités au taux de 3 fois le taux d'intérêt légal seront appliquées, ainsi qu'une indemnité forfaitaire de recouvrement de 40 € (art. L441-10 du Code de commerce).</p><p>Ce devis peut être accepté par retour d'email confirmant votre accord explicite (art. 1366-1367 du Code civil). La création débutera après un appel de lancement et réception de l'acompte.</p><p>Ce devis est valable 30 jours. Sa signature vaut acceptation des CGV disponibles sur agence-aurore.fr/cgv/</p></div>
            <div class="paper-signature"><p class="paper-signature-title">Bon pour accord - Lu et approuvé</p><div class="paper-signature-fields"><p>Date : _______________</p><p>Signature :</p></div><div class="signature-line"></div></div>
            <div class="paper-footer">Aurore - Élodie Penarrubia - SIRET 91387543100029 - agence-aurore.fr</div>
          </div>
        </div>
      </section>
    </div>

    <!-- ═══ SECTION AUDIT ═══ -->
    <div id="section-audit" class="admin-section" style="display:none;">
      <div class="admin-section-header">
        <h2>Audit SEO</h2>
        <p>Analysez le référencement d'un site prospect</p>
      </div>
      <div class="audit-form"><div class="audit-form-fields"><div class="field"><label for="audit-url">URL du site à analyser</label><input type="url" id="audit-url" class="input" placeholder="https://www.exemple.com" /></div><div class="field"><label for="audit-name">Nom du prospect</label><input type="text" id="audit-name" class="input" placeholder="Nicolas Pécard - BlackWoodDeck" /></div><div class="field"><label for="audit-email">Email du prospect <span style="color:var(--gray-500);font-weight:400;">(optionnel)</span></label><input type="email" id="audit-email" class="input" placeholder="contact@exemple.com" /></div></div><button id="btn-analyze" class="btn btn-aurora btn-lg" style="margin-top:16px;">Analyser le site →</button><p id="analyze-error" style="display:none;color:#dc2626;font-size:13px;margin-top:8px;"></p></div>
      <div id="audit-results" style="display:none;margin-top:40px;"></div>
    </div>

    <!-- ═══ SECTION DASHBOARD ═══ -->
    <div id="section-dashboard" class="admin-section" style="display:none;">
      <div class="admin-section-header">
        <h2>Dashboard</h2>
        <p>Historique et suivi de vos devis</p>
      </div>
      <div class="dashboard-table-wrap"><table class="dashboard-table" id="dashboard-table"><thead><tr><th>N&deg; devis</th><th>Date</th><th>Client</th><th>Total HT</th><th>Statut</th><th>Actions</th></tr></thead><tbody id="dashboard-body"><tr class="dashboard-empty"><td colspan="6">Aucun devis envoy&eacute;</td></tr></tbody></table></div>
    </div>

    <!-- ═══ SECTION ARTICLES ═══ -->
    <div id="section-articles" class="admin-section" style="display:none;">
      <div class="admin-section-header">
        <h2>Articles</h2>
        <p>Rédigez et publiez des articles sur le blog</p>
      </div>
      <div class="editor-container">

        <!-- Steps -->
        <div class="editor-steps" id="editor-steps">
          <div class="estep active" data-step="0"><span class="estep-dot">1</span><span class="estep-label">Informations</span></div>
          <div class="estep-line"></div>
          <div class="estep" data-step="1"><span class="estep-dot">2</span><span class="estep-label">Contenu</span></div>
          <div class="estep-line"></div>
          <div class="estep" data-step="2"><span class="estep-dot">3</span><span class="estep-label">Aperçu</span></div>
        </div>

        <!-- Panel 0 : Informations -->
        <div class="editor-panel active" id="epanel-0">
          <h1 class="editor-title">Informations de l'article</h1>
          <p class="editor-subtitle">Ces informations apparaissent dans Google et sur la liste du blog.</p>
          <div class="field">
            <label class="field-label">Titre de l'article *</label>
            <p class="editor-hint">Soyez précis, c'est ce que Google affiche en premier</p>
            <input type="text" class="input" id="art-titre" placeholder="Ex : Comment créer un site web professionnel en 2025 ?" />
            <p class="editor-slug" id="art-slug-preview" style="display:none">URL : <span id="art-slug-display"></span></p>
          </div>
          <div class="field">
            <label class="field-label">Description SEO *</label>
            <p class="editor-hint">1-2 phrases qui résument l'article (max 160 caractères)</p>
            <textarea class="input textarea" id="art-description" rows="3" maxlength="160" placeholder="Guide complet pour créer un site web professionnel..."></textarea>
            <p class="editor-charcount" id="art-charcount">0/160</p>
          </div>
          <div class="field">
            <label class="field-label">Auteur</label>
            <input type="text" class="input" id="art-auteur" value="Élodie - aurore" />
          </div>
          <button class="btn btn-aurora" id="art-btn-next-0" style="width:100%;justify-content:center;" disabled>Continuer →</button>
        </div>

        <!-- Panel 1 : Contenu -->
        <div class="editor-panel" id="epanel-1">
          <h1 class="editor-title">Contenu de l'article</h1>
          <p class="editor-subtitle">Pour les sous-titres, commencez la ligne par <code style="background:var(--gray-100);padding:1px 5px;border-radius:4px;font-size:12px">## </code></p>
          <div class="field">
            <label class="field-label">Introduction *</label>
            <p class="editor-hint">Premier paragraphe visible, doit accrocher le lecteur</p>
            <textarea class="input textarea" id="art-intro" rows="4" placeholder="Quand on cherche à créer un site web pour son activité..."></textarea>
          </div>
          <div class="field">
            <label class="field-label">Corps de l'article *</label>
            <p class="editor-hint">Utilisez ## pour les sous-titres, **texte** pour le gras</p>
            <textarea class="input textarea" id="art-corps" rows="14" style="font-family:monospace;font-size:13px;" placeholder="## Les 4 grandes options&#10;&#10;### 1. Le template Wix&#10;&#10;Les constructeurs no-code..."></textarea>
          </div>
          <div style="display:flex;gap:12px;">
            <button class="btn btn-outline" id="art-btn-back-1" style="flex:0 0 auto;">← Retour</button>
            <button class="btn btn-aurora" id="art-btn-next-1" style="flex:1;justify-content:center;" disabled>Prévisualiser →</button>
          </div>
        </div>

        <!-- Panel 2 : Aperçu -->
        <div class="editor-panel" id="epanel-2">
          <h1 class="editor-title">Aperçu avant publication</h1>
          <p class="editor-subtitle">Vérifiez que tout est correct avant de publier.</p>

          <div class="editor-preview-card">
            <div class="epc-header">
              <p class="epc-meta" id="epc-meta"></p>
              <h2 class="epc-titre" id="epc-titre"></h2>
              <p class="epc-desc" id="epc-desc"></p>
            </div>
            <div class="epc-body">
              <p class="epc-intro" id="epc-intro"></p>
              <div class="epc-corps" id="epc-corps"></div>
            </div>
          </div>

          <div class="editor-url-preview">
            URL : <span id="epc-url"></span>
          </div>

          <div id="art-status-container"></div>

          <div style="display:flex;gap:12px;">
            <button class="btn btn-outline" id="art-btn-back-2" style="flex:0 0 auto;">← Modifier</button>
            <button class="btn btn-aurora" id="art-btn-publish" style="flex:1;justify-content:center;">Publier l'article →</button>
          </div>
        </div>

      </div>
    </div>

  </main>
</div>

<!-- Modales -->
<div id="modal-preview" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;"><div style="background:white;border-radius:12px;padding:32px;max-width:480px;width:90%;"><h3 style="margin:0 0 16px;font-size:18px;font-weight:700;">Envoyer le lien de preview</h3><p style="color:#6B6B6B;font-size:14px;margin:0 0 20px;">Le client recevra un email avec le lien pour valider son site.</p><label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px;">URL de preview Vercel</label><input id="preview-url-input" type="url" placeholder="https://aurore-dupont.vercel.app" style="width:100%;padding:10px 12px;border:1px solid #E5E7EB;border-radius:8px;font-size:14px;box-sizing:border-box;margin-bottom:20px;" /><div style="display:flex;gap:12px;justify-content:flex-end;"><button id="btn-cancel-preview" class="btn btn-outline">Annuler</button><button id="btn-confirm-preview" class="btn btn-aurora">Envoyer au client</button></div></div></div>
<div id="modal-delete" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;">
  <div style="background:white;border-radius:12px;padding:32px;max-width:400px;width:90%;">
    <h3 style="margin:0 0 8px;font-size:18px;font-weight:700;">Supprimer ce devis ?</h3>
    <p style="color:#6B6B6B;font-size:14px;margin:0 0 4px;">Devis <strong id="modal-delete-id"></strong></p>
    <p style="color:#6B6B6B;font-size:14px;margin:0 0 8px;">Cette action est irréversible et supprime :</p>
    <ul style="color:#6B6B6B;font-size:13px;margin:0 0 20px;padding-left:20px;">
      <li>Le devis de votre dashboard</li>
      <li>Le lead associé dans la base de données</li>
      <li>Toutes les données personnelles du client (conformité RGPD)</li>
    </ul>
    <div style="display:flex;gap:12px;justify-content:flex-end;">
      <button id="btn-cancel-delete" class="btn btn-outline">Annuler</button>
      <button id="btn-confirm-delete" class="btn" style="background:#DC2626;color:white;">Supprimer définitivement</button>
    </div>
  </div>
</div>
<div id="toast-container" class="toast-container"></div>

</BaseLayout>

<style is:global>
/* ─── ADMIN LAYOUT ─── */
#admin-app{display:flex;min-height:100vh;background:var(--gray-50);font-family:var(--font-display)}
#admin-sidebar{width:240px;min-width:240px;background:white;border-right:1px solid var(--gray-100);display:flex;flex-direction:column;padding:24px 0;position:fixed;top:0;left:0;height:100vh;z-index:100}
.sidebar-logo{font-family:var(--font-display);font-size:22px;font-weight:900;color:var(--black);padding:0 24px 24px;border-bottom:1px solid var(--gray-100);margin-bottom:12px;letter-spacing:-0.5px}
.sidebar-logo span{color:var(--aurora)}
.sidebar-nav{display:flex;flex-direction:column}
.sidebar-item{display:flex;align-items:center;gap:10px;width:100%;padding:11px 24px;background:none;border:none;border-right:3px solid transparent;color:var(--gray-500);font-family:var(--font-display);font-size:14px;font-weight:500;cursor:pointer;text-align:left;transition:all 0.15s ease}
.sidebar-item:hover{background:var(--gray-50);color:var(--black)}
.sidebar-item.active{background:var(--aurora-pale);color:var(--aurora);border-right-color:var(--aurora);font-weight:600}
.sidebar-icon{font-size:15px}
.sidebar-logout{margin-top:auto;padding:12px 24px;background:none;border:none;color:var(--gray-300);font-family:var(--font-display);font-size:13px;cursor:pointer;text-align:left;transition:color 0.15s;border-top:1px solid var(--gray-100)}
.sidebar-logout:hover{color:#DC2626}
#admin-main{margin-left:240px;flex:1;padding:40px;min-height:100vh}
/* ─── SECTION HEADER ─── */
.admin-section-header{margin-bottom:32px;padding-bottom:24px;border-bottom:1px solid var(--gray-100)}
.admin-section-header h2{font-family:var(--font-display);font-size:24px;font-weight:700;color:var(--black);margin:0 0 4px;letter-spacing:-0.3px}
.admin-section-header p{font-size:14px;color:var(--gray-500);margin:0}
/* ─── LOGIN ─── */
.admin-login{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--gray-50)}
.login-box{background:white;border-radius:16px;padding:48px 40px;width:100%;max-width:380px;box-shadow:0 4px 24px rgba(0,0,0,0.06);text-align:center;border:1px solid var(--gray-100)}
.login-logo{font-family:var(--font-display);font-size:36px;font-weight:900;color:var(--black);letter-spacing:-1px;margin-bottom:8px}
.login-logo span{color:var(--aurora)}
.login-box h1{font-family:var(--font-display);font-size:20px;font-weight:600;color:var(--black);margin:0 0 24px}
.login-form{display:flex;flex-direction:column;gap:12px}
.login-error{color:#dc2626;font-size:13px;margin:0}
/* ─── DEVIS ─── */
.devis-layout{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
.devis-page-title{display:none}
.message-prefill-box{background:var(--aurora-pale);border-left:3px solid var(--aurora);padding:12px 16px;border-radius:0 8px 8px 0;margin-bottom:20px}
.message-prefill-label{font-size:11px;font-weight:700;color:var(--aurora);text-transform:uppercase;letter-spacing:0.05em;margin:0 0 6px}
.message-prefill-text{font-size:13px;color:var(--black);margin:0;line-height:1.6}
.devis-fieldset{border:none;padding:0;margin:0 0 32px}
.devis-legend{font-family:var(--font-display);font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--aurora);margin-bottom:16px;display:block}
.field{margin-bottom:12px}
.field label{display:block;font-size:13px;font-weight:500;color:var(--gray-700);margin-bottom:4px}
.field-opt{color:var(--gray-500);font-weight:400}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.presta-row{display:grid;grid-template-columns:1fr 200px 70px 90px 36px;gap:8px;align-items:end;margin-bottom:8px}
.presta-row .field{margin-bottom:0}
.presta-remove{width:36px;height:38px;border:none;background:none;color:var(--gray-500);cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;border-radius:var(--radius-sm);transition:var(--transition)}
.presta-remove:hover{background:#fef2f2;color:#e53e3e}
.total-row{display:flex;justify-content:space-between;align-items:center;padding:16px 0;margin-top:16px;border-top:2px solid var(--black);font-size:18px;font-weight:600}
.tva-mention{font-size:12px;color:var(--gray-500);margin-top:4px}
