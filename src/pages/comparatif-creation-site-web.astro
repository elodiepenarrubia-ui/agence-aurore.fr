---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Quelle est la meilleure solution pour créer un site web en 2026 ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Cela dépend de votre budget, de votre temps disponible et de vos compétences techniques. Pour un budget serré et un besoin simple, le Pack Starter aurore à 490 € est idéal. Pour un projet complexe de +50 pages, une agence spécialisée sera plus adaptée." }},
    { "@type": "Question", "name": "Pourquoi aurore plutôt que Wix ou WordPress ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Aurore livre un site clé en main, sans abonnement mensuel, avec un SEO optimisé et une vitesse de chargement imbattable. Pas de template générique, pas de plugin à maintenir, pas de faille de sécurité WordPress." }},
    { "@type": "Question", "name": "Combien coûte un site web en 2026 ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Les prix varient de 0 € (Wix gratuit avec publicités) à plus de 10 000 € (agence haut de gamme). Chez aurore, les sites démarrent à 490 € pour le Pack Starter et vont jusqu'à 1 390 € pour le Pack Pro tout inclus." }},
    { "@type": "Question", "name": "Est-ce que je suis propriétaire de mon site avec aurore ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, à 100 %. Le code source, le design, le contenu et le nom de domaine vous appartiennent. Vous pouvez partir quand vous voulez, sans frais ni pénalité." }},
    { "@type": "Question", "name": "Faut-il choisir entre un beau site et un site bien référencé ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Non. Un site peut être beau ET bien référencé - ce sont deux qualités complémentaires. Chez Aurore, le design sur mesure et le SEO on-page sont inclus dans toutes les formules. Vous n'avez pas à choisir." }},
  ],
};
---

<BaseLayout
  title="Comparatif création de site web 2026 : toutes les solutions | aurore"
  description="WordPress, Wix, Squarespace, agence, freelance ou aurore ? Comparatif complet et honnête de toutes les solutions pour créer votre site web en 2026."
  slug="comparatif-creation-site-web"
  schema={[faqSchema]}
>

  <!-- ─── HERO ─── -->
  <section class="lp-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Comparatif complet 2026
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="lp-h1">
        Toutes les solutions pour créer<br />votre site web en 2026.
      </h1>
      <p class="hero-serif-line">Le comparatif honnête.</p>
      <p class="lp-sub">
        WordPress, Wix, Squarespace, agence web, freelance ou aurore : voici les vraies différences pour faire le bon choix selon votre situation et votre budget.
      </p>
      <div class="hero-ctas">
        <a href="#comparatif" class="btn btn-primary btn-lg">Voir le comparatif →</a>
        <a href="/contact/" class="btn btn-outline btn-lg">Demander un devis</a>
      </div>
    </div>
  </section>

  <!-- ─── TABLEAU COMPARATIF ─── -->
  <section class="section" id="comparatif">
    <div class="container">
      <span class="section-label fade-in">Comparatif détaillé</span>
      <h2 class="section-title fade-in">Les 7 solutions comparées point par point.</h2>
      <div class="comparatif-table-wrapper fade-in">
        <table class="comparatif-table">
          <thead>
            <tr>
              <th>Critère</th>
              <th>WordPress</th>
              <th>Wix</th>
              <th>Squarespace</th>
              <th>Agence</th>
              <th>Freelance</th>
              <th>1&1 / Yello</th>
              <th class="col-aurora">aurore</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Prix création</strong></td>
              <td>0 € (DIY)</td>
              <td>0 € (gratuit limité)</td>
              <td>0 € (DIY)</td>
              <td>3 000 – 15 000 €</td>
              <td>800 – 3 000 €</td>
              <td>0 – 500 €</td>
              <td class="col-aurora"><strong>490 – 1 390 €</strong></td>
            </tr>
            <tr>
              <td><strong>Coût mensuel</strong></td>
              <td>5 – 30 €/mois</td>
              <td>13 – 39 €/mois</td>
              <td>16 – 42 €/mois</td>
              <td>50 – 200 €/mois</td>
              <td>Variable</td>
              <td>10 – 40 €/mois</td>
              <td class="col-aurora"><strong>0 €</strong></td>
            </tr>
            <tr>
              <td><strong>Délai</strong></td>
              <td>1 – 4 semaines (DIY)</td>
              <td>1 – 7 jours (DIY)</td>
              <td>1 – 7 jours (DIY)</td>
              <td>4 – 12 semaines</td>
              <td>2 – 6 semaines</td>
              <td>1 – 3 jours</td>
              <td class="col-aurora"><strong>2 semaines</strong></td>
            </tr>
            <tr>
              <td><strong>Propriété</strong></td>
              <td>Oui (si auto-hébergé)</td>
              <td>Non (plateforme)</td>
              <td>Non (plateforme)</td>
              <td>Oui (selon contrat)</td>
              <td>Oui (selon contrat)</td>
              <td>Non (plateforme)</td>
              <td class="col-aurora"><strong>Oui, 100 %</strong></td>
            </tr>
            <tr>
              <td><strong>Personnalisation</strong></td>
              <td>Illimitée (technique)</td>
              <td>Limitée (templates)</td>
              <td>Limitée (templates)</td>
              <td>Illimitée</td>
              <td>Élevée</td>
              <td>Très limitée</td>
              <td class="col-aurora"><strong>Sur mesure</strong></td>
            </tr>
            <tr>
              <td><strong>SEO</strong></td>
              <td>Bon (avec plugins)</td>
              <td>Moyen</td>
              <td>Correct</td>
              <td>Excellent</td>
              <td>Variable</td>
              <td>Faible</td>
              <td class="col-aurora"><strong>Excellent</strong></td>
            </tr>
            <tr>
              <td><strong>Vitesse</strong></td>
              <td>Moyenne (plugins)</td>
              <td>Moyenne</td>
              <td>Correcte</td>
              <td>Variable</td>
              <td>Variable</td>
              <td>Lente</td>
              <td class="col-aurora"><strong>Ultra-rapide</strong></td>
            </tr>
            <tr>
              <td><strong>Sécurité</strong></td>
              <td>Risquée (mises à jour)</td>
              <td>Correcte (plateforme)</td>
              <td>Correcte (plateforme)</td>
              <td>Bonne</td>
              <td>Variable</td>
              <td>Correcte</td>
              <td class="col-aurora"><strong>Maximale (statique)</strong></td>
            </tr>
            <tr>
              <td><strong>Support</strong></td>
              <td>Communauté</td>
              <td>Chat / email</td>
              <td>Chat / email</td>
              <td>Dédié</td>
              <td>Direct</td>
              <td>Téléphone</td>
              <td class="col-aurora"><strong>Direct (Élodie)</strong></td>
            </tr>
            <tr>
              <td><strong>Prise en main guidée</strong></td>
              <td>Non</td>
              <td>Tutoriels</td>
              <td>Tutoriels</td>
              <td>Parfois</td>
              <td>Parfois</td>
              <td>Non</td>
              <td class="col-aurora"><strong>Oui</strong></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ─── QUEL CHOIX SELON VOTRE PROFIL ─── -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <span class="section-label fade-in">Quel choix selon votre profil</span>
      <h2 class="section-title fade-in">La bonne solution dépend de votre situation.</h2>
      <div class="lp-profiles fade-in">
        <div class="card lp-profile-card">
          <div class="lp-profile-badge">Budget serré</div>
          <h3>Besoin simple, budget limité</h3>
          <p>Vous démarrez et avez besoin d'un site pro sans vous ruiner. 5 pages, domaine, emails pro et fiche Google Business.</p>
          <div class="lp-profile-reco">
            <strong>Notre recommandation :</strong> Pack Starter aurore - 490 €
          </div>
          <a href="/tarifs/" class="btn btn-outline" style="width:100%;justify-content:center;">Voir le Pack Starter →</a>
        </div>
        <div class="card lp-profile-card card-aurora">
          <div class="lp-profile-badge" style="color:var(--aurora);">Recommandé</div>
          <h3>Besoin complet clé en main</h3>
          <p>Vous voulez un site complet avec logo, SEO, formulaire, blog et accompagnement. Sans vous prendre la tête.</p>
          <div class="lp-profile-reco">
            <strong>Notre recommandation :</strong> Pack Vitrine ou Pro aurore
          </div>
          <a href="/tarifs/" class="btn btn-aurora" style="width:100%;justify-content:center;">Voir les packs →</a>
        </div>
        <div class="card lp-profile-card">
          <div class="lp-profile-badge">Projet complexe</div>
          <h3>Projet très complexe +50 pages</h3>
          <p>E-commerce, marketplace, application métier : un projet qui nécessite une équipe pluridisciplinaire.</p>
          <div class="lp-profile-reco">
            <strong>Notre recommandation :</strong> Agence spécialisée
          </div>
        </div>
        <div class="card lp-profile-card">
          <div class="lp-profile-badge">DIY</div>
          <h3>Vous avez du temps et aimez la technique</h3>
          <p>Vous êtes à l'aise avec l'informatique et voulez tout contrôler vous-même, même si ça prend du temps.</p>
          <div class="lp-profile-reco">
            <strong>Notre recommandation :</strong> WordPress DIY
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="section" id="faq">
    <div class="container" style="max-width:720px;">
      <span class="section-label fade-in">FAQ</span>
      <h2 class="section-title fade-in">Questions fréquentes.</h2>
      <div class="faq-list fade-in">
        {faqSchema.mainEntity.map((item: any) => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">{item.name}<span class="faq-icon" aria-hidden="true">+</span></button>
            <div class="faq-answer">{item.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA FINAL ─── -->
  <section class="section">
    <div class="container">
      <div class="cta-section">
        <h2>Vous hésitez encore ? Demandez un devis gratuit.</h2>
        <p>Un formulaire de 2 minutes suffit pour recevoir un devis détaillé sous 48h. Sans engagement.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:32px;">
          <a href="/contact/" class="btn btn-aurora btn-lg">Demander mon devis gratuit →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ─── */
  .lp-hero { padding: 140px 0 80px; text-align: center; position: relative; overflow: hidden; }
  .lp-hero > .container { position: relative; z-index: 1; }
  .lp-h1 { font-family: var(--font-display); font-size: clamp(32px, 5vw, 58px); font-weight: 700; letter-spacing: -0.05em; line-height: 1.08; margin: 20px 0 12px; color: var(--black); }
  .hero-serif-line { font-family: var(--font-serif); font-style: italic; font-size: clamp(36px, 5.5vw, 64px); color: var(--aurora); line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 20px; }
  .lp-sub { font-size: clamp(15px, 1.3vw, 18px); line-height: 1.65; max-width: 600px; margin: 0 auto 32px; color: var(--gray-700); }

  /* ─── TABLEAU ─── */
  .comparatif-table-wrapper { overflow-x: auto; margin-top: 48px; border-radius: var(--radius-lg); border: 1.5px solid var(--gray-100); }
  .comparatif-table { width: 100%; border-collapse: collapse; font-size: 14px; min-width: 900px; }
  .comparatif-table thead { background: var(--gray-50); }
  .comparatif-table th { padding: 16px 14px; text-align: left; font-weight: 600; font-size: 13px; letter-spacing: -0.01em; border-bottom: 1.5px solid var(--gray-100); white-space: nowrap; }
  .comparatif-table td { padding: 14px 14px; border-bottom: 1px solid var(--gray-100); color: var(--gray-700); line-height: 1.5; }
  .comparatif-table tbody tr:last-child td { border-bottom: none; }
  .comparatif-table tbody tr:hover { background: var(--gray-50); }
  .col-aurora { background: var(--aurora-pale) !important; color: var(--black); }
  .comparatif-table th.col-aurora { color: var(--aurora); font-weight: 700; }

  /* ─── PROFILS ─── */
  .lp-profiles { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 48px; }
  .lp-profile-card { display: flex; flex-direction: column; gap: 16px; }
  .lp-profile-card h3 { font-size: 18px; font-weight: 700; letter-spacing: -0.02em; }
  .lp-profile-card p { font-size: 15px; line-height: 1.65; color: var(--gray-700); flex: 1; }
  .lp-profile-badge { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-500); }
  .lp-profile-reco { font-size: 14px; color: var(--black); padding: 12px 16px; background: var(--gray-50); border-radius: var(--radius-sm); }
  .lp-profile-reco strong { color: var(--aurora); }

  /* ─── FAQ ─── */
  .faq-list { margin-top: 40px; }
  .faq-item { border-bottom: 1px solid var(--gray-100); }
  .faq-question { width: 100%; text-align: left; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 0; font-size: 16px; font-weight: 600; color: var(--black); cursor: pointer; background: none; border: none; font-family: var(--font-display); transition: color 0.2s ease; }
  .faq-question:hover { color: var(--aurora); }
  .faq-icon { width: 28px; height: 28px; border-radius: 50%; background: var(--gray-100); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; color: var(--gray-500); transition: all 0.2s ease; }
  .faq-item.open .faq-icon { background: var(--aurora-pale); color: var(--aurora); transform: rotate(45deg); }
  .faq-answer { font-size: 15px; color: var(--gray-700); line-height: 1.7; padding-bottom: 20px; display: none; }
  .faq-item.open .faq-answer { display: block; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .lp-profiles { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .lp-hero { padding: 100px 0 56px; }
  }
</style>
