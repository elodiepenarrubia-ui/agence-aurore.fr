---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de site web pour conciergerie",
  "serviceType": "Création de site web pour conciergerie de location saisonnière",
  "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://agence-aurore.fr" },
  "areaServed": "France",
  "description": "Site web professionnel pour conciergerie de location saisonnière. Clé en main, livré en 2 semaines, SEO local inclus.",
  "offers": [
    { "@type": "Offer", "name": "Pack Starter", "priceCurrency": "EUR", "price": "290" },
    { "@type": "Offer", "name": "Pack Vitrine", "priceCurrency": "EUR", "price": "690" },
    { "@type": "Offer", "name": "Pack Pro",     "priceCurrency": "EUR", "price": "1290" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Mon site peut-il référencer mes propriétés ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, votre site peut présenter chaque propriété avec photos, description, équipements et disponibilités. C'est un excellent complément aux plateformes type Airbnb ou Booking." }},
    { "@type": "Question", "name": "Puis-je recevoir des demandes de propriétaires via le site ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolument. Un formulaire dédié permet aux propriétaires de vous contacter directement pour confier la gestion de leur bien. C'est un canal d'acquisition clé pour développer votre portefeuille." }},
    { "@type": "Question", "name": "Le site est-il compatible avec mes outils Airbnb/Booking ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Votre site est indépendant des plateformes, mais peut inclure des liens directs vers vos annonces Airbnb et Booking. L'objectif est de réduire votre dépendance aux commissions en générant des réservations directes." }},
    { "@type": "Question", "name": "Puis-je modifier les propriétés moi-même ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, avec les packs Vitrine et Pro, un espace rédaction vous permet de modifier vos textes, ajouter des propriétés et mettre à jour vos tarifs sans aucune connaissance technique." }},
    { "@type": "Question", "name": "Comment réduire ma dépendance à Airbnb et Booking ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Votre site vous permet de générer des réservations directes, sans commission. Même si vous gardez vos annonces sur les plateformes, chaque réservation directe vous économise 15 à 20% de commission. Sur une saison, ça représente plusieurs milliers d'euros récupérés." }},
    { "@type": "Question", "name": "Comment trouver de nouveaux propriétaires à qui proposer mes services ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Un formulaire dédié aux propriétaires sur votre site capte les demandes de gestion locative. Avec le SEO local inclus, vous apparaissez quand un propriétaire cherche \"conciergerie [votre ville]\" - un canal d'acquisition que vos concurrents n'exploitent souvent pas." }},
  ],
};
---

<BaseLayout
  title="Création de site web pour conciergerie | aurore, à partir de 290 €"
  description="Site web professionnel pour conciergerie de location saisonnière. Clé en main, livré en 2 semaines, SEO local inclus. Basé à Aix-en-Provence, intervention toute la France."
  slug="site-web-conciergerie"
  schema={[serviceSchema, faqSchema]}
>

  <!-- ─── HERO ─── -->
  <section class="lp-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Spécial conciergeries de location saisonnière
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="lp-h1">
        Un site qui remplit vos calendriers,<br />pas vos nuits.
      </h1>
      <p class="hero-serif-line">Livré en 2 semaines.</p>
      <p class="lp-sub">
        Votre conciergerie mérite une présence digitale à la hauteur de vos propriétés. SEO local, fiche Google, réservations en ligne, clé en main à partir de 290&nbsp;€.
      </p>
      <div class="hero-ctas">
        <a href="/tarifs/" class="btn btn-primary btn-lg">Voir les tarifs →</a>
        <a href="/contact/?type=conciergerie" class="btn btn-outline btn-lg">Demander un devis</a>
      </div>
    </div>
  </section>

  <!-- ─── PROBLÈME ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label fade-in">Le problème</span>
      <h2 class="section-title fade-in">Sans site, vous dépendez des plateformes.<br />Avec le mauvais site, vous perdez des propriétaires.</h2>
      <div class="lp-problems fade-in">
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
          <p>Vos voyageurs cherchent sur Google avant de réserver, et <strong>sans site vous dépendez à 100% des plateformes</strong> et leurs commissions.</p>
        </div>
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <p>Un site amateur <strong>fait fuir les propriétaires</strong> qui cherchent un gestionnaire sérieux pour leur bien.</p>
        </div>
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <p>Gérer Airbnb, Booking ET votre site vous prend un temps fou : <strong>vous avez besoin d'un site qui travaille pour vous</strong>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CE QU'AURORE CRÉE ─── -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <span class="section-label fade-in">Ce qu'aurore crée pour vous</span>
      <h2 class="section-title fade-in">Un site pensé pour votre activité de conciergerie.</h2>
      <div class="lp-features fade-in">
        {[
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, title: "Design haut de gamme adapté au secteur", desc: "Un site élégant qui reflète la qualité de vos propriétés et inspire confiance aux propriétaires comme aux voyageurs." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`, title: "Présentation de vos propriétés et services", desc: "Page dédiée à chaque bien avec photos, description, équipements et localisation, un véritable catalogue en ligne." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`, title: "Formulaire de contact propriétaires et voyageurs", desc: "Deux formulaires distincts pour recevoir des demandes de gestion et des demandes de réservation directe." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`, title: "SEO local \"conciergerie [ville]\"", desc: "Optimisation on-page pour apparaître dans les résultats Google quand propriétaires et voyageurs vous cherchent." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`, title: "Fiche Google Business optimisée", desc: "Créée et configurée pour que vous apparaissiez sur Google Maps avec vos horaires, avis et photos de propriétés." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`, title: "Emails pro @votre-conciergerie.fr", desc: "Adresse email professionnelle incluse, renforcez votre crédibilité auprès des propriétaires et voyageurs." },
        ].map(f => (
          <div class="card lp-feature">
            <div class="lp-feature-icon" set:html={f.icon} />
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── RÉALISATION ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label fade-in">Ils nous font confiance</span>
      <h2 class="section-title fade-in">Le Mazarin, conciergerie à Aix-en-Provence.</h2>
      <div class="lp-realisation fade-in">
        <div class="lp-realisation-img">
          <img src="/lemazarin-1.webp" alt="Site web de Le Mazarin, conciergerie de location saisonnière à Aix-en-Provence, créé par aurore" loading="lazy" />
        </div>
        <div class="lp-realisation-content">
          <blockquote class="lp-testimonial">
            <p>« Un site qui reflète parfaitement l'image haut de gamme de notre conciergerie. Élodie a compris notre positionnement dès le premier échange. »</p>
            <footer>
              <cite>Le Mazarin</cite>, conciergerie à Aix-en-Provence
            </footer>
          </blockquote>
          <a href="/realisations/le-mazarin-conciergerie-aix/" class="btn btn-link">Voir la réalisation complète →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TARIFS ─── -->
  <section class="section section-aurora-gradient">
    <div class="container">
      <span class="section-label fade-in" style="color:var(--aurora);">Tarifs</span>
      <h2 class="section-title fade-in">Des tarifs clairs, sans surprise.</h2>
      <div class="lp-pricing fade-in">
        <div class="card lp-price-card">
          <div class="lp-price-badge">Starter</div>
          <div class="lp-price">290 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Site 5 pages + design responsive</li>
            <li>Domaine + emails pro</li>
            <li>Fiche Google Business</li>
          </ul>
          <a href="/tarifs/" class="btn btn-outline" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
        <div class="card lp-price-card lp-price-card-highlight">
          <div class="lp-price-badge lp-price-badge-aurora">Vitrine</div>
          <div class="lp-price">690 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Jusqu'à 8 pages + logo</li>
            <li>SEO on-page + Search Console</li>
            <li>Formulaire de contact</li>
          </ul>
          <a href="/tarifs/" class="btn btn-aurora" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
        <div class="card lp-price-card">
          <div class="lp-price-badge">Pro</div>
          <div class="lp-price">1 290 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Jusqu'à 12 pages + blog + RDV en ligne</li>
            <li>Automatisation email</li>
            <li>Espace rédaction autonome</li>
          </ul>
          <a href="/tarifs/" class="btn btn-outline" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="section" id="faq">
    <div class="container" style="max-width:720px;">
      <span class="section-label fade-in">FAQ</span>
      <h2 class="section-title fade-in">Questions fréquentes.</h2>
      <div class="faq-list fade-in">
        {faqSchema.mainEntity.map((item: any) => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">{item.name}<span class="faq-icon" aria-hidden="true">+</span></button>
            <div class="faq-answer">{item.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA FINAL ─── -->
  <section class="section">
    <div class="container">
      <div class="cta-section">
        <h2>Développez votre portefeuille de propriétés.</h2>
        <p>Un formulaire de 2 minutes suffit pour recevoir un devis détaillé sous 48h.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:32px;">
          <a href="/contact/?type=conciergerie" class="btn btn-aurora btn-lg">Demander mon devis gratuit →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ─── */
  .lp-hero { padding: 140px 0 80px; text-align: center; position: relative; overflow: hidden; }
  .lp-hero > .container { position: relative; z-index: 1; }
  .lp-h1 { font-family: var(--font-display); font-size: clamp(32px, 5vw, 58px); font-weight: 700; letter-spacing: -0.05em; line-height: 1.08; margin: 20px 0 12px; color: var(--black); }
  .hero-serif-line { font-family: var(--font-serif); font-style: italic; font-size: clamp(36px, 5.5vw, 64px); color: var(--aurora); line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 20px; }
  .lp-sub { font-size: clamp(15px, 1.3vw, 18px); line-height: 1.65; max-width: 540px; margin: 0 auto 32px; color: var(--gray-700); }

  /* ─── PROBLÈMES ─── */
  .lp-problems { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
  .lp-problem-card { display: flex; flex-direction: column; gap: 16px; }
  .lp-problem-card p { font-size: 15px; line-height: 1.65; color: var(--gray-700); }
  .lp-problem-icon { width: 44px; height: 44px; background: #FFF0E6; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; }

  /* ─── FEATURES ─── */
  .lp-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 48px; }
  .lp-feature { display: flex; flex-direction: column; gap: 10px; }
  .lp-feature-icon { width: 44px; height: 44px; background: var(--aurora-pale); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--aurora); }
  .lp-feature h3 { font-size: 17px; font-weight: 600; letter-spacing: -0.02em; }
  .lp-feature p { font-size: 14px; line-height: 1.65; color: var(--gray-500); }

  /* ─── RÉALISATION ─── */
  .lp-realisation { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; margin-top: 48px; }
  .lp-realisation-img { border-radius: var(--radius-lg); overflow: hidden; border: 1.5px solid var(--gray-100); }
  .lp-realisation-img img { width: 100%; display: block; }
  .lp-testimonial { margin-bottom: 24px; }
  .lp-testimonial p { font-size: 18px; line-height: 1.7; color: var(--gray-700); font-style: italic; margin-bottom: 16px; }
  .lp-testimonial footer { font-size: 15px; color: var(--gray-500); }
  .lp-testimonial cite { font-style: normal; font-weight: 600; color: var(--black); }

  /* ─── PRICING ─── */
  .lp-pricing { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
  .lp-price-card { display: flex; flex-direction: column; gap: 20px; text-align: center; }
  .lp-price-card-highlight { border-color: var(--aurora); position: relative; }
  .lp-price-card-highlight::before { content: ''; position: absolute; top: 0; left: 24px; right: 24px; height: 2px; background: linear-gradient(90deg, transparent, var(--aurora), transparent); border-radius: 2px; }
  .lp-price-badge { font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-500); }
  .lp-price-badge-aurora { color: var(--aurora); }
  .lp-price { font-family: var(--font-display); font-size: 48px; font-weight: 800; letter-spacing: -0.05em; color: var(--black); line-height: 1; }
  .lp-price span { font-size: 0.5em; opacity: 0.6; }
  .lp-price-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .lp-price-list li { font-size: 14px; color: var(--gray-700); line-height: 1.5; padding-left: 20px; position: relative; text-align: left; }
  .lp-price-list li::before { content: ''; position: absolute; left: 0; top: 7px; width: 8px; height: 8px; border-radius: 50%; background: var(--aurora-pale); border: 1.5px solid var(--aurora); }

  /* ─── FAQ ─── */
  .faq-list { margin-top: 40px; }
  .faq-item { border-bottom: 1px solid var(--gray-100); }
  .faq-question { width: 100%; text-align: left; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 0; font-size: 16px; font-weight: 600; color: var(--black); cursor: pointer; background: none; border: none; font-family: var(--font-display); transition: color 0.2s ease; }
  .faq-question:hover { color: var(--aurora); }
  .faq-icon { width: 28px; height: 28px; border-radius: 50%; background: var(--gray-100); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; color: var(--gray-500); transition: all 0.2s ease; }
  .faq-item.open .faq-icon { background: var(--aurora-pale); color: var(--aurora); transform: rotate(45deg); }
  .faq-answer { font-size: 15px; color: var(--gray-700); line-height: 1.7; padding-bottom: 20px; display: none; }
  .faq-item.open .faq-answer { display: block; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .lp-problems { grid-template-columns: 1fr; }
    .lp-pricing { grid-template-columns: 1fr; max-width: 400px; margin-left: auto; margin-right: auto; }
  }
  @media (max-width: 768px) {
    .lp-hero { padding: 100px 0 56px; }
    .lp-features { grid-template-columns: 1fr; }
    .lp-realisation { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
