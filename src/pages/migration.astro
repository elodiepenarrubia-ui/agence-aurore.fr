---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Migration de site web",
    "provider": { "@type": "LocalBusiness", "name": "Aurore" },
    "areaServed": "France",
    "description": "Migration de votre site WordPress, Wix ou Squarespace vers du code Astro propre. Arrêtez de payer un abonnement mensuel.",
    "offers": { "@type": "Offer", "priceCurrency": "EUR", "price": "285" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Que comprend la migration à 285 € ?", "acceptedAnswer": { "@type": "Answer", "text": "Récupération de votre contenu existant (textes, images), reconstruction en code Astro propre, conservation de votre domaine, configuration hébergement gratuit et mise en ligne." } },
      { "@type": "Question", "name": "Est-ce que je perds mon référencement en migrant ?", "acceptedAnswer": { "@type": "Answer", "text": "Non. Les URLs sont conservées ou redirigées, et le code propre améliore généralement les performances et donc le SEO." } },
      { "@type": "Question", "name": "Combien de temps prend une migration ?", "acceptedAnswer": { "@type": "Answer", "text": "En moyenne 5 à 7 jours ouvrés selon la taille du site." } },
      { "@type": "Question", "name": "Est-ce que je garde mon nom de domaine ?", "acceptedAnswer": { "@type": "Answer", "text": "Oui, absolument. Votre domaine est transféré ou reconfiguré pour pointer vers votre nouveau site." } },
      { "@type": "Question", "name": "Vais-je devoir tout réécrire depuis zéro ?", "acceptedAnswer": { "@type": "Answer", "text": "Non. On récupère intégralement votre contenu existant : textes, images, pages, articles de blog. On l'optimise et on le restructure sur une base technique moderne. Vous ne repartez pas de zéro, vous améliorez ce qui existe." } },
      { "@type": "Question", "name": "Pourquoi migrer maintenant plutôt que d'attendre ?", "acceptedAnswer": { "@type": "Answer", "text": "Chaque mois que vous restez sur Wix ou Squarespace est un mois d'abonnement payé pour un site qui ne vous appartient pas. En migrant, vous arrêtez immédiatement ces frais récurrents et vous gagnez en performances SEO. Le coût de la migration est souvent amorti en moins d'un an d'abonnements économisés." } }
    ]
  }
];

const plateformes = [
  { nom: 'WordPress', mensuel: 25, annuel: 300, troisAns: 900 },
  { nom: 'Wix', mensuel: 17, annuel: 204, troisAns: 612 },
  { nom: 'Squarespace', mensuel: 16, annuel: 192, troisAns: 576 },
];

const inclus = [
  { icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>', label: 'Récupération du contenu existant (textes, images)' },
  { icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>', label: 'Reconstruction en site rapide et léger' },
  { icon: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>', label: 'Vous gardez votre adresse web actuelle' },
  { icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>', label: 'Votre site tourne sans abonnement mensuel' },
  { icon: '<polyline points="20 6 9 17 4 12"/>', label: 'Mise en ligne et vérification complète' },
  { icon: '<path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/>', label: '2 pages supplémentaires incluses' },
];

const options = [
  { label: 'Visibilité Google', prix: '150 €' },
  { label: 'Logo professionnel', prix: '150 €' },
  { label: 'Formulaire de contact', prix: '60 €' },
  { label: 'Publiez vos contenus vous-même', prix: '150 €' },
  { label: 'Session de modifications', prix: '30 €' },
  { label: 'Pack landing pages (10 pages SEO)', prix: '190 €' },
];

const faqMigration = [
  { q: "Que comprend la migration à 285 € ?", r: "Récupération de votre contenu existant (textes, images), reconstruction en site rapide et léger, conservation de votre domaine, configuration hébergement gratuit et mise en ligne." },
  { q: "Est-ce que je perds mon référencement en migrant ?", r: "Non. Les URLs sont conservées ou redirigées, et le code propre améliore généralement les performances et donc le SEO." },
  { q: "Combien de temps prend une migration ?", r: "En moyenne 5 à 7 jours ouvrés selon la taille du site." },
  { q: "Est-ce que je garde mon nom de domaine ?", r: "Oui, absolument. Votre domaine est transféré ou reconfiguré pour pointer vers votre nouveau site." },
  { q: "Vais-je devoir tout réécrire depuis zéro ?", r: "Non. On récupère intégralement votre contenu existant : textes, images, pages, articles de blog. On l'optimise et on le restructure sur une base technique moderne. Vous ne repartez pas de zéro, vous améliorez ce qui existe." },
  { q: "Pourquoi migrer maintenant plutôt que d'attendre ?", r: "Chaque mois que vous restez sur Wix ou Squarespace est un mois d'abonnement payé pour un site qui ne vous appartient pas. En migrant, vous arrêtez immédiatement ces frais récurrents et vous gagnez en performances SEO. Le coût de la migration est souvent amorti en moins d'un an d'abonnements économisés." },
];

const catalogSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Migration de site web",
  "description": "Migration de site WordPress, Wix ou Squarespace vers un site rapide, sécurisé et sans abonnement. Conservation du SEO et du domaine.",
  "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://www.agence-aurore.fr" },
  "areaServed": "France",
  "offers": { "@type": "Offer", "name": "Migration site web", "price": "285", "priceCurrency": "EUR", "description": "Migration complète depuis WordPress, Wix ou Squarespace. Conservation du domaine, du contenu et du SEO." }
};
---

<BaseLayout
  title="Migration WordPress, Wix, Squarespace → code propre | aurore"
  description="Migrez votre site WordPress, Wix ou Squarespace pour 285 €. Arrêtez de payer un abonnement mensuel. Hébergement gratuit, code en propre."
  slug="migration"
  schema={[...schema, catalogSchema]}
>

  <!-- ─── HERO ─── -->
  <section class="mig-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Migration · aurore
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="mig-h1">
        Arrêtez de louer votre site.<br />
        <span class="hero-serif">Possédez-le.</span>
      </h1>
      <p class="mig-sub">
        Vous payez 17 à 50 € par mois pour un site qui ne vous appartient pas.
        Je récupère tout votre contenu et le reconstruis proprement. Vous arrêtez de payer pour toujours.
      </p>
      <div class="mig-ctas">
        <a href="/contact/?type=migration" class="btn btn-aurora btn-lg">Demander ma migration →</a>
        <a href="/simulateur/" class="btn btn-outline btn-lg">Calculer mon économie</a>
      </div>
    </div>
  </section>

  <!-- ─── CE QUI EST INCLUS ─── -->
  <section class="section">
    <div class="container" style="max-width:820px;">
      <span class="section-label">L'offre</span>
      <h2 class="section-title">Pour 285 €, vous arrêtez de payer un abonnement qui vous coûte des centaines d'euros par an</h2>

      <div class="mig-inclus">
        {inclus.map(item => (
          <div class="mig-inclus-item">
            <div class="mig-inclus-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
            </div>
            <span>{item.label}</span>
          </div>
        ))}
      </div>

      <div class="mig-prix-bloc">
        <div class="mig-prix-tag">285 €</div>
        <div class="mig-prix-detail">
          <span>Prix unique, tout inclus</span>
          <span class="mig-prix-note">Puis 0 € par mois. Vos seuls frais : ~15 €/an pour le domaine</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CE QUE VOUS ÉCONOMISEZ ─── -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container" style="max-width:820px;">
      <span class="section-label">Les chiffres</span>
      <h2 class="section-title">Ce que vous économisez</h2>
      <p class="section-subtitle">Votre abonnement actuel vous coûte des centaines d'euros par an. Voici ce que vous perdez en restant.</p>

      <div class="mig-table">
        <div class="mig-table-head">
          <span>Plateforme</span>
          <span>Coût / mois</span>
          <span>Coût sur 3 ans</span>
        </div>
        {plateformes.map(p => (
          <div class="mig-table-row">
            <span class="mig-table-name">{p.nom}</span>
            <span>{p.mensuel} €/mois</span>
            <span class="mig-table-total">{p.troisAns} €</span>
          </div>
        ))}
        <div class="mig-table-row mig-table-aurore">
          <span class="mig-table-name">aurore (migration)</span>
          <span>0 €/mois</span>
          <span class="mig-table-total">285 € + 45 € domaine = 330 €</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── OPTIONS À LA CARTE ─── -->
  <section class="section">
    <div class="container" style="max-width:820px;">
      <span class="section-label">Aller plus loin</span>
      <h2 class="section-title">Options disponibles en supplément</h2>
      <p class="section-subtitle">Profitez de la migration pour améliorer votre site.</p>

      <div class="mig-options">
        {options.map(opt => (
          <div class="mig-option">
            <span class="mig-option-label">{opt.label}</span>
            <span class="mig-option-prix">{opt.prix}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── SIMULATEUR CTA ─── -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <div class="cta-section">
        <span class="section-label" style="color:var(--aurora);">Faites le calcul</span>
        <h2>Combien vous coûte votre site aujourd'hui ?</h2>
        <p>Combien avez-vous déjà payé en abonnements pour un site qui ne vous appartient pas ? Faites le calcul en 30 secondes.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:32px;">
          <a href="/simulateur/" class="btn btn-aurora btn-lg">Calculer mon économie →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="section">
    <div class="container" style="max-width:720px;">
      <span class="section-label">Questions fréquentes</span>
      <h2 class="section-title">Tout savoir sur la migration.</h2>
      <div class="faq-list" style="margin-top:36px;">
        {faqMigration.map(item => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">
              {item.q}
              <span class="faq-icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-answer">{item.r}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA FINAL ─── -->
  <section class="section">
    <div class="container">
      <div class="cta-section">
        <span class="section-label" style="color:var(--aurora);">On y va ?</span>
        <h2>Libérez-vous de votre abonnement.</h2>
        <p>Un message suffit. Je vous réponds sous 48h avec un plan de migration clair.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:32px;">
          <a href="/contact/?type=migration" class="btn btn-aurora btn-lg">Demander ma migration →</a>
          <a href="/tarifs/" class="btn btn-outline btn-lg">Voir tous les tarifs</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .mig-hero { padding: 140px 0 80px; text-align: center; }
  .mig-h1 { font-family: var(--font-display); font-size: clamp(32px,5vw,58px); font-weight: 700; letter-spacing: -0.05em; line-height: 1.05; margin: 20px 0 16px; }
  .mig-sub { font-size: clamp(15px,1.3vw,18px); line-height: 1.65; max-width: 560px; margin: 0 auto 32px; color: var(--gray-700); }
  .mig-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  /* Inclus */
  .mig-inclus { display: flex; flex-direction: column; gap: 16px; margin: 36px 0; }
  .mig-inclus-item { display: flex; align-items: center; gap: 14px; font-size: 15px; color: var(--gray-700); }
  .mig-inclus-icon { width: 40px; height: 40px; background: var(--aurora-pale); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--aurora); flex-shrink: 0; }

  .mig-prix-bloc { display: flex; align-items: center; gap: 20px; padding: 24px 28px; background: var(--aurora-pale); border: 1.5px solid rgba(255,107,26,0.2); border-radius: var(--radius-lg); margin-top: 32px; }
  .mig-prix-tag { font-family: var(--font-display); font-size: 36px; font-weight: 800; color: var(--aurora); letter-spacing: -0.03em; }
  .mig-prix-detail { display: flex; flex-direction: column; gap: 2px; }
  .mig-prix-detail span:first-child { font-size: 16px; font-weight: 600; color: var(--black); }
  .mig-prix-note { font-size: 13px; color: var(--gray-500); }

  /* Tableau comparatif */
  .mig-table { margin-top: 36px; border: 1.5px solid var(--gray-100); border-radius: var(--radius-lg); overflow: hidden; }
  .mig-table-head { display: grid; grid-template-columns: 1fr 1fr 1fr; padding: 14px 20px; background: var(--gray-50); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gray-500); }
  .mig-table-row { display: grid; grid-template-columns: 1fr 1fr 1fr; padding: 16px 20px; border-top: 1px solid var(--gray-100); font-size: 14px; color: var(--gray-700); align-items: center; }
  .mig-table-name { font-weight: 600; color: var(--black); }
  .mig-table-total { font-weight: 700; }
  .mig-table-aurore { background: var(--aurora-pale); }
  .mig-table-aurore .mig-table-name { color: var(--aurora); }
  .mig-table-aurore .mig-table-total { color: var(--aurora); }

  /* Options */
  .mig-options { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 36px; }
  .mig-option { display: flex; justify-content: space-between; align-items: center; padding: 18px 24px; background: var(--white); border: 1.5px solid var(--gray-100); border-radius: var(--radius-md); transition: var(--transition); }
  .mig-option:hover { border-color: var(--gray-300); }
  .mig-option-label { font-size: 14px; font-weight: 600; color: var(--black); }
  .mig-option-prix { font-size: 15px; font-weight: 700; color: var(--aurora); }

  @media (max-width: 768px) {
    .mig-hero { padding: 110px 0 56px; }
    .mig-prix-bloc { flex-direction: column; text-align: center; }
    .mig-table-head, .mig-table-row { grid-template-columns: 1fr 1fr; }
    .mig-table-head span:last-child, .mig-table-row span:last-child { display: none; }
    .mig-options { grid-template-columns: 1fr; }
  }
</style>
