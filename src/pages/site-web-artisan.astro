---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de site web pour artisan",
  "serviceType": "Création de site web pour artisan",
  "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://agence-aurore.fr" },
  "areaServed": "France",
  "description": "Site web professionnel pour artisan. Devis en ligne, galerie de réalisations, SEO local. Clé en main, livré en 2 semaines.",
  "offers": [
    { "@type": "Offer", "name": "Pack Starter", "priceCurrency": "EUR", "price": "290" },
    { "@type": "Offer", "name": "Pack Vitrine", "priceCurrency": "EUR", "price": "690" },
    { "@type": "Offer", "name": "Pack Pro",     "priceCurrency": "EUR", "price": "1290" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Un artisan a-t-il vraiment besoin d'un site web ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui. 97% des consommateurs cherchent un artisan en ligne avant de le contacter. Sans site, vous laissez ces clients à vos concurrents. Un site professionnel renforce votre crédibilité et génère des demandes de devis en continu." }},
    { "@type": "Question", "name": "Puis-je afficher mes réalisations en photos ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolument. Une galerie photo de vos réalisations est incluse. Rien ne convainc mieux un client que de voir la qualité de votre travail. Vous pouvez ajouter des photos avant/après, par type de chantier." }},
    { "@type": "Question", "name": "Mes clients pourront-ils me demander un devis en ligne ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, un formulaire de demande de devis est inclus. Vos clients décrivent leur besoin, vous recevez la demande par email et pouvez répondre rapidement. Fini les appels manqués sur le chantier." }},
    { "@type": "Question", "name": "Le site fonctionnera-t-il sur mobile ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, tous les sites sont responsive : ils s'adaptent parfaitement aux smartphones, tablettes et ordinateurs. C'est essentiel car plus de 70% de vos clients vous chercheront depuis leur téléphone." }},
    { "@type": "Question", "name": "Comment aurore m'aide à me différencier des autres artisans sur Google ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Votre site est optimisé pour les recherches locales de votre métier : \"électricien Marseille\", \"menuisier Aix-en-Provence\". La fiche Google Business incluse vous fait apparaître sur Google Maps. Les photos de vos réalisations montrent concrètement la qualité de votre travail avant même le premier contact." }},
    { "@type": "Question", "name": "Puis-je recevoir des demandes de devis même quand je suis sur un chantier ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui. Le formulaire de contact sur votre site reçoit les demandes 24h/24. Vous les retrouvez par email dès que vous avez un moment. Fini les clients perdus parce que vous n'avez pas pu décrocher." }},
  ],
};
---

<BaseLayout
  title="Création de site web pour artisan | aurore, à partir de 290 €"
  description="Site web professionnel pour artisan. Devis en ligne, galerie de réalisations, SEO local. Clé en main, livré en 2 semaines. Basé à Aix-en-Provence, intervention toute la France."
  slug="site-web-artisan"
  schema={[serviceSchema, faqSchema]}
>

  <!-- ─── HERO ─── -->
  <section class="lp-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Spécial artisans et professionnels du bâtiment
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="lp-h1">
        Votre savoir-faire mérite d'être<br />trouvé sur Google.
      </h1>
      <p class="hero-serif-line">Livré en 2 semaines.</p>
      <p class="lp-sub">
        Plombier, électricien, menuisier, peintre : vos clients vous cherchent en ligne. Soyez là avant vos concurrents. À partir de 290&nbsp;€, clé en main.
      </p>
      <div class="hero-ctas">
        <a href="/tarifs/" class="btn btn-primary btn-lg">Voir les tarifs →</a>
        <a href="/contact/?type=artisan" class="btn btn-outline btn-lg">Demander un devis</a>
      </div>
    </div>
  </section>

  <!-- ─── PROBLÈME ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label fade-in">Le problème</span>
      <h2 class="section-title fade-in">Le bouche-à-oreille ne suffit plus.<br />Vos prochains clients sont sur Google.</h2>
      <div class="lp-problems fade-in">
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
          <p>Vos clients cherchent <strong>"artisan [métier] [ville]"</strong> sur Google, et si vous n'apparaissez pas, ils appellent le suivant.</p>
        </div>
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <p>Le bouche-à-oreille ne suffit plus, et <strong>une présence en ligne multiplie vos demandes de devis</strong>.</p>
        </div>
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <p>Créer et maintenir un site prend du temps que vous n'avez pas : <strong>c'est mon travail, pas le vôtre</strong>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CE QU'AURORE CRÉE ─── -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <span class="section-label fade-in">Ce qu'aurore crée pour vous</span>
      <h2 class="section-title fade-in">Un site pensé pour votre métier d'artisan.</h2>
      <div class="lp-features fade-in">
        {[
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`, title: "Galerie de vos réalisations", desc: "Montrez la qualité de votre travail avec des photos avant/après et par type de chantier. Rien ne convainc mieux un client." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`, title: "Formulaire de demande de devis", desc: "Vos clients décrivent leur besoin en ligne, vous recevez la demande par email. Fini les appels manqués sur le chantier." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`, title: "Zones d'intervention affichées", desc: "Carte ou liste des communes et départements que vous couvrez. Vos clients savent immédiatement si vous intervenez chez eux." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`, title: "SEO local \"[métier] [ville]\"", desc: "Optimisation on-page pour apparaître dans les résultats Google quand vos clients cherchent un artisan dans votre zone." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, title: "Fiche Google Business avec avis clients", desc: "Créée et optimisée pour que vous apparaissiez sur Google Maps. Les avis clients renforcent votre crédibilité en ligne." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`, title: "Emails pro @votre-metier.fr", desc: "Adresse email professionnelle incluse, renforcez votre image auprès de vos clients et fournisseurs." },
        ].map(f => (
          <div class="card lp-feature">
            <div class="lp-feature-icon" set:html={f.icon} />
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── ENCART PREMIER CLIENT ─── -->
  <section class="section">
    <div class="container">
      <div class="lp-first-client fade-in">
        <div class="lp-first-client-content">
          <span class="section-label">Réalisations</span>
          <h2 class="section-title">Vous êtes artisan ?<br />Soyez le premier de votre secteur à nous faire confiance.</h2>
          <p class="lp-first-client-text">Nous n'avons pas encore de réalisation artisan à vous montrer, mais votre projet pourrait être le premier. Profitez d'un accompagnement sur-mesure et d'une attention particulière.</p>
          <a href="/contact/?type=artisan" class="btn btn-aurora">Parlons de votre projet →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TARIFS ─── -->
  <section class="section section-aurora-gradient">
    <div class="container">
      <span class="section-label fade-in" style="color:var(--aurora);">Tarifs</span>
      <h2 class="section-title fade-in">Des tarifs clairs, sans surprise.</h2>
      <div class="lp-pricing fade-in">
        <div class="card lp-price-card">
          <div class="lp-price-badge">Starter</div>
          <div class="lp-price">290 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Site 3 pages + design responsive</li>
            <li>Domaine + emails pro</li>
            <li>Fiche Google Business</li>
          </ul>
          <a href="/tarifs/" class="btn btn-outline" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
        <div class="card lp-price-card lp-price-card-highlight">
          <div class="lp-price-badge lp-price-badge-aurora">Vitrine</div>
          <div class="lp-price">690 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Jusqu'à 6 pages + logo</li>
            <li>SEO on-page + Search Console</li>
            <li>Formulaire de contact</li>
          </ul>
          <a href="/tarifs/" class="btn btn-aurora" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
        <div class="card lp-price-card">
          <div class="lp-price-badge">Pro</div>
          <div class="lp-price">1 290 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Jusqu'à 8 pages + blog + RDV en ligne</li>
            <li>Automatisation email</li>
            <li>Espace rédaction autonome</li>
          </ul>
          <a href="/tarifs/" class="btn btn-outline" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="section" id="faq">
    <div class="container" style="max-width:720px;">
      <span class="section-label fade-in">FAQ</span>
      <h2 class="section-title fade-in">Questions fréquentes.</h2>
      <div class="faq-list fade-in">
        {faqSchema.mainEntity.map((item: any) => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">{item.name}<span class="faq-icon" aria-hidden="true">+</span></button>
            <div class="faq-answer">{item.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA FINAL ─── -->
  <section class="section">
    <div class="container">
      <div class="cta-section">
        <h2>Plus de devis. Moins de démarchage.</h2>
        <p>Un formulaire de 2 minutes suffit pour recevoir un devis détaillé sous 48h.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:32px;">
          <a href="/contact/?type=artisan" class="btn btn-aurora btn-lg">Demander mon devis gratuit →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ─── */
  .lp-hero { padding: 140px 0 80px; text-align: center; position: relative; overflow: hidden; }
  .lp-hero > .container { position: relative; z-index: 1; }
  .lp-h1 { font-family: var(--font-display); font-size: clamp(32px, 5vw, 58px); font-weight: 700; letter-spacing: -0.05em; line-height: 1.08; margin: 20px 0 12px; color: var(--black); }
  .hero-serif-line { font-family: var(--font-serif); font-style: italic; font-size: clamp(36px, 5.5vw, 64px); color: var(--aurora); line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 20px; }
  .lp-sub { font-size: clamp(15px, 1.3vw, 18px); line-height: 1.65; max-width: 540px; margin: 0 auto 32px; color: var(--gray-700); }

  /* ─── PROBLÈMES ─── */
  .lp-problems { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
  .lp-problem-card { display: flex; flex-direction: column; gap: 16px; }
  .lp-problem-card p { font-size: 15px; line-height: 1.65; color: var(--gray-700); }
  .lp-problem-icon { width: 44px; height: 44px; background: #FFF0E6; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; }

  /* ─── FEATURES ─── */
  .lp-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 48px; }
  .lp-feature { display: flex; flex-direction: column; gap: 10px; }
  .lp-feature-icon { width: 44px; height: 44px; background: var(--aurora-pale); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--aurora); }
  .lp-feature h3 { font-size: 17px; font-weight: 600; letter-spacing: -0.02em; }
  .lp-feature p { font-size: 14px; line-height: 1.65; color: var(--gray-500); }

  /* ─── PREMIER CLIENT ─── */
  .lp-first-client { background: var(--aurora-pale); border: 1.5px solid rgba(255,107,26,0.2); border-radius: var(--radius-lg); padding: 48px; text-align: center; position: relative; }
  .lp-first-client::before { content: ''; position: absolute; top: 0; left: 24px; right: 24px; height: 2px; background: linear-gradient(90deg, transparent, var(--aurora), transparent); border-radius: 2px; }
  .lp-first-client-text { font-size: 16px; line-height: 1.7; color: var(--gray-700); max-width: 560px; margin: 20px auto 32px; }

  /* ─── PRICING ─── */
  .lp-pricing { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
  .lp-price-card { display: flex; flex-direction: column; gap: 20px; text-align: center; }
  .lp-price-card-highlight { border-color: var(--aurora); position: relative; }
  .lp-price-card-highlight::before { content: ''; position: absolute; top: 0; left: 24px; right: 24px; height: 2px; background: linear-gradient(90deg, transparent, var(--aurora), transparent); border-radius: 2px; }
  .lp-price-badge { font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-500); }
  .lp-price-badge-aurora { color: var(--aurora); }
  .lp-price { font-family: var(--font-display); font-size: 48px; font-weight: 800; letter-spacing: -0.05em; color: var(--black); line-height: 1; }
  .lp-price span { font-size: 0.5em; opacity: 0.6; }
  .lp-price-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .lp-price-list li { font-size: 14px; color: var(--gray-700); line-height: 1.5; padding-left: 20px; position: relative; text-align: left; }
  .lp-price-list li::before { content: ''; position: absolute; left: 0; top: 7px; width: 8px; height: 8px; border-radius: 50%; background: var(--aurora-pale); border: 1.5px solid var(--aurora); }

  /* ─── FAQ ─── */
  .faq-list { margin-top: 40px; }
  .faq-item { border-bottom: 1px solid var(--gray-100); }
  .faq-question { width: 100%; text-align: left; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 0; font-size: 16px; font-weight: 600; color: var(--black); cursor: pointer; background: none; border: none; font-family: var(--font-display); transition: color 0.2s ease; }
  .faq-question:hover { color: var(--aurora); }
  .faq-icon { width: 28px; height: 28px; border-radius: 50%; background: var(--gray-100); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; color: var(--gray-500); transition: all 0.2s ease; }
  .faq-item.open .faq-icon { background: var(--aurora-pale); color: var(--aurora); transform: rotate(45deg); }
  .faq-answer { font-size: 15px; color: var(--gray-700); line-height: 1.7; padding-bottom: 20px; display: none; }
  .faq-item.open .faq-answer { display: block; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 1024px) {
    .lp-problems { grid-template-columns: 1fr; }
    .lp-pricing { grid-template-columns: 1fr; max-width: 400px; margin-left: auto; margin-right: auto; }
  }
  @media (max-width: 768px) {
    .lp-hero { padding: 100px 0 56px; }
    .lp-features { grid-template-columns: 1fr; }
    .lp-first-client { padding: 32px 24px; }
  }
</style>
