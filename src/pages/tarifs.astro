---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de présence digitale clé en main",
  "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://agence-aurore.fr" },
  "areaServed": "France",
  "description": "Création de site web, identité visuelle, SEO et automatisations pour TPE et professionnels. À partir de 290 €, livraison en 2 semaines, hébergement gratuit.",
  "offers": [
    {
      "@type": "Offer",
      "name": "Starter",
      "priceCurrency": "EUR",
      "price": "290",
      "description": "Site 5 pages (3 + 2 incluses), responsive, domaine, emails pro, fiche Google Business, SEO on-page."
    },
    {
      "@type": "Offer",
      "name": "Vitrine",
      "priceCurrency": "EUR",
      "price": "690",
      "description": "Site jusqu'à 8 pages (6 + 2 incluses), SEO complet + Schema.org, formulaire de contact, fiche Google Business optimisée, espace rédaction."
    },
    {
      "@type": "Offer",
      "name": "Pro",
      "priceCurrency": "EUR",
      "price": "1290",
      "description": "Site jusqu'à 12 pages (10 + 2 incluses) + blog, réservation en ligne + Stripe, emails automatisés, SEO avancé + maillage interne."
    },
    {
      "@type": "Offer",
      "name": "Migration",
      "priceCurrency": "EUR",
      "price": "190",
      "description": "Récupération contenu existant, reconstruction en code pur, conservation domaine, SEO de base."
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Pourquoi vos tarifs sont-ils inférieurs à ceux d'une agence classique ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Aurore est une auto-entreprise avec zéro frais généraux : pas de locaux, pas d'équipe commerciale, pas d'intermédiaire. Vous payez uniquement le travail de création. De plus, l'hébergement professionnel inclus supprime les frais d'hébergement habituels."
      }
    },
    {
      "@type": "Question",
      "name": "Que se passe-t-il si j'ai besoin de plus de pages que ce qui est prévu dans mon pack ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Chaque page supplémentaire est facturée 50 à 80 € selon le contenu, quelle que soit la formule choisie. Ce tarif est annoncé dès le départ, sans surprise."
      }
    },
    {
      "@type": "Question",
      "name": "Comment se passe le paiement ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un acompte de 50 % est demandé au démarrage du projet, le solde à la livraison. Pour les projets importants (au-dessus de 1 000 €), un échelonnement en 3 fois peut être envisagé sur demande."
      }
    },
    {
      "@type": "Question",
      "name": "Le Starter est-il vraiment à 290 € tout compris ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, le Starter à 290 € inclut : site 5 pages responsive, domaine, emails pro, SEO on-page de base, fiche Google Business + Search Console, mise en ligne et hébergement inclus. Les options comme le logo, les pages supplémentaires ou les automatisations sont disponibles en supplément à des tarifs fixes."
      }
    },
    {
      "@type": "Question",
      "name": "Quels sont les frais récurrents après livraison ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "L'hébergement professionnel est inclus et gratuit. Le seul coût récurrent est le nom de domaine, environ 15 €/an. Si vous optez pour la maintenance mensuelle, celle-ci est proposée à partir de 19 €/mois et inclut sauvegardes et suivi technique."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je commencer par le Pack Starter et évoluer vers une formule supérieure ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tout à fait. Le Pack Starter est conçu pour démarrer rapidement avec l'essentiel. Vous pouvez ensuite ajouter des pages, un espace rédaction, du SEO ou des automatisations au fil du temps, aux tarifs à la carte affichés sur cette page."
      }
    }
  ]
};

const atLaCarte = [
  { label: "Page supplémentaire",         prix: "50 à 80 €/page" },
  { label: "Formulaire de contact",       prix: "60 €" },
  { label: "Automatisation et connexion API", prix: "À partir de 100 €" },
  { label: "Maintenance technique",      prix: "19 €/mois" },
  { label: "Espace rédaction (Starter et Migration)", prix: "150 €" },
  { label: "Session de modifications",  prix: "30 €" },
  { label: "Pack landing pages (10 pages SEO)", prix: "190 €" },
];
---

<BaseLayout
  title="Tarifs création de site web, Transparents, sans surprise | aurore"
  description="Découvrez les tarifs d'aurore : Starter à 290 €, Vitrine à 690 €, Pro à 1 290 €. SEO et fiche Google inclus dans toutes les formules. Hébergement gratuit, livraison en 2 semaines."
  slug="tarifs"
  schema={[serviceSchema, faqSchema]}
>

  <!-- ─── HERO ─── -->
  <section class="tarifs-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Tarifs · Aurore Aix-en-Provence
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="tarifs-h1">Tarifs transparents,<br /><span class="hero-serif">sans surprise.</span></h1>
      <p class="tarifs-sub">Vous savez exactement ce que vous payez et ce que vous obtenez. Pas de devis qui s'envole, pas de frais cachés, pas d'abonnement mensuel.</p>
      <div class="hero-ctas">
        <a href="#offres" class="btn btn-primary btn-lg">Voir les offres →</a>
        <a href="/contact/" class="btn btn-outline btn-lg">Demander un devis</a>
      </div>
    </div>
  </section>

  <!-- ─── GRILLE TARIFAIRE ─── -->
  <section class="section" id="offres" style="background: var(--gray-50);">
    <div class="container">
      <span class="section-label fade-in">Nos formules</span>
      <h2 class="section-title fade-in">La formule qui correspond<br />à votre projet.</h2>
      <p class="section-subtitle fade-in">Vos clients vous trouvent sur Google avec chaque formule. Zéro abonnement mensuel, en ligne avant la fin du mois.</p>

      <div class="pricing-grid fade-in">
        <!-- STARTER -->
        <div class="pricing-card">
          <div>
            <div class="pricing-name">Starter</div>
            <div class="pricing-price">
              <span class="pricing-currency">€</span>
              <span class="pricing-amount">290</span>
            </div>
            <p class="pricing-desc">Vos clients vous trouvent sur Google et vous contactent directement.</p>
          </div>
          <ul class="pricing-features" aria-label="Inclus dans Starter">
            {[
              "Votre site 5 pages (3 + 2 offertes), visible sur mobile et ordinateur",
              "Votre adresse web + emails professionnels",
              "Vous apparaissez quand on cherche votre métier près de chez vous",
              "Google comprend ce que vous faites et pour qui",
              "Tout est mis en ligne pour vous",
              "Prise en main guidée pour être autonome",
            ].map(f => (
              <li class="pricing-feature">
                <span class="pricing-check" aria-hidden="true">
                  <svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#FF6B1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact/" class="btn btn-outline" style="width:100%; justify-content:center;">Choisir Starter</a>
        </div>

        <!-- VITRINE -->
        <div class="pricing-card pricing-card-featured">
          <span class="pricing-badge">Recommandé</span>
          <div>
            <div class="pricing-name">Vitrine</div>
            <div class="pricing-price">
              <span class="pricing-currency">€</span>
              <span class="pricing-amount">690</span>
            </div>
            <p class="pricing-desc">Vos clients vous trouvent, vous contactent et vous font confiance au premier regard.</p>
          </div>
          <ul class="pricing-features" aria-label="Inclus dans Vitrine">
            {[
              "Votre site jusqu'à 8 pages (6 + 2 offertes)",
              "Google comprend exactement votre activité et la montre à vos futurs clients",
              "Vos prospects vous écrivent directement, sans intermédiaire",
              "Vous apparaissez en tête des résultats locaux",
              "Publiez vos actualités vous-même, sans appeler personne",
              "Prise en main complète pour tout gérer en autonomie",
            ].map(f => (
              <li class="pricing-feature">
                <span class="pricing-check" aria-hidden="true">
                  <svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#FF6B1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact/" class="btn btn-aurora" style="width:100%; justify-content:center;">Choisir Vitrine</a>
        </div>

        <!-- PRO -->
        <div class="pricing-card">
          <div>
            <div class="pricing-name">Pro</div>
            <div class="pricing-price">
              <span class="pricing-currency">€</span>
              <span class="pricing-amount">1 290</span>
            </div>
            <p class="pricing-desc">Vos clients réservent, paient en ligne et reçoivent une confirmation immédiate.</p>
          </div>
          <ul class="pricing-features" aria-label="Inclus dans Pro">
            {[
              "Votre site jusqu'à 12 pages (10 + 2 offertes) + blog",
              "Vos clients réservent et paient en ligne pendant que vous travaillez",
              "Chaque nouveau contact reçoit une réponse immédiate, même le dimanche",
              "Votre visibilité Google renforcée sur toutes vos pages",
              "Tout ce qui est dans Vitrine, inclus",
              "Tout est documenté pour être 100 % autonome",
            ].map(f => (
              <li class="pricing-feature">
                <span class="pricing-check" aria-hidden="true">
                  <svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#FF6B1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact/" class="btn btn-outline" style="width:100%; justify-content:center;">Choisir Pro</a>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── MIGRATION ─── -->
  <section class="section migration-section">
    <div class="container">
      <div class="migration-block fade-in">
        <div class="migration-content">
          <span class="migration-badge">Vous avez déjà un site ?</span>
          <h2 class="migration-title">Arrêtez de payer<br />pour un site qui ne vous appartient pas.</h2>
          <p class="migration-subtitle">Je récupère tout votre contenu et le reconstruis proprement. Vous gardez votre adresse web et vous arrêtez de payer pour toujours.</p>
          <ul class="migration-features">
            <li class="migration-feature">
              <span class="migration-check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              Vos textes et images récupérés intégralement
            </li>
            <li class="migration-feature">
              <span class="migration-check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              Un site rapide et léger, reconstruit proprement
            </li>
            <li class="migration-feature">
              <span class="migration-check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              Vous gardez votre adresse web actuelle
            </li>
            <li class="migration-feature">
              <span class="migration-check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              Visibilité Google préservée + prise en main incluse
            </li>
            <li class="migration-feature">
              <span class="migration-check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              2 pages supplémentaires incluses
            </li>
          </ul>
        </div>
        <div class="migration-cta-col">
          <div class="migration-price">190<span class="migration-price-symbol">€</span></div>
          <p class="migration-price-note">investissement unique</p>
          <a href="/contact/" class="btn btn-aurora" style="width:100%; justify-content:center;">Demander ma migration →</a>
          <a href="/simulateur/" class="migration-link">Calculer mon économie →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── PRESTATIONS À LA CARTE ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label fade-in">Flexibilité</span>
      <h2 class="section-title fade-in">Prestations à la carte.</h2>
      <p class="section-subtitle fade-in">Vous avez déjà un site ? Améliorez un point précis sans tout refaire.</p>

      <div class="carte-grid fade-in" style="margin-top: 40px;">
        {atLaCarte.map(item => (
          <div class="carte-item">
            <span class="carte-label">{item.label}</span>
            <span class="carte-prix">{item.prix}</span>
          </div>
        ))}
        <div class="carte-item carte-item-custom">
          <span class="carte-custom-text">Vous avez un besoin spécifique non listé ? Décrivez-moi votre projet, j'étudie chaque demande et vous réponds sous 48h.</span>
          <a href="/contact/" class="carte-custom-link">Me contacter →</a>
        </div>
      </div>

      <div class="options-note fade-in">
        <p class="options-title">Options disponibles avec chaque pack</p>
        <div class="options-grid">
          <div class="option-item">
            <span class="option-price">+150 €</span>
            <span class="option-label">Création de logo</span>
          </div>
          <div class="option-item">
            <span class="option-price">+100 €</span>
            <span class="option-label">Charte graphique complète</span>
          </div>
          <div class="option-item">
            <span class="option-price">+150 €</span>
            <span class="option-label">Espace rédaction (Starter et Migration)</span>
          </div>
          <div class="option-item">
            <span class="option-price">+30 €</span>
            <span class="option-label">Session de modifications</span>
          </div>
          <div class="option-item">
            <span class="option-price">+190 €</span>
            <span class="option-label">Pack landing pages (10 pages SEO)</span>
          </div>
        </div>
        <p class="options-mention">Ces options s'ajoutent uniquement à un pack Starter, Vitrine, Pro ou Migration.</p>
      </div>

    </div>
  </section>

  <!-- ─── FAQ TARIFS ─── -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container" style="max-width: 720px;">
      <span class="section-label fade-in">Questions fréquentes</span>
      <h2 class="section-title fade-in">Tout savoir sur les tarifs.</h2>

      <div style="margin-top: 40px;" class="fade-in">
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Pourquoi vos tarifs sont-ils inférieurs à ceux d'une agence classique ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            Pas de locaux, pas d'équipe commerciale, pas d'intermédiaire. Vous payez uniquement le travail de création. Et comme votre site ne nécessite aucun abonnement d'hébergement (contrairement aux solutions qui coûtent 20–40 €/mois), vous économisez dès le premier mois.
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Que se passe-t-il si j'ai besoin de plus de pages ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            Chaque page supplémentaire est facturée <strong>50 à 80 €</strong> selon le contenu, quelle que soit la formule choisie. Ce tarif est annoncé dès le départ, sans surprise.
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Comment se passe le paiement ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            Un <strong>acompte de 50 %</strong> est demandé au démarrage du projet, le solde à la livraison. Pour les projets supérieurs à 1 000 €, un échelonnement en 3 fois peut être envisagé sur demande.
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Le Starter est-il vraiment tout compris à 290 € ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            Oui. Pour 290 €, vos clients vous trouvent sur Google, découvrent votre activité et vous contactent. Concrètement : votre site 5 pages, votre adresse web, vos emails pro et votre visibilité Google. Si vous voulez aller plus loin (logo, pages supplémentaires, automatisations), les tarifs sont affichés et fixes.
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Quels sont les frais récurrents après livraison ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            Zéro abonnement mensuel. Votre site tourne 24h/24 sans rien payer. Le seul coût récurrent : le nom de domaine (~15 €/an). La maintenance est optionnelle, à partir de 19 €/mois si vous le souhaitez.
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Puis-je démarrer avec le Pack Starter et évoluer ensuite ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            Tout à fait. Le Pack Starter est conçu pour démarrer vite avec l'essentiel. Vous pouvez ensuite ajouter des pages, un espace rédaction, du SEO ou des automatisations au fil du temps, aux <strong>tarifs à la carte</strong> affichés sur cette page.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA DEVIS ─── -->
  <section class="section">
    <div class="container">
      <div class="cta-section fade-in">
        <h2>Prêt à recevoir vos premiers clients en ligne ?</h2>
        <p>Décrivez votre activité en 2 minutes. Je vous réponds sous 48h avec un plan clair et un devis détaillé.</p>
        <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
          <a href="/contact/" class="btn btn-aurora btn-lg">Demander un devis gratuit →</a>
          <a href="/realisations/" class="btn btn-outline btn-lg">Voir les réalisations</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO TARIFS ─── */
  .tarifs-hero {
    padding: 160px 0 80px;
    text-align: center;
  }

  .tarifs-h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1.05;
    color: var(--black);
    margin: 20px 0 16px;
  }

  .tarifs-sub {
    font-size: clamp(15px, 1.3vw, 18px);
    color: var(--gray-500);
    line-height: 1.65;
    max-width: 520px;
    margin: 0 auto;
  }

  /* ─── PACK STARTER ─── */
  .starter-section {
    padding-top: 0;
  }

  .starter-card {
    background: var(--white);
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-xl);
    padding: 48px;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 56px;
    position: relative;
    overflow: hidden;
  }

  .starter-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--aurora), var(--aurora-mid));
  }

  .starter-title {
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--black);
    margin-bottom: 12px;
  }

  .starter-desc {
    font-size: 16px;
    color: var(--gray-500);
    line-height: 1.65;
    margin-bottom: 28px;
  }

  .starter-features {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 32px;
  }

  .starter-feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    color: var(--gray-700);
  }

  .check-icon {
    width: 22px;
    height: 22px;
    background: var(--aurora-pale);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .options-title {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-500);
    margin-bottom: 12px;
  }

  .options-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .option-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    padding: 6px 0;
    border-bottom: 1px solid var(--gray-100);
    gap: 8px;
  }

  .option-label {
    color: var(--gray-700);
  }

  .option-prix {
    color: var(--black);
    font-weight: 500;
    white-space: nowrap;
  }

  /* Prix starter */
  .starter-prix-block {
    background: var(--gray-50);
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }

  .starter-prix {
    display: flex;
    align-items: baseline;
    gap: 4px;
    justify-content: center;
