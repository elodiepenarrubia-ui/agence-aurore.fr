<script>
  document.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);

    // Hero
    // @ts-ignore
    gsap.timeline({ delay: 0.15 })
      // @ts-ignore
      .from('.hero-eyebrow', { y: 16, opacity: 0, duration: 0.5, ease: 'power2.out' })
      // @ts-ignore
      .from('.tarifs-h1',    { y: 24, opacity: 0, duration: 0.6, ease: 'power2.out' }, '-=0.25')
      // @ts-ignore
      .from('.tarifs-sub',   { y: 16, opacity: 0, duration: 0.5, ease: 'power2.out' }, '-=0.25');

    // Scroll reveals
    // @ts-ignore
    gsap.utils.toArray('.reveal').forEach((el: any) => {
      // @ts-ignore
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: 'top 85%' },
        y: 40, opacity: 0, duration: 0.65, ease: 'power2.out'
      });
    });
  });
</script>
