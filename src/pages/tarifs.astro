<script>
  document.addEventListener('DOMContentLoaded', () => {
    // FAQ accordion accessible
    document.querySelectorAll('.faq-question').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const answer = item?.querySelector('.faq-answer');
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        document.querySelectorAll('.faq-question').forEach((b) => {
          const a = b.closest('.faq-item')?.querySelector('.faq-answer');
          b.setAttribute('aria-expanded', 'false');
          if (a) (a as HTMLElement).hidden = true;
        });

        if (!isOpen && answer) {
          btn.setAttribute('aria-expanded', 'true');
          (answer as HTMLElement).hidden = false;
        }
      });
    });

    // GSAP scroll reveal
    if (typeof gsap !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);

      gsap.timeline({ delay: 0.1 })
        .from('.hero-eyebrow', { y: 16, opacity: 0, duration: 0.5, ease: 'power2.out' })
        .from('.tarifs-h1',    { y: 24, opacity: 0, duration: 0.6, ease: 'power2.out' }, '-=0.25')
        .from('.tarifs-sub',   { y: 16, opacity: 0, duration: 0.5, ease: 'power2.out' }, '-=0.25')
        .from('.hero-metrics', { y: 16, opacity: 0, duration: 0.4, ease: 'power2.out' }, '-=0.2');

      gsap.utils.toArray('.reveal').forEach((el) => {
        gsap.from(el as Element, {
          scrollTrigger: { trigger: el as Element, start: 'top 85%' },
          y: 40, opacity: 0, duration: 0.65, ease: 'power2.out'
        });
      });

      gsap.utils.toArray('.reveal-stagger').forEach((container) => {
        gsap.from(Array.from((container as Element).children), {
          scrollTrigger: { trigger: container as Element, start: 'top 80%' },
          y: 24, opacity: 0, stagger: 0.07, duration: 0.55, ease: 'power2.out'
        });
      });
    }
  });
</script>