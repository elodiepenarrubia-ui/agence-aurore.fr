---
// src/pages/tarifs.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Tarifs création site web Aix-en-Provence"
  description="Tarifs transparents pour la création de site web, identité visuelle et SEO. Sites statiques à partir de 590 €, livrés en 2 semaines. Basé à Aix-en-Provence, intervention toute la France."
  canonical="/tarifs/"
>

  <!-- ─── SCHEMA.ORG ─── -->
  <script slot="schema" type="application/ld+json">{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "name": "Création de site vitrine",
        "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://agence-aurore.fr" },
        "areaServed": "France",
        "description": "Création de site vitrine clé en main pour TPE et indépendants. Logo, domaine, emails pro, SEO et fiche Google inclus.",
        "offers": [
          { "@type": "Offer", "name": "Site Statique Essentiel", "priceCurrency": "EUR", "price": "590" },
          { "@type": "Offer", "name": "Site Vitrine Complet Essentiel", "priceCurrency": "EUR", "price": "1100" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Combien coûte la création d'un site web avec Aurore ?",
            "acceptedAnswer": { "@type": "Answer", "text": "Les tarifs démarrent à 290 € pour le Pack Starter. Les sites statiques commencent à 590 €, les sites vitrines complets à 1 100 €. Tous les tarifs sont affichés publiquement, sans frais cachés." }
          },
          {
            "@type": "Question",
            "name": "Quelle est la différence entre l'offre Essentielle et l'offre Autonome ?",
            "acceptedAnswer": { "@type": "Answer", "text": "L'offre Autonome inclut le Decap CMS (interface d'édition simple pour modifier votre contenu sans coder) et une formation incluse. L'offre Essentielle est idéale si vous préférez déléguer les modifications ou souscrire à la maintenance mensuelle." }
          },
          {
            "@type": "Question",
            "name": "Y a-t-il des frais d'hébergement mensuels ?",
            "acceptedAnswer": { "@type": "Answer", "text": "Non. Tous les sites sont hébergés sur GitHub Pages, un hébergement professionnel et gratuit. Vous ne payez que le nom de domaine (environ 12–15 €/an), inclus la première année dans toutes les offres." }
          },
          {
            "@type": "Question",
            "name": "Quel est le délai de livraison d'un site web ?",
            "acceptedAnswer": { "@type": "Answer", "text": "Le délai moyen est de 2 semaines pour un site statique ou vitrine, à partir de la réception de vos contenus. Les projets avec réservation en ligne sont livrés en 3 à 4 semaines." }
          },
          {
            "@type": "Question",
            "name": "Puis-je modifier mon site moi-même après livraison ?",
            "acceptedAnswer": { "@type": "Answer", "text": "Oui, avec l'option Autonome. Vous bénéficiez du Decap CMS, une interface d'administration simple pour modifier vos textes, ajouter des articles et mettre à jour vos photos sans aucune connaissance technique." }
          },
          {
            "@type": "Question",
            "name": "Est-ce qu'Aurore intervient en dehors d'Aix-en-Provence ?",
            "acceptedAnswer": { "@type": "Answer", "text": "Oui, j'interviens dans toute la France en remote. Tout se passe par appel vidéo et échanges en ligne." }
          }
        ]
      }
    ]
  }</script>

  <!-- ─── HERO ─── -->
  <section class="tarifs-hero">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Tarifs · Aix-en-Provence &amp; toute la France
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="tarifs-h1">
        Tarifs transparents,<br>
        <span class="hero-serif">sans surprise.</span>
      </h1>
      <p class="tarifs-sub">
        Tout est affiché. Pas de devis flou, pas de frais cachés. Vous savez exactement
        ce que vous obtenez — avant même de me contacter.
      </p>
      <div class="hero-metrics" aria-label="Chiffres clés">
        <div class="metric">
          <span class="metric-value">590 €</span>
          <span class="metric-label">à partir de</span>
        </div>
        <div class="metric-sep" aria-hidden="true"></div>
        <div class="metric">
          <span class="metric-value">2 sem.</span>
          <span class="metric-label">délai moyen</span>
        </div>
        <div class="metric-sep" aria-hidden="true"></div>
        <div class="metric">
          <span class="metric-value">0 €</span>
          <span class="metric-label">hébergement / mois</span>
        </div>
        <div class="metric-sep" aria-hidden="true"></div>
        <div class="metric">
          <span class="metric-value">100 %</span>
          <span class="metric-label">clé en main</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── BANDEAU OFFRE DE LANCEMENT ─── -->
  <section class="section" style="padding-top: 0; padding-bottom: 0;">
    <div class="container">
      <div class="lancement-banner reveal">
        <div class="lancement-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Offre de lancement
        </div>
        <div class="lancement-content">
          <div class="lancement-text">
            <strong>Pack Starter — 290 €</strong>
            <span>Site 3 pages · Design responsive · Domaine + emails · Fiche Google Business</span>
          </div>
          <div class="lancement-places">
            <span class="places-count">5 places</span>
            <span class="places-label">disponibles</span>
          </div>
        </div>
        <a href="/contact/" class="btn btn-aurora">Réserver ma place →</a>
      </div>
    </div>
  </section>

  <!-- ─── GRILLE DES OFFRES ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label reveal">Offres</span>
      <h2 class="section-title reveal">Choisissez votre formule.</h2>
      <p class="section-subtitle reveal">Deux niveaux pour chaque type de projet : Essentiel si vous préférez déléguer, Autonome si vous voulez garder la main.</p>

      <!-- SITE STATIQUE -->
      <div class="offre-bloc reveal">
        <div class="offre-header">
          <div class="offre-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          </div>
          <div class="offre-header-text">
            <h2 class="offre-titre">Site Statique</h2>
            <p class="offre-desc">Artisans, micro-entrepreneurs et professions libérales. Jusqu'à 4 pages, présence locale soignée.</p>
          </div>
          <div class="offre-cible">
            <span class="badge">Artisans</span>
            <span class="badge">Thérapeutes</span>
          </div>
        </div>
        <div class="offre-cards">
          <div class="offre-card">
            <span class="offre-niveau">Essentiel</span>
            <div class="offre-prix">
              <span class="prix-valeur">590 €</span>
              <span class="prix-note">tout inclus, une seule fois</span>
            </div>
            <ul class="offre-liste" role="list">
              <li><span class="check" aria-hidden="true">✓</span> Jusqu'à 4 pages</li>
              <li><span class="check" aria-hidden="true">✓</span> Logo + charte graphique</li>
              <li><span class="check" aria-hidden="true">✓</span> Nom de domaine + configuration</li>
              <li><span class="check" aria-hidden="true">✓</span> Emails professionnels (Zoho)</li>
              <li><span class="check" aria-hidden="true">✓</span> SEO on-page</li>
              <li><span class="check" aria-hidden="true">✓</span> Fiche Google Business + Search Console</li>
              <li><span class="check" aria-hidden="true">✓</span> Design responsive mobile</li>
              <li class="offre-note-item"><span class="note-icon" aria-hidden="true">→</span> Modifications : contactez Aurore</li>
            </ul>
            <a href="/contact/" class="btn btn-outline btn-full">Démarrer ce projet</a>
          </div>
          <div class="offre-card offre-card-aurora">
            <div class="offre-niveau-wrap">
              <span class="offre-niveau">Autonome</span>
              <span class="badge badge-aurora">Recommandé</span>
            </div>
            <div class="offre-prix">
              <span class="prix-valeur">790 €</span>
              <span class="prix-note">tout inclus, une seule fois</span>
            </div>
            <ul class="offre-liste" role="list">
              <li><span class="check check-aurora" aria-hidden="true">✓</span> <strong>Tout l'Essentiel</strong></li>
              <li><span class="check check-aurora" aria-hidden="true">✓</span> Decap CMS — éditez votre site seul</li>
              <li><span class="check check-aurora" aria-hidden="true">✓</span> Formation 30 min incluse</li>
              <li class="offre-note-item"><span class="note-icon" aria-hidden="true">→</span> Vous repartez 100 % autonome</li>
            </ul>
            <a href="/contact/" class="btn btn-aurora btn-full">Démarrer ce projet</a>
          </div>
        </div>
      </div>

      <!-- SITE VITRINE COMPLET -->
      <div class="offre-bloc reveal">
        <div class="offre-header">
          <div class="offre-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <div class="offre-header-text">
            <h2 class="offre-titre">Site Vitrine Complet</h2>
            <p class="offre-desc">Commerces, cabinets, restaurants et PME. Blog, formulaire de contact, prise de RDV.</p>
          </div>
          <div class="offre-cible">
            <span class="badge">PME</span>
            <span class="badge">Restaurants</span>
            <span class="badge">Cabinets</span>
          </div>
        </div>
        <div class="offre-cards">
          <div class="offre-card">
            <span class="offre-niveau">Essentiel</span>
            <div class="offre-prix">
              <span class="prix-valeur">1 100 €</span>
              <span class="prix-note">tout inclus, une seule fois</span>
            </div>
            <ul class="offre-liste" role="list">
              <li><span class="check" aria-hidden="true">✓</span> Jusqu'à 8 pages + blog</li>
              <li><span class="check" aria-hidden="true">✓</span> Formulaire contact + notifications</li>
              <li><span class="check" aria-hidden="true">✓</span> Prise de RDV en ligne</li>
              <li><span class="check" aria-hidden="true">✓</span> Automatisation email</li>
              <li><span class="check" aria-hidden="true">✓</span> Logo + charte graphique complète</li>
              <li><span class="check" aria-hidden="true">✓</span> Domaine + emails professionnels</li>
              <li><span class="check" aria-hidden="true">✓</span> SEO avancé</li>
              <li><span class="check" aria-hidden="true">✓</span> Fiche Google Business + Search Console</li>
            </ul>
            <a href="/contact/" class="btn btn-outline btn-full">Démarrer ce projet</a>
          </div>
          <div class="offre-card offre-card-aurora">
            <div class="offre-niveau-wrap">
              <span class="offre-niveau">Autonome</span>
              <span class="badge badge-aurora">Recommandé</span>
            </div>
            <div class="offre-prix">
              <span class="prix-valeur">1 490 €</span>
              <span class="prix-note">tout inclus, une seule fois</span>
            </div>
            <ul class="offre-liste" role="list">
              <li><span class="check check-aurora" aria-hidden="true">✓</span> <strong>Tout l'Essentiel</strong></li>
              <li><span class="check check-aurora" aria-hidden="true">✓</span> Decap CMS — éditez articles et pages</li>
              <li><span class="check check-aurora" aria-hidden="true">✓</span> Formation 1h incluse</li>
              <li class="offre-note-item"><span class="note-icon" aria-hidden="true">→</span> Vous repartez 100 % autonome</li>
            </ul>
            <a href="/contact/" class="btn btn-aurora btn-full">Démarrer ce projet</a>
          </div>
        </div>
      </div>

      <!-- SITE AVEC RÉSERVATION -->
      <div class="offre-bloc reveal">
        <div class="offre-header">
          <div class="offre-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div class="offre-header-text">
            <h2 class="offre-titre">Site avec Réservation</h2>
            <p class="offre-desc">Paiement Stripe, emails transactionnels et agenda en ligne. Pour prestataires et hébergements.</p>
          </div>
          <div class="offre-cible">
            <span class="badge">Hébergements</span>
            <span class="badge">Activités</span>
          </div>
        </div>
        <div class="offre-cards">
          <div class="offre-card">
            <span class="offre-niveau">Essentiel</span>
            <div class="offre-prix">
              <span class="prix-valeur">1 400 €</span>
              <span class="prix-note">tout inclus, une seule fois</span>
            </div>
            <ul class="offre-liste" role="list">
              <li><span class="check" aria-hidden="true">✓</span> Jusqu'à 8 pages</li>
              <li><span class="check" aria-hidden="true">✓</span> Système de réservation en ligne</li>
              <li><span class="check" aria-hidden="true">✓</span> Paiement en ligne (Stripe)</li>
              <li><span class="check" aria-hidden="true">✓</span> Emails transactionnels automatisés</li>
              <li><span class="check" aria-hidden="true">✓</span> Tout l'Essentiel Vitrine inclus</li>
            </ul>
            <a href="/contact/" class="btn btn-outline btn-full">Démarrer ce projet</a>
          </div>
          <div class="offre-card offre-card-aurora">
            <div class="offre-niveau-wrap">
              <span class="offre-niveau">Autonome</span>
              <span class="badge badge-aurora">Recommandé</span>
            </div>
            <div class="offre-prix">
              <span class="prix-valeur">1 800 €</span>
              <span class="prix-note">tout inclus, une seule fois</span>
            </div>
            <ul class="offre-liste" role="list">
              <li><span class="check check-aurora" aria-hidden="true">✓</span> <strong>Tout l'Essentiel</strong></li>
              <li><span class="check check-aurora" aria-hidden="true">✓</span> Decap CMS</li>
              <li><span class="check check-aurora" aria-hidden="true">✓</span> Formation 1h30 incluse</li>
            </ul>
            <a href="/contact/" class="btn btn-aurora btn-full">Démarrer ce projet</a>
          </div>
        </div>
      </div>

      <!-- LOGICIEL MÉTIER -->
      <div class="offre-bloc offre-bloc-devis reveal">
        <div class="offre-header">
          <div class="offre-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <div class="offre-header-text">
            <h2 class="offre-titre">Logiciel Métier</h2>
            <p class="offre-desc">Application sur-mesure pour digitaliser vos processus. Espace client, base de données, authentification, intégrations API.</p>
          </div>
          <div class="offre-cible">
            <span class="badge">Entreprises</span>
            <span class="badge">Sur-mesure</span>
          </div>
        </div>
        <div class="devis-grid">
          <div class="offre-card">
            <h3 class="devis-titre">Cadrage &amp; cahier des charges</h3>
            <span class="prix-valeur">300 €</span>
            <p class="devis-desc">Session de travail pour définir votre besoin, les fonctionnalités et l'architecture technique. <strong>Déduit du devis final si vous signez.</strong></p>
          </div>
          <div class="offre-card offre-card-aurora">
            <h3 class="devis-titre">Développement</h3>
            <span class="prix-valeur">Sur devis</span>
            <p class="devis-desc">Calculé selon la complexité, le nombre de fonctionnalités et les intégrations requises. Généralement à partir de 3 000 €.</p>
            <a href="/contact/" class="btn btn-aurora" style="margin-top: 20px; display: inline-flex;">Demander un devis →</a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── PRESTATIONS À LA CARTE ─── -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <span class="section-label reveal">À la carte</span>
      <h2 class="section-title reveal">Vous avez déjà un site ?</h2>
      <p class="section-subtitle reveal">Ces prestations peuvent être commandées séparément ou s'ajouter à une offre existante.</p>

      <div class="carte-grid reveal-stagger">
        <div class="carte-categorie">
          <h3 class="carte-titre">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            Identité visuelle
          </h3>
          <div class="carte-items">
            <div class="carte-item"><span>Logo seul</span><span class="carte-prix">150 €</span></div>
            <div class="carte-item"><span>Charte graphique</span><span class="carte-prix">100 €</span></div>
            <div class="carte-item"><span>Support marketing <em>(flyer, carte…)</em></span><span class="carte-prix">80 € / support</span></div>
          </div>
        </div>

        <div class="carte-categorie">
          <h3 class="carte-titre">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
            Site web
          </h3>
          <div class="carte-items">
            <div class="carte-item"><span>Page supplémentaire</span><span class="carte-prix">120 € / page</span></div>
            <div class="carte-item"><span>Decap CMS</span><span class="carte-prix">150 €</span></div>
            <div class="carte-item"><span>Formulaire de contact</span><span class="carte-prix">60 €</span></div>
            <div class="carte-item"><span>Automatisation email</span><span class="carte-prix">100 € / auto.</span></div>
            <div class="carte-item"><span>Domaine + configuration</span><span class="carte-prix">60 € + domaine</span></div>
            <div class="carte-item"><span>Emails pro (Zoho)</span><span class="carte-prix">80 €</span></div>
          </div>
        </div>

        <div class="carte-categorie">
          <h3 class="carte-titre">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            SEO &amp; Visibilité
          </h3>
          <div class="carte-items">
            <div class="carte-item"><span>SEO on-page</span><span class="carte-prix">150 €</span></div>
            <div class="carte-item"><span>Fiche Google Business</span><span class="carte-prix">90 €</span></div>
            <div class="carte-item"><span>Google Search Console</span><span class="carte-prix">60 €</span></div>
          </div>
        </div>

        <div class="carte-categorie">
          <h3 class="carte-titre">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Maintenance mensuelle
          </h3>
          <div class="carte-items">
            <div class="carte-item"><span>Technique <em>(sauvegardes, sécurité)</em></span><span class="carte-prix">19 € / mois</span></div>
            <div class="carte-item"><span>Technique + support <em>(30 min/mois)</em></span><span class="carte-prix">29 € / mois</span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── EXEMPLE DE PROJET TYPE ─── -->
  <section class="section">
    <div class="container">
      <div class="exemple-bloc reveal">
        <div class="exemple-text">
          <span class="section-label">Exemple concret</span>
          <h2 class="section-title">Un artisan qui part de zéro.</h2>
          <p class="section-subtitle">Voici ce que représente une présence digitale complète pour un professionnel sans rien au départ.</p>
        </div>
        <div class="exemple-table">
          <div class="exemple-item"><span>Logo + charte</span><span>250 €</span></div>
          <div class="exemple-item"><span>Domaine + emails professionnels</span><span>140 € + domaine</span></div>
          <div class="exemple-item"><span>Site 5 pages + Decap CMS + formulaire</span><span>760 €</span></div>
          <div class="exemple-item"><span>SEO + Google Business + Search Console</span><span>300 €</span></div>
          <div class="exemple-item exemple-total">
            <span><strong>Total</strong></span>
            <span><strong>~1 450 €</strong></span>
          </div>
          <div class="exemple-item exemple-option">
            <span>Maintenance optionnelle</span>
            <span>+ 19 € / mois</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="section" style="background: var(--gray-50);" aria-labelledby="faq-titre">
    <div class="container">
      <span class="section-label reveal">FAQ</span>
      <h2 class="section-title reveal" id="faq-titre">Questions fréquentes.</h2>
      <div class="faq-list reveal">

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Combien coûte la création d'un site web avec Aurore ?
            <span class="faq-arrow" aria-hidden="true">▾</span>
          </button>
          <div class="faq-answer" hidden>
            Les tarifs démarrent à 290 € pour le Pack Starter. Les sites statiques commencent à 590 €, les sites vitrines complets à 1 100 €. Tous les tarifs sont affichés publiquement — aucun frais caché.
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Quelle est la différence entre Essentiel et Autonome ?
