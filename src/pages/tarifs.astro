<script>
  document.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);
    gsap.config({ force3D: true });

    // Hero
    // @ts-ignore
    gsap.timeline({ delay: 0.15 })
      // @ts-ignore
      .fromTo('.hero-eyebrow', { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' })
      // @ts-ignore
      .fromTo('.tarifs-h1',    { y: 24, opacity: 0 }, { y: 0, opacity: 1, duration: 1.0, ease: 'power2.out' }, '-=0.25')
      // @ts-ignore
      .fromTo('.tarifs-sub',   { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' }, '-=0.25')
      // @ts-ignore
      .fromTo('.hero-ctas',    { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out' }, '-=0.2');

    // Scroll reveals
    // @ts-ignore
    gsap.utils.toArray('.reveal').forEach((el: any) => {
      // @ts-ignore
      gsap.fromTo(el, { y: 40, opacity: 0 }, {
        y: 0, opacity: 1,
        scrollTrigger: { trigger: el, start: 'top 85%' },
        duration: 1.1, ease: 'power2.out'
      });
    });
  });
</script>
