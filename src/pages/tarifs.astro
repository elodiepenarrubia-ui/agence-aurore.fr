---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de présence digitale clé en main",
  "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://agence-aurore.fr" },
  "areaServed": "France",
  "description": "Création de site web, identité visuelle, SEO et automatisations pour TPE et professionnels. À partir de 290 €, livraison en 2 semaines, hébergement gratuit.",
  "offers": [
    {
      "@type": "Offer",
      "name": "Starter",
      "priceCurrency": "EUR",
      "price": "290",
      "description": "Site 3 pages responsive, domaine, emails pro, fiche Google Business, SEO on-page, accès formation vidéo."
    },
    {
      "@type": "Offer",
      "name": "Vitrine",
      "priceCurrency": "EUR",
      "price": "690",
      "description": "Site jusqu'à 6 pages, SEO complet + Schema.org, formulaire de contact, fiche Google Business optimisée, espace rédaction, formation vidéo complète."
    },
    {
      "@type": "Offer",
      "name": "Pro",
      "priceCurrency": "EUR",
      "price": "1290",
      "description": "Site jusqu'à 10 pages + blog, réservation en ligne + Stripe, emails automatisés, SEO avancé + maillage interne, toutes formations vidéo."
    },
    {
      "@type": "Offer",
      "name": "Migration",
      "priceCurrency": "EUR",
      "price": "190",
      "description": "Récupération contenu existant, reconstruction en code pur, conservation domaine, SEO de base, accès formation vidéo."
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Pourquoi vos tarifs sont-ils inférieurs à ceux d'une agence classique ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Aurore est une auto-entreprise avec zéro frais généraux : pas de locaux, pas d'équipe commerciale, pas d'intermédiaire. Vous payez uniquement le travail de création. De plus, l'hébergement professionnel inclus supprime les frais d'hébergement habituels."
      }
    },
    {
      "@type": "Question",
      "name": "Que se passe-t-il si j'ai besoin de plus de pages que ce qui est prévu dans mon pack ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Chaque page supplémentaire est facturée 120 € quelle que soit la formule choisie. Ce tarif est fixe et annoncé dès le départ, sans surprise."
      }
    },
    {
      "@type": "Question",
      "name": "Comment se passe le paiement ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un acompte de 50 % est demandé au démarrage du projet, le solde à la livraison. Pour les projets importants (au-dessus de 1 000 €), un échelonnement en 3 fois peut être envisagé sur demande."
      }
    },
    {
      "@type": "Question",
      "name": "Le Starter est-il vraiment à 290 € tout compris ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, le Starter à 290 € inclut : site 3 pages responsive, domaine, emails pro, SEO on-page de base, fiche Google Business + Search Console, mise en ligne et hébergement inclus, et accès à la formation vidéo. Les options comme le logo, les pages supplémentaires ou les automatisations sont disponibles en supplément à des tarifs fixes."
      }
    },
    {
      "@type": "Question",
      "name": "Quels sont les frais récurrents après livraison ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "L'hébergement professionnel est inclus et gratuit. Le seul coût récurrent est le nom de domaine, environ 15 €/an. Si vous optez pour la maintenance mensuelle, celle-ci est proposée à partir de 19 €/mois et inclut sauvegardes et suivi technique."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je commencer par le Pack Starter et évoluer vers une formule supérieure ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tout à fait. Le Pack Starter est conçu pour démarrer rapidement avec l'essentiel. Vous pouvez ensuite ajouter des pages, un espace rédaction, du SEO ou des automatisations au fil du temps, aux tarifs à la carte affichés sur cette page."
      }
    }
  ]
};

const atLaCarte = [
  { label: "Logo",                        prix: "150 €" },
  { label: "Charte graphique",            prix: "100 €" },
  { label: "Page supplémentaire",         prix: "120 €/page" },
  { label: "Formulaire de contact",       prix: "60 €" },
  { label: "Automatisation et connexion API", prix: "À partir de 100 €" },
  { label: "Maintenance technique",      prix: "19 €/mois" },
];
---

<BaseLayout
  title="Tarifs création de site web, Transparents, sans surprise | aurore"
  description="Découvrez les tarifs d'aurore : Starter à 290 €, Vitrine à 690 €, Pro à 1 290 €. SEO et fiche Google inclus dans toutes les formules. Hébergement gratuit, livraison en 2 semaines."
  slug="tarifs"
  schema={[serviceSchema, faqSchema]}
>

  <!-- ─── HERO ─── -->
  <section class="tarifs-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Tarifs · Aurore Aix-en-Provence
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="tarifs-h1">Tarifs transparents,<br /><span class="hero-serif">sans surprise.</span></h1>
      <p class="tarifs-sub">Tout est affiché. Pas de devis qui s'envole, pas de frais cachés. Vous savez exactement ce que vous payez avant de signer.</p>
      <div class="hero-ctas">
        <a href="#offres" class="btn btn-primary btn-lg">Voir les offres →</a>
        <a href="/contact/" class="btn btn-outline btn-lg">Demander un devis</a>
      </div>
    </div>
  </section>

  <!-- ─── GRILLE TARIFAIRE ─── -->
  <section class="section" id="offres" style="background: var(--gray-50);">
    <div class="container">
      <span class="section-label reveal">Nos formules</span>
      <h2 class="section-title reveal">La formule qui correspond<br />à votre projet.</h2>
      <p class="section-subtitle reveal">SEO on-page et fiche Google Business inclus dans toutes les formules. Hébergement gratuit, livraison en 2 semaines.</p>

      <div class="pricing-grid reveal">
        <!-- STARTER -->
        <div class="pricing-card">
          <div>
            <div class="pricing-name">Starter</div>
            <div class="pricing-price">
              <span class="pricing-currency">€</span>
              <span class="pricing-amount">290</span>
            </div>
            <p class="pricing-desc">L'essentiel pour exister en ligne rapidement.</p>
          </div>
          <ul class="pricing-features" aria-label="Inclus dans Starter">
            {[
              "Site 3 pages responsive",
              "Domaine + emails pro",
              "Fiche Google Business + Search Console",
              "SEO on-page de base",
              "Mise en ligne incluse",
              "Accès formation vidéo",
            ].map(f => (
              <li class="pricing-feature">
                <span class="pricing-check" aria-hidden="true">
                  <svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#FF6B1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact/" class="btn btn-outline" style="width:100%; justify-content:center;">Choisir Starter</a>
        </div>

        <!-- VITRINE -->
        <div class="pricing-card pricing-card-featured">
          <span class="pricing-badge">Recommandé</span>
          <div>
            <div class="pricing-name">Vitrine</div>
            <div class="pricing-price">
              <span class="pricing-currency">€</span>
              <span class="pricing-amount">690</span>
            </div>
            <p class="pricing-desc">La solution complète pour une présence professionnelle.</p>
          </div>
          <ul class="pricing-features" aria-label="Inclus dans Vitrine">
            {[
              "Site jusqu'à 6 pages",
              "SEO on-page complet + Schema.org",
              "Formulaire de contact",
              "Fiche Google Business optimisée",
              "Espace rédaction inclus",
              "Accès formation vidéo complète",
            ].map(f => (
              <li class="pricing-feature">
                <span class="pricing-check" aria-hidden="true">
                  <svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#FF6B1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact/" class="btn btn-aurora" style="width:100%; justify-content:center;">Choisir Vitrine</a>
        </div>

        <!-- PRO -->
        <div class="pricing-card">
          <div>
            <div class="pricing-name">Pro</div>
            <div class="pricing-price">
              <span class="pricing-currency">€</span>
              <span class="pricing-amount">1 290</span>
            </div>
            <p class="pricing-desc">Tout Vitrine + réservation, blog et automatisations.</p>
          </div>
          <ul class="pricing-features" aria-label="Inclus dans Pro">
            {[
              "Site jusqu'à 10 pages + blog",
              "Réservation en ligne + Stripe",
              "Emails automatisés",
              "SEO avancé + maillage interne",
              "Tout Vitrine inclus",
              "Accès toutes formations vidéo",
            ].map(f => (
              <li class="pricing-feature">
                <span class="pricing-check" aria-hidden="true">
                  <svg width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#FF6B1A" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact/" class="btn btn-outline" style="width:100%; justify-content:center;">Choisir Pro</a>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── MIGRATION ─── -->
  <section class="section migration-section">
    <div class="container">
      <div class="migration-block reveal">
        <div class="migration-content">
          <span class="migration-badge">Vous avez déjà un site ?</span>
          <h2 class="migration-title">Arrêtez de payer<br />un abonnement.</h2>
          <p class="migration-subtitle">Je récupère votre contenu existant et le reconstruis en code pur. Vous conservez votre domaine et arrêtez de payer pour toujours.</p>
          <ul class="migration-features">
            <li class="migration-feature">
              <span class="migration-check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              Récupération de tout votre contenu existant
            </li>
            <li class="migration-feature">
              <span class="migration-check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              Reconstruction en code pur, rapide et léger
            </li>
            <li class="migration-feature">
              <span class="migration-check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              Conservation de votre domaine actuel
            </li>
            <li class="migration-feature">
              <span class="migration-check" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="var(--aurora-pale)"/><path d="M5.5 9.5l2 2L12.5 7" stroke="var(--aurora)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              SEO de base + accès formation vidéo
            </li>
          </ul>
        </div>
        <div class="migration-cta-col">
          <div class="migration-price">190<span class="migration-price-symbol">€</span></div>
          <p class="migration-price-note">investissement unique</p>
          <a href="/contact/" class="btn btn-aurora" style="width:100%; justify-content:center;">Demander ma migration →</a>
          <a href="/simulateur/" class="migration-link">Calculer mon économie →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── PRESTATIONS À LA CARTE ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label reveal">Flexibilité</span>
      <h2 class="section-title reveal">Prestations à la carte.</h2>
      <p class="section-subtitle reveal">Vous avez déjà un site et souhaitez l'améliorer ? Choisissez uniquement ce dont vous avez besoin.</p>

      <div class="carte-grid reveal" style="margin-top: 40px;">
        {atLaCarte.map(item => (
          <div class="carte-item">
            <span class="carte-label">{item.label}</span>
            <span class="carte-prix">{item.prix}</span>
          </div>
        ))}
        <div class="carte-item carte-item-custom">
          <span class="carte-custom-text">Vous avez un besoin spécifique non listé ? Décrivez-moi votre projet, j'étudie chaque demande et vous réponds sous 48h.</span>
          <a href="/contact/" class="carte-custom-link">Me contacter →</a>
        </div>
      </div>

    </div>
  </section>

  <!-- ─── FAQ TARIFS ─── -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container" style="max-width: 720px;">
      <span class="section-label reveal">Questions fréquentes</span>
      <h2 class="section-title reveal">Tout savoir sur les tarifs.</h2>

      <div style="margin-top: 40px;" class="reveal">
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Pourquoi vos tarifs sont-ils inférieurs à ceux d'une agence classique ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            Aurore est une auto-entreprise avec zéro frais généraux : pas de locaux, pas d'équipe commerciale, pas d'intermédiaire. Vous payez uniquement le travail de création. De plus, l'<strong>hébergement professionnel est inclus</strong>, ce qui supprime les frais d'hébergement habituels (souvent 20–40 €/mois ailleurs).
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Que se passe-t-il si j'ai besoin de plus de pages ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            Chaque page supplémentaire est facturée <strong>120 €</strong> quelle que soit la formule choisie. Ce tarif est fixe et annoncé dès le départ, sans surprise.
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Comment se passe le paiement ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            Un <strong>acompte de 50 %</strong> est demandé au démarrage du projet, le solde à la livraison. Pour les projets supérieurs à 1 000 €, un échelonnement en 3 fois peut être envisagé sur demande.
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Le Starter est-il vraiment tout compris à 290 € ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            Oui. Le Starter à 290 € inclut : site 3 pages responsive, domaine, emails pro, SEO on-page de base, fiche Google Business + Search Console, mise en ligne et hébergement inclus, et accès à la formation vidéo. Les options (logo, pages supplémentaires, automatisations) sont disponibles en supplément à des tarifs affichés.
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Quels sont les frais récurrents après livraison ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            L'hébergement professionnel est <strong>inclus et gratuit</strong>. Le seul coût récurrent est le nom de domaine (~15 €/an). La maintenance mensuelle est optionnelle et proposée à partir de 19 €/mois.
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Puis-je démarrer avec le Pack Starter et évoluer ensuite ?
            <span class="faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-answer">
            Tout à fait. Le Pack Starter est conçu pour démarrer vite avec l'essentiel. Vous pouvez ensuite ajouter des pages, un espace rédaction, du SEO ou des automatisations au fil du temps, aux <strong>tarifs à la carte</strong> affichés sur cette page.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA DEVIS ─── -->
  <section class="section">
    <div class="container">
      <div class="cta-section reveal">
        <h2>Un projet en tête ?</h2>
        <p>Un formulaire de 2 minutes suffit pour recevoir un devis détaillé sous 48h.</p>
        <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
          <a href="/contact/" class="btn btn-aurora btn-lg">Demander un devis gratuit →</a>
          <a href="/realisations/" class="btn btn-outline btn-lg">Voir les réalisations</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO TARIFS ─── */
  .tarifs-hero {
    padding: 160px 0 80px;
    text-align: center;
  }

  .tarifs-h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1.05;
    color: var(--black);
    margin: 20px 0 16px;
  }

  .tarifs-sub {
    font-size: clamp(15px, 1.3vw, 18px);
    color: var(--gray-500);
    line-height: 1.65;
    max-width: 520px;
    margin: 0 auto;
  }

  /* ─── PACK STARTER ─── */
  .starter-section {
    padding-top: 0;
  }

  .starter-card {
    background: var(--white);
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-xl);
    padding: 48px;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 56px;
    position: relative;
    overflow: hidden;
  }

  .starter-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--aurora), var(--aurora-mid));
  }

  .starter-title {
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--black);
    margin-bottom: 12px;
  }

  .starter-desc {
    font-size: 16px;
    color: var(--gray-500);
    line-height: 1.65;
    margin-bottom: 28px;
  }

  .starter-features {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 32px;
  }

  .starter-feature {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    color: var(--gray-700);
  }

  .check-icon {
    width: 22px;
    height: 22px;
    background: var(--aurora-pale);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .options-title {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-500);
    margin-bottom: 12px;
  }

  .options-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .option-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    padding: 6px 0;
    border-bottom: 1px solid var(--gray-100);
    gap: 8px;
  }

  .option-label {
    color: var(--gray-700);
  }

  .option-prix {
    color: var(--black);
    font-weight: 500;
    white-space: nowrap;
  }

  /* Prix starter */
  .starter-prix-block {
    background: var(--gray-50);
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }

  .starter-prix {
    display: flex;
    align-items: baseline;
    gap: 4px;
    justify-content: center;
  }

  .prix-amount {
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1;
    color: var(--black);
  }

  .prix-currency {
    font-size: 32px;
    font-weight: 600;
    color: var(--gray-500);
    align-self: flex-start;
    margin-top: 12px;
  }

  .prix-note {
    text-align: center;
    font-size: 13px;
    color: var(--gray-500);
    margin: 0;
  }

  /* Garanties */
  .starter-garanties {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .garantie-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--gray-700);
  }

  .garantie-icon {
    font-size: 16px;
  }

  /* ─── PACK GROUPE ─── */
  .pack-groupe {
    margin-top: 64px;
  }

  .pack-groupe-header {
    margin-bottom: 24px;
  }

  .pack-groupe-title {
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--black);
    margin-bottom: 6px;
  }

  .pack-groupe-desc {
    font-size: 14px;
    color: var(--gray-500);
    line-height: 1.6;
    max-width: 600px;
    margin: 0;
  }

  /* ─── PRESTATIONS À LA CARTE ─── */
  .carte-grid {
    border: 1.5px solid var(--gray-100);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .carte-item {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 14px 24px;
    font-size: 14px;
    border-bottom: 1px solid var(--gray-100);
    transition: var(--transition);
  }

  .carte-item:last-child {
    border-bottom: none;
  }

  .carte-item:hover {
    background: var(--gray-50);
  }

  .carte-label {
