---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Création de site web pour photographe",
  "serviceType": "Création de site web pour photographe",
  "provider": { "@type": "LocalBusiness", "name": "Aurore", "url": "https://agence-aurore.fr" },
  "areaServed": "France",
  "description": "Site web professionnel pour photographe. Portfolio optimisé, galeries rapides, SEO local. Livré en 2 semaines.",
  "offers": [
    { "@type": "Offer", "name": "Pack Starter", "priceCurrency": "EUR", "price": "290" },
    { "@type": "Offer", "name": "Pack Vitrine", "priceCurrency": "EUR", "price": "690" },
    { "@type": "Offer", "name": "Pack Pro",     "priceCurrency": "EUR", "price": "1290" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Mon site sera-t-il rapide malgré les photos ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, vos images sont optimisées automatiquement pour le web (compression, formats modernes) tout en conservant leur qualité visuelle. Le site reste ultra-rapide." }},
    { "@type": "Question", "name": "Puis-je protéger mes photos contre le vol ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, des mesures de protection sont mises en place : désactivation du clic droit, filigrane optionnel, et images servies dans des formats qui découragent le téléchargement." }},
    { "@type": "Question", "name": "Puis-je ajouter des galeries moi-même ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, avec les packs Vitrine et Pro, un espace rédaction vous permet d'ajouter, modifier ou supprimer des galeries sans aucune connaissance technique." }},
    { "@type": "Question", "name": "Comment me différencier des autres photographes sur Google ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le SEO local est inclus dans toutes les formules : optimisation on-page pour « photographe [votre ville] », fiche Google Business et Google Search Console configurées." }},
    { "@type": "Question", "name": "Comment obtenir des demandes régulières de nouveaux clients ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le SEO local inclus vous positionne sur les recherches \"photographe [votre spécialité] [votre ville]\". Un formulaire de contact sur chaque galerie capte les demandes directement. Votre portfolio est votre meilleur argument commercial - votre site le met en valeur 24h/24." }},
  ],
};
---

<BaseLayout
  title="Création de site web pour photographe | aurore — À partir de 290 €"
  description="Site web professionnel pour photographe de mariage, portrait, corporate ou nature. Portfolio optimisé, galeries ultra-rapides, SEO local inclus. À partir de 290 €."
  slug="site-web-photographe"
  schema={[serviceSchema, faqSchema]}
>

  <!-- ─── HERO ─── -->
  <section class="lp-hero section-aurora-gradient">
    <div class="container">
      <div class="hero-eyebrow">
        <span class="eyebrow-line" aria-hidden="true"></span>
        Spécial photographes
        <span class="eyebrow-line" aria-hidden="true"></span>
      </div>
      <h1 class="lp-h1">
        Votre portfolio en ligne,<br />aussi beau que vos photos.
      </h1>
      <p class="hero-serif-line">Livré en 2 semaines.</p>
      <p class="lp-sub">
        Photographe de mariage, portrait, corporate ou nature — votre site web est votre vitrine principale. Il doit sublimer votre travail et convertir les visiteurs en clients. À partir de 290&nbsp;€.
      </p>
      <div class="hero-ctas">
        <a href="/tarifs/" class="btn btn-primary btn-lg">Voir les tarifs →</a>
        <a href="/contact/?type=photographe" class="btn btn-outline btn-lg">Demander un devis</a>
      </div>
    </div>
  </section>

  <!-- ─── PROBLÈME ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label fade-in">Le problème</span>
      <h2 class="section-title fade-in">Sans site, votre talent reste invisible.<br />Avec le mauvais site, vos photos ne parlent pas.</h2>
      <div class="lp-problems fade-in">
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
          <p>Instagram ne suffit plus — vos clients veulent un site professionnel <strong>avant de vous confier leur mariage ou leur événement</strong>.</p>
        </div>
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <p>Un site lent qui charge mal les photos <strong>fait fuir les visiteurs en moins de 3 secondes</strong>.</p>
        </div>
        <div class="card lp-problem-card">
          <div class="lp-problem-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#D94F00" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <p>Sans SEO, vous êtes invisible pour les clients qui cherchent <strong>un photographe dans votre ville</strong>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CE QU'AURORE CRÉE ─── -->
  <section class="section" style="background:var(--gray-50);">
    <div class="container">
      <span class="section-label fade-in">Ce qu'aurore crée pour vous</span>
      <h2 class="section-title fade-in">Un site qui sublime votre travail.</h2>
      <div class="lp-features fade-in">
        {[
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`, title: "Galerie photos optimisée ultra-rapide", desc: "Vos images chargent instantanément grâce à l'optimisation automatique, sans perte de qualité visible." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>`, title: "Portfolio organisé par catégories", desc: "Mariage, portrait, corporate, nature — vos visiteurs trouvent immédiatement ce qu'ils cherchent." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`, title: "Formulaire de demande de devis", desc: "Vos prospects vous contactent directement depuis votre site avec les détails de leur projet." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`, title: "SEO local « photographe [votre ville] »", desc: "Optimisation on-page pour apparaître dans les résultats Google quand vos clients cherchent un photographe." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`, title: "Fiche Google Business", desc: "Créée et configurée pour apparaître sur Google Maps avec vos spécialités, avis et exemples de travaux." },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, title: "Protection de vos images", desc: "Désactivation du clic droit, filigrane optionnel et formats optimisés pour décourager le téléchargement." },
        ].map(f => (
          <div class="card lp-feature">
            <div class="lp-feature-icon" set:html={f.icon} />
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── TÉMOIGNAGES ─── -->
  <section class="section">
    <div class="container">
      <span class="section-label fade-in">Ils nous font confiance</span>
      <h2 class="section-title fade-in">Des professionnels satisfaits partout en France.</h2>
      <div class="lp-testimonials fade-in">
        <div class="card lp-testimonial-card">
          <blockquote>
            <p>« Mon portfolio en ligne est exactement ce que j'imaginais. Les photos chargent vite et le design est épuré. Mes clients adorent. »</p>
            <footer><cite>Photographe client</cite>, Provence</footer>
          </blockquote>
        </div>
        <div class="card lp-testimonial-card">
          <blockquote>
            <p>« Rapide, professionnel, et un résultat qui dépasse mes attentes. Je recommande les yeux fermés. »</p>
            <footer><cite>Client aurore</cite>, France</footer>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── TARIFS ─── -->
  <section class="section section-aurora-gradient">
    <div class="container">
      <span class="section-label fade-in" style="color:var(--aurora);">Tarifs</span>
      <h2 class="section-title fade-in">Des tarifs clairs, sans surprise.</h2>
      <div class="lp-pricing fade-in">
        <div class="card lp-price-card">
          <div class="lp-price-badge">Starter</div>
          <div class="lp-price">290 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Site 3 pages + design responsive</li>
            <li>Domaine + emails pro</li>
            <li>Fiche Google Business</li>
          </ul>
          <a href="/tarifs/" class="btn btn-outline" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
        <div class="card lp-price-card lp-price-card-highlight">
          <div class="lp-price-badge lp-price-badge-aurora">Vitrine</div>
          <div class="lp-price">690 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Jusqu'à 6 pages + logo</li>
            <li>SEO on-page + Search Console</li>
            <li>Formulaire de contact</li>
          </ul>
          <a href="/tarifs/" class="btn btn-aurora" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
        <div class="card lp-price-card">
          <div class="lp-price-badge">Pro</div>
          <div class="lp-price">1 290 <span>€</span></div>
          <ul class="lp-price-list">
            <li>Jusqu'à 8 pages + blog + galeries</li>
            <li>Automatisation email</li>
            <li>Espace rédaction autonome</li>
          </ul>
          <a href="/tarifs/" class="btn btn-outline" style="width:100%;justify-content:center;">Choisir →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ─── -->
  <section class="section" id="faq">
    <div class="container" style="max-width:720px;">
      <span class="section-label fade-in">FAQ</span>
      <h2 class="section-title fade-in">Questions fréquentes.</h2>
      <div class="faq-list fade-in">
        {faqSchema.mainEntity.map((item: any) => (
          <div class="faq-item">
            <button class="faq-question" aria-expanded="false">{item.name}<span class="faq-icon" aria-hidden="true">+</span></button>
            <div class="faq-answer">{item.acceptedAnswer.text}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA FINAL ─── -->
  <section class="section">
    <div class="container">
      <div class="cta-section">
        <h2>Votre portfolio mérite un site à sa hauteur.</h2>
        <p>Un formulaire de 2 minutes suffit pour recevoir un devis détaillé sous 48h.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:32px;">
          <a href="/contact/?type=photographe" class="btn btn-aurora btn-lg">Demander mon devis gratuit →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .lp-hero { padding: 140px 0 80px; text-align: center; position: relative; overflow: hidden; }
  .lp-hero > .container { position: relative; z-index: 1; }
  .lp-h1 { font-family: var(--font-display); font-size: clamp(32px, 5vw, 58px); font-weight: 700; letter-spacing: -0.05em; line-height: 1.08; margin: 20px 0 12px; color: var(--black); }
  .hero-serif-line { font-family: var(--font-serif); font-style: italic; font-size: clamp(36px, 5.5vw, 64px); color: var(--aurora); line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 20px; }
  .lp-sub { font-size: clamp(15px, 1.3vw, 18px); line-height: 1.65; max-width: 540px; margin: 0 auto 32px; color: var(--gray-700); }
  .lp-problems { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
  .lp-problem-card { display: flex; flex-direction: column; gap: 16px; }
  .lp-problem-card p { font-size: 15px; line-height: 1.65; color: var(--gray-700); }
  .lp-problem-icon { width: 44px; height: 44px; background: #FFF0E6; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; }
  .lp-features { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 48px; }
  .lp-feature { display: flex; flex-direction: column; gap: 10px; }
  .lp-feature-icon { width: 44px; height: 44px; background: var(--aurora-pale); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: var(--aurora); }
  .lp-feature h3 { font-size: 17px; font-weight: 600; letter-spacing: -0.02em; }
  .lp-feature p { font-size: 14px; line-height: 1.65; color: var(--gray-500); }
  .lp-testimonials { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 48px; }
  .lp-testimonial-card blockquote p { font-size: 16px; line-height: 1.7; color: var(--gray-700); font-style: italic; margin-bottom: 16px; }
  .lp-testimonial-card blockquote footer { font-size: 14px; color: var(--gray-500); }
  .lp-testimonial-card blockquote cite { font-style: normal; font-weight: 600; color: var(--black); }
  .lp-pricing { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
  .lp-price-card { display: flex; flex-direction: column; gap: 20px; text-align: center; }
  .lp-price-card-highlight { border-color: var(--aurora); position: relative; }
  .lp-price-card-highlight::before { content: ''; position: absolute; top: 0; left: 24px; right: 24px; height: 2px; background: linear-gradient(90deg, transparent, var(--aurora), transparent); border-radius: 2px; }
  .lp-price-badge { font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-500); }
  .lp-price-badge-aurora { color: var(--aurora); }
  .lp-price { font-family: var(--font-display); font-size: 48px; font-weight: 800; letter-spacing: -0.05em; color: var(--black); line-height: 1; }
  .lp-price span { font-size: 0.5em; opacity: 0.6; }
  .lp-price-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .lp-price-list li { font-size: 14px; color: var(--gray-700); line-height: 1.5; padding-left: 20px; position: relative; text-align: left; }
  .lp-price-list li::before { content: ''; position: absolute; left: 0; top: 7px; width: 8px; height: 8px; border-radius: 50%; background: var(--aurora-pale); border: 1.5px solid var(--aurora); }
  .faq-list { margin-top: 40px; }
  .faq-item { border-bottom: 1px solid var(--gray-100); }
  .faq-question { width: 100%; text-align: left; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 20px 0; font-size: 16px; font-weight: 600; color: var(--black); cursor: pointer; background: none; border: none; font-family: var(--font-display); transition: color 0.2s ease; }
  .faq-question:hover { color: var(--aurora); }
  .faq-icon { width: 28px; height: 28px; border-radius: 50%; background: var(--gray-100); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; color: var(--gray-500); transition: all 0.2s ease; }
  .faq-item.open .faq-icon { background: var(--aurora-pale); color: var(--aurora); transform: rotate(45deg); }
  .faq-answer { font-size: 15px; color: var(--gray-700); line-height: 1.7; padding-bottom: 20px; display: none; }
  .faq-item.open .faq-answer { display: block; }
  @media (max-width: 1024px) {
    .lp-problems { grid-template-columns: 1fr; }
    .lp-pricing { grid-template-columns: 1fr; max-width: 400px; margin-left: auto; margin-right: auto; }
  }
  @media (max-width: 768px) {
    .lp-hero { padding: 100px 0 56px; }
    .lp-features { grid-template-columns: 1fr; }
    .lp-testimonials { grid-template-columns: 1fr; }
  }
</style>
