---
// ─── BaseLayout.astro  -  Layout de base avec head SEO complet
// agence-aurore.fr

export interface Props {
  // SEO
  title: string;
  description: string;
  slug?: string;          // ex: "tarifs" → canonical = https://agence-aurore.fr/tarifs/
  ogImage?: string;

  // Schema.org JSON-LD (sérialisé en string)
  schema?: object | object[];

  // Options de page
  noindex?: boolean;
  bodyClass?: string;
}

import '../styles/global.css';
import '../styles/components.css';
import '../styles/animations.css';

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const {
  title,
  description,
  slug = '',
  ogImage = '/assets/images/og-image.jpg',
  schema,
  noindex = false,
  bodyClass = '',
} = Astro.props;

const siteUrl    = 'https://agence-aurore.fr';
const canonicalUrl = slug
  ? `${siteUrl}/${slug}/`
  : `${siteUrl}/`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// Sérialisation du schema JSON-LD
const schemaJson = schema
  ? (Array.isArray(schema) ? schema : [schema])
  : null;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ─── SEO DE BASE ─── -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />

    <!-- ─── OPEN GRAPH ─── -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageUrl} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="fr_FR" />
    <meta property="og:site_name"   content="aurore" />

    <!-- ─── TWITTER CARD ─── -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageUrl} />

    <!-- ─── FAVICON ─── -->
    <link rel="icon" type="image/png" href="/favicon.png?v=3" />
    <link rel="shortcut icon" href="/favicon.png?v=3" />

    <!-- ─── FONTS ─── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- ─── GSAP ─── -->
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
      defer
    ></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
      defer
    ></script>

    <!-- ─── SCHEMA.ORG JSON-LD ─── -->
    {schemaJson && schemaJson.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- ─── SLOT HEAD (pour métadonnées supplémentaires par page) ─── -->
    <slot name="head" />
  </head>

  <body class={bodyClass}>

    <!-- ─── NAVIGATION ─── -->
    <Nav />

    <!-- ─── MENU MOBILE PLEIN ÉCRAN ─── -->
    <div id="mobile-menu" aria-hidden="true">
      <div class="mm-header">
        <span class="mm-logo">aur<span>o</span>re</span>
        <button id="burger-close" aria-label="Fermer le menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1A1A1A" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <div class="mm-bar"></div>
      <nav class="mm-nav">
        <a href="/" class="mm-link" data-num="01">Accueil</a>
        <a href="/creation-site-web/" class="mm-link" data-num="02">Création de site web</a>
        <a href="/identite-visuelle/" class="mm-link" data-num="03">Identité visuelle</a>
        <a href="/referencement-seo/" class="mm-link" data-num="04">Référencement SEO</a>
        <a href="/automatisation/" class="mm-link" data-num="05">Automatisation</a>
        <a href="/realisations/" class="mm-link" data-num="06">Réalisations</a>
        <a href="/tarifs/" class="mm-link" data-num="07">Tarifs</a>
        <a href="/blog/" class="mm-link" data-num="08">Blog</a>
      </nav>
      <div class="mm-footer">
        <a href="/contact/" class="btn btn-aurora mm-cta">Démarrer mon projet →</a>
      </div>
    </div>
    <div id="mobile-overlay"></div>

    <!-- ─── CONTENU DE LA PAGE ─── -->
    <main>
      <slot />
    </main>

    <!-- ─── FOOTER ─── -->
    <Footer />

    <!-- ─── SCRIPTS ─── -->
    <script is:inline>
      // ─── js-loaded : active les états initiaux GSAP (.reveal, .reveal-stagger) ───
      document.documentElement.classList.add('js-loaded');
      document.body.classList.add('js-loaded');

      // ─── Barre de progression scroll ───
      var progressBar = document.createElement('div');
      progressBar.id = 'scroll-progress';
      progressBar.style.cssText = 'position:fixed;top:0;left:0;height:3px;background:#FF6B1A;z-index:9999;width:0%;transition:width 0.1s linear;pointer-events:none;';
      document.body.appendChild(progressBar);
      window.addEventListener('scroll', function() {
        var scrollTop = window.scrollY;
        var docHeight = document.documentElement.scrollHeight - window.innerHeight;
        var progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = progress + '%';
      }, { passive: true });

      // ─── Fade-in minimal via IntersectionObserver ───
      var fadeObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            fadeObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.fade-in').forEach(function(el) { fadeObserver.observe(el); });

      // ─── Compteurs animés globaux ([data-counter]) ───
      function animateCounter(el) {
        var target = parseInt(el.dataset.target || el.textContent.replace(/\D/g, ''));
        if (!target || target === 0) return;

        // Préserver le <span> suffixe s'il existe (ex: <span>€</span>)
        var suffixSpan = el.querySelector('span');
        var suffixHTML = suffixSpan ? suffixSpan.outerHTML : '';
        var plainSuffix = suffixSpan ? '' : el.textContent.replace(/[\d]/g, '').trim();

        var duration = 1800;
        var start = performance.now();

        function update(now) {
          var elapsed = now - start;
          var progress = Math.min(elapsed / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          var val = Math.floor(eased * target);
          if (suffixHTML) {
            el.innerHTML = val + suffixHTML;
          } else {
            el.textContent = val + plainSuffix;
          }
          if (progress < 1) requestAnimationFrame(update);
          else {
            if (suffixHTML) {
              el.innerHTML = target + suffixHTML;
            } else {
              el.textContent = target + plainSuffix;
            }
          }
        }
        requestAnimationFrame(update);
      }

      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        var counterObserver = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              animateCounter(entry.target);
              counterObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.3 });
        document.querySelectorAll('[data-counter]').forEach(function(el) { counterObserver.observe(el); });
      }

      // ─── Navigation : scroll behavior ───
      const nav = document.getElementById('main-nav');
      if (nav) {
        window.addEventListener('scroll', () => {
          nav.classList.toggle('scrolled', window.scrollY > 60);
        }, { passive: true });
      }

      // ─── Menu mobile plein écran ───
      (function() {
        const burgerBtn = document.getElementById('burger-btn');
        const burgerClose = document.getElementById('burger-close');
        const mobileMenu = document.getElementById('mobile-menu');
        const overlay = document.getElementById('mobile-overlay');
        const links = document.querySelectorAll('.mm-link');

        function openMenu() {
          mobileMenu.classList.add('open');
          overlay.classList.add('open');
          mobileMenu.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';

          // Animation cascade des liens (stagger 50ms)
          links.forEach((link, i) => {
            setTimeout(() => {
              link.classList.add('visible');
            }, i * 50);
          });
        }

        function closeMenu() {
          mobileMenu.classList.remove('open');
          overlay.classList.remove('open');
          mobileMenu.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';

          // Reset animations
          links.forEach(link => link.classList.remove('visible'));
        }

        burgerBtn?.addEventListener('click', openMenu);
        burgerClose?.addEventListener('click', closeMenu);
        overlay?.addEventListener('click', closeMenu);

        // Fermer au clic sur un lien
        links.forEach(link => {
          link.addEventListener('click', closeMenu);
        });

        // Fermer avec Escape
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeMenu();
        });
      })();

      // ─── Dropdown Services (Nav) ───
      document.querySelectorAll('.nav-dropdown-parent').forEach(parent => {
        const trigger = parent.querySelector('.nav-dropdown-trigger');
        if (!trigger) return;

        trigger.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = parent.classList.toggle('open');
          trigger.setAttribute('aria-expanded', String(isOpen));
        });

        // Fermer au hover-out sur desktop
        parent.addEventListener('mouseleave', () => {
          if (window.innerWidth > 768) {
            parent.classList.remove('open');
            trigger.setAttribute('aria-expanded', 'false');
          }
        });
      });

      // Fermer les dropdowns au clic ailleurs
      document.addEventListener('click', () => {
        document.querySelectorAll('.nav-dropdown-parent.open').forEach(p => {
          p.classList.remove('open');
          const t = p.querySelector('.nav-dropdown-trigger');
          if (t) t.setAttribute('aria-expanded', 'false');
        });
      });

      // ─── FAQ accordion ───
      document.querySelectorAll('.faq-question').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.faq-item');
          if (!item) return;
          const isOpen = item.classList.contains('open');

          // Fermer tous les autres
          document.querySelectorAll('.faq-item.open').forEach(el => {
            el.classList.remove('open');
          });

          if (!isOpen) {
            item.classList.add('open');
          }
        });
      });
    </script>

    <!-- ─── SLOT SCRIPTS (pour scripts spécifiques à la page) ─── -->
    <slot name="scripts" />

  </body>
</html>
