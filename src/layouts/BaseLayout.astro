---
// ─── BaseLayout.astro — Layout de base avec head SEO complet
// agence-aurore.fr

export interface Props {
  // SEO
  title: string;
  description: string;
  slug?: string;          // ex: "tarifs" → canonical = https://agence-aurore.fr/tarifs/
  ogImage?: string;

  // Schema.org JSON-LD (sérialisé en string)
  schema?: object | object[];

  // Options de page
  noindex?: boolean;
  bodyClass?: string;
}

import '../styles/global.css';
import '../styles/components.css';
import '../styles/animations.css';

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const {
  title,
  description,
  slug = '',
  ogImage = '/assets/images/og-image.jpg',
  schema,
  noindex = false,
  bodyClass = '',
} = Astro.props;

const siteUrl    = 'https://agence-aurore.fr';
const canonicalUrl = slug
  ? `${siteUrl}/${slug}/`
  : `${siteUrl}/`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// Sérialisation du schema JSON-LD
const schemaJson = schema
  ? (Array.isArray(schema) ? schema : [schema])
  : null;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ─── SEO DE BASE ─── -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />

    <!-- ─── OPEN GRAPH ─── -->
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageUrl} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="fr_FR" />
    <meta property="og:site_name"   content="aurore" />

    <!-- ─── TWITTER CARD ─── -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageUrl} />

    <!-- ─── FAVICON ─── -->
    <link rel="icon" type="image/png" href="/favicon.png?v=3" />
    <link rel="shortcut icon" href="/favicon.png?v=3" />

    <!-- ─── FONTS ─── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- ─── GSAP ─── -->
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
      defer
    ></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
      defer
    ></script>

    <!-- ─── SCHEMA.ORG JSON-LD ─── -->
    {schemaJson && schemaJson.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- ─── SLOT HEAD (pour métadonnées supplémentaires par page) ─── -->
    <slot name="head" />
  </head>

  <body class={bodyClass}>

    <!-- ─── NAVIGATION ─── -->
    <Nav />

    <!-- ─── CONTENU DE LA PAGE ─── -->
    <main>
      <slot />
    </main>

    <!-- ─── FOOTER ─── -->
    <Footer />

    <!-- ─── SCRIPTS ─── -->
    <script is:inline>
      // ─── js-loaded : active les états initiaux GSAP (.reveal, .reveal-stagger) ───
      document.documentElement.classList.add('js-loaded');
      document.body.classList.add('js-loaded');

      // ─── Barre de progression scroll ───
      var progressBar = document.createElement('div');
      progressBar.id = 'scroll-progress';
      progressBar.style.cssText = 'position:fixed;top:0;left:0;height:3px;background:#FF6B1A;z-index:9999;width:0%;transition:width 0.1s linear;pointer-events:none;';
      document.body.appendChild(progressBar);
      window.addEventListener('scroll', function() {
        var scrollTop = window.scrollY;
        var docHeight = document.documentElement.scrollHeight - window.innerHeight;
        var progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = progress + '%';
      }, { passive: true });

      // ─── Fade-in minimal via IntersectionObserver ───
      var fadeObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            fadeObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.fade-in').forEach(function(el) { fadeObserver.observe(el); });

      // ─── Compteurs animés globaux ([data-counter]) ───
      function animateCounter(el) {
        var target = parseInt(el.dataset.target || el.textContent.replace(/\D/g, ''));
        if (!target || target === 0) return;

        // Préserver le <span> suffixe s'il existe (ex: <span>€</span>)
        var suffixSpan = el.querySelector('span');
        var suffixHTML = suffixSpan ? suffixSpan.outerHTML : '';
        var plainSuffix = suffixSpan ? '' : el.textContent.replace(/[\d]/g, '').trim();

        var duration = 1800;
        var start = performance.now();

        function update(now) {
          var elapsed = now - start;
          var progress = Math.min(elapsed / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          var val = Math.floor(eased * target);
          if (suffixHTML) {
            el.innerHTML = val + suffixHTML;
          } else {
            el.textContent = val + plainSuffix;
          }
          if (progress < 1) requestAnimationFrame(update);
          else {
            if (suffixHTML) {
              el.innerHTML = target + suffixHTML;
            } else {
              el.textContent = target + plainSuffix;
            }
          }
        }
        requestAnimationFrame(update);
      }

      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        var counterObserver = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              animateCounter(entry.target);
              counterObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.3 });
        document.querySelectorAll('[data-counter]').forEach(function(el) { counterObserver.observe(el); });
      }

      // ─── Navigation : scroll behavior ───
      const nav = document.getElementById('main-nav');
      if (nav) {
        window.addEventListener('scroll', () => {
          nav.classList.toggle('scrolled', window.scrollY > 60);
        }, { passive: true });
      }

      // ─── Burger menu mobile ───
      const burger = document.getElementById('nav-burger');
      const navLinks = document.getElementById('nav-links');

      if (burger && navLinks) {
        // Sur mobile, déplacer nav-links dans le body pour échapper au stacking context du nav (backdrop-filter)
        function setupMobileMenu() {
          if (window.innerWidth <= 768) {
            if (navLinks.parentElement !== document.body) {
              document.body.appendChild(navLinks);
            }
          }
        }

        setupMobileMenu();
        window.addEventListener('resize', setupMobileMenu);

        function closeMenu() {
          navLinks.classList.remove('open');
          burger.setAttribute('aria-expanded', 'false');
          burger.setAttribute('aria-label', 'Ouvrir le menu');
          document.documentElement.style.overflow = '';
        }

        burger.addEventListener('click', () => {
          const isOpen = navLinks.classList.toggle('open');
          burger.setAttribute('aria-expanded', String(isOpen));
          burger.setAttribute('aria-label', isOpen ? 'Fermer le menu' : 'Ouvrir le menu');
          document.documentElement.style.overflow = isOpen ? 'hidden' : '';
        });

        // Fermer le menu au clic sur un lien (attaché une seule fois)
        navLinks.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', closeMenu);
        });

        // Fermer avec Escape (attaché une seule fois)
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && navLinks.classList.contains('open')) {
            closeMenu();
            burger.focus();
          }
        });
      }

      // ─── Dropdown Services (Nav) ───
      document.querySelectorAll('.nav-dropdown-parent').forEach(parent => {
        const trigger = parent.querySelector('.nav-dropdown-trigger');
        if (!trigger) return;

        trigger.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = parent.classList.toggle('open');
          trigger.setAttribute('aria-expanded', String(isOpen));
        });

        // Fermer au hover-out sur desktop
        parent.addEventListener('mouseleave', () => {
          if (window.innerWidth > 768) {
            parent.classList.remove('open');
            trigger.setAttribute('aria-expanded', 'false');
          }
        });
      });

      // Fermer les dropdowns au clic ailleurs
      document.addEventListener('click', () => {
        document.querySelectorAll('.nav-dropdown-parent.open').forEach(p => {
          p.classList.remove('open');
          const t = p.querySelector('.nav-dropdown-trigger');
          if (t) t.setAttribute('aria-expanded', 'false');
        });
      });

      // ─── FAQ accordion ───
      document.querySelectorAll('.faq-question').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.faq-item');
          if (!item) return;
          const isOpen = item.classList.contains('open');

          // Fermer tous les autres
          document.querySelectorAll('.faq-item.open').forEach(el => {
            el.classList.remove('open');
          });

          if (!isOpen) {
            item.classList.add('open');
          }
        });
      });
    </script>

    <!-- ─── SLOT SCRIPTS (pour scripts spécifiques à la page) ─── -->
    <slot name="scripts" />

    <!-- ─── CHATBOT AURORE ─── -->
    <div id="chat-bubble" aria-label="Ouvrir le chat">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
        <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
      </svg>
      <span id="chat-notif">1</span>
    </div>

    <div id="chat-window" role="dialog" aria-label="Chat Aurore">
      <div id="chat-header">
        <div id="chat-header-info">
          <div id="chat-avatar">É</div>
          <div>
            <div id="chat-name">Élodie - Aurore</div>
            <div id="chat-status">En ligne</div>
          </div>
        </div>
        <button id="chat-close" aria-label="Fermer">✕</button>
      </div>

      <div id="chat-messages"></div>

      <div id="chat-options"></div>

      <div id="chat-input-zone">
        <input type="text" id="chat-input" placeholder="Votre message..." />
        <button id="chat-send">→</button>
      </div>
    </div>

    <style>
      /* ─── CHATBOT : Bulle ─── */
      #chat-bubble {
        position: fixed;
        bottom: 24px;
        right: 24px;
        width: 56px;
        height: 56px;
        background: #FF6B1A;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 9000;
        box-shadow: 0 4px 16px rgba(255,107,26,0.4);
        transition: transform 0.2s ease;
      }
      #chat-bubble:hover { transform: scale(1.08); }

      #chat-notif {
        position: absolute;
        top: -4px;
        right: -4px;
        width: 20px;
        height: 20px;
        background: #DC2626;
        color: white;
        border-radius: 50%;
        font-size: 11px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* ─── CHATBOT : Fenêtre ─── */
      #chat-window {
        position: fixed;
        bottom: 90px;
        right: 24px;
        width: 340px;
        max-height: 500px;
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.15);
        display: none;
        flex-direction: column;
        z-index: 9001;
        overflow: hidden;
        font-family: Arial, sans-serif;
      }
      #chat-window.open { display: flex; }

      /* ─── CHATBOT : Header ─── */
      #chat-header {
        background: #FF6B1A;
        padding: 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      #chat-header-info { display: flex; align-items: center; gap: 10px; }
      #chat-avatar {
        width: 36px;
        height: 36px;
        background: rgba(255,255,255,0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 16px;
      }
      #chat-name { color: white; font-weight: 700; font-size: 14px; }
      #chat-status { color: rgba(255,255,255,0.8); font-size: 11px; }
      #chat-close {
        background: none;
        border: none;
        color: white;
        cursor: pointer;
        font-size: 16px;
        padding: 4px;
      }

      /* ─── CHATBOT : Messages ─── */
      #chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-height: 280px;
      }
      .chat-msg {
        padding: 10px 14px;
        font-size: 13px;
        line-height: 1.6;
        white-space: pre-line;
      }
      .chat-msg-row.bot {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        align-self: flex-start;
        max-width: 85%;
      }
      .chat-bot-icon {
        width: 24px;
        height: 24px;
        min-width: 24px;
        background: #FF6B1A;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        margin-top: 2px;
      }
      .chat-msg.bot {
        background: #F3F4F6;
        color: #1a1a1a;
        border-radius: 4px 12px 12px 12px;
        flex: 1;
      }
      .chat-msg.user {
        background: #FF6B1A;
        color: white;
        align-self: flex-end;
        border-radius: 12px 4px 12px 12px;
        max-width: 75%;
      }

      /* ─── CHATBOT : Options ─── */
      #chat-options {
        padding: 8px 16px 12px;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .chat-option {
        background: white;
        border: 1.5px solid #FF6B1A;
        color: #FF6B1A;
        border-radius: 100px;
        padding: 9px 16px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-align: center;
        transition: all 0.15s ease;
        width: 100%;
      }
      .chat-option:hover {
        background: #FF6B1A;
        color: white;
      }

      /* ─── CHATBOT : Input ─── */
      #chat-input-zone {
        padding: 12px 16px;
        border-top: 1px solid #F3F4F6;
        display: flex;
        gap: 8px;
      }
      #chat-input {
        flex: 1;
        border: 1px solid #E5E7EB;
        border-radius: 100px;
        padding: 8px 14px;
        font-size: 13px;
        outline: none;
      }
      #chat-input:focus { border-color: #FF6B1A; }
      #chat-send {
        background: #FF6B1A;
        color: white;
        border: none;
        border-radius: 50%;
        width: 36px;
        height: 36px;
        cursor: pointer;
        font-size: 16px;
      }

      @media (max-width: 480px) {
        #chat-window {
          width: calc(100vw - 32px);
          right: 16px;
          bottom: 80px;
        }
      }
    </style>

    <script is:inline>
    // ─── CHATBOT AURORE ───
    (function() {
      var bubble = document.getElementById('chat-bubble');
      var chatWin = document.getElementById('chat-window');
      var closeBtn = document.getElementById('chat-close');
      var messages = document.getElementById('chat-messages');
      var optionsZone = document.getElementById('chat-options');
      var input = document.getElementById('chat-input');
      var sendBtn = document.getElementById('chat-send');
      var notif = document.getElementById('chat-notif');

      var step = 'start';

      // Scénarios
      var FLOWS = {
        start: {
          msg: 'Bonjour ! Je suis Élodie. Comment puis-je vous aider ?',
          options: [
            { label: 'Je veux créer un site web', next: 'create' },
            { label: "J'ai déjà un site à améliorer", next: 'improve' },
            { label: 'Je veux migrer depuis Wix/WordPress', next: 'migrate' },
            { label: "J'ai une question sur les tarifs", next: 'pricing' },
          ]
        },
        create: {
          msg: "Super ! Quel type d'activité avez-vous ?",
          options: [
            { label: 'Artisan / Commerce', next: 'create_artisan' },
            { label: 'Thérapeute / Praticien', next: 'create_therapist' },
            { label: 'Professionnel libéral', next: 'create_pro' },
            { label: 'Autre', next: 'create_other' },
          ]
        },
        create_artisan: {
          msg: "Parfait. Pour un artisan, je recommande le Pack Starter à 290\u202F€ (3 pages, SEO local, fiche Google Business) ou le Pack Vitrine à 690\u202F€ (jusqu'à 6 pages + blog). Livraison en 2 semaines.",
          options: [
            { label: 'En savoir plus sur les tarifs', next: 'pricing' },
            { label: 'Demander un devis gratuit', next: 'contact' },
          ]
        },
        create_therapist: {
          msg: "Pour un thérapeute, je recommande le Pack Vitrine à 690\u202F€ avec prise de RDV, ou le Pack Pro à 1\u202F290\u202F€ avec paiement en ligne intégré. SEO local inclus dans les deux.",
          options: [
            { label: 'En savoir plus sur les tarifs', next: 'pricing' },
            { label: 'Demander un devis gratuit', next: 'contact' },
          ]
        },
        create_pro: {
          msg: "Pour un professionnel libéral, le Pack Vitrine à 690\u202F€ est souvent idéal : jusqu'à 6 pages, blog, espace rédaction et fiche Google Business optimisée.",
          options: [
            { label: 'En savoir plus sur les tarifs', next: 'pricing' },
            { label: 'Demander un devis gratuit', next: 'contact' },
          ]
        },
        create_other: {
          msg: "Pas de problème ! Décrivez-moi votre projet en quelques mots via le formulaire et je vous envoie un devis détaillé sous 48h.",
          options: [
            { label: 'Accéder au formulaire', next: 'contact' },
          ]
        },
        improve: {
          msg: "D'accord. Quel est votre principal objectif ?",
          options: [
            { label: 'Mieux apparaître sur Google', next: 'seo' },
            { label: 'Moderniser le design', next: 'design' },
            { label: 'Ajouter des fonctionnalités', next: 'features' },
          ]
        },
        seo: {
          msg: "L'optimisation SEO locale démarre à 150\u202F€ (balises, Schema.org, fiche Google Business). C'est souvent le levier le plus rapide pour remonter sur Google.",
          options: [
            { label: 'Demander un audit gratuit', next: 'contact' },
            { label: 'En savoir plus sur les tarifs', next: 'pricing' },
          ]
        },
        design: {
          msg: "Une refonte ou migration depuis votre plateforme actuelle démarre à 190\u202F€. On récupère tout votre contenu et on reconstruit sur une base moderne.",
          options: [
            { label: 'Demander un devis', next: 'contact' },
            { label: 'En savoir plus', next: 'pricing' },
          ]
        },
        features: {
          msg: "Réservation en ligne, paiement Stripe, blog, espace client... Dites-moi ce dont vous avez besoin et je vous propose la solution adaptée.",
          options: [
            { label: 'Décrire mon besoin', next: 'contact' },
          ]
        },
        migrate: {
          msg: "La migration depuis WordPress, Wix ou Squarespace coûte 190\u202F€. On récupère tout votre contenu, votre domaine reste le même et vous quittez définitivement les abonnements mensuels.",
          options: [
            { label: 'Demander un devis migration', next: 'contact' },
            { label: 'En savoir plus', next: 'pricing' },
          ]
        },
        pricing: {
          msg: "Voici les tarifs :\n\u2022 Starter : 290\u202F€ (3 pages, SEO, GBP)\n\u2022 Vitrine : 690\u202F€ (6 pages, blog, CMS)\n\u2022 Pro : 1\u202F290\u202F€ (réservation, paiement en ligne)\n\u2022 Migration : 190\u202F€\nTout inclus, sans abonnement mensuel.",
          options: [
            { label: 'Demander un devis gratuit', next: 'contact' },
            { label: 'Voir tous les tarifs', next: 'link_tarifs' },
          ]
        },
        contact: {
          msg: "Je vous redirige vers le formulaire de contact. Je vous réponds avec un devis détaillé sous 48h !",
          options: [],
          action: function() { window.location.href = '/contact/'; }
        },
        link_tarifs: {
          msg: "Je vous redirige vers la page tarifs complète.",
          options: [],
          action: function() { window.location.href = '/tarifs/'; }
        },
      };

      function addMessage(text, type) {
        if (type === 'bot') {
          var wrapper = document.createElement('div');
          wrapper.className = 'chat-msg-row bot';
          var icon = document.createElement('span');
          icon.className = 'chat-bot-icon';
          icon.textContent = 'É';
          var div = document.createElement('div');
          div.className = 'chat-msg bot';
          div.textContent = text;
          wrapper.appendChild(icon);
          wrapper.appendChild(div);
          messages.appendChild(wrapper);
        } else {
          var div = document.createElement('div');
          div.className = 'chat-msg user';
          div.textContent = text;
          messages.appendChild(div);
        }
        messages.scrollTop = messages.scrollHeight;
      }

      function showOptions(options) {
        optionsZone.innerHTML = '';
        options.forEach(function(opt) {
          var btn = document.createElement('button');
          btn.className = 'chat-option';
          btn.textContent = opt.label;
          btn.addEventListener('click', function() {
            addMessage(opt.label, 'user');
            optionsZone.innerHTML = '';
            setTimeout(function() { goToStep(opt.next); }, 400);
          });
          optionsZone.appendChild(btn);
        });
      }

      function goToStep(stepName) {
        var flow = FLOWS[stepName];
        if (!flow) return;
        step = stepName;
        setTimeout(function() {
          addMessage(flow.msg, 'bot');
          if (flow.options && flow.options.length > 0) {
            showOptions(flow.options);
          }
          if (flow.action) {
            setTimeout(flow.action, 800);
          }
        }, 300);
      }

      // Ouvrir/fermer
      bubble.addEventListener('click', function() {
        chatWin.classList.toggle('open');
        notif.style.display = 'none';
        if (chatWin.classList.contains('open') && messages.children.length === 0) {
          setTimeout(function() { goToStep('start'); }, 300);
        }
      });

      closeBtn.addEventListener('click', function() {
        chatWin.classList.remove('open');
      });

      // Input libre
      function sendMessage() {
        var text = input.value.trim();
        if (!text) return;
        addMessage(text, 'user');
        input.value = '';
        setTimeout(function() {
          addMessage("Merci pour votre message ! Pour une réponse rapide, utilisez notre formulaire de contact - je réponds sous 48h.", 'bot');
          showOptions([{ label: 'Accéder au formulaire', next: 'contact' }]);
        }, 500);
      }

      sendBtn.addEventListener('click', sendMessage);
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') sendMessage();
      });

      // Notification après 5 secondes si pas encore ouvert
      setTimeout(function() {
        if (!chatWin.classList.contains('open')) {
          notif.style.display = 'flex';
        }
      }, 5000);

    })();
    </script>

