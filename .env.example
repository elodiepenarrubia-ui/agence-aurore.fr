# Firebase Admin SDK
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_service_account@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Resend (emails transactionnels)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API interne (authentification devis-generateur)
API_SECRET_TOKEN=your_secret_token_here

# Mot de passe generateur de devis
DEVIS_PASSWORD=your_password_here

# Code d'accès formations (universel, envoyé aux clients dans l'email de livraison)
PUBLIC_FORMATIONS_CODE=AURORE-2026
